{"data":[{"type":"questionAttempts","id":"17585669","links":{"self":"https://app.emedici.com/api/questionAttempts/17585669"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T08:16:25+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T08:16:25+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15000"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15000","links":{"self":"https://app.emedici.com/api/questions/15000"},"attributes":{"optionProportions":[0.18,0.13,0.13,0.13,0.45]},"relationships":{"item":{"data":{"type":"items","id":"7688"}},"activeRevision":{"data":{"type":"questionRevisions","id":"66736"}}}},{"type":"items","id":"7688","links":{"self":"https://app.emedici.com/api/items/7688"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15000"}},"activeRevision":{"data":{"type":"itemRevisions","id":"52189"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4936"},{"type":"tags","id":"4943"},{"type":"tags","id":"4944"},{"type":"tags","id":"5438"},{"type":"tags","id":"7882"},{"type":"tags","id":"10920"}]},"contributions":{"data":[{"type":"contributions","id":"18785"},{"type":"contributions","id":"18787"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"66736","links":{"self":"https://app.emedici.com/api/questionRevisions/66736"},"attributes":{"stem":"\u003Cp\u003EVaccines can be classified into two main categories based on whether they contain live or inactivated organisms.\u003C/p\u003E","stemQuestion":"Which one of the following best describes a vaccine that contains inactivated components?","responseType":"sba","marks":1,"options":["Measles-mumps-rubella vaccine","Rotavirus vaccine","Tuberculosis vaccine","Varicella zoster vaccine","Pneumococcal polysaccharide vaccine"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Epneumococcal polysaccharide vaccine\u003C/strong\u003E is an inactivated vaccine containing purified capsular polysaccharide antigens from 23 different serotypes of \u003Cem\u003EStreptococcus pneumoniae\u003C/em\u003E. As it contains only bacterial components rather than whole organisms, it cannot cause infection.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EMeasles-mumps-rubella vaccine\u003C/strong\u003E contains live attenuated forms of all three viruses\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ERotavirus vaccine\u003C/strong\u003E is a live attenuated vaccine given orally\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ETuberculosis vaccine\u003C/strong\u003E contains live attenuated \u003Cem\u003EMycobacterium bovis\u003C/em\u003E\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EVaricella zoster vaccine\u003C/strong\u003E contains live attenuated varicella zoster virus\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003ELive attenuated vaccines contain weakened but viable organisms that can replicate in the host, while inactivated vaccines contain killed organisms or their components that cannot cause infection.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Pneumococcal 23-valent vaccine contains purified bacterial capsular polysaccharide antigens from 23 serotypes of Streptococcus pneumoniae","Live attenuated vaccines contain weakened but viable organisms and include measles-mumps-rubella, rotavirus, and tuberculosis vaccines","Inactivated vaccines contain killed organisms or their components and cannot cause infection"],"references":["Bona, C. A., \u0026 Bonilla, F. A. (2019). Textbook of immunology. CRC press","Kumar, V., Abbas, A. K., \u0026 Aster, J. C. (Eds.). (2012). Robbins basic pathology e-book. Elsevier Health Science","Kamboj M, Sepkowitz KA. Risk of transmission associated with live attenuated vaccines given to healthy persons caring for or residing with an immunocompromised patient. Infect Control Hosp Epidemiol. 2007 Jun;28(6):702-7. doi: 10.1086/517952. Epub 2007 Apr 20. PMID: 17520544","Briles DE, Paton JC, Mukerji R, Swiatlo E, Crain MJ. Pneumococcal Vaccines. Microbiol Spectr. 2019 Nov;7(6):10.1128/microbiolspec.gpp3-0028-2018. doi: 10.1128/microbiolspec.GPP3-0028-2018. PMID: 31858954; PMCID: PMC10921951."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"52189"}},"question":{"data":{"type":"questions","id":"15000"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"52189","links":{"self":"https://app.emedici.com/api/itemRevisions/52189"},"attributes":{"createdAt":"2024-12-01T20:38:31+10:30","updatedAt":"2024-12-01T20:38:42+10:30"},"relationships":{"item":{"data":{"type":"items","id":"7688"}},"content":{"data":{"type":"questionRevisions","id":"66736"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships