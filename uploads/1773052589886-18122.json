{"data":[{"type":"questionAttempts","id":"17645644","links":{"self":"https://app.emedici.com/api/questionAttempts/17645644"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T20:19:23+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T20:19:23+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18122"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18122","links":{"self":"https://app.emedici.com/api/questions/18122"},"attributes":{"optionProportions":[0.8,0.08,0,0.08,0.04]},"relationships":{"item":{"data":{"type":"items","id":"10836"}},"activeRevision":{"data":{"type":"questionRevisions","id":"73588"}}}},{"type":"items","id":"10836","links":{"self":"https://app.emedici.com/api/items/10836"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18122"}},"activeRevision":{"data":{"type":"itemRevisions","id":"59058"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"3000"},{"type":"tags","id":"4931"},{"type":"tags","id":"4941"}]},"contributions":{"data":[{"type":"contributions","id":"25218"},{"type":"contributions","id":"25221"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"73588","links":{"self":"https://app.emedici.com/api/questionRevisions/73588"},"attributes":{"stem":"\u003Cp\u003E\u003C/p\u003E","stemQuestion":"Which one of the following muscles is innervated by the axillary nerve?","responseType":"sba","marks":1,"options":["Deltoid","Coracobrachialis","Brachialis","Pectoralis major","Latissimus dorsi"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThe axillary nerve is responsible for innervating the \u003Cstrong\u003Edeltoid\u003C/strong\u003E and teres minor muscles. It also provides sensory innervation to the skin over the deltoid muscle, known as the \u0027regimental badge\u0027 area. Injury to the axillary nerve, such as from shoulder dislocation or trauma, can lead to weakness in shoulder abduction and sensory loss over the lateral shoulder.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Ecoracobrachialis\u003C/strong\u003E is innervated by the musculocutaneous nerve, which also supplies the biceps brachii and brachialis muscles.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Ebrachialis\u003C/strong\u003E muscle is primarily innervated by the musculocutaneous nerve, with a small contribution from the radial nerve.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Epectoralis major\u003C/strong\u003E is innervated by the medial and lateral pectoral nerves, which are branches of the brachial plexus.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Elatissimus dorsi\u003C/strong\u003E is innervated by the thoracodorsal nerve, a branch of the posterior cord of the brachial plexus.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["The axillary nerve innervates the deltoid and teres minor muscles.","The axillary nerve provides sensory innervation to the skin over the deltoid muscle.","Injury to the axillary nerve can result in weakness of shoulder abduction."],"references":["West, S. G. (2019). Anatomy and physiology of the musculoskeletal system. Rheumatology Secrets E-Book: Rheumatology Secrets E-Book, 17","Miniato MA, Anand P, Varacallo M. Anatomy, Shoulder and Upper Limb, Shoulder. 2023 Jul 24. In: StatPearls [Internet]. Treasure Island (FL): StatPearls Publishing; 2024 Jan\u2013. PMID: 30725618","Hutson, M., \u0026 Ward, A. (Eds.). (2015). Oxford textbook of musculoskeletal medicine. Oxford University Press","McCausland C, Sawyer E, Eovaldi BJ, Varacallo M. Anatomy, Shoulder and Upper Limb, Shoulder Muscles. 2023 Aug 8. In: StatPearls [Internet]. Treasure Island (FL): StatPearls Publishing; 2024 Jan\u2013. PMID: 30521257","Paulsen, F., \u0026 Waschke, J. (Eds.). (2023). Sobotta Atlas of Anatomy, Vol. 1, English/Latin: General Anatomy and Musculoskeletal System (Vol. 1). Elsevier Health Sciences"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"59058"}},"question":{"data":{"type":"questions","id":"18122"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"59058","links":{"self":"https://app.emedici.com/api/itemRevisions/59058"},"attributes":{"createdAt":"2024-12-24T00:21:37+10:30","updatedAt":"2024-12-24T00:22:26+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10836"}},"content":{"data":{"type":"questionRevisions","id":"73588"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"3000","links":{"self":"https://app.emedici.com/api/tags/3000"},"attributes":{"emoji":"","name":"Brachial plexus","synonyms":[],"description":null,"position":null,"createdAt":"2024-09-16T20:31:17+09:30","updatedAt":