{"data":[{"type":"questionAttempts","id":"17585320","links":{"self":"https://app.emedici.com/api/questionAttempts/17585320"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T08:09:05+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T08:09:05+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"14955"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"14955","links":{"self":"https://app.emedici.com/api/questions/14955"},"attributes":{"optionProportions":[0.89,0.03,0.06,0.01,0.01]},"relationships":{"item":{"data":{"type":"items","id":"7643"}},"activeRevision":{"data":{"type":"questionRevisions","id":"64331"}}}},{"type":"items","id":"7643","links":{"self":"https://app.emedici.com/api/items/7643"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"14955"}},"activeRevision":{"data":{"type":"itemRevisions","id":"49763"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4927"},{"type":"tags","id":"4936"},{"type":"tags","id":"4944"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"6798"},{"type":"tags","id":"7882"},{"type":"tags","id":"8095"},{"type":"tags","id":"8109"}]},"contributions":{"data":[{"type":"contributions","id":"18696"},{"type":"contributions","id":"18699"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"64331","links":{"self":"https://app.emedici.com/api/questionRevisions/64331"},"attributes":{"stem":"\u003Cp\u003ECommunity-acquired pneumonia is a significant cause of morbidity and mortality worldwide, particularly affecting young children and older adults. It is an infection of the lung parenchyma acquired outside of hospital settings.\u003C/p\u003E","stemQuestion":"Which one of the following microorganisms is the most common cause of community-acquired pneumonia?","responseType":"sba","marks":1,"options":["Streptococcus pneumoniae","Mycoplasma pneumoniae","Haemophilus influenzae","Klebsiella pneumoniae","Staphylococcus aureus"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EPneumonia is an inflammatory condition of the lung primarily affecting the alveoli, and it can be caused by a variety of infectious agents, including bacteria, viruses, and fungi.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cem\u003EStreptococcus pneumoniae\u003C/em\u003E\u003C/strong\u003E (also known as pneumococcus) is the most common bacterial cause of community-acquired pneumonia worldwide, accounting for approximately 30-50% of cases where a pathogen is identified.\u003C/p\u003E\u003Cp\u003EThe other causes of pneumonia are less prevalent than Streptococcus pneumonia. \u003Cstrong\u003E\u003Cem\u003EMycoplasma pneumoniae\u003C/em\u003E\u003C/strong\u003E is an important cause of atypical pneumonia, particularly in young adults. \u003Cstrong\u003E\u003Cem\u003EHaemophilus influenzae\u003C/em\u003E\u003C/strong\u003E typically causes pneumonia in people with underlying lung disease. \u003Cstrong\u003E\u003Cem\u003EKlebsiella pneumoniae\u003C/em\u003E\u003C/strong\u003E is more commonly associated with hospital-acquired pneumonia. \u003Cstrong\u003E\u003Cem\u003EStaphylococcus aureus\u003C/em\u003E\u003C/strong\u003E pneumonia is relatively rare in community settings but more common in post-viral infections or healthcare settings.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Streptococcus pneumoniae is the most common bacterial cause of community-acquired pneumonia worldwide.","Community-acquired pneumonia differs from hospital-acquired pneumonia in its typical causative organisms."],"references":["Sastry, A. S., \u0026 Bhat, S. (2018). Essentials of medical microbiology. JP Medical Ltd","Kumar, V., Abbas, A. K., \u0026 Aster, J. C. (Eds.). (2012). Robbins basic pathology e-book. Elsevier Health Sciences","Vaughn VM, Dickson RP, Horowitz JK, Flanders SA. Community-Acquired Pneumonia: A Review. JAMA. 2024 Oct 15;332(15):1282-1295. doi: 10.1001/jama.2024.14796. PMID: 39283629."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"49763"}},"question":{"data":{"type":"questions","id":"14955"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"49763","links":{"self":"https://app.emedici.com/api/itemRevisions/49763"},"attributes":{"createdAt":"2024-11-23T12:35:37+10:30","updatedAt":"2024-11-23T12:36:07+10:30"},"relationships":{"item":{"data":{"type":"items","id":"7643"}},"content":{"data":{"type":"questionRevisions","id":"64331"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4927","links":{"self":"https://app.emedici.com/api/tags/4927"},"attributes":{"emoji":"\ud83e\udec1","name":"Respiratory"