# ─── iMD Admin Panel Environment ───
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# Server port (Hostinger may set this automatically)
PORT=3000

# ─── Admin credentials ───
# CHANGE THESE before going live!
IMD_ADMIN_USERNAME=admin
IMD_ADMIN_PASSWORD=change_this_strong_password
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IMD_ADMIN_COOKIE_SECRET=change-this-to-a-random-64-char-string

# ─── MySQL database ───
# Local (XAMPP):
#   MYSQL_HOST=127.0.0.1
#   MYSQL_USER=root
#   MYSQL_PASSWORD=
#   MYSQL_DATABASE=imd_app
#   MYSQL_SOCKET_PATH=/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock
#
# Hostinger production:
#   MYSQL_HOST=localhost
#   MYSQL_USER=u123456789_imd
#   MYSQL_PASSWORD=YourHostingerDbPassword
#   MYSQL_DATABASE=u123456789_imd_app
#
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=imd_app

# Set to production on the server
NODE_ENV=development
