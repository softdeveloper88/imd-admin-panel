{"data":[{"type":"questionAttempts","id":"17650556","links":{"self":"https://app.emedici.com/api/questionAttempts/17650556"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T21:13:01+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T21:13:01+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18407"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18407","links":{"self":"https://app.emedici.com/api/questions/18407"},"attributes":{"optionProportions":[0.07,0.03,0.77,0.07,0.07]},"relationships":{"item":{"data":{"type":"items","id":"11125"}},"activeRevision":{"data":{"type":"questionRevisions","id":"74497"}}}},{"type":"items","id":"11125","links":{"self":"https://app.emedici.com/api/items/11125"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18407"}},"activeRevision":{"data":{"type":"itemRevisions","id":"59988"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4930"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"10334"}]},"contributions":{"data":[{"type":"contributions","id":"25786"},{"type":"contributions","id":"25790"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"74497","links":{"self":"https://app.emedici.com/api/questionRevisions/74497"},"attributes":{"stem":"\u003Cp\u003EUpper motor neurons are responsible for transmitting motor signals from the brain to the spinal cord. Damage to these neurons can lead to various clinical manifestations.\u003C/p\u003E","stemQuestion":"Which one of the following may result from an upper motor neuron lesion?","responseType":"sba","marks":1,"options":["Muscle atrophy","Flaccid paralysis","Increased muscle tone","Fasciculations","Decreased reflexes"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EUpper motor neuron lesions are characterised by damage to the neural pathways above the anterior horn cell or motor nuclei. These lesions typically result in \u003Cstrong\u003Eincreased muscle tone\u003C/strong\u003E due to the loss of inhibitory control over the lower motor neurons, leading to spasticity. This is often accompanied by \u003Cstrong\u003Emuscle weakness\u003C/strong\u003E and \u003Cstrong\u003Elack of muscle control\u003C/strong\u003E, as the affected muscles receive less input from the brain.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EMuscle atrophy\u003C/strong\u003E is not a typical feature of upper motor neuron lesions. It is more commonly associated with lower motor neuron lesions, where there is direct damage to the motor neurons innervating the muscles, leading to denervation and subsequent atrophy.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Upper motor neuron lesions typically result in spasticity, increased reflexes, and weakness.","Muscle atrophy is more characteristic of lower motor neuron lesions.","Upper motor neuron lesions often lead to paralysis on the contralateral side of the body."],"references":["Patton, K. T., \u0026 Thibodeau, G. A. (2018). Anthony\u0027s Textbook of Anatomy \u0026 Physiology-E-Book: Anthony\u0027s Textbook of Anatomy \u0026 Physiology-E-Book. Elsevier Health Sciences","Hutson, M., \u0026 Ward, A. (Eds.). (2015). Oxford textbook of musculoskeletal medicine. Oxford University Press","Longo, U. G., \u0026 Denaro, V. (Eds.). (2023). Textbook of musculoskeletal disorders. Springer Nature","Hughes, S. H. (2022). The Musculoskeletal System: The Musculoskeletal System-E-Book. Elsevier Health Sciences","Frontera WR, Ochala J. Skeletal muscle: a brief review of structure and function. Calcif Tissue Int. 2015 Mar;96(3):183-95. doi: 10.1007/s00223-014-9915-y. Epub 2014 Oct 8. PMID: 25294644","Morrison BM. Neuromuscular Diseases. Semin Neurol. 2016 Oct;36(5):409-418. doi: 10.1055/s-0036-1586263. Epub 2016 Sep 23. PMID: 27704495"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"59988"}},"question":{"data":{"type":"questions","id":"18407"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"59988","links":{"self":"https://app.emedici.com/api/itemRevisions/59988"},"attributes":{"createdAt":"2024-12-25T05:56:26+10:30","updatedAt":"2025-01-14T23:52:56+10:30"},"relationships":{"item":{"data":{"type":"items","id":"11125"}},"content":{"data":{"type":"questionRevisions","id":"74497"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4930","links":{"self":"https://app.emedici.com/api/tags/4930"},"attributes":{"emoji":"\ud83e\udde0","name":"Nervous System","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-11-27T10:23:42+10:30"},"relationships":{"group":{"dat