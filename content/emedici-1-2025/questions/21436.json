com/api/questions/21436/relationships/activeRevision"}}}},{"type":"items","id":"14305","links":{"self":"https://app.emedici.com/api/items/14305"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/14305/packs","self":"https://app.emedici.com/api/items/14305/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/14305/revisions","self":"https://app.emedici.com/api/items/14305/relationships/revisions"}},"content":{"data":{"type":"questions","id":"21436"},"links":{"related":"https://app.emedici.com/api/items/14305/content","self":"https://app.emedici.com/api/items/14305/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/14305/specialtyTags","self":"https://app.emedici.com/api/items/14305/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/14305/primaryTags","self":"https://app.emedici.com/api/items/14305/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/14305/contributionTypes","self":"https://app.emedici.com/api/items/14305/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/14305/contributors","self":"https://app.emedici.com/api/items/14305/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/14305/contribution","self":"https://app.emedici.com/api/items/14305/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/14305/myContribution","self":"https://app.emedici.com/api/items/14305/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"102026"},"links":{"related":"https://app.emedici.com/api/items/14305/activeRevision","self":"https://app.emedici.com/api/items/14305/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"5"},{"type":"tags","id":"24"},{"type":"tags","id":"65"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"1061"},{"type":"tags","id":"3390"},{"type":"tags","id":"4061"},{"type":"tags","id":"5771"},{"type":"tags","id":"9270"},{"type":"tags","id":"9598"}],"links":{"related":"https://app.emedici.com/api/items/14305/tags","self":"https://app.emedici.com/api/items/14305/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"35407"},{"type":"contributions","id":"35408"},{"type":"contributions","id":"35409"},{"type":"contributions","id":"35410"},{"type":"contributions","id":"35411"},{"type":"contributions","id":"35412"},{"type":"contributions","id":"35413"},{"type":"contributions","id":"53409"},{"type":"contributions","id":"53449"}],"links":{"related":"https://app.emedici.com/api/items/14305/contributions","self":"https://app.emedici.com/api/items/14305/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"120432","links":{"self":"https://app.emedici.com/api/questionRevisions/120432"},"attributes":{"stem":"\u003Cp\u003EA 55-year-old woman presents to the Emergency Department with a three-day history of worsening epigastric pain radiating to the right upper quadrant. She has a medical history of type 2 diabetes and hypothyroidism, for which she takes metformin and levothyroxine. She has no history of alcohol use or recent travel.\u003C/p\u003E\u003Cp\u003EOn examination, she appears uncomfortable but not acutely unwell. Her pulse rate is 85/min, blood pressure 135/85 mmHg, respiratory rate 16/min, SpO2 97% on room air, and temperature 37.2\u00b0C. She has mild scleral icterus and tenderness in the right upper quadrant without guarding. Her laboratory investigations show:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EHaemoglobin 128 g/L (115-155)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EWhite blood cell count 9.5 x10\u003Csup\u003E9\u003C/sup\u003E /L (4.0-11.0)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EAlanine transaminase 95 U/L (5-40)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EAspartate transaminase 88 U/L (10-40)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EAlkaline phosphatase 320 U/L (35-110)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EGamma-glutamyl transferase 280 U/L (5-50)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003ETotal bilirubin 32 \u03bcmol/L (4-20)\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EAn abdominal ultrasound shows multiple gallstones and a dilated common bile duct measuring 11 mm, but no definite common bile duct stones are visualised.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate next investigation?","responseType":"sba","marks":1,"options":["Endoscopic ultrasonography","Liver biopsy","Endoscopic retrograde cholangiopancreatography","Magnetic resonance cholangiopancreatography","Percutaneous transhepatic cholangiography"],"correctOptions":[3],"correctResponses":[],"explanation":"\u003Cp\u003EThis patient\u0027s right upper quadrant pain, mild jaundice, and abnormal liver function tests is suggestive of choledocholithiasis. Her abnormal liver tests and a dilated common bile duct on ultrasound means she would be considered at immediate-risk for this diagnosis, as per the American Society for Gastrointestinal Endoscopy guideline. She does not meet high-risk criteria, which would include a total bilirubin \u0026gt;68 \u03bcmol/L (\u0026gt;4 mg/dL), visible common bile duct stone on imaging, or clinical evidence of ascending cholangitis. Therefore, further non-invasive imaging is indicated before possibly proceeding to any therapeutic intervention.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EMagnetic resonance cholangiopancreatography\u003C/strong\u003E is the most appropriate next investigation. It is non-invasive, provides excellent visualisation of the biliary tree, and can detect stones as small as 2mm. MRCP has \u0026gt;90% sensitivity and specificity for detecting bile duct stones. Both the American Society for Gastrointestinal Endoscopy and Australian guidelines recommend MRCP as the preferred initial imaging modality when common bile duct stones are suspected, unless there is a clear need for therapeutic intervention. A Cochrane systematic review found MRCP to be as accurate as ERCP for diagnosing choledocholithiasis, but with fewer complications. If MRCP reveals an obstructing stone, therapeutic ERCP can then be considered.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EEndoscopic retrograde cholangiopancreatography\u003C/strong\u003E carries significant risks including pancreatitis (3-10% risk), bleeding, infection, and perforation. While it offers therapeutic potential, it should not be used purely for diagnosis when safer imaging options are available. The Therapeutic Guidelines Australia specifically states that MRCP is preferred unless there is a clear need for therapeutic intervention (e.g. cholangitis). The clinical picture in this case does not suggest cholangitis.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EEndoscopic ultrasonography\u003C/strong\u003E is highly sensitive for detecting common bile duct stones but is invasive, operator-dependent, and requires sedation. It is generally reserved for cases where MRCP is contraindicated or results are equivocal. While guidelines do mention EUS as an alternative to MRCP, it is more invasive and less widely available.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ELiver biopsy\u003C/strong\u003E would not help diagnose biliary obstruction and carries unnecessary risks. The pattern of liver function tests and imaging findings make primary liver disease unlikely.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPercutaneous transhepatic cholangiography\u003C/strong\u003E is an invasive procedure typically reserved for cases where ERCP is not possible or has failed. It carries risks of bleeding, infection, and bile leak and is not appropriate as a first-line investigation.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Magnetic resonance cholangiopancreatography is the preferred initial imaging modality for suspected choledocholithiasis when ultrasound is inconclusive","The clinical presentation of right upper quadrant pain with abnormal liver function tests and dilated common bile duct suggests choledocholithiasis","Endoscopic retrograde cholangiopancreatography should be reserved for therapeutic intervention rather than purely diagnostic purposes due to its associated risks"],"references":["ASGE Standards of Practice Committee; Buxbaum JL, Abbas Fehmi SM, Sultan S, Fishman DS, Qumseya BJ, Cortessis VK, Schilperoort H, Kysh L, Matsuoka L, Yachimski P, Agrawal D, Gurudu SR, Jamil LH, Jue TL, Khashab MA, Law JK, Lee JK, Naveed M, Sawhney MS, Thosani N, Yang J, Wani SB. ASGE guideline on the role of endoscopy in the evaluation and management of choledocholithiasis. Gastrointest Endosc. 2019 Jun;89(6):1075-1105.e15. doi: 10.1016/j.gie.2018.10.001","Kaltenthaler EC, Walters SJ, Chilcott J, Blakeborough A, Vergel YB, Thomas S. MRCP compared to diagnostic ERCP for diagnosis when biliary obstruction is suspected: a systematic review. BMC Med Imaging. 2006 Aug 14;6:9. Available at: https://pubmed.ncbi.nlm.nih.gov/16907974/","Al-Dhuhli H. Role of magnetic resonance cholangiopancreatography in the evaluation of biliary disease. Sultan Qaboos Univ Med J. 2009 Dec;9(3):341-52. Available at: https://pmc.ncbi.nlm.nih.gov/articles/PMC3074788/","Baron TH. Approaches to ERCP in Patients With Roux-en-Y Gastric Bypass Anatomy. Gastroenterol Hepatol (N Y). 2019; 15:622\u201324.","Smith SE. Management of Acute Cholangitis and Choledocholithiasis. Surg Clin N Am 2024; 104:1175\u2013189 https://doi.org/10.1016/j.suc.2024.03.007","Cianci P, Restini E. Management of cholelithiasis with choledocholithiasis: Endoscopic  and surgical approaches. World J Gastroenterol 2021; 27:4536-554"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"102026"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120432/itemRevision","self":"https://app.emedici.com/api/questionRevisions/120432/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"21436"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120432/question","self":"https://app.emedici.com/api/questionRevisions/120432/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/120432/stemMedia","self":"https://app.emedici.com/api/questionRevisions/120432/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/120432/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/120432/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"102026","links":{"self":"https://app.emedici.com/api/itemRevisions/102026"},"attributes":{"createdAt":"2025-10-15T20:15:56+10:30","updatedAt":"2025-10-15T20:16:32+10:30"},"relationships":{"item":{"data":{"type":"items","id":"14305"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102026/item","self":"https://app.emedici.com/api/itemRevisions/102026/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"120432"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102026/content","self":"https://app.emedici.com/api/itemRevisions/102026/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"5","links":{"self":"https://app.emedici.com/api/tags/5"},"attributes":{"emoji":"\ud83d\udd2d","name":"Gastroenterology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/5/group","self":"https://app.emedici.com/api/tags/