{"data":[{"type":"questionAttempts","id":"20889736","links":{"self":"https://app.emedici.com/api/questionAttempts/20889736"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-11-07T13:07:45+10:30","options":[1],"response":null,"finalizedAt":"2025-11-07T13:07:45+10:30"},"relationships":{"user":{"data":{"type":"users","id":"56433"},"links":{"related":"https://app.emedici.com/api/questionAttempts/20889736/user","self":"https://app.emedici.com/api/questionAttempts/20889736/relationships/user"}},"questionSession":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889736/questionSession","self":"https://app.emedici.com/api/questionAttempts/20889736/relationships/questionSession"}},"session":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889736/session","self":"https://app.emedici.com/api/questionAttempts/20889736/relationships/session"}},"question":{"data":{"type":"questions","id":"25131"},"links":{"related":"https://app.emedici.com/api/questionAttempts/20889736/question","self":"https://app.emedici.com/api/questionAttempts/20889736/relationships/question"}},"bookmark":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889736/bookmark","self":"https://app.emedici.com/api/questionAttempts/20889736/relationships/bookmark"}}}}],"included":[{"type":"questions","id":"25131","links":{"self":"https://app.emedici.com/api/questions/25131"},"relationships":{"attempts":{"links":{"related":"https://app.emedici.com/api/questions/25131/attempts","self":"https://app.emedici.com/api/questions/25131/relationships/attempts"}},"item":{"data":{"type":"items","id":"17958"},"links":{"related":"https://app.emedici.com/api/questions/25131/item","self":"https://app.emedici.com/api/questions/25131/relationships/item"}},"activeRevision":{"data":{"type":"questionRevisions","id":"121560"},"links":{"related":"https://app.emedici.com/api/questions/25131/activeRevision","self":"https://app.emedici.com/api/questions/25131/relationships/activeRevision"}}}},{"type":"items","id":"17958","links":{"self":"https://app.emedici.com/api/items/17958"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/17958/packs","self":"https://app.emedici.com/api/items/17958/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/17958/revisions","self":"https://app.emedici.com/api/items/17958/relationships/revisions"}},"content":{"data":{"type":"questions","id":"25131"},"links":{"related":"https://app.emedici.com/api/items/17958/content","self":"https://app.emedici.com/api/items/17958/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/17958/specialtyTags","self":"https://app.emedici.com/api/items/17958/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/17958/primaryTags","self":"https://app.emedici.com/api/items/17958/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/17958/contributionTypes","self":"https://app.emedici.com/api/items/17958/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/17958/contributors","self":"https://app.emedici.com/api/items/17958/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/17958/contribution","self":"https://app.emedici.com/api/items/17958/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/17958/myContribution","self":"https://app.emedici.com/api/items/17958/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"103132"},"links":{"related":"https://app.emedici.com/api/items/17958/activeRevision","self":"https://app.emedici.com/api/items/17958/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"9"},{"type":"tags","id":"25"},{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"351"},{"type":"tags","id":"1985"},{"type":"tags","id":"1986"},{"type":"tags","id":"1993"},{"type":"tags","id":"2333"},{"type":"tags","id":"3696"},{"type":"tags","id":"4578"},{"type":"tags","id":"4954"},{"type":"tags","id":"4987"},{"type":"tags","id":"5771"},{"type":"tags","id":"12920"},{"type":"tags","id":"13209"}],"links":{"related":"https://app.emedici.com/api/items/17958/tags","self":"https://app.emedici.com/api/items/17958/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"53534"},{"type":"contributions","id":"54113"}],"links":{"related":"https://app.emedici.com/api/items/17958/contributions","self":"https://app.emedici.com/api/items/17958/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"121560","links":{"self":"https://app.emedici.com/api/questionRevisions/121560"},"attributes":{"stem":"\u003Cp\u003EA six-week-old exclusively breastfed infant presents to the General Practice clinic with a two-week history of being generally unsettled. The mother describes that the baby becomes particularly distressed when passing stools, drawing up the legs and crying. The baby feeds 12-14 times daily, spending three to five minutes on each breast before switching. There is a stool with every nappy change, and the stools are frothy, large and green. The mother has trialled a newborn probiotic as well as \u0022colic relief\u0022 (containing simethicone) with no improvement. The infant was born at term, with no antenatal or postnatal concerns. The infant is gaining weight appropriately along the 50th percentile.\u003C/p\u003E\u003Cp\u003EOn examination, the baby appears well with vital signs within normal limits. Physical examination reveals a well-hydrated infant with mild perianal erythema but no other abnormalities.\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely cause of this infant\u0027s symptoms?","responseType":"sba","marks":1,"options":["Congenital lactase deficiency","Gastro-oesophageal reflux disease","Lactose overload","Infectious gastroenteritis","Cow\u0027s milk protein allergy"],"correctOptions":[2],"correctResponses":[],"explanation":"\u003Cp\u003EBreastfed infants can develop gastrointestinal symptoms from various causes, requiring careful differentiation based on clinical presentation. The key features in this case - frequent short feeds with breast switching (three to five minutes per breast), frothy green stools with every nappy change, appropriate weight gain, and distress during defecation - point to a specific feeding-related issue rather than an allergic or infectious process. Parents often trial several over the counter therapies with minimal response.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ELactose overload\u003C/strong\u003E typically occurs in cases where infants feed from mothers with large milk supply for short periods of time (e.g. in this case 3-5 minutes per breast) and/or with frequent changes from one breast to another, resulting in ingestion of large volumes of milk that is lower in fat content. This occurs as throughout a feed the level of lactose in milk stays about the same, however levels of fat increases within a feed as the amount of milk in the woman\u0027s breast decreases. As fat slows the movement of milk through the baby\u0027s gastrointestinal tract, milk that is higher in fat provides increased time for lactose to be broken down. When babies predominantly drink low fat milk rapid gut transit can result in incomplete lactose digestion, and characteristic frothy, green stools. The distress during defecation is due to the fermentation of undigested lactose causing gas and cramping. Importantly, the infant remains well-nourished as they receive adequate calories, distinguishing this from malabsorptive conditions.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECow\u0027s milk protein allergy\u003C/strong\u003E typically presents with blood or mucus in stools, eczema, and often other allergic manifestations. The absence of blood or mucus in the stools and the characteristic frothy green appearance make this diagnosis less likely.\u003C/p\u003E\u003Cp\u003ETrue \u003Cstrong\u003Egastro-oesophageal reflux disease (GORD)\u003C/strong\u003E is fairly rare in infants and should be distinguished from simple reflux, which is common and benign. Simple reflux occurs when babies bring up milk but are otherwise happy and gaining weight well. This usually resolves spontaneously and without need for treatment. In contrast, true GORD involves acid damage to the oesophagus and presents with vomiting (often containing blood), refusal to feed, poor weight gain or weight loss, and significant distress during and after feeds. This infant\u0027s appropriate weight gain, lack of vomiting, and specific distress only during defecation make GORD unlikely in this case.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EInfectious gastroenteritis\u003C/strong\u003E would have a more acute onset with systemic symptoms such as fever, lethargy, or signs of dehydration. The two-week duration and lack of systemic illness make this unlikely.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECongenital lactase deficiency\u003C/strong\u003E is extremely rare and presents from birth with severe watery diarrhoea, dehydration, and failure to thrive. This infant\u0027s appropriate weight gain and relatively mild symptoms exclude this diagnosis.\u003C/p\u003E\u003Cp\u003EFor women with milk oversupply and lactose overload initial measures to reduce oversupply include feeding from one breast per feed (with advice to express just enough from the other breast to keep comfortable), catching leaking milk using a cloth such as a breast pad rather than silicon milk catchers (which can remove more milk than would naturally leak), and trialling alternative settling and soothing techniques when the baby requires comfort but has recently had a large feed (such techniques may include rocking, cuddling, baby wearing, taking baby for a walk and in some cases using dummies, with the latter very much dependent on parental preference).\u003C/p\u003E\u003Cp\u003EFor cases of oversupply and lactose overload which are not responsive to these practices, advice from a lactation consultant (LC) or a suitably experienced/trained general practitioner (GP) should be sought. LC\u0027s can be invaluable in providing guidance for more intensive management techniques such as block feeding (feeding from one breast for several feeds), which should not be attempted without good quality support and guidance due to risk of development of mastitis and milk undersupply if undertaken without appropriate monitoring and adjustment.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Lactose overload in breastfed infants can cause frothy green stools and discomfort during defecation, but without blood, mucus, or failure to thrive.","Unlike cow\u0027s milk protein allergy, lactose overload improves with feeding technique modifications and does not require maternal dietary restrictions.","Simple reflux is common and benign in infants, while true gastro-oesophageal reflux disease with oesophagitis is rare and presents with specific symptoms including poor weight gain and blood in vomit."],"references":["Lactose overload in babies. In: Australian Breastfeeding Association [Online]. Accessed 2025 Oct 22. Available at: https://www.breastfeeding.asn.au/resources/lactose-overload","Breastfeeding and reflux. In: Australian Breastfeeding Association [Online]. Accessed 2025 Oct 22. Available at: https://www.breastfeeding.asn.au/resources/breastfeeding-and-reflux","Amir LH, Bearzatto A. Overcoming challenges faced by breastfeeding mothers. Aust Fam Physician 2016;45(8):552-556. Available at: https://www.racgp.org.au/afp/2016/august/overcoming-challenges-faced-by-breastfeeding-mothe","The Royal Children\u0027s Hospital Melbourne. Clinical Practice Guidelines: Unsettled or crying babies (colic). Available at: https://www.rch.org.au/clinicalguide/guideline_index/Crying_Baby_Infant_Distress/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"103132"},"links":{"related":"https://app.emedici.com/api/questionRevisions/121560/itemRevision","self":"https://app.emedici.com/api/questionRevisions/121560/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"25131"},"links":{"related":"https://app.emedici.com/api/questionRevisions/121560/question","self":"https://app.emedici.com/api/questionRevisions/121560/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/121560/stemMedia","self":"https://app.emedici.com/api/questionRevisions/121560/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/121560/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/121560/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"103132","links":{"self":"https://app.emedici.com/api/itemRevisions/103132"},"attributes":{"createdAt":"2025-10-22T11:35:22+10:30","updatedAt":"2025-10-23T08:39:13+10:30"},"relationships":{"item":{"data":{"type":"items","id":"17958"},"links":{"related":"https://app.emedici.com/api/itemRevisions/103132/item","self":"https://app.emedici.com/api/itemRevisions/103132/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"121560"},"links":{"related":"https://app.emedici.com/api/itemRevisions/103132/content","self":"https://app.emedici.com/api/itemRevisions/103132/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"9","links":{"self":"https://app.emedici.com/api/tags/9"},"attributes":{"emoji":"\ud83d\udc76","name":"Paediatrics","synonyms":[],"description":null,"position":null,"createdAt":