{"data":[{"type":"questionAttempts","id":"17656811","links":{"self":"https://app.emedici.com/api/questionAttempts/17656811"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T22:19:50+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T22:19:50+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18770"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18770","links":{"self":"https://app.emedici.com/api/questions/18770"},"relationships":{"item":{"data":{"type":"items","id":"11502"}},"activeRevision":{"data":{"type":"questionRevisions","id":"80326"}}}},{"type":"items","id":"11502","links":{"self":"https://app.emedici.com/api/items/11502"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18770"}},"activeRevision":{"data":{"type":"itemRevisions","id":"65596"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4904"},{"type":"tags","id":"4930"},{"type":"tags","id":"4941"},{"type":"tags","id":"7130"},{"type":"tags","id":"10367"},{"type":"tags","id":"10375"},{"type":"tags","id":"10379"},{"type":"tags","id":"10386"}]},"contributions":{"data":[{"type":"contributions","id":"26619"},{"type":"contributions","id":"26629"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"80326","links":{"self":"https://app.emedici.com/api/questionRevisions/80326"},"attributes":{"stem":"\u003Cp\u003EThe limbic system has important connections with the prefrontal cortex that enable emotional input into decision-making processes. These connections are formed by specific white matter pathways.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the primary direct connection between the amygdala and prefrontal cortex?","responseType":"sba","marks":1,"options":["Fornix","Stria terminalis","Cingulate bundle","Mammillothalamic tract","Uncinate fasciculus"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Euncinate fasciculus\u003C/strong\u003E is the primary white matter tract that directly connects the amygdala to the orbitofrontal cortex. This pathway allows emotional information processed in the amygdala to influence decision-making and behavioural responses in the prefrontal cortex.\u003C/p\u003E    \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003EThe \u003Cstrong\u003Ecingulate bundle\u003C/strong\u003E connects the cingulate cortex with other parts of the limbic system but does not directly connect the amygdala to prefrontal cortex\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Efornix\u003C/strong\u003E connects the hippocampus to the mammillary bodies and septal nuclei\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Emammillothalamic tract\u003C/strong\u003E connects the mammillary bodies to the anterior thalamic nuclei\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Estria terminalis\u003C/strong\u003E connects the amygdala to the hypothalamus and septal nuclei\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThe uncinate fasciculus forms a hook-shaped bundle that curves from the temporal lobe to the frontal lobe, providing the anatomical substrate for emotional influence on executive function.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["The amygdala connects directly to the orbitofrontal cortex via the uncinate fasciculus white matter tract.","The limbic system influences emotional processing and decision-making in the prefrontal cortex through direct neural connections.","The uncinate fasciculus is the primary white matter pathway linking temporal lobe limbic structures with the prefrontal cortex."],"references":["Netter FH. Netter\u0027s Atlas of Human Anatomy: A Systems Approach. 8th ed. Philadelphia: Elsevier; 2021","Moore KL, Dalley AF, Agur A. Clinically Oriented Anatomy. 8th ed. Lippincott Williams and Wilkins; 2017."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"65596"}},"question":{"data":{"type":"questions","id":"18770"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"65596","links":{"self":"https://app.emedici.com/api/itemRevisions/65596"},"attributes":{"createdAt":"2025-01-20T13:52:29+10:30","updatedAt":"2025-01-20T13:53:44+10:30"},"relationships":{"item":{"data":{"type":"items","id":"11502"}},"content":{"data":{"type":"questionRevisions","id":"80326"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4904","links":{"self":"https://app.emedici.com/api/tags/4904"},"attributes":{"emoji":"","name":"Neuroanatomy","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-13T23:02:33+10:30","updatedAt":"2024-10-13T23:02:33+10