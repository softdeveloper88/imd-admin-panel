{"data":[{"type":"questionAttempts","id":"17418350","links":{"self":"https://app.emedici.com/api/questionAttempts/17418350"},"attributes":{"position":1,"marks":1,"answeredAt":null,"options":[],"response":null,"finalizedAt":null},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":{"type":"questionSessions","id":"1261502"}},"session":{"data":{"type":"questionSessions","id":"1261502"}},"question":{"data":{"type":"questions","id":"2305"}},"bookmark":{"data":null}}},{"type":"questionAttempts","id":"17504172","links":{"self":"https://app.emedici.com/api/questionAttempts/17504172"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-29T11:12:06+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T11:12:06+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"2305"}},"bookmark":{"data":null}}}],"included":[{"type":"questionSessions","id":"1261502","links":{"self":"https://app.emedici.com/api/questionSessions/1261502"},"attributes":{"startedAt":"2025-09-28T10:32:06+09:30","updatedAt":"2025-09-28T10:35:00+09:30","sessionType":"qbank","questionStatus":"all","difficulty":[],"timeLimit":null,"questionCount":2,"questionsAnswered":1,"marksTotal":1,"marksAttainable":1,"marksAttempted":1,"finishedAt":"2025-09-28T10:32:18+09:30","resultsAvailable":true,"score":0,"questionsCorrect":0,"marksCorrect":0},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"pack":{"data":{"type":"packs","id":"5"}},"exam":{"data":null}}},{"type":"questions","id":"2305","links":{"self":"https://app.emedici.com/api/questions/2305"},"attributes":{"optionProportions":[0.18,0.7,0.06,0.05,0.01]},"relationships":{"item":{"data":{"type":"items","id":"2305"}},"activeRevision":{"data":{"type":"questionRevisions","id":"108315"}}}},{"type":"items","id":"2305","links":{"self":"https://app.emedici.com/api/items/2305"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"2305"}},"activeRevision":{"data":{"type":"itemRevisions","id":"90718"}},"tags":{"data":[{"type":"tags","id":"7"},{"type":"tags","id":"24"},{"type":"tags","id":"25"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"78"},{"type":"tags","id":"348"},{"type":"tags","id":"1184"},{"type":"tags","id":"1418"},{"type":"tags","id":"4961"},{"type":"tags","id":"4975"},{"type":"tags","id":"4977"},{"type":"tags","id":"4987"},{"type":"tags","id":"4992"},{"type":"tags","id":"11625"},{"type":"tags","id":"11626"},{"type":"tags","id":"11630"},{"type":"tags","id":"11642"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"599"},{"type":"contributions","id":"610"},{"type":"contributions","id":"1263"},{"type":"contributions","id":"1406"},{"type":"contributions","id":"11524"},{"type":"contributions","id":"11778"},{"type":"contributions","id":"35508"},{"type":"contributions","id":"40418"},{"type":"contributions","id":"42466"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"108315","links":{"self":"https://app.emedici.com/api/questionRevisions/108315"},"attributes":{"stem":"\u003Cp\u003EAn 80-year-old man presents with 10 minutes of sudden weakness in his right upper and lower limb. \u003C/p\u003E\u003Cp\u003ETwo weeks ago, he experienced a transient loss of vision in his left eye that resolved spontaneously after five minutes. He had also had a similar episode when dropping a frypan in the kitchen a month ago, but these symptoms spontaneously resolved after 30 minutes. \u003C/p\u003E\u003Cp\u003EHe has a medical history of diet-controlled type 2 diabetes. He is not on any regular medication. His home blood pressure readings are consistently between 130/70 to 138/75mmHg. His neurological examination is normal.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate management?","responseType":"sba","marks":1,"options":["Aspirin 100 mg and refer him to the nearest Emergency Department within 24 hours","Aspirin 300 mg and refer him to the nearest Emergency Department within 24 hours","Aspirin 100  mg and arrange a follow-up appointment with the General Practice clinic in a week","Aspirin 300 mg and arrange a follow-up appointment with the General Practice clinic in a week","Reassure the patient and advise him to call the General Practice clinic again if the weakness persists"],"correctOptions":[1],"correctResponses":[],"explanation":"\u003Cp\u003EThis patient\u2019s sudden onset of transient neurological deficit \u2013 right hemiplegia, with transient vision loss in prior episodes \u2013 is suggestive of a transient ischaemic attack (TIA). Symptoms of neurological symptoms can be screened using FAST (Face Arm Speech Test) \u2013 facial drooping, arm weakness, and slurred or confused speech.\u003C/p\u003E\u003Cp\u003ENICE guidelines state all patients who have had a suspected TIA should immediately be given 300mg of aspirin, unless contraindicated. They also recommend referral to specialist assessment and investigation within 24 hours of onset of symptoms. Previous management of clinical predictor tools (i.e. ABCD2) to determine urgency of referral in suspected or confirmed TIA is not recommended in the most current NICE guidelines \u2013 therefore, \u003Cstrong\u003Easpirin 300mg and referral to the nearest Emergency Department within 24 hours \u003C/strong\u003Eis the correct option. \u00a0This recommendation is also in line with the Australian and New Zealand Living Clinical Guidelines for Stroke Management.\u00a0\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003E100mg of aspirin and referral to the nearest ED within 24 hours \u003C/strong\u003Eis incorrect, due to the dose of aspirin being lower than the recommended 300mg. For this reason, \u003Cstrong\u003Easpirin 100mg and follow-up with GP in a week \u003C/strong\u003Eis also an inappropriate management option.\u003C/p\u003E\u003Cp\u003EAs discussed above, most current guidelines recommend urgent referral to specialist care, rather than stratification of risk of future stroke using ABCD2. Even if ABCD2 were to be used in this patient\u2019s case, he would score 5 (age \u226560 years = 1, focal weakness = 2, diabetes = 1 and duration lasting 10\u201359min = 1), indicating moderate risk. This score would further encourage prompt review by ED. Thus, \u003Cstrong\u003Eproviding 300mg of aspirin and arranging a follow-up appointment with the GP clinic in a week\u003C/strong\u003E is not appropriate management.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EReassurance and safety netting via advice to call the GP clinic if weakness persists \u003C/strong\u003Ewould be inappropriate for several reasons. Early assessment of suspected TIA allows confirmation of diagnosis, identification and treatment of cause, early rehabilitation, and early secondary prevention. Reassurance alone without any form of management would likely contribute to further TIA or stroke \u2013 potentially leading to long-term complications and sequalae.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Individuals with a transient ischaemic attack (TIA) should be given 300 mg aspirin and immediately referred for specialist assessment within 24 hours of symptom onset.","Use of ABCD2 as a clinical predictor score to determine urgency of review is not recommended for best practice management of suspected or confirmed TIA."],"references":["National Institute for Health and Care Excellence. Stroke and transient ischaemic attack in over 16s: diagnosis and initial management. Updated 13 April 2022. Accessed 23 April 2024. https://www.nice.org.uk/guidance/ng128","Stroke Foundation. Australian and New Zealand Living Clinical Guidelines for Stroke Management. July 28 2023. Accessed 23 April 2024. https://informme.org.au/guidelines/living-clinical-guidelines-for-stroke-management#"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"90718"}},"question":{"data":{"type":"questions","id":"2305"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"90718","links":{"self":"https://app.emedici.com/api/itemRevisions/90718"},"attributes":{"createdAt":"2025-07-09T16:45:42+09:30","updatedAt":"2025-07-09T16:47:07+09:30"},"relationships":{"item":{"data":{"type":"items","id":"2305"}},"content":{"data":{"type":"questionRevisions","id":"108315"}}},"meta":{"canDelete":false}},{"type":"tags","id":"7","links":{"self":"https://app.emedici.com/api/tags/7"},"attributes":{"emoji":"\ud83e\udde0","name":"Neurology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"24","links":{"self":"https://app.emedici.com/api/tags/24"},"attributes":{"emoji":"\ud83d\ude91","name":"Emergency Medicine","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"5"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":"Management","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"