com/api/questions/21293/relationships/activeRevision"}}}},{"type":"items","id":"14166","links":{"self":"https://app.emedici.com/api/items/14166"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/14166/packs","self":"https://app.emedici.com/api/items/14166/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/14166/revisions","self":"https://app.emedici.com/api/items/14166/relationships/revisions"}},"content":{"data":{"type":"questions","id":"21293"},"links":{"related":"https://app.emedici.com/api/items/14166/content","self":"https://app.emedici.com/api/items/14166/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/14166/specialtyTags","self":"https://app.emedici.com/api/items/14166/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/14166/primaryTags","self":"https://app.emedici.com/api/items/14166/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/14166/contributionTypes","self":"https://app.emedici.com/api/items/14166/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/14166/contributors","self":"https://app.emedici.com/api/items/14166/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/14166/contribution","self":"https://app.emedici.com/api/items/14166/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/14166/myContribution","self":"https://app.emedici.com/api/items/14166/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"102778"},"links":{"related":"https://app.emedici.com/api/items/14166/activeRevision","self":"https://app.emedici.com/api/items/14166/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"4"},{"type":"tags","id":"25"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"1196"},{"type":"tags","id":"4534"},{"type":"tags","id":"4535"},{"type":"tags","id":"4962"},{"type":"tags","id":"4987"},{"type":"tags","id":"8126"},{"type":"tags","id":"11625"},{"type":"tags","id":"11650"},{"type":"tags","id":"12883"}],"links":{"related":"https://app.emedici.com/api/items/14166/tags","self":"https://app.emedici.com/api/items/14166/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"34351"},{"type":"contributions","id":"34352"},{"type":"contributions","id":"34353"},{"type":"contributions","id":"34355"},{"type":"contributions","id":"54078"}],"links":{"related":"https://app.emedici.com/api/items/14166/contributions","self":"https://app.emedici.com/api/items/14166/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"121167","links":{"self":"https://app.emedici.com/api/questionRevisions/121167"},"attributes":{"stem":"\u003Cp\u003EA 27-year-old Aboriginal woman presents to the General Practice clinic for a routine health check. She has no significant medical history and does not take any regular medications. Her grandmother developed type 2 diabetes at age 50. She works as a community support worker and reports occasional physical activity. She has never smoked and drinks alcohol occasionally.\u003C/p\u003E\u003Cp\u003EOn examination, she appears well with vital signs within normal limits. Her height is 165 cm, weight 78 kg, and BMI 28.7 kg/m\u00b2. Her waist circumference is 88 cm. Investigations reveal fasting plasma glucose of 5.1 mmol/L (3.9-5.5) and HbA1c of 5.6% (4.0-6.0).\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate screening regimen for diabetes in this patient?","responseType":"sba","marks":1,"options":["HbA1c every three years based on AUSDRISK score calculation","Fasting blood glucose every three years from age 30","Annual fasting blood glucose or HbA1c from age 18","HbA1c every five years until age 40, then every two years","Fasting blood glucose every two years from age 25 only if BMI exceeds 30 kg/m\u00b2"],"correctOptions":[2],"correctResponses":[],"explanation":"\u003Cp\u003EThis patient is a 27-year-old Aboriginal woman with normal glucose parameters on current testing. The appropriate screening regimen for diabetes in this case needs to consider her Indigenous status as a key risk factor.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAnnual fasting blood glucose or HbA1c from age 18\u003C/strong\u003E is the correct screening regimen for Aboriginal and Torres Strait Islander peoples. According to the RACGP and NHMRC guidelines, Aboriginal and Torres Strait Islander peoples should be offered screening for diabetes with fasting blood glucose or HbA1c annually from age 18 years due to their significantly higher risk of developing type 2 diabetes at younger ages and experiencing more severe complications.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHbA1c every three years based on AUSDRISK score calculation\u003C/strong\u003E is incorrect because the AUSDRISK tool is not validated for Aboriginal and Torres Strait Islander populations. While AUSDRISK is useful for the general Australian population, it does not adequately capture the unique risk profile of Indigenous Australians, who have a risk of diabetes that is 3-4 times higher than non-Indigenous Australians.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EFasting blood glucose every three years from age 30\u003C/strong\u003E is insufficient for Aboriginal and Torres Strait Islander peoples. This recommendation underestimates the risk and delays appropriate screening. The earlier onset of type 2 diabetes in Indigenous populations necessitates earlier and more frequent screening than in the general population.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHbA1c every five years until age 40, then every two years\u003C/strong\u003E would result in missed opportunities for early intervention. This interval is too infrequent given the high prevalence of diabetes in Aboriginal and Torres Strait Islander communities and the potential for rapid progression of the disease.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EFasting blood glucose every two years from age 25 only if BMI exceeds 30 kg/m\u00b2\u003C/strong\u003E is an inappropriate approach that fails to recognize that Aboriginal and Torres Strait Islander peoples have increased risk of diabetes at lower BMI thresholds compared to non-Indigenous populations. Waiting until obesity is established before screening would miss many cases of diabetes in this high-risk population. Additionally, using BMI as the sole determinant for screening ignores other important risk factors relevant to Indigenous populations.\u003C/p\u003E\u003Cp\u003EIn addition to appropriate screening, comprehensive care for this patient should include culturally safe education about diabetes risk factors, lifestyle modifications, and the importance of regular health checks. The higher prevalence of diabetes in Aboriginal and Torres Strait Islander peoples is influenced by multiple factors including historical, social, and environmental determinants of health, making preventive care and early detection particularly important.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Aboriginal and Torres Strait Islander peoples should be screened annually for diabetes with fasting blood glucose or HbA1c from age 18 years.","Risk assessment tools like AUSDRISK are not validated for Aboriginal and Torres Strait Islander populations.","Early and regular screening for diabetes in high-risk populations reduces complications through timely intervention."],"references":["Royal Australian College of General Practitioners. Management of type 2 diabetes: A handbook for general practice \u2013 Summary of recommendations. Available at: https://www.racgp.org.au/clinical-resources/clinical-guidelines/key-racgp-guidelines/view-all-racgp-guidelines/management-of-type-2-diabetes/summary-of-recommendations"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"102778"},"links":{"related":"https://app.emedici.com/api/questionRevisions/121167/itemRevision","self":"https://app.emedici.com/api/questionRevisions/121167/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"21293"},"links":{"related":"https://app.emedici.com/api/questionRevisions/121167/question","self":"https://app.emedici.com/api/questionRevisions/121167/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/121167/stemMedia","self":"https://app.emedici.com/api/questionRevisions/121167/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/121167/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/121167/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"102778","links":{"self":"https://app.emedici.com/api/itemRevisions/102778"},"attributes":{"createdAt":"2025-10-20T08:46:06+10:30","updatedAt":"2025-10-20T08:47:40+10:30"},"relationships":{"item":{"data":{"type":"items","id":"14166"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102778/item","self":"https://app.emedici.com/api/itemRevisions/102778/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"121167"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102778/content","self":"https://app.emedici.com/api/itemRevisions/102778/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"4","links":{"self":"https://app.emedici.com/api/tags/4"},"attributes":{"emoji":"\ud83c\udf6c","name":"Endocrinology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type