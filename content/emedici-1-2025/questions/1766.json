{"data":[{"type":"questionAttempts","id":"17501559","links":{"self":"https://app.emedici.com/api/questionAttempts/17501559"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-29T10:30:11+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T10:30:11+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"1766"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"1766","links":{"self":"https://app.emedici.com/api/questions/1766"},"attributes":{"optionProportions":[0.07,0.68,0.08,0.13,0.04]},"relationships":{"item":{"data":{"type":"items","id":"1766"}},"activeRevision":{"data":{"type":"questionRevisions","id":"97830"}}}},{"type":"items","id":"1766","links":{"self":"https://app.emedici.com/api/items/1766"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1766"}},"activeRevision":{"data":{"type":"itemRevisions","id":"80385"}},"tags":{"data":[{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"74"},{"type":"tags","id":"2043"},{"type":"tags","id":"8088"}]},"contributions":{"data":[{"type":"contributions","id":"302"},{"type":"contributions","id":"28919"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"97830","links":{"self":"https://app.emedici.com/api/questionRevisions/97830"},"attributes":{"stem":"\u003Cp\u003EA 45-year-old woman presents concerned about a lump in her left breast. She reports that the lump is around her nipple and she first felt this about three weeks ago. At the same time she has also noticed discharge from that nipple, which is bloody and can be \u2018chocolate\u2019 in colour. She does not have any personal or family history of breast or ovarian cancer. She has three children, all born by normal vaginal delivery.\u003C/p\u003E\u003Cp\u003EOn examination there is a one centimetre soft mobile mass palpable lateral to the left nipple underneath the areola. There is no axillary lymphadenopathy or overlying skin changes. The nipple is not inverted.\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Phyllodes tumour","Intraductal papilloma","Intrapapillary ductitis","Ductal carcinoma in situ","Atypical ductal hyperplasia"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EWhilst there are many pathological causes for nipple discharge, \u003Cstrong\u003Eintraductal papilloma\u003C/strong\u003E is the commonest and the one most likely to be associated with a blood-stained discharge. Duct ectasia tends to be associated with a thickened cream-coloured or white discharge. The other listed conditions more characteristically present as a lump in the breast and not nipple discharge.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Duct papillomas are a common cause of nipple discharge."],"references":["Salzman B, Collins E, Hersh L. Common Breast Problems. Am Fam Physician. 2019; 99:505-14."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"80385"}},"question":{"data":{"type":"questions","id":"1766"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"80385","links":{"self":"https://app.emedici.com/api/itemRevisions/80385"},"attributes":{"createdAt":"2025-04-09T17:06:33+09:30","updatedAt":"2025-04-09T17:06:33+09:30"},"relationships":{"item":{"data":{"type":"items","id":"1766"}},"content":{"data":{"type":"questionRevisions","id":"97830"}}},"meta":{"canDelete":false}},{"type":"tags","id":"64","links":{"self":"https://app.emedici.com/api/tags/64"},"attributes":{"emoji":"","name":"Diagnosis","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta