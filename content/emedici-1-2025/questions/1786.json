{"data":[{"type":"questionAttempts","id":"17501759","links":{"self":"https://app.emedici.com/api/questionAttempts/17501759"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T10:33:36+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T10:33:36+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"1786"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"1786","links":{"self":"https://app.emedici.com/api/questions/1786"},"attributes":{"optionProportions":[0.05,0.09,0.06,0.46,0.35]},"relationships":{"item":{"data":{"type":"items","id":"1786"}},"activeRevision":{"data":{"type":"questionRevisions","id":"92353"}}}},{"type":"items","id":"1786","links":{"self":"https://app.emedici.com/api/items/1786"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1786"}},"activeRevision":{"data":{"type":"itemRevisions","id":"75656"}},"tags":{"data":[{"type":"tags","id":"7"},{"type":"tags","id":"25"},{"type":"tags","id":"27"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"921"},{"type":"tags","id":"2560"},{"type":"tags","id":"4625"},{"type":"tags","id":"4975"},{"type":"tags","id":"4990"},{"type":"tags","id":"11625"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"2215"},{"type":"contributions","id":"31323"},{"type":"contributions","id":"42401"},{"type":"contributions","id":"44727"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"92353","links":{"self":"https://app.emedici.com/api/questionRevisions/92353"},"attributes":{"stem":"\u003Cp\u003EA 65-year-old man truck driver presents for review of his driver\u2019s license one month following a stroke. On examination today he has 4/5 power of his left arm with normal reflexes, coordination and sensation. The rest of his neurological examination is normal. His vision is 6/6 unaided bilaterally. There are no visual\u00a0field defects or visual inattention. He feels that he has recovered relatively well from his stroke. He has been cleared by his stroke specialist to go back to driving private\u00a0vehicles. He would like to seek advice on when he can go back to truck driving.\u00a0\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate advice regarding when this patient can return to truck driving?","responseType":"sba","marks":1,"options":["Six months post stroke","Three months post stroke","He can never return to truck driving","Six months post stroke if he is cleared by a specialist","Three months post stroke if he is cleared by a specialist"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThe AustRoads assessing fitness to drive guidelines provide extensive guidance on driving assessment and fitness to drive in Australia for both private vehicles and commercial\u00a0vehicles. After a stroke, the guidelines to returning to driving private vehicles is at least four weeks after stroke with information provided by specialist about level of impairment. An on-road driving assessment may be required depending on level of impairment. The standard is much stricter for commercial\u00a0licenses where the guidance is at least \u003Cstrong\u003Ethree months after stroke with information from specialist\u003C/strong\u003E about level of impairment.\u00a0An on-road driving assessment may be required depending on level of impairment.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["An individual holding a commercial licence will require at least 3 months and clearance from a relevant specialist before a conditional licence will be approved post stroke."],"references":["AustRoads. Assessing Fitness to Drive 2016 (as updated and amended to 2017) [Internet]. Sydney NSW: AustRoads; [updated 2017 August; cited 2021 Mar 26]. Available from:\u00a0https://austroads.com.au/publications/assessing-fitness-to-drive/ap-g56"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"75656"}},"question":{"data":{"type":"questions","id":"1786"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"75656","links":{"self":"https://app.emedici.com/api/itemRevisions/75656"},"attributes":{"createdAt":"2025-03-17T12:22:48+10:30","updatedAt":"2025-03-17T12:24:37+10:30"},"relationships":{"item":{"data":{"type":"items","id":"1786"}},"content":{"data":{"type":"questionRevisions","id":"92353"}}},"meta":{"canDelete":false}},{"type":"tags","id":"7","links":{"self":"https://app.emedici.com/api/tags/7"},"attributes":{"emoji":"\ud83e\udde0","name":"Neurology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"27","links":{"self":"https://app.emedici.com/api/tags/27"},"attributes":{"emoji":"\ud83d\udc77","name":"Occupational/Environmental Medicine","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":"Management","synonyms":null,"description":n