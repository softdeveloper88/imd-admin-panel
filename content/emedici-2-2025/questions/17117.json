{"data":[{"type":"questionAttempts","id":"17627442","links":{"self":"https://app.emedici.com/api/questionAttempts/17627442"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T16:48:28+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T16:48:28+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17117"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17117","links":{"self":"https://app.emedici.com/api/questions/17117"},"attributes":{"optionProportions":[0.14,0.4,0.32,0.14,0]},"relationships":{"item":{"data":{"type":"items","id":"9807"}},"activeRevision":{"data":{"type":"questionRevisions","id":"70084"}}}},{"type":"items","id":"9807","links":{"self":"https://app.emedici.com/api/items/9807"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17117"}},"activeRevision":{"data":{"type":"itemRevisions","id":"55547"}},"tags":{"data":[{"type":"tags","id":"25"},{"type":"tags","id":"36"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"1894"},{"type":"tags","id":"4911"},{"type":"tags","id":"4926"},{"type":"tags","id":"4943"},{"type":"tags","id":"4947"},{"type":"tags","id":"5027"}]},"contributions":{"data":[{"type":"contributions","id":"22985"},{"type":"contributions","id":"23028"},{"type":"contributions","id":"23526"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"70084","links":{"self":"https://app.emedici.com/api/questionRevisions/70084"},"attributes":{"stem":"\u003Cp\u003EA 65-year-old man presents to his general practitioner with urinary hesitancy, weak stream, and nocturia. Digital rectal examination reveals an enlarged, smooth prostate. His blood pressure is 135/85 mmHg. It is decided to treat his urinary tract symptoms with a medication.\u003C/p\u003E","stemQuestion":"Which one of the following would be the most appropriate first-line medication?","responseType":"sba","marks":1,"options":["Muscarinic receptor antagonist","5-alpha reductase inhibitor","Alpha-1 receptor blocker","Beta receptor blocker","Calcium channel blocker"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EAn \u003Cstrong\u003Ealpha-1 receptor blocker\u003C/strong\u003E is the first-line treatment for benign prostatic hyperplasia (BPH). These drugs relax smooth muscle in the prostate and bladder neck, reducing urinary obstruction and improving symptoms rapidly.\u003C/p\u003E    \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E    \u003Cul\u003E        \u003Cli\u003E\u003Cstrong\u003EMuscarinic receptor antagonists\u003C/strong\u003E are used for overactive bladder symptoms but are not first-line therapy for BPH as they do not address the underlying obstruction.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003E5-alpha reductase inhibitors\u003C/strong\u003E reduce prostate size over several months but are typically reserved for second-line therapy or combination treatment in men with larger prostates.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EBeta receptor blockers\u003C/strong\u003E are used for hypertension and other cardiovascular conditions but have no therapeutic effect on prostatic smooth muscle or urinary symptoms.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003ECalcium channel blockers\u003C/strong\u003E are antihypertensive medications that do not have any significant effect on prostatic tissue or lower urinary tract symptoms.\u003C/li\u003E    \u003C/ul\u003E    \u003Cp\u003EAlpha-1 blockers like tamsulosin, terazosin, and prazosin are particularly effective because the prostate has a high density of alpha-1 receptors. While these medications can lower blood pressure, newer agents like tamsulosin are relatively prostate-selective.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Alpha-1 receptor blockers are first-line agents for benign prostatic hyperplasia due to their ability to relax prostatic smooth muscle.","Alpha-1 blockers can also be used to treat hypertension, though they are not first-line agents due to orthostatic hypotension risk.","Common alpha-1 blockers include prazosin, terazosin, and tamsulosin."],"references":["Therapeutic Guidelines. Melbourne: Therapeutic Guidelines Limited. Available from: https://www.tg.org.au","Australian Medicines Handbook\u00a0(online). Adelaide: Australian Medicines Handbook Pty Ltd. Available from:\u00a0https://amhonline.amh.net.au/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"55547"}},"question":{"data":{"type":"questions","id":"17117"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"55547","links":{"self":"https://app.emedici.com/api/itemRevisions/55547"},"attributes":{"createdAt":"2024-12-13T17:35:57+10:30","updatedAt":"2024-12-13T17:36:57+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9807"}},"content":{"data":{"type":"questionRevisions","id":"70084"}}},"meta":{"canDelete":false}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"36","links":{"self":"https://app.emedici.com/api/tags/36"},"attributes":{"emoji":"\ud83e\udd43","name":"Urology","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"2"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https: