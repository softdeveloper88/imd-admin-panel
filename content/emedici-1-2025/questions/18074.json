{"data":[{"type":"questionAttempts","id":"17565646","links":{"self":"https://app.emedici.com/api/questionAttempts/17565646"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-29T23:30:01+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T23:30:01+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18074"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18074","links":{"self":"https://app.emedici.com/api/questions/18074"},"attributes":{"optionProportions":[0.2,0.59,0.01,0.17,0.03]},"relationships":{"item":{"data":{"type":"items","id":"10788"}},"activeRevision":{"data":{"type":"questionRevisions","id":"80936"}}}},{"type":"items","id":"10788","links":{"self":"https://app.emedici.com/api/items/10788"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18074"}},"activeRevision":{"data":{"type":"itemRevisions","id":"66262"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5631"},{"type":"tags","id":"5738"},{"type":"tags","id":"11260"},{"type":"tags","id":"12867"}]},"contributions":{"data":[{"type":"contributions","id":"25142"},{"type":"contributions","id":"27696"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"80936","links":{"self":"https://app.emedici.com/api/questionRevisions/80936"},"attributes":{"stem":"\u003Cp\u003EProfessional boundaries are fundamental to the doctor-patient relationship. The Medical Board of Australia requires doctors to maintain appropriate professional relationships with their patients.\u003C/p\u003E","stemQuestion":"Which one of the following best describes sexual misconduct in the medical profession?","responseType":"sba","marks":1,"options":["Inappropriate physical contact during clinical examinations","Behaviour that exploits the doctor-patient relationship in a sexual way","Making suggestive comments during consultations","Pursuing romantic relationships with current patients","Engaging in intimate relationships with former patients"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EBehaviour that exploits the doctor-patient relationship in a sexual way\u003C/strong\u003E accurately describes sexual misconduct. This includes any sexualised behaviour, inappropriate touching, sexual relationships, or exploitation of the power imbalance inherent in the doctor-patient relationship.\u003C/p\u003E\u003Cp\u003EThe incorrect options represent specific examples of misconduct but are too narrow in scope:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EInappropriate physical contact during clinical examinations\u003C/strong\u003E is one form of sexual misconduct but does not encompass the full range of inappropriate behaviours\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EMaking suggestive comments during consultations\u003C/strong\u003E represents verbal misconduct but excludes physical forms of misconduct\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EPursuing romantic relationships with current patients\u003C/strong\u003E is one type of misconduct but does not include other forms of sexual exploitation\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EEngaging in intimate relationships with former patients\u003C/strong\u003E may still constitute misconduct due to ongoing power imbalances but is only one aspect\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003ESexual misconduct represents a serious breach of professional ethics and trust. This inappropriate and unprofessional behaviour can cause significant harm to patients and may result in disciplinary action or de-registration of the practitioner.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Sexual misconduct includes any behaviour that exploits the doctor-patient relationship in a sexual way.","Doctors must maintain clear professional boundaries and never engage in sexual relationships with current patients.","Sexual misconduct can range from inappropriate comments to physical contact and sexual relationships."],"references":["Good medical practice: a code of conduct for doctors in Australia. Medical Board of Australia. Updated 2024. Available from: https://www.medicalboard.gov.au/Codes-Guidelines-Policies/Code-of-conduct.aspx?_gl=1*1imm9nu*_ga*MzYzODczMjE1LjE3MDQ5Nzk3NDM.*_ga_F1G6LRCHZB*MTczNTM4Mzk2My4xMC4wLjE3MzUzODM5NjMuMC4wLjA."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"66262"}},"question":{"data":{"type":"questions","id":"18074"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"66262","links":{"self":"https://app.emedici.com/api/itemRevisions/66262"},"attributes":{"createdAt":"2025-01-23T20:12:51+10:30","updatedAt":"2025-01-23T20:15:30+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10788"}},"content":{"data":{"type":"questionRevisions","id":"80936"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/