{"data":[{"type":"questionAttempts","id":"17513650","links":{"self":"https://app.emedici.com/api/questionAttempts/17513650"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T13:12:19+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T13:12:19+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"12185"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"12185","links":{"self":"https://app.emedici.com/api/questions/12185"},"attributes":{"optionProportions":[0.19,0.19,0.14,0,0.48]},"relationships":{"item":{"data":{"type":"items","id":"4713"}},"activeRevision":{"data":{"type":"questionRevisions","id":"103570"}}}},{"type":"items","id":"4713","links":{"self":"https://app.emedici.com/api/items/4713"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"12185"}},"activeRevision":{"data":{"type":"itemRevisions","id":"85987"}},"tags":{"data":[{"type":"tags","id":"14"},{"type":"tags","id":"25"},{"type":"tags","id":"37"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"1487"},{"type":"tags","id":"4097"},{"type":"tags","id":"4815"},{"type":"tags","id":"4966"},{"type":"tags","id":"4983"},{"type":"tags","id":"11625"},{"type":"tags","id":"11643"}]},"contributions":{"data":[{"type":"contributions","id":"7406"},{"type":"contributions","id":"7453"},{"type":"contributions","id":"26772"},{"type":"contributions","id":"35924"},{"type":"contributions","id":"44373"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"103570","links":{"self":"https://app.emedici.com/api/questionRevisions/103570"},"attributes":{"stem":"\u003Cp\u003EA 19-year-man presents to his general practitioner requesting STI testing after notification from a casual partner who has tested positive to Chlamydia. This young man has had three casual female partners over the past six months with whom he sometimes uses condoms. He identifies as heterosexual and has only engaged in oral and vaginal sex.\u003C/p\u003E\u003Cp\u003EHe is asymptomatic, so a first pass urine test is performed for chlamydia and gonorrhoea. He is offered testing for blood borne viruses and agrees. He is provided with an STI fact sheet and a follow-up appointment arranged. His test returns positive for Chlamydia trachomatis.\u003C/p\u003E","stemQuestion":"Which one of the following would be the most appropriate treatment?","responseType":"sba","marks":1,"options":["Azithromycin 1g PO, stat + doxycycline 100mg PO, BD for 3 days","Azithromycin 1g PO, stat, with a test of cure 7 days later","Azithromycin 1g PO, stat","Clarithromycin 1g PO, stat","Doxycycline 100mg PO, BD 7 days"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThe Australian STI Management Guidelines now recommend \u003Cstrong\u003Edoxycycline 100mg PO, BD 7 days \u003C/strong\u003Eas treatment for uncomplicated genital chlamydia.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAzithromycin 1g PO, stat \u003C/strong\u003Eis the alternative treatment but should be preserved for cases where the patient is unlikely to be compliant to the above treatment. \u003Cstrong\u003EA test of cure\u003C/strong\u003E is typically recommended for pregnant people and for people with an anorectal infection. However, this patient should be tested for re-infection in three months.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Recommended treatment for uncomplicated genital chlamydia infections is now doxycycline for 7 days.","Azithromycin is an alternative treatment for chlamydia but is less preferred due to concerns about resistance."],"references":["Chlamydia - STI Guidelines Australia [Internet]. STI Guidelines Australia. 2021. Available from: https://sti.guidelines.org.au/sexually-transmissible-infections/chlamydia/","Rodrigues R, Marques L, Vieira-Baptista P, Sousa C, Vale N. Therapeutic Options for Chlamydia trachomatis Infection: Present and Future. Antibiotics (Basel). 2022 Nov 16;11(11):1634. doi: 10.3390/antibiotics11111634. PMID: 36421278; PMCID: PMC9686482. Available from: https://pmc.ncbi.nlm.nih.gov/articles/PMC9686482/","Fairley CK, Hocking JS, Kong FYS. Doxycycline: the universal treatment for anogenital chlamydia. Lancet Infect Dis. 2022 Aug;22(8):1102-1103. doi: 10.1016/S1473-3099(22)00173-6. Epub 2022 May 9. PMID: 35550260. Available from: https://pubmed.ncbi.nlm.nih.gov/35550260/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"85987"}},"question":{"data":{"type":"questions","id":"12185"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"85987","links":{"self":"https://app.emedici.com/api/itemRevisions/85987"},"attributes":{"createdAt":"2025-05-23T20:49:33+09:30","updatedAt":"2025-05-23T20:50:15+09:30"},"relationships":{"item":{"data":{"type":"items","id":"4713"}},"content":{"data":{"type":"questionRevisions","id":"103570"}}},"meta":{"canDelete":false}},{"type":"tags","id":"14","links":{"self":"https://app.emedici.com/api/tags/14"},"attributes":{"emoji":"\ud83e\udda0","name":"Infectious Diseases","synonyms":["ID"],"description":null,"position":null,"createdAt":null,"updatedAt":"2021-05-21T07:51:58+09:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"37","links":{"self":"https://app