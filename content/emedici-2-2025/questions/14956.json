{"data":[{"type":"questionAttempts","id":"17585327","links":{"self":"https://app.emedici.com/api/questionAttempts/17585327"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T08:09:11+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T08:09:11+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"14956"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"14956","links":{"self":"https://app.emedici.com/api/questions/14956"},"attributes":{"optionProportions":[0.2,0.57,0.09,0.06,0.08]},"relationships":{"item":{"data":{"type":"items","id":"7644"}},"activeRevision":{"data":{"type":"questionRevisions","id":"64328"}}}},{"type":"items","id":"7644","links":{"self":"https://app.emedici.com/api/items/7644"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"14956"}},"activeRevision":{"data":{"type":"itemRevisions","id":"49760"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4927"},{"type":"tags","id":"4936"},{"type":"tags","id":"4944"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"6798"},{"type":"tags","id":"7567"},{"type":"tags","id":"7882"},{"type":"tags","id":"8109"}]},"contributions":{"data":[{"type":"contributions","id":"18698"},{"type":"contributions","id":"18701"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"64328","links":{"self":"https://app.emedici.com/api/questionRevisions/64328"},"attributes":{"stem":"\u003Cp\u003ECommunity-acquired pneumonia is a common childhood illness, with viral pathogens being particularly prevalent in children under two years of age.\u003C/p\u003E","stemQuestion":"Which one of the following viruses is the most commonly identified cause of viral community-acquired pneumonia in children?","responseType":"sba","marks":1,"options":["Influenza A virus","Respiratory syncytial virus","Parainfluenza virus","Influenza B virus","Adenovirus"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EInfluenza A virus\u003C/strong\u003E causes seasonal epidemics of respiratory illness but is not the most common cause of viral pneumonia in children. \u003Cstrong\u003ERespiratory syncytial virus\u003C/strong\u003E is the leading viral cause of community-acquired pneumonia in children, particularly affecting those under two years of age. It accounts for approximately 20-30% of all pneumonia cases in young children.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EParainfluenza virus\u003C/strong\u003E commonly causes croup but is less frequently associated with pneumonia. \u003Cstrong\u003EInfluenza B virus\u003C/strong\u003E typically causes milder disease than Influenza A and is less common. \u003Cstrong\u003EAdenovirus\u003C/strong\u003E can cause severe pneumonia but accounts for a smaller percentage of cases compared to RSV.\u003C/p\u003E\u003Cp\u003EIn paediatric populations, viral community-acquired pneumonia (CAP) is predominantly caused by RSV, which peaks during winter months. RSV can lead to significant lower respiratory tract infections, including bronchiolitis and pneumonia. Nearly all children have been infected with RSV by age two.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Respiratory syncytial virus (RSV) is the most common viral cause of community-acquired pneumonia in children.","RSV causes significant lower respiratory tract infections in children under 2 years of age.","Viral pneumonia accounts for approximately 80% of community-acquired pneumonia cases in children under 2 years."],"references":["Sastry, A. S., \u0026 Bhat, S. (2018). Essentials of medical microbiology. JP Medical Ltd","Kumar, V., Abbas, A. K., \u0026 Aster, J. C. (Eds.). (2012). Robbins basic pathology e-book. Elsevier Health Sciences","Vaughn VM, Dickson RP, Horowitz JK, Flanders SA. Community-Acquired Pneumonia: A Review. JAMA. 2024 Oct 15;332(15):1282-1295. doi: 10.1001/jama.2024.14796. PMID: 39283629","Popovsky EY, Florin TA. Community-Acquired Pneumonia in Childhood. Encyclopedia of Respiratory Medicine. 2022:119\u201331. doi: 10.1016/B978-0-08-102723-3.00013-5. Epub 2021 Sep 17. PMCID: PMC7458534."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"49760"}},"question":{"data":{"type":"questions","id":"14956"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"49760","links":{"self":"https://app.emedici.com/api/itemRevisions/49760"},"attributes":{"createdAt":"2024-11-23T12:29:31+10:30","updatedAt":"2024-11-23T12:30:29+10:30"},"relationships":{"item":{"data":{"type":"items","id":"7644"}},"content":{"data":{"type":"questionRevisions","id":"64328"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"item