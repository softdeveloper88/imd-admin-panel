{"data":[{"type":"questionAttempts","id":"17583075","links":{"self":"https://app.emedici.com/api/questionAttempts/17583075"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T07:06:32+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T07:06:32+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"1962"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"1962","links":{"self":"https://app.emedici.com/api/questions/1962"},"relationships":{"item":{"data":{"type":"items","id":"1962"}},"activeRevision":{"data":{"type":"questionRevisions","id":"85598"}}}},{"type":"items","id":"1962","links":{"self":"https://app.emedici.com/api/items/1962"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1962"}},"activeRevision":{"data":{"type":"itemRevisions","id":"69890"}},"tags":{"data":[{"type":"tags","id":"42"},{"type":"tags","id":"65"},{"type":"tags","id":"72"},{"type":"tags","id":"74"},{"type":"tags","id":"3779"},{"type":"tags","id":"4936"},{"type":"tags","id":"4945"},{"type":"tags","id":"7992"}]},"contributions":{"data":[{"type":"contributions","id":"802"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"85598","links":{"self":"https://app.emedici.com/api/questionRevisions/85598"},"attributes":{"stem":"\u003Cp\u003EA 32-year-old man presents to the General Practice clinic for initiation of antiretroviral therapy following a new diagnosis of human immunodeficiency virus (HIV) infection. He has no significant medical history and takes no regular medications. On examination, he appears well with vital signs within normal limits.\u003C/p\u003E","stemQuestion":"Which one of the following HLA polymorphisms is most strongly associated with severe hypersensitivity reactions to abacavir?","responseType":"sba","marks":1,"options":["HLA-B*5701","HLA-B*5801","HLA-B*1502","HLA-B27","HLA-A*3101"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EPharmacogenetic testing has become an important tool in preventing severe adverse drug reactions. \u003Cstrong\u003EHLA-B*5701\u003C/strong\u003E screening is mandatory before initiating abacavir therapy due to the risk of life-threatening hypersensitivity reactions, which occur in approximately 5% of patients. These reactions typically present with fever, rash, gastrointestinal symptoms, and respiratory symptoms within the first six weeks of therapy.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHLA-B*5801\u003C/strong\u003E is associated with severe cutaneous adverse reactions to allopurinol, particularly in individuals of Asian descent. Testing is recommended before starting allopurinol in these populations.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHLA-B*1502\u003C/strong\u003E is associated with Stevens-Johnson syndrome and toxic epidermal necrolysis in patients taking carbamazepine, particularly in individuals of Southeast Asian descent. Testing is recommended in these populations before starting carbamazepine.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHLA-B27\u003C/strong\u003E is associated with various autoimmune conditions including ankylosing spondylitis, reactive arthritis, and anterior uveitis, but is not associated with drug reactions.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHLA-A*3101\u003C/strong\u003E is associated with carbamazepine-induced hypersensitivity reactions in European populations, but the association is not as strong as that between HLA-B*5701 and abacavir reactions.\u003C/p\u003E","optionExplanations":null,"learningPoints":["HLA-B*5701 testing is mandatory before initiating abacavir therapy due to risk of severe hypersensitivity reactions.","Different HLA polymorphisms are associated with drug reactions in specific ethnic populations.","Genetic screening can prevent severe adverse drug reactions by identifying at-risk patients before drug administration."],"references":["Fan WL et al, 2017. \u2018HLA Association with Drug-Induced Adverse Reactions\u2019 in Journal of Immunology Research, vol. 2017."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"69890"}},"question":{"data":{"type":"questions","id":"1962"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"69890","links":{"self":"https://app.emedici.com/api/itemRevisions/69890"},"attributes":{"createdAt":"2025-02-16T20:58:58+10:30","updatedAt":"2025-02-16T21:00:35+10:30"},"relationships":{"item":{"data":{"type":"items","id":"1962"}},"content":{"data":{"type":"questionRevisions","id":"85598"}}},"meta":{"canDelete":false}},{"type":"tags","id":"42","links":{"self":"https://app.emedici.com/api/tags/42"},"attributes":{"emoji":"\ud83e\uddec","name":"Genetics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"4"}}},"meta":{"itemCount":0}},{"type":"tags","id":"65","links":{"self":"https://app.emedici.com/api/tags/65"},"attributes":{"emoji":"","name":"Investigations","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"72","links":{"self":"https://app.emedici.com/api/tags/72"},"attributes":{"emoji":"","name":"Graduating","synonyms":null,"description":"Only suitable for a graduating medical student at the end of their degree","position":1,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"de