{"data":[{"type":"questionAttempts","id":"17604590","links":{"self":"https://app.emedici.com/api/questionAttempts/17604590"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T12:56:03+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T12:56:03+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15848"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15848","links":{"self":"https://app.emedici.com/api/questions/15848"},"attributes":{"optionProportions":[0.03,0.02,0.94,0,0.02]},"relationships":{"item":{"data":{"type":"items","id":"8539"}},"activeRevision":{"data":{"type":"questionRevisions","id":"66496"}}}},{"type":"items","id":"8539","links":{"self":"https://app.emedici.com/api/items/8539"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15848"}},"activeRevision":{"data":{"type":"itemRevisions","id":"51949"}},"tags":{"data":[{"type":"tags","id":"22"},{"type":"tags","id":"31"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4100"},{"type":"tags","id":"4935"},{"type":"tags","id":"4936"},{"type":"tags","id":"4937"},{"type":"tags","id":"4944"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"7026"},{"type":"tags","id":"7882"},{"type":"tags","id":"8095"}]},"contributions":{"data":[{"type":"contributions","id":"20486"},{"type":"contributions","id":"20489"},{"type":"contributions","id":"22246"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"66496","links":{"self":"https://app.emedici.com/api/questionRevisions/66496"},"attributes":{"stem":"\u003Cp\u003ECervical cancer is the fourth most common cancer affecting women globally. The vast majority of cases begin in the transformation zone of the cervix where columnar epithelium meets squamous epithelium. An infectious agent is a key factor in the development of these squamous cell carcinomas of the cervix.\u003C/p\u003E","stemQuestion":"Which one of the following is the primary causative agent?","responseType":"sba","marks":1,"options":["Herpes simplex virus","Human immunodeficiency virus","Human papillomavirus","Mycobacterium tuberculosis","Epstein-Barr virus"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EHuman papillomavirus (HPV)\u003C/strong\u003E is responsible for over 99% of cervical cancers, particularly high-risk types 16 and 18. The virus infects basal cells of the cervical epithelium, integrating its DNA into the host genome and disrupting normal cell cycle regulation through viral proteins E6 and E7.\u003C/p\u003E\u003Cp\u003EWhile \u003Cstrong\u003Eherpes simplex virus\u003C/strong\u003E can cause cervicitis, it does not cause cervical cancer. \u003Cstrong\u003EHuman immunodeficiency virus\u003C/strong\u003E increases the risk of cervical cancer by compromising immune surveillance but is not directly carcinogenic. \u003Cstrong\u003EMycobacterium tuberculosis\u003C/strong\u003E can affect the cervix but does not cause cancer. \u003Cstrong\u003EEpstein-Barr virus\u003C/strong\u003E is associated with nasopharyngeal carcinoma and lymphomas but not cervical cancer.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Human papillomavirus (HPV), particularly types 16 and 18, causes over 99% of cervical cancers","HPV infection of cervical cells leads to integration of viral DNA and disruption of cell cycle control","Persistent high-risk HPV infection is necessary but not sufficient for cervical cancer development"],"references":["Burd EM. Human papillomavirus and cervical cancer. Clin Microbiol Rev. 2003 Jan;16(1):1-17. doi: 10.1128/CMR.16.1.1-17.2003. PMID: 12525422; PMCID: PMC145302.","Okunade KS. Human papillomavirus and cervical cancer. J Obstet Gynaecol. 2020 Jul;40(5):602-608. doi: 10.1080/01443615.2019.1634030. Epub 2019 Sep 10. Erratum in: J Obstet Gynaecol. 2020 May;40(4):590. doi: 10.1080/01443615.2020.1713592. PMID: 31500479; PMCID: PMC7062568.","Arulkumaran, S., Ledger, W., Denny, L., \u0026 Doumouchtsis, S. (Eds.). (2019). Oxford Textbook of Obstetrics and Gynaecology. Oxford University Press.","Padubidri, V. G., \u0026 Daftary, S. N. (Eds.). (2014). Shaw\u0027s Textbook of Gynecology E-book. Elsevier health sciences."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"51949"}},"question":{"data":{"type":"questions","id":"15848"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"51949","links":{"self":"https://app.emedici.com/api/itemRevisions/51949"},"attributes":{"createdAt":"2024-11-30T16:54:36+10:30","updatedAt":"2024-11-30T16:55:29+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8539"}},"content":{"data":{"type":"questionRevisions","id":"66496"}}},"meta":{"canDelete":false}},{"type":"tags","id":"22","links":{"self":"https://app.emedici.com/api/tags/22"},"attributes":{"emoji":"\ud83c\udf53","name":"Gynaecology","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"3"}}},"meta":{"itemCount":0}},{"type":"tags","id":"31","links":{"self":"https://app.emedici.com/api/tags/31"},"attributes":{"emoji":"\ud83c\udf97","name":"Oncology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"grou