{"data":[{"type":"questionAttempts","id":"17489496","links":{"self":"https://app.emedici.com/api/questionAttempts/17489496"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T04:18:46+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T04:18:46+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"672"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"672","links":{"self":"https://app.emedici.com/api/questions/672"},"attributes":{"optionProportions":[0.7,0.04,0.04,0.18,0.05]},"relationships":{"item":{"data":{"type":"items","id":"672"}},"activeRevision":{"data":{"type":"questionRevisions","id":"54856"}}}},{"type":"items","id":"672","links":{"self":"https://app.emedici.com/api/items/672"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"672"}},"activeRevision":{"data":{"type":"itemRevisions","id":"40389"}},"tags":{"data":[{"type":"tags","id":"5"},{"type":"tags","id":"65"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"504"},{"type":"tags","id":"4964"},{"type":"tags","id":"4967"},{"type":"tags","id":"4978"},{"type":"tags","id":"9598"},{"type":"tags","id":"11625"}]},"contributions":{"data":[{"type":"contributions","id":"1118"},{"type":"contributions","id":"1430"},{"type":"contributions","id":"18651"},{"type":"contributions","id":"35608"},{"type":"contributions","id":"43806"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"54856","links":{"self":"https://app.emedici.com/api/questionRevisions/54856"},"attributes":{"stem":"\u003Cp\u003EA 32-year-old woman presents with a ten-year history of intermittent, generalised abdominal pain, bloating and loose stools. There is no blood nor mucus passed with the stool. The pain is worse immediately prior to defecation, which then relieves the pain. She gets an episode of such pain about once a week and there do not appear to be any apparent triggers. Her symptoms are persistent, but not getting any worse or more frequent. She is otherwise well and has no significant medical history. There is no family history of bowel cancer. The physical examination is unremarkable. Her full blood count and serum biochemistry are normal.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate next step in management?","responseType":"sba","marks":1,"options":["Lifestyle and dietary modifications","Abdominal ultrasound","Abdominal CT scan","Colonoscopy","Gastroscopy and small bowel biopsy"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient has the irritable bowel syndrome, based on the clinical picture of history, normal examination findings and no blood test abnormalities. This diagnosis must be explained carefully to the patient and she must be reassured that she does not need any investigations. Time must then be taken to provide advice on looking for possible triggers and avoiding issues or foods that might precipitate her symptoms. The focus should be on \u003Cstrong\u003Elifestyle and dietary modifications.\u003C/strong\u003E\u003C/p\u003E\u003Cp\u003EIf there were red flag symptoms present, such as anaemia, rectal bleeding, weight loss or a family history of colorectal cancer, it would be important to further investigate with a colonoscopy. Similarly, if she had other symptoms such as weakness and fatigue, foul-smelling or oily stools, then coeliac disease might need to be considered and excluded. Serology, gastroscopy and small bowel biopsy is diagnostic for coeliac disease, but there is nothing in the history to suggest such a diagnosis.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Most cases of irritable bowel syndrome do not need any formal investigations"],"references":["Camilleri M. Diagnosis and Treatment of Irritable Bowel Syndrome A Review. JAMA 2021; 325:865-77."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"40389"}},"question":{"data":{"type":"questions","id":"672"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"40389","links":{"self":"https://app.emedici.com/api/itemRevisions/40389"},"attributes":{"createdAt":"2024-10-11T09:21:06+10:30","updatedAt":"2024-10-11T09:29:59+10:30"},"relationships":{"item":{"data":{"type":"items","id":"672"}},"content":{"data":{"type":"questionRevisions","id":"54856"}}},"meta":{"canDelete":false}},{"type":"tags","id":"5","links":{"self":"https://app.emedici.com/api/tags/5"},"attributes":{"emoji":"\ud83d\udd2d","name":"Gastroenterology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"65","links":{"self":"https://app.emedici.com/api/tags/65"},"attributes":{"emoji":"","name":"Investigations","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"72","links":{"self":"https://app.emedici.com/api/tags/72"},"attributes":{"emoji":"","name":"Graduating","synonyms":null,"description":"Only suitable for a graduating medical student at the end of their degree","position":1,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Level II","synonyms":null,"description":"Understand (interpreting and summarizing information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type"