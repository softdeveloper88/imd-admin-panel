{"data":[{"type":"questionAttempts","id":"17636678","links":{"self":"https://app.emedici.com/api/questionAttempts/17636678"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T18:31:58+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T18:31:58+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17597"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17597","links":{"self":"https://app.emedici.com/api/questions/17597"},"attributes":{"optionProportions":[0.04,0.04,0.04,0.22,0.65]},"relationships":{"item":{"data":{"type":"items","id":"10311"}},"activeRevision":{"data":{"type":"questionRevisions","id":"71433"}}}},{"type":"items","id":"10311","links":{"self":"https://app.emedici.com/api/items/10311"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17597"}},"activeRevision":{"data":{"type":"itemRevisions","id":"56942"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"4948"},{"type":"tags","id":"5326"},{"type":"tags","id":"7796"},{"type":"tags","id":"7797"}]},"contributions":{"data":[{"type":"contributions","id":"24106"},{"type":"contributions","id":"24112"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"71433","links":{"self":"https://app.emedici.com/api/questionRevisions/71433"},"attributes":{"stem":"\u003Cp\u003EClinical trials often employ various methods to reduce bias in research studies.\u003C/p\u003E","stemQuestion":"Which one of the following best describes double-blinding in a clinical trial?","responseType":"sba","marks":1,"options":["Participants receive two different treatments without knowing the order","Two different research teams assess each participant independently","Only participants are unaware of treatment allocation","Neither participants nor any study personnel know treatment allocation","Neither participants nor researchers who interact with participants know treatment allocation"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EIn a double-blind clinical trial, \u003Cstrong\u003Eneither the participants nor the researchers who interact with participants know the treatment allocation\u003C/strong\u003E. This prevents both participant and researcher expectations from influencing the study outcomes.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EParticipants receive two different treatments without knowing the order\u003C/strong\u003E - This describes a crossover trial design rather than blinding\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ETwo different research teams assess each participant independently\u003C/strong\u003E - This describes inter-rater reliability testing rather than blinding\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EOnly participants are unaware of treatment allocation\u003C/strong\u003E - This describes single-blinding, which provides less protection against bias than double-blinding\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ENeither participants nor any study personnel know treatment allocation\u003C/strong\u003E - Some study personnel must know the allocation to prepare treatments and maintain safety\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EIn practice, double-blinding requires careful planning. Third-party personnel prepare identical-appearing interventions and maintain allocation codes. The codes are only broken after data collection or in case of emergency.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Double-blinding in clinical trials means neither participants nor researchers directly interacting with participants know treatment allocation.","Blinding helps prevent bias from expectations and beliefs affecting study outcomes.","Third-party personnel maintain treatment allocation codes and prepare identical-appearing interventions."],"references":["Sullivan LM. Essentials of biostatistics in public health. 3rd ed. Burlington (MA): Jones \u0026 Bartlett Learning; 2018.","Dawson B, Trapp RG. Basic \u0026 clinical biostatistics. 4th ed. New York: McGraw-Hill; 2004."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"56942"}},"question":{"data":{"type":"questions","id":"17597"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"56942","links":{"self":"https://app.emedici.com/api/itemRevisions/56942"},"attributes":{"createdAt":"2024-12-18T15:54:00+10:30","updatedAt":"2024-12-18T15:59:22+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10311"}},"content":{"data":{"type":"questionRevisions","id":"71433"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Level II","synonyms":null,"description":"Understand (interpreting and summarizing information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4948","links":{"self