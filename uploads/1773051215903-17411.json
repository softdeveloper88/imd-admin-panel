{"data":[{"type":"questionAttempts","id":"17631991","links":{"self":"https://app.emedici.com/api/questionAttempts/17631991"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T17:35:38+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T17:35:38+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17411"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17411","links":{"self":"https://app.emedici.com/api/questions/17411"},"attributes":{"optionProportions":[0.05,0,0.95,0,0]},"relationships":{"item":{"data":{"type":"items","id":"10101"}},"activeRevision":{"data":{"type":"questionRevisions","id":"70508"}}}},{"type":"items","id":"10101","links":{"self":"https://app.emedici.com/api/items/10101"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17411"}},"activeRevision":{"data":{"type":"itemRevisions","id":"55972"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5446"}]},"contributions":{"data":[{"type":"contributions","id":"23663"},{"type":"contributions","id":"23664"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"70508","links":{"self":"https://app.emedici.com/api/questionRevisions/70508"},"attributes":{"stem":"\u003Cp\u003EHealthcare providers frequently encounter patients or parents who express concerns about vaccination. Understanding common reasons for vaccine hesitancy is essential for effective communication.\u003C/p\u003E","stemQuestion":"Which one of the following is the most commonly cited reason for vaccine refusal in developed countries?","responseType":"sba","marks":1,"options":["Lack of time to attend appointments","Religious objections","Concerns about vaccine safety","Cost of vaccines","Preference for alternative medicine"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EConcerns about vaccine safety\u003C/strong\u003E represent the most frequently cited reason for vaccine refusal in developed countries. These concerns often stem from misinformation about adverse effects and misconceptions about vaccine ingredients.\u003C/p\u003E    \u003Cp\u003EThe other reasons are less commonly cited:\u003C/p\u003E    \u003Cul\u003E        \u003Cli\u003E\u003Cstrong\u003EReligious objections\u003C/strong\u003E represent a small minority of cases, with most major religions supporting vaccination programmes.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003ECost of vaccines\u003C/strong\u003E is rarely a barrier in developed countries as vaccines are typically provided free through public immunisation programmes.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003ELack of time to attend appointments\u003C/strong\u003E is occasionally mentioned but studies show this is more often an excuse rather than the primary reason for vaccine refusal.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EPreference for alternative medicine\u003C/strong\u003E influences some decisions but research shows this is not the predominant factor in vaccine refusal.\u003C/li\u003E    \u003C/ul\u003E    \u003Cp\u003EUnderstanding that safety concerns are the primary driver of vaccine hesitancy helps healthcare providers focus their communication strategies on addressing these specific concerns with evidence-based information.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Vaccine hesitancy is driven by concerns about safety, religious/philosophical beliefs, and misinformation about vaccine risks.","Common vaccine misconceptions include beliefs about autism links, natural immunity superiority, and vaccine ingredient toxicity.","Healthcare providers play a crucial role in addressing vaccine hesitancy through evidence-based communication."],"references":["Shen SC, Dubey V. Addressing vaccine hesitancy: Clinical guidance for primary care physicians working with parents. Can Fam Physician. 2019 Mar;65(3):175-181. PMID: 30867173; PMCID: PMC6515949.","Shultz JM, Sullivan LM, Galea S. Public Health: An Introduction to the Science and Practice of Population Health. Springer Publishing Company; 2021."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"55972"}},"question":{"data":{"type":"questions","id":"17411"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"55972","links":{"self":"https://app.emedici.com/api/itemRevisions/55972"},"attributes":{"createdAt":"2024-12-15T18:57:11+10:30","updatedAt":"2024-12-15T18:57:45+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10101"}},"content":{"data":{"type":"questionRevisions","id":"70508"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tag