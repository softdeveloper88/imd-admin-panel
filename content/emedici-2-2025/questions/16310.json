{"data":[{"type":"questionAttempts","id":"17613151","links":{"self":"https://app.emedici.com/api/questionAttempts/17613151"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T14:36:25+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T14:36:25+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16310"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"16310","links":{"self":"https://app.emedici.com/api/questions/16310"},"relationships":{"item":{"data":{"type":"items","id":"9001"}},"activeRevision":{"data":{"type":"questionRevisions","id":"66589"}}}},{"type":"items","id":"9001","links":{"self":"https://app.emedici.com/api/items/9001"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16310"}},"activeRevision":{"data":{"type":"itemRevisions","id":"52042"}},"tags":{"data":[{"type":"tags","id":"7"},{"type":"tags","id":"35"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"2089"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"5586"},{"type":"tags","id":"5851"},{"type":"tags","id":"5931"},{"type":"tags","id":"7198"},{"type":"tags","id":"9718"}]},"contributions":{"data":[{"type":"contributions","id":"21424"},{"type":"contributions","id":"21428"},{"type":"contributions","id":"22172"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"66589","links":{"self":"https://app.emedici.com/api/questionRevisions/66589"},"attributes":{"stem":"\u003Cp\u003EA 55-year-old man presents to clinic with episodes of vertigo lasting several hours to days, accompanied by tinnitus and hearing loss. His parent had similar symptoms. He has no history of recent infections.\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Benign paroxysmal positional vertigo","Labyrinthitis","Meniere\u0027s disease","Vestibular neuritis","Migraine"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EThe clinical presentation strongly suggests \u003Cstrong\u003EMeniere\u0027s disease\u003C/strong\u003E. The classic triad includes episodic vertigo lasting hours, fluctuating sensorineural hearing loss, and tinnitus. The family history also supports this diagnosis, as there is often a genetic component.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EBenign paroxysmal positional vertigo (BPPV)\u003C/strong\u003E typically causes brief episodes of vertigo lasting seconds to minutes and is triggered by head position changes. \u003Cstrong\u003ELabyrinthitis\u003C/strong\u003E usually follows an infection and causes persistent rather than episodic symptoms. \u003Cstrong\u003EVestibular neuritis\u003C/strong\u003E presents with acute onset vertigo without hearing loss.\u003C/p\u003E\u003Cp\u003EA\u003Cstrong\u003E migraine \u003C/strong\u003Eheadache could cause these symptoms, but they would be very unlikely to be so persistent.\u003C/p\u003E\u003Cp\u003EMeniere\u0027s disease is thought to be caused by endolymphatic hydrops - an excess of endolymph fluid in the membranous labyrinth of the inner ear. This leads to periodic symptoms when the pressure becomes excessive.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Meniere\u0027s disease is characterized by episodes of vertigo, fluctuating hearing loss, tinnitus, and aural fullness.","Meniere\u0027s disease is thought to be caused by endolymphatic hydrops, an excess of endolymph fluid in the inner ear.","There is often a family history in Meniere\u0027s disease, suggesting genetic factors may play a role."],"references":["Wright T. Meni\u00e8re\u0027s disease. BMJ Clin Evid. 2015 Nov 5;2015:0505. PMID: 26545070; PMCID: PMC4636025.","G\u00fcrkov R, Pyyk\u00f6 I, Zou J, Kentala E. What is Meni\u00e8re\u0027s disease? A contemporary re-evaluation of endolymphatic hydrops. J Neurol. 2016 Apr;263 Suppl 1:S71-81. doi: 10.1007/s00415-015-7930-1. Epub 2016 Apr 15. PMID: 27083887; PMCID: PMC4833790.","Koenen L, Andaloro C. Meniere Disease. 2023 Aug 21. In: StatPearls [Internet]. Treasure Island (FL): StatPearls Publishing; 2024 Jan\u2013. PMID: 30725640.","Nakashima T, Pyykk\u00f6 I, Arroll MA, Casselbrant ML, Foster CA, Manzoor NF, Megerian CA, Naganawa S, Young YH. Meniere\u0027s disease. Nat Rev Dis Primers. 2016 May 12;2:16028. doi: 10.1038/nrdp.2016.28. PMID: 27170253."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"52042"}},"question":{"data":{"type":"questions","id":"16310"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"52042","links":{"self":"https://app.emedici.com/api/itemRevisions/52042"},"attributes":{"createdAt":"2024-12-01T09:53:24+10:30","updatedAt":"2024-12-01T09:54:00+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9001"}},"content":{"data":{"type":"questionRevisions","id":"66589"}}},"meta":{"canDelete":false}},{"type":"tags","id":"7","links":{"self":"https://app.emedici.com/api/tags/7"},"attributes":{"emoji":"\ud83e\udde0","name":"Neurology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"35","links":{"self":"https://app.emedici.com/api/tags/35"},"attributes":{"emoji":"\ud83d\udc43","name":"Otorhinolaryngology","synonyms":["ENT","HEENT"],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:40:48+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"2"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emed