<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard – iMD Admin</title>
  <style>
    :root {
      --bg: #f4efe7; --panel: rgba(255,251,245,0.9); --panel-strong: #fffdf8;
      --ink: #1d2a2f; --muted: #66757e; --line: rgba(35,50,58,0.12);
      --brand: #0f766e; --brand-deep: #0b4f49;
      --danger: #b42318; --danger-bg: #fff0ed;
      --success: #0f7b4d; --success-bg: #edf9f0;
      --warn: #b45309;
      --shadow: 0 22px 50px rgba(31,38,43,0.12); --radius: 22px;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:"Avenir Next","Helvetica Neue","Segoe UI",sans-serif;color:var(--ink);background:radial-gradient(circle at top left,rgba(15,118,110,0.14),transparent 26%),radial-gradient(circle at top right,rgba(217,119,6,0.12),transparent 20%),linear-gradient(180deg,#f8f2e8 0%,var(--bg) 100%);min-height:100vh;display:flex}
    a{color:inherit}
    .sidebar{width:250px;min-height:100vh;background:linear-gradient(180deg,rgba(12,58,69,0.97),rgba(22,90,84,0.93));color:#f9fafb;padding:0;flex-shrink:0;position:fixed;left:0;top:0;bottom:0;z-index:100;transition:transform .2s}
    .sidebar-header{padding:20px 18px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,0.1)}
    .logo{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:700}
    .logo-icon{font-size:24px}
    .sidebar-toggle{background:none;border:none;color:#f9fafb;font-size:20px;cursor:pointer;padding:4px 8px}
    .sidebar-menu{padding:12px 0}
    .menu-section{margin-bottom:8px}
    .menu-label{padding:8px 20px 4px;font-size:10px;text-transform:uppercase;letter-spacing:.1em;opacity:.5}
    .menu-item{display:flex;align-items:center;gap:10px;padding:10px 20px;text-decoration:none;color:rgba(255,255,255,.7);font-size:14px;transition:all .15s}
    .menu-item:hover{background:rgba(255,255,255,.08);color:#fff}
    .menu-item.active{background:rgba(255,255,255,.12);color:#fff;border-left:3px solid #5eead4}
    .menu-icon{font-size:16px;width:22px;text-align:center}
    .main-content{margin-left:250px;flex:1;min-width:0}
    .topbar{display:flex;justify-content:space-between;align-items:center;padding:16px 28px;background:var(--panel);border-bottom:1px solid var(--line)}
    .topbar-left{display:flex;align-items:center;gap:12px}
    .topbar-right{display:flex;align-items:center;gap:16px}
    .breadcrumbs{font-size:14px;color:var(--muted)}
    .breadcrumbs a{color:var(--brand);text-decoration:none}
    .mobile-toggle{display:none;background:none;border:none;font-size:20px;cursor:pointer}
    .btn-logout-sm{background:none;border:1px solid var(--line);padding:6px 14px;border-radius:8px;cursor:pointer;font-size:13px;color:var(--muted)}
    .admin-name{font-size:13px;color:var(--muted)}
    .notif-bell{cursor:pointer;font-size:18px;position:relative}
    .notif-count{position:absolute;top:-6px;right:-8px;background:var(--danger);color:#fff;font-size:10px;padding:1px 5px;border-radius:99px}
    .notif-dropdown{position:absolute;right:80px;top:52px;width:340px;background:#fff;border:1px solid var(--line);border-radius:14px;box-shadow:var(--shadow);z-index:200;max-height:400px;overflow:auto}
    .notif-header{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--line)}
    .notif-mark-all{background:none;border:none;color:var(--brand);cursor:pointer;font-size:12px}
    .notif-item{padding:12px 16px;border-bottom:1px solid rgba(0,0,0,.04);cursor:pointer}
    .notif-item.unread{background:#f0fdf4}
    .notif-title{font-size:13px;font-weight:600}
    .notif-msg{font-size:12px;color:var(--muted);margin-top:2px}
    .notif-time{font-size:11px;color:var(--muted);margin-top:4px}
    .page-content{padding:28px}
    .page-header{margin-bottom:24px}
    .page-title{font-size:28px;font-weight:700;letter-spacing:-0.02em;margin:0}
    .page-subtitle{color:var(--muted);font-size:14px;margin:4px 0 0}
    .stat-cards{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:16px;margin-bottom:24px}
    .stat-card{background:var(--panel);border:1px solid rgba(255,255,255,0.7);border-radius:var(--radius);box-shadow:var(--shadow);padding:20px}
    .stat-label{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:600}
    .stat-value{font-size:32px;font-weight:700;margin:8px 0 4px;font-family:Georgia,serif}
    .card{background:var(--panel);border:1px solid rgba(255,255,255,0.7);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:20px}
    .card-header{padding:20px 24px;border-bottom:1px solid var(--line)}
    .card-body{padding:20px 24px}
    .card-title{font-size:18px;font-weight:700;margin:0}
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
    .grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
    table{width:100%;border-collapse:collapse}
    thead th{padding:12px 16px;text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);border-bottom:2px solid var(--line);font-weight:600}
    tbody td{padding:12px 16px;border-bottom:1px solid rgba(29,42,47,0.06);font-size:14px}
    tbody tr:hover td{background:rgba(255,255,255,0.5)}
    .bar-chart{display:flex;flex-direction:column;gap:8px}
    .bar-row{display:flex;align-items:center;gap:12px}
    .bar-label{width:100px;font-size:13px;color:var(--muted);text-align:right;flex-shrink:0}
    .bar-track{flex:1;height:28px;background:#eee;border-radius:8px;overflow:hidden}
    .bar-fill{height:100%;background:linear-gradient(90deg,var(--brand),#14b8a6);border-radius:8px;display:flex;align-items:center;padding-left:8px;font-size:12px;color:#fff;font-weight:600;min-width:fit-content;transition:width .5s ease}
    .pie-chart{display:flex;gap:20px;align-items:center;flex-wrap:wrap}
    .pie-legend{display:flex;flex-direction:column;gap:8px}
    .pie-legend-item{display:flex;align-items:center;gap:8px;font-size:14px}
    .pie-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0}
    .badge{display:inline-block;padding:4px 10px;border-radius:999px;font-size:11px;font-weight:600;text-transform:uppercase}
    .empty-state{text-align:center;padding:40px;color:var(--muted)}
    .activity-item{padding:12px 0;border-bottom:1px solid rgba(0,0,0,0.04);font-size:13px;display:flex;gap:12px;align-items:flex-start}
    .activity-icon{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
    .activity-icon.user{background:#e0f2fe}
    .activity-icon.download{background:#dcfce7}
    .activity-icon.admin{background:#fef3c7}
    .activity-text{flex:1}
    .activity-time{font-size:11px;color:var(--muted);margin-top:2px}
    @media(max-width:900px){
      .sidebar{transform:translateX(-250px)}.main-content{margin-left:0}.sidebar.show{transform:translateX(0)}.mobile-toggle{display:block}
      .stat-cards{grid-template-columns:repeat(2,1fr)}.grid-2,.grid-3{grid-template-columns:1fr}
    }
    @media(max-width:600px){.stat-cards{grid-template-columns:1fr}.page-content{padding:16px}}
  </style>
</head>
<body>
  <%- include('partials/sidebar', { activePage: 'dashboard' }) %>
  <div class="main-content">
    <%- include('partials/header', { breadcrumb: 'Dashboard', currentAdminUser: typeof currentAdminUser !== 'undefined' ? currentAdminUser : 'Admin' }) %>
    <div class="page-content">
      <div class="page-header">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Overview of platform usage, downloads, and user activity</p>
      </div>

      <div class="stat-cards">
        <div class="stat-card"><div class="stat-label">Total Users</div><div class="stat-value" id="sUsers">–</div></div>
        <div class="stat-card"><div class="stat-label">Active Users</div><div class="stat-value" id="sActive">–</div></div>
        <div class="stat-card"><div class="stat-label">Active Sessions</div><div class="stat-value" id="sSessions">–</div></div>
        <div class="stat-card"><div class="stat-label">Total Downloads</div><div class="stat-value" id="sDownloads">–</div></div>
        <div class="stat-card"><div class="stat-label">Packages</div><div class="stat-value" id="sPackages">–</div></div>
      </div>

      <div class="grid-2">
        <div class="card">
          <div class="card-header"><h2 class="card-title">Subscription Distribution</h2></div>
          <div class="card-body">
            <div class="pie-chart">
              <div class="pie-legend" id="subDistribution">
                <p class="empty-state">Loading...</p>
              </div>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h2 class="card-title">Top Downloads</h2></div>
          <div class="card-body">
            <div class="bar-chart" id="topDownloads">
              <p class="empty-state">Loading...</p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid-2">
        <div class="card">
          <div class="card-header"><h2 class="card-title">Recent Downloads</h2></div>
          <div class="card-body" style="padding:0;overflow-x:auto">
            <table>
              <thead><tr><th>User</th><th>Package</th><th>Date</th></tr></thead>
              <tbody id="recentDownloadsBody"><tr><td colspan="3" class="empty-state">Loading...</td></tr></tbody>
            </table>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h2 class="card-title">Recent Admin Activity</h2></div>
          <div class="card-body" id="recentActivity">
            <p class="empty-state">Loading...</p>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h2 class="card-title">Revenue Overview</h2></div>
        <div class="card-body">
          <div class="grid-3" id="revenueCards" style="margin-bottom:20px">
            <div class="stat-card"><div class="stat-label">Total Revenue</div><div class="stat-value" id="sTotalRev" style="color:var(--success)">$–</div></div>
            <div class="stat-card"><div class="stat-label">Monthly Revenue</div><div class="stat-value" id="sMonthRev" style="color:var(--success)">$–</div></div>
            <div class="stat-card"><div class="stat-label">Paid Subscribers</div><div class="stat-value" id="sPaidCount">–</div></div>
          </div>
          <div class="bar-chart" id="revenueChart">
            <p class="empty-state">Loading revenue data...</p>
          </div>
        </div>
      </div>
    </div>
  </div>

<script>
function esc(s){const d=document.createElement('div');d.textContent=s||'';return d.innerHTML}
function fmtDate(d){return d?new Date(d).toLocaleDateString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}):'—'}
function fmtMoney(n){return '$'+(parseFloat(n)||0).toFixed(2)}
function toggleSidebar(){document.body.classList.toggle('collapsed');const sb=document.querySelector('.sidebar');sb&&sb.classList.toggle('show')}

const colors = ['#0f766e','#0369a1','#b45309','#b42318','#7c3aed','#059669'];

async function loadAnalytics() {
  try {
    const [analytics, revenue] = await Promise.all([
      fetch('/api/admin/analytics').then(r=>r.json()),
      fetch('/api/admin/revenue').then(r=>r.json())
    ]);

    document.getElementById('sUsers').textContent = analytics.total_users;
    document.getElementById('sActive').textContent = analytics.active_users;
    document.getElementById('sSessions').textContent = analytics.active_sessions;
    document.getElementById('sDownloads').textContent = analytics.total_downloads;
    document.getElementById('sPackages').textContent = analytics.total_packages;

    // Subscription distribution
    const distEl = document.getElementById('subDistribution');
    if (analytics.subscription_counts && analytics.subscription_counts.length) {
      const total = analytics.subscription_counts.reduce((s,c)=>s+c.count,0);
      distEl.innerHTML = analytics.subscription_counts.map((c,i) => {
        const pct = total > 0 ? Math.round(c.count/total*100) : 0;
        return '<div class="pie-legend-item"><div class="pie-dot" style="background:' + colors[i%colors.length] + '"></div>' +
          '<span><strong>' + esc(c.subscription_type) + '</strong> — ' + c.count + ' users (' + pct + '%)</span></div>';
      }).join('');
    } else {
      distEl.innerHTML = '<p class="empty-state">No data</p>';
    }

    // Top downloads bar chart
    const dlEl = document.getElementById('topDownloads');
    if (analytics.top_downloads && analytics.top_downloads.length) {
      const maxDl = Math.max(...analytics.top_downloads.map(d=>d.download_count));
      dlEl.innerHTML = analytics.top_downloads.slice(0,8).map(d => {
        const pct = maxDl > 0 ? Math.round(d.download_count/maxDl*100) : 0;
        const shortName = (d.package_name||'').length > 15 ? d.package_name.slice(0,15)+'…' : d.package_name;
        return '<div class="bar-row"><div class="bar-label" title="' + esc(d.package_name) + '">' + esc(shortName) + '</div>' +
          '<div class="bar-track"><div class="bar-fill" style="width:' + pct + '%">' + d.download_count + '</div></div></div>';
      }).join('');
    } else {
      dlEl.innerHTML = '<p class="empty-state">No download data</p>';
    }

    // Recent downloads table
    const rdBody = document.getElementById('recentDownloadsBody');
    if (analytics.recent_downloads && analytics.recent_downloads.length) {
      rdBody.innerHTML = analytics.recent_downloads.slice(0,10).map(d =>
        '<tr><td>' + esc(d.username) + '</td><td>' + esc(d.package_name) + '</td><td>' + fmtDate(d.downloaded_at) + '</td></tr>'
      ).join('');
    } else {
      rdBody.innerHTML = '<tr><td colspan="3" class="empty-state">No downloads yet</td></tr>';
    }

    // Recent admin activity
    const actEl = document.getElementById('recentActivity');
    if (analytics.recent_activity && analytics.recent_activity.length) {
      actEl.innerHTML = analytics.recent_activity.slice(0,10).map(a => {
        const iconClass = a.target_type === 'user' ? 'user' : a.target_type === 'download' ? 'download' : 'admin';
        const icon = a.target_type === 'user' ? '👤' : a.target_type === 'package' ? '📦' : '⚙️';
        return '<div class="activity-item">' +
          '<div class="activity-icon ' + iconClass + '">' + icon + '</div>' +
          '<div class="activity-text"><strong>' + esc(a.admin_username||'system') + '</strong> ' + esc(a.action) +
          ' on ' + esc(a.target_type || '') + (a.target_id ? ' #' + a.target_id : '') +
          '<div class="activity-time">' + fmtDate(a.created_at) + '</div></div></div>';
      }).join('');
    } else {
      actEl.innerHTML = '<p class="empty-state">No activity yet</p>';
    }

    // Revenue
    document.getElementById('sTotalRev').textContent = fmtMoney(revenue.total_revenue);
    document.getElementById('sMonthRev').textContent = fmtMoney(revenue.monthly_revenue);
    const paidSubs = analytics.subscription_counts ? analytics.subscription_counts.filter(c=>c.subscription_type!=='free').reduce((s,c)=>s+c.count,0) : 0;
    document.getElementById('sPaidCount').textContent = paidSubs;

    const revChart = document.getElementById('revenueChart');
    if (revenue.revenue_by_month && revenue.revenue_by_month.length) {
      const maxRev = Math.max(...revenue.revenue_by_month.map(r=>parseFloat(r.revenue)||0));
      revChart.innerHTML = revenue.revenue_by_month.map(r => {
        const pct = maxRev > 0 ? Math.round((parseFloat(r.revenue)||0)/maxRev*100) : 0;
        return '<div class="bar-row"><div class="bar-label">' + esc(r.month) + '</div>' +
          '<div class="bar-track"><div class="bar-fill" style="width:' + pct + '%">' + fmtMoney(r.revenue) + '</div></div></div>';
      }).join('');
    } else {
      revChart.innerHTML = '<p class="empty-state">No revenue data yet</p>';
    }

  } catch(e) {
    console.error('Analytics load error:', e);
  }
}

loadAnalytics();
</script>
</body>
</html>
