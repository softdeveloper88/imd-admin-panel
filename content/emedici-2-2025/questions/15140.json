{"data":[{"type":"questionAttempts","id":"17588428","links":{"self":"https://app.emedici.com/api/questionAttempts/17588428"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T09:07:45+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T09:07:45+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15140"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15140","links":{"self":"https://app.emedici.com/api/questions/15140"},"attributes":{"optionProportions":[0.54,0.04,0.27,0,0.15]},"relationships":{"item":{"data":{"type":"items","id":"7828"}},"activeRevision":{"data":{"type":"questionRevisions","id":"66806"}}}},{"type":"items","id":"7828","links":{"self":"https://app.emedici.com/api/items/7828"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15140"}},"activeRevision":{"data":{"type":"itemRevisions","id":"52260"}},"tags":{"data":[{"type":"tags","id":"9"},{"type":"tags","id":"25"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"152"},{"type":"tags","id":"4933"},{"type":"tags","id":"4936"},{"type":"tags","id":"4950"},{"type":"tags","id":"7882"},{"type":"tags","id":"8115"}]},"contributions":{"data":[{"type":"contributions","id":"19088"},{"type":"contributions","id":"19090"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"66806","links":{"self":"https://app.emedici.com/api/questionRevisions/66806"},"attributes":{"stem":"\u003Cp\u003EA clinician needs to obtain a urine specimen for culture from a six-month-old infant with suspected urinary tract infection. The infant is wearing nappies and has frequent bowel movements.\u003C/p\u003E\u003Cp\u003EIt is necessary to obtain an uncontaminated urine specimen\u003C/p\u003E","stemQuestion":"Which one of the following methods is most appropriate?","responseType":"sba","marks":1,"options":["Clean catch midstream specimen","Nappy pad collection","Suprapubic bladder aspiration","Urinary catheterisation","Urine bag collection"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003ESuprapubic bladder aspiration\u003C/strong\u003E is the gold standard method for obtaining uncontaminated urine specimens in infants and young children. It involves direct needle aspiration of urine from the bladder through the anterior abdominal wall under sterile conditions.\u003C/p\u003E        \u003Cp\u003EA \u003Cstrong\u003Eclean catch midstream specimen\u003C/strong\u003E is difficult to obtain in infants and young children who cannot follow instructions. \u003Cstrong\u003EUrinary catheterisation\u003C/strong\u003E is invasive and carries a risk of introducing infection. \u003Cstrong\u003ENappy pad collection\u003C/strong\u003E and \u003Cstrong\u003Eurine bag collection\u003C/strong\u003E methods have high contamination rates due to skin flora and faecal contamination.\u003C/p\u003E        \u003Cp\u003EWhile less invasive collection methods may be more convenient, they are associated with higher false-positive rates and may lead to unnecessary antibiotic treatment.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Suprapubic aspiration is the most reliable method for obtaining uncontaminated urine specimens in young children and elderly patients who cannot provide clean catch samples.","Suprapubic aspiration involves direct needle puncture of the bladder through the anterior abdominal wall under sterile conditions."],"references":["Schmiemann G, Kniehl E, Gebhardt K, Matejczyk MM, Hummers-Pradier E. The diagnosis of urinary tract infection: a systematic review. Dtsch Arztebl Int. 2010 May;107(21):361-7. doi: 10.3238/arztebl.2010.0361. Epub 2010 May 28. PMID: 20539810; PMCID: PMC2883276.","Kaur R, Kaur R. Symptoms, risk factors, diagnosis and treatment of urinary tract infections. Postgrad Med J. 2021 Dec;97(1154):803-812. doi: 10.1136/postgradmedj-2020-139090. Epub 2020 Nov 24. PMID: 33234708.","Kumar, V., Abbas, A. K., \u0026 Aster, J. C. (Eds.). (2012). Robbins basic pathology e-book. Elsevier Health Science"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"52260"}},"question":{"data":{"type":"questions","id":"15140"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"52260","links":{"self":"https://app.emedici.com/api/itemRevisions/52260"},"attributes":{"createdAt":"2024-12-02T15:12:44+10:30","updatedAt":"2024-12-02T15:13:10+10:30"},"relationships":{"item":{"data":{"type":"items","id":"7828"}},"content":{"data":{"type":"questionRevisions","id":"66806"}}},"meta":{"canDelete":false}},{"type":"tags","id":"9","links":{"self":"https://app.emedici.com/api/tags/9"},"attributes":{"emoji":"\ud83d\udc76","name":"Paediatrics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:39:03+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedic