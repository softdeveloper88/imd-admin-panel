{"data":[{"type":"questionAttempts","id":"17472307","links":{"self":"https://app.emedici.com/api/questionAttempts/17472307"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-28T21:56:13+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T21:56:13+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"1179"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"1179","links":{"self":"https://app.emedici.com/api/questions/1179"},"attributes":{"optionProportions":[0.72,0.12,0.11,0.04,0.01]},"relationships":{"item":{"data":{"type":"items","id":"1179"}},"activeRevision":{"data":{"type":"questionRevisions","id":"46186"}}}},{"type":"items","id":"1179","links":{"self":"https://app.emedici.com/api/items/1179"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1179"}},"activeRevision":{"data":{"type":"itemRevisions","id":"31111"}},"tags":{"data":[{"type":"tags","id":"9"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"659"},{"type":"tags","id":"1061"},{"type":"tags","id":"1387"}]},"contributions":{"data":[{"type":"contributions","id":"16106"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"46186","links":{"self":"https://app.emedici.com/api/questionRevisions/46186"},"attributes":{"stem":"\u003Cp\u003EA four-year-old boy presents to his General Practice clinic with his mother with a one-day history of left-sided ear ache and fever. He is otherwise well with no significant medical history and is up to date with immunisations. On examination, he appears well with a temperature of 38.2\u00b0C. Otoscopy shows an erythematous and bulging left tympanic membrane. This is his first episode of acute otitis media.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate initial management?","responseType":"sba","marks":1,"options":["Conservative measures and review in 48 hours","Oral amoxicillin for five days","Oral amoxicillin/clavulanic acid for five days","Oral azithromycin for three days","Referral to ENT for consideration of grommets"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EMost cases of \u003Cstrong\u003Eacute otitis media (AOM)\u003C/strong\u003E will resolve spontaneously and require supportive care only. Indications for antibiotics include age \u0026lt;6 months, toxic appearance, uncertain access to follow-up, severe otalgia, symptoms present for longer than 48 hours, bilateral otitis, pyorrhoea, or high fever (\u0026gt;39\u00b0C).\u003C/p\u003E\u003Cp\u003EDespite \u003Cstrong\u003Eantibiotics\u003C/strong\u003E being commonly prescribed in AOM, in most cases they have little effect on early symptoms when compared to placebo. The number needed to harm for antibiotic therapy in children is approximately 14, and therefore judicious use of antibiotics is important. When antibiotics are indicated, \u003Cstrong\u003Eamoxicillin\u003C/strong\u003E is first-line. \u003Cstrong\u003EAmoxicillin/clavulanic acid\u003C/strong\u003E provides additional anaerobic cover and may be used for treatment failures. \u003Cstrong\u003EAzithromycin\u003C/strong\u003E is an option for penicillin-allergic patients.\u003C/p\u003E\u003Cp\u003EManagement options may vary for children from higher risk groups, such as those living in Aboriginal or Torres Strait Islander communities, where use of antibiotics might be more readily considered.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EReferral for grommets\u003C/strong\u003E may be considered for recurrent episodes of AOM (\u22653 in 6 months or \u22654 in 12 months), but would not be indicated for an initial presentation.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Acute otitis media usually resolves spontaneously without the need for any intervention."],"references":["The Royal Children\u2019s Hospital Melbourne. (2018). Acute otitis media: clinical practice guidelines.","Venekamp RP, Sanders SL, Glasziou PP, et al. Antibiotics for acute otitis media in children. Cochrane Database Syst Rev 2015; :CD000219."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"31111"}},"question":{"data":{"type":"questions","id":"1179"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"31111","links":{"self":"https://app.emedici.com/api/itemRevisions/31111"},"attributes":{"createdAt":"2024-05-30T19:42:02+09:30","updatedAt":"2024-10-13T07:58:20+10:30"},"relationships":{"item":{"data":{"type":"items","id":"1179"}},"content":{"data":{"type":"questionRevisions","id":"46186"}}},"meta":{"canDelete":false}},{"type":"tags","id":"9","links":{"self":"https://app.emedici.com/api/tags/9"},"attributes":{"emoji":"\ud83d\udc76","name":"Paediatrics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:39:03+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":"Management","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"72","links":{"self":"https://app.emedici.com/api/tags/72"},"attributes":{"emoji":"","name":"Graduating","synonyms":null,"description":"Only suitable for a graduating medical student at the end of their degree","position":1,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"659","links":{"self":"https://app.emedici.com/api/tags/659"},"attributes":{"emoji":"