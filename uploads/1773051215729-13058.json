nsCorrect":12,"marksCorrect":12},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"pack":{"data":{"type":"packs","id":"5"}},"exam":{"data":null}}},{"type":"questions","id":"13058","links":{"self":"https://app.emedici.com/api/questions/13058"},"attributes":{"optionProportions":[0.61,0.02,0.09,0.21,0.06]},"relationships":{"item":{"data":{"type":"items","id":"5495"}},"activeRevision":{"data":{"type":"questionRevisions","id":"112800"}}}},{"type":"items","id":"5495","links":{"self":"https://app.emedici.com/api/items/5495"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"13058"}},"activeRevision":{"data":{"type":"itemRevisions","id":"94834"}},"tags":{"data":[{"type":"tags","id":"13"},{"type":"tags","id":"64"},{"type":"tags","id":"73"},{"type":"tags","id":"76"},{"type":"tags","id":"1013"},{"type":"tags","id":"2173"},{"type":"tags","id":"2436"},{"type":"tags","id":"3549"},{"type":"tags","id":"4941"},{"type":"tags","id":"4947"},{"type":"tags","id":"4965"},{"type":"tags","id":"5090"},{"type":"tags","id":"7875"},{"type":"tags","id":"9278"},{"type":"tags","id":"11625"}]},"contributions":{"data":[{"type":"contributions","id":"9342"},{"type":"contributions","id":"9401"},{"type":"contributions","id":"44295"},{"type":"contributions","id":"46376"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"112800","links":{"self":"https://app.emedici.com/api/questionRevisions/112800"},"attributes":{"stem":"\u003Cp\u003EA 49-year-old man presents to the General Practice clinic with weakness, decreased appetite and night sweats for six weeks. He has also had weight loss of 6.5 kg over the past six months. He has no significant medical history and takes no regular medications.\u003C/p\u003E\u003Cp\u003EOn examination, he appears unwell. His pulse rate is 88/min, blood pressure 125/75 mmHg, respiratory rate 16/min, SpO2 98% on room air, and temperature 36.8\u00b0C. He is pale with splenomegaly extending 15 cm below the left costal margin.\u003C/p\u003E\u003Cp\u003EBlood tests reveal:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003EHaemoglobin 95 g/L (123-166)\u003C/li\u003E\u003Cli\u003EWhite cell count 166 x10^9/L (4.0-10)\u003C/li\u003E\u003Cli\u003EPlatelet count 455 x10^9/L (150-400)\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EPeripheral blood smear shows leukocytosis with all maturation stages seen, including 3% blast cells, as well as moderate eosinophilia and basophilia.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate genetic test to confirm the diagnosis?","responseType":"sba","marks":1,"options":["BCR::ABL1 fusion","CALR mutation","P53 mutation","JAK2 V617F mutation","MPL mutation"],"correctOptions":[0],"correctResponses":[],"explanation":"\u003Cp\u003EThis patient presents with features characteristic of chronic myeloid leukaemia (CML), including hyperleukocytosis, immature granulocytes in peripheral blood, basophilia, and marked splenomegaly. The \u003Cstrong\u003EBCR::ABL1 fusion gene analysis\u003C/strong\u003E is the most appropriate test as it detects the hallmark genetic abnormality in CML, resulting from the Philadelphia chromosome t(9;22)(q34;q11.2) reciprocal translocation.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECALR mutation analysis\u003C/strong\u003E would be appropriate for investigating JAK2-negative essential thrombocythaemia and primary myelofibrosis, which typically present with different blood count patterns and do not show the marked leukocytosis seen here.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EP53 mutation analysis\u003C/strong\u003E might be relevant in various haematological malignancies including acute myeloid leukaemia and myelodysplastic syndrome, particularly in cases with complex karyotype, but is not the primary diagnostic test in suspected CML.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EJAK2 V617F mutation analysis\u003C/strong\u003E would be appropriate for investigating polycythaemia vera and can be found in essential thrombocythaemia and primary myelofibrosis. These conditions typically present with elevated haemoglobin or platelets rather than marked leukocytosis.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EMPL mutation analysis\u003C/strong\u003E would be relevant in some cases of essential thrombocythaemia and primary myelofibrosis, which present with different clinical and laboratory features.\u003C/p\u003E\u003Cp\u003EThe diagnosis of CML requires demonstration of either the BCR::ABL1 fusion gene (by PCR or FISH) or the Philadelphia chromosome (by conventional cytogenetics). Once confirmed, CML is treated with tyrosine kinase inhibitors that specifically target the BCR::ABL1 protein.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["The diagnosis of CML requires demonstration of the Philadelphia chromosome or the BCR::ABL1 fusion gene.","Hyperleukocytosis with basophilia, splenomegaly and presence of BCR::ABL1 fusion gene or Philadelphia chromosome is characteristic of CML.","Constitutional symptoms like night sweats, weight loss and fatigue are common presenting features of CML."],"references":["Jabbour E, Kantarjian H. Chronic myeloid leukemia: 2025 update on diagnosis, therapy, and monitoring. Am J Hematol. 2024;99(11):2191-2212. doi:10.1002/ajh.27443","Cortes J, Pavlovsky C, Sau\u00dfele S. Chronic myeloid leukaemia. Lancet. 2021;398(10314):1914-1926. doi:10.1016/S0140-6736(21)01204-6"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"94834"}},"question":{"data":{"type":"questions","id":"13058"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"94834","links":{"self":"https://app.emedici.com/api/itemRevisions/94834"},"attributes":{"createdAt":"2025-09-06T12:25:21+09:30","updatedAt":"2025-09-06T12:26:32+09:30"},"relationships":{"item":{"data":{"type":"items","id":"5495"}},"content":{"data":{"type":"questionRevisions","id":"112800"}}},"m