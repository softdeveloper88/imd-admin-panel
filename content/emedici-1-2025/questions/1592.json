uestions/1592/relationships/activeRevision"}}}},{"type":"items","id":"1592","links":{"self":"https://app.emedici.com/api/items/1592"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/1592/packs","self":"https://app.emedici.com/api/items/1592/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/1592/revisions","self":"https://app.emedici.com/api/items/1592/relationships/revisions"}},"content":{"data":{"type":"questions","id":"1592"},"links":{"related":"https://app.emedici.com/api/items/1592/content","self":"https://app.emedici.com/api/items/1592/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/1592/specialtyTags","self":"https://app.emedici.com/api/items/1592/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/1592/primaryTags","self":"https://app.emedici.com/api/items/1592/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/1592/contributionTypes","self":"https://app.emedici.com/api/items/1592/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/1592/contributors","self":"https://app.emedici.com/api/items/1592/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/1592/contribution","self":"https://app.emedici.com/api/items/1592/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/1592/myContribution","self":"https://app.emedici.com/api/items/1592/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"99981"},"links":{"related":"https://app.emedici.com/api/items/1592/activeRevision","self":"https://app.emedici.com/api/items/1592/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"3"},{"type":"tags","id":"8"},{"type":"tags","id":"25"},{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"436"},{"type":"tags","id":"4955"},{"type":"tags","id":"4963"},{"type":"tags","id":"4987"},{"type":"tags","id":"11629"},{"type":"tags","id":"11636"},{"type":"tags","id":"11650"}],"links":{"related":"https://app.emedici.com/api/items/1592/tags","self":"https://app.emedici.com/api/items/1592/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"13303"},{"type":"contributions","id":"39050"},{"type":"contributions","id":"40365"},{"type":"contributions","id":"42348"},{"type":"contributions","id":"46434"},{"type":"contributions","id":"46767"},{"type":"contributions","id":"48047"}],"links":{"related":"https://app.emedici.com/api/items/1592/contributions","self":"https://app.emedici.com/api/items/1592/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"118167","links":{"self":"https://app.emedici.com/api/questionRevisions/118167"},"attributes":{"stem":"\u003Cp\u003EA 32-year-old woman presents to her General Practice clinic with a two-day history of increased swelling and pain in her left upper eyelid. She also noticed a pimple-like lesion at her lid margin and some yellow discharge on her lashes. She has no significant medical history and takes no regular medications. On examination, she appears well with vital signs within normal limits. There is a localised, erythematous, tender swelling at the margin of her left upper eyelid with associated purulent discharge (Image).\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Hordeolum (stye)","Blepharitis","Chalazion","Dacryocystitis","Trichiasis"],"correctOptions":[0],"correctResponses":[],"explanation":"\u003Cp\u003EThe clinical presentation is most consistent with an external \u003Cstrong\u003Ehordeolum\u003C/strong\u003E, also known as a stye. A hordeolum is an acute infection in the upper or lower modified sebaceous glands (Meibomian gland - internal) or its associated glands (glands of Zeiss or Moll - external) and is usually caused by bacteria. It typically presents as a localised, painful, erythematous swelling at the eyelid margin, often with a visible pustule or preseptal cellulitis. The presence of purulent discharge is also characteristic.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EBlepharitis\u003C/strong\u003E is a chronic inflammatory condition affecting the eyelid margins. While it can cause redness and irritation, it typically involves the entire lid margin rather than a localised swelling. Blepharitis is often bilateral and associated with scales or crusts along the lash line.\u003C/p\u003E\u003Cp\u003EA \u003Cstrong\u003Echalazion\u003C/strong\u003E (meibomian cyst) is a chronic granulomatous inflammation caused by blockage of a meibomian gland (sebaceous gland). It usually forms following an episode of hordeolum, which may or may not resolve spontaneously. By definition, chalazion is an encapsulated cyst which is usually non tender. If it doesn\u0027t resolve spontaneously, it is treated by incision and curettage of the cyst. Upon incising it, a collection of white sebaceous material is drained. It is most commonly located at the lid margin, however it can be also away from the lid margin along the length of the blocked duct. \u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EDacryocystitis\u003C/strong\u003E is an infection of the lacrimal sac. It typically presents with pain, redness, and swelling in the medial canthal area (inner corner of the eye), not at the lid margin as described in this case.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ETrichiasis\u003C/strong\u003E refers to a condition where eyelashes are misdirected and grow inwards towards the eye. While it can cause irritation and discomfort, it does not cause the localised swelling and discharge described in this scenario.\u003C/p\u003E\u003Cp\u003EManagement of a hordeolum typically involves warm compresses applied to the affected area for 10-15 minutes, 3-4 times daily. This helps to promote drainage of the infected gland. Most cases will resolve spontaneously within 1-2 weeks with this conservative treatment. Oral antibiotics (not topical) may be added if pre-septal cellulitis is present. In severe or persistent cases, incision and drainage may be necessary for refractory cases.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Most cases of hordeolum will respond to warm compresses.","Hordeolum is an acute infection of an eyelash follicle or adjacent gland, typically caused by Staphylococcus aureus."],"references":["Lindsley K, Nichols JJ, Dickersin K. Interventions for acute internal hordeolum. Cochrane Database Syst Rev. ; 4: CD007742. doi:10.1002/14651858.CD007742.pub3.","Sharma S. Opthaproblem Chalazion. Canada Family Physician. 1998: 44 (1249-1257). Available from: https://www.ncbi.nlm.nih.gov/pmc/articles/PMC2278269/?page=2","Boyd K, Mendoza O, Tubert D. What is the difference between a stye and a chalazion? Causes, Symptoms, Treatment. American Academy of ophthalmology. 2023. Available from: https://www.aao.org/eye-health/diseases/what-are-chalazia-styes"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"99981"},"links":{"related":"https://app.emedici.com/api/questionRevisions/118167/itemRevision","self":"https://app.emedici.com/api/questionRevisions/118167/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"1592"},"links":{"related":"https://app.emedici.com/api/questionRevisions/118167/question","self":"https://app.emedici.com/api/questionRevisions/118167/relationships/question"}},"stemMedia":{"data":[{"type":"media","id":"16369"}],"links":{"related":"https://app.emedici.com/api/questionRevisions/118167/stemMedia","self":"https://app.emedici.com/api/questionRevisions/118167/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/118167/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/118167/relationships/explanationMedia"}}}},{"type":"media","id":"16369","links":{"self":"https://app.emedici.com/api/media/16369"},"attributes":{"mimeType":"image/jpeg","url":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/70388504-fa92-49ba-a89f-33dfd4b3365d.jpg","thumbUrl":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/70388504-fa92-49ba-a89f-33dfd4b3365d.jpg","isProcessed":true,"width":800,"height":535}},{"type":"itemRevisions","id":"99981","links":{"self":"https://app.emedici.com/api/itemRevisions/99981"},"attributes":{"createdAt":"2025-10-05T23:02:25+10:30","updatedAt":"2025-10-06T08:21:43+10:30"},"relationships":{"item":{"data":{"type":"items","id":"1592"},"links":{"related":"https://app.emedici.com/api/itemRevisions/99981/item","self":"https://app.emedici.com/api/itemRevisions/99981/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"118167"},"links":{"related":"https://app.emedici.com/api/itemRevisions/99981/content","self":"https://app.emedici.com/api/itemRevisions/99981/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"3","links":{"self":"https://app.emedici.com/api/tags/3"},"attributes":{"emoji":"\ud83e\uddf4","name":"Dermatology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:42+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/3/group","self":"https://app.emedici.com/api/tags/3/relationships/group"}},"heading":{"data":{"type":"tagHeadings","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/3/heading","self":"https://app.emedici.com/api/tags/3/relationships/heading"}},"ancestors":{"links":{"related":"https://app.emedici.com/api/tags/3/ancestors","self":"https://app.emedici.com/api/tags/3/relat