{"data":[{"type":"questionAttempts","id":"17638124","links":{"self":"https://app.emedici.com/api/questionAttempts/17638124"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T18:49:19+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T18:49:19+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17690"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17690","links":{"self":"https://app.emedici.com/api/questions/17690"},"relationships":{"item":{"data":{"type":"items","id":"10404"}},"activeRevision":{"data":{"type":"questionRevisions","id":"72067"}}}},{"type":"items","id":"10404","links":{"self":"https://app.emedici.com/api/items/10404"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17690"}},"activeRevision":{"data":{"type":"itemRevisions","id":"57537"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4942"},{"type":"tags","id":"5586"},{"type":"tags","id":"10470"}]},"contributions":{"data":[{"type":"contributions","id":"24315"},{"type":"contributions","id":"24352"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"72067","links":{"self":"https://app.emedici.com/api/questionRevisions/72067"},"attributes":{"stem":"\u003Cp\u003EThe cerebellum plays a crucial role in maintaining balance and posture through its connections with various parts of the nervous system.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the primary pathway that carries vestibular information to the cerebellum?","responseType":"sba","marks":1,"options":["Reticulocerebellar tract","Spinocerebellar tract","Olivocerebellar tract","Vestibulocerebellar tract","Pontocerebellar tract"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Evestibulocerebellar tract\u003C/strong\u003E is the main pathway carrying vestibular information to the cerebellum, particularly to the flocculonodular lobe. This pathway enables the integration of vestibular signals for balance and spatial orientation.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003EThe \u003Cstrong\u003Ereticulocerebellar tract\u003C/strong\u003E transmits information from the reticular formation about arousal states and postural control.\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Espinocerebellar tract\u003C/strong\u003E conveys proprioceptive information from muscles, tendons and joints of the body to the cerebellum.\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Eolivocerebellar tract\u003C/strong\u003E transmits signals from the inferior olivary nucleus that are important for motor learning and timing.\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Epontocerebellar tract\u003C/strong\u003E relays information from the cerebral cortex via the pontine nuclei for motor planning.\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThe vestibulocerebellar pathway is essential for coordinating eye movements, maintaining balance, and making postural adjustments in response to head position changes.\u003C/p\u003E","optionExplanations":null,"learningPoints":["The cerebellum receives input from vestibular nuclei via the vestibulocerebellar tract to help maintain balance.","The flocculonodular lobe of the cerebellum is primarily involved in balance and vestibular function.","Vestibular information helps the cerebellum coordinate eye movements and postural adjustments."],"references":["Hall JE, Hall ME. Guyton and Hall Textbook of Medical Physiology. 14th ed. Philadelphia, PA: Elsevier; 2020.","Tortora, G. J., Mellifont, R., Derrickson, B., Burkett, B., Peoples, G., D, D. Principles of Anatomy and Physiology, Asia-Pacific Edition,  2nd Edition. John Wiley \u0026 Sons Australia; 2019."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"57537"}},"question":{"data":{"type":"questions","id":"17690"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"57537","links":{"self":"https://app.emedici.com/api/itemRevisions/57537"},"attributes":{"createdAt":"2024-12-20T22:14:09+10:30","updatedAt":"2024-12-20T22:21:56+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10404"}},"content":{"data":{"type":"questionRevisions","id":"72067"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4942","links":{"self":"https://app.emedici.com/api/tags/4942"},"attributes":{"emoji":"\u2699\ufe0f","name":"Physiology","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-11-21T12:54:08+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"14"}},"heading":{"data":null}},"meta":{"i