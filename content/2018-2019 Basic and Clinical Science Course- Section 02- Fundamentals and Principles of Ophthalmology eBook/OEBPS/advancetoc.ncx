<mediaMap>
<mediaPoint id="fig01_30" type="IMG" mediaType="TID1" mediaSize="3" order="34" href="chap01.html#fig01_30"><desc><![CDATA[<b>Figure 1-30</b> The lacrimal drainage system. <span style="font-size:0.8em"><i>(Reproduced with permission from Katowitz JA, ed.</i> Pediatric Oculoplastic Surgery. <i>Philadelphia: Springer-Verlag; 2002.)</i></span>]]></desc><mediaPath src="images/img_p29.jpg" thumbSrc="images/img_p29.jpg"/></mediaPoint>
