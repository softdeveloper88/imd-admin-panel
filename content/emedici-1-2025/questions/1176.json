{"data":[{"type":"questionAttempts","id":"17472300","links":{"self":"https://app.emedici.com/api/questionAttempts/17472300"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-28T21:56:02+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T21:56:02+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"1176"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"1176","links":{"self":"https://app.emedici.com/api/questions/1176"},"attributes":{"optionProportions":[0.15,0.41,0.03,0.39,0.01]},"relationships":{"item":{"data":{"type":"items","id":"1176"}},"activeRevision":{"data":{"type":"questionRevisions","id":"6025"}}}},{"type":"items","id":"1176","links":{"self":"https://app.emedici.com/api/items/1176"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1176"}},"activeRevision":{"data":{"type":"itemRevisions","id":"6025"}},"tags":{"data":[{"type":"tags","id":"9"},{"type":"tags","id":"14"},{"type":"tags","id":"24"},{"type":"tags","id":"35"},{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"657"},{"type":"tags","id":"1061"},{"type":"tags","id":"1155"},{"type":"tags","id":"1156"},{"type":"tags","id":"2058"},{"type":"tags","id":"4954"},{"type":"tags","id":"4959"},{"type":"tags","id":"4961"},{"type":"tags","id":"11630"},{"type":"tags","id":"11637"},{"type":"tags","id":"11638"},{"type":"tags","id":"11644"}]},"contributions":{"data":[{"type":"contributions","id":"3319"},{"type":"contributions","id":"3354"},{"type":"contributions","id":"15996"},{"type":"contributions","id":"42237"},{"type":"contributions","id":"44043"},{"type":"contributions","id":"44935"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"6025","links":{"self":"https://app.emedici.com/api/questionRevisions/6025"},"attributes":{"stem":"\u003Cp\u003EA previously well 17-year-old girl presents to the ED with a four hour history of facial swelling (see photograph) and difficulty opening her mouth. This was preceded by a 12 hour history of pain in the left side of her jaw. She has not been able to eat and drink, and has not had difficulty breathing. She had her wisdom teeth removed 7 days ago without complications and completed a 5 day course of amoxicillin. \u003C/p\u003E\u003Cp\u003EShe is otherwise well and takes no regular medications. Nursing staff take a baseline set of observations which are unremarkable except for a temperature of 38.5 degrees.\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Quinsy","Suppurative parotitis","Infectious mononucleosis","Ludwig\u0027s angina","Glossitis"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThis is \u003Cstrong\u003ELudwig\u0027s angina\u003C/strong\u003E, a deep neck infection evidenced by the submandibular swelling and fever, differentiated from other causes by its rapid onset over a few hours. The recent dental surgery is a major risk factor for this kind of deep neck infection. It is extremely important to monitor and stabilise the airway. It is otherwise managed with IV antibiotics and surgical drainage.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EQuinsy\u003C/strong\u003E, also known as peritonsillar abscess, presents similarly, but usually develops after a known episode of tonsillitis.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESuppurative parotitis\u003C/strong\u003E causes preauricular swelling and often has purulent exudate from Stenson\u0027s duct opening in the mouth.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EInfectious mononucleosis\u003C/strong\u003E does not develop this acutely. It presents with symmetrical cervical lymphadenopathy, pharyngitis and chronic fatigue.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EGlossitis\u003C/strong\u003E is inflammation of the tongue often due to medication or food allergy.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Ludwig\u0027s angina is a deep neck infection posing risk to the airway."],"references":["Kassam K, Messiha A, Heliotis M. Ludwig\u0027s Angina: The Original Angina. Case Rep Surg. 2013;2013:974269."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"6025"}},"question":{"data":{"type":"questions","id":"1176"}},"stemMedia":{"data":[{"type":"media","id":"1785"}]},"explanationMedia":{"data":[]}}},{"type":"media","id":"1785","links":{"self":"https://app.emedici.com/api/media/1785"},"attributes":{"mimeType":"image/jpeg","url":"https://app.emedici.com/storage/media/60509279-a511-4519-b456-db694895e413.jpg","thumbUrl":"https://app.emedici.com/storage/media/60509279-a511-4519-b456-db694895e413.jpg","isProcessed":true,"width":433,"height":440}},{"type":"itemRevisions","id":"6025","links":{"self":"https://app.emedici.com/api/itemRevisions/6025"},"attributes":{"createdAt":"2021-07-28T01:06:49+09:30","updatedAt":"2021-07-28T01:06:49+09:30"},"relationships":{"item":{"data":{"type":"items","id":"1176"}},"content":{"data":{"type":"questionRevisions","id":"6025"}}},"meta":{"canDelete":false}},{"type":"tags","id":"9","links":{"self":"https://app.emedici.com/api/tags/9"},"attributes":{"emoji":"\ud83d\udc76","name":"Paediatrics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:39:03+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"14","links":{"self":"https://app.emedici.com/api/tags/14"},"attributes":{"emoji":"\ud83e\udda0","name":"Infectious Diseases","synonyms":["ID"],"description":null,"position":null,"createdAt":null,"updatedAt":"2021-05-21T07:51:58+09:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading