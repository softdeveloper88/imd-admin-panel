{"data":[{"type":"questionAttempts","id":"17633065","links":{"self":"https://app.emedici.com/api/questionAttempts/17633065"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T17:48:18+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T17:48:18+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17458"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17458","links":{"self":"https://app.emedici.com/api/questions/17458"},"relationships":{"item":{"data":{"type":"items","id":"10148"}},"activeRevision":{"data":{"type":"questionRevisions","id":"70857"}}}},{"type":"items","id":"10148","links":{"self":"https://app.emedici.com/api/items/10148"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17458"}},"activeRevision":{"data":{"type":"itemRevisions","id":"56324"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5348"}]},"contributions":{"data":[{"type":"contributions","id":"23748"},{"type":"contributions","id":"23818"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"70857","links":{"self":"https://app.emedici.com/api/questionRevisions/70857"},"attributes":{"stem":"\u003Cp\u003EEnvironmental scientists have detected plastic particles in marine life, drinking water, and food products intended for human consumption.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the size classification for microplastics?","responseType":"sba","marks":1,"options":["Less than 5mm in any dimension","Between 5mm and 10mm in diameter","Less than 1 micrometre in diameter","Between 1cm and 5cm in length","Greater than 5mm but less than 1cm"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003ELess than 5mm in any dimension\u003C/strong\u003E is the internationally accepted definition of microplastics. This classification encompasses both primary microplastics (manufactured at this size) and secondary microplastics (resulting from larger plastic degradation).\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EBetween 5mm and 10mm in diameter\u003C/strong\u003E would be too large to be classified as microplastics.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003ELess than 1 micrometre in diameter\u003C/strong\u003E would describe nanoplastics, rather than microplastics.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EBetween 1cm and 5cm in length\u003C/strong\u003E describes mesoplastics, which are larger than microplastics.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EGreater than 5mm but less than 1cm\u003C/strong\u003E exceeds the size definition for microplastics.\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EUnderstanding the size classification of microplastics is crucial as it determines their ability to enter food chains and potentially impact human health through ingestion or inhalation.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Microplastics are plastic particles less than 5mm in size that persist in the environment and can enter the food chain.","Primary microplastics are manufactured at microscopic size while secondary microplastics result from breakdown of larger plastic items.","Microplastics can accumulate in living organisms and potentially cause physical and chemical toxicity."],"references":["Ziani K, Ioni\u021b\u0103-M\u00eendrican CB, Mititelu M, et al. Microplastics: A Real Global Threat for Environment and Food Safety: A State of the Art Review. Nutrients. 2023;15(3):617. Published 2023 Jan 25. doi:10.3390/nu15030617","Shultz JM, Sullivan LM, Galea S. Public Health: An Introduction to the Science and Practice of Population Health. Springer Publishing Company; 2021."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"56324"}},"question":{"data":{"type":"questions","id":"17458"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"56324","links":{"self":"https://app.emedici.com/api/itemRevisions/56324"},"attributes":{"createdAt":"2024-12-16T14:42:12+10:30","updatedAt":"2024-12-16T14:42:38+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10148"}},"content":{"data":{"type":"questionRevisions","id":"70857"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"5326","links":{"self":"https://app.emedici.com/api/tags/5326"},"attributes":{"emoji":"\ud83c\udf0f","name":"Public Health","synonyms":null,"description":null,"position":null,"createdAt":"2024-10-24T05:44:22+10:30","updatedAt":"2024-10-24T05:44:22+10:30"},"relationships":{"group":{"da