{"data":[{"type":"questionAttempts","id":"17603930","links":{"self":"https://app.emedici.com/api/questionAttempts/17603930"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T12:47:51+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T12:47:51+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15791"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15791","links":{"self":"https://app.emedici.com/api/questions/15791"},"attributes":{"optionProportions":[0.19,0,0.76,0,0.05]},"relationships":{"item":{"data":{"type":"items","id":"8482"}},"activeRevision":{"data":{"type":"questionRevisions","id":"71479"}}}},{"type":"items","id":"8482","links":{"self":"https://app.emedici.com/api/items/8482"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15791"}},"activeRevision":{"data":{"type":"itemRevisions","id":"56988"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"2994"},{"type":"tags","id":"4929"},{"type":"tags","id":"4934"},{"type":"tags","id":"4935"},{"type":"tags","id":"4940"},{"type":"tags","id":"4942"},{"type":"tags","id":"7004"},{"type":"tags","id":"7607"},{"type":"tags","id":"10148"}]},"contributions":{"data":[{"type":"contributions","id":"20387"},{"type":"contributions","id":"20389"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"71479","links":{"self":"https://app.emedici.com/api/questionRevisions/71479"},"attributes":{"stem":"\u003Cp\u003EInhibin B is a protein hormone produced by the gonads that plays a key role in reproductive endocrine regulation.\u003C/p\u003E","stemQuestion":"Which one of the following cell types best described how Inhibin B directly inhibits the reproductive axis?","responseType":"sba","marks":1,"options":["Hypothalamic arcuate nucleus neurons","Hypothalamic preoptic area neurons","Pituitary gonadotrophs","Pituitary thyrotrophs","Pituitary lactotrophs"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EInhibin B is produced by Sertoli cells in males and granulosa cells in females. It acts through negative feedback specifically on \u003Cstrong\u003Ehypothalamic arcuate nucleus neurons\u003C/strong\u003E and \u003Cstrong\u003Ehypothalamic preoptic area neurons\u003C/strong\u003E. Its main target is the \u003Cstrong\u003Epituitary gonadotrophs\u003C/strong\u003E, where it selectively suppresses follicle stimulating hormone synthesis and secretion.\u003C/p\u003E\u003Cp\u003EInhibin B does not directly affect \u003Cstrong\u003Epituitary thyrotrophs\u003C/strong\u003E or \u003Cstrong\u003Epituitary lactotrophs\u003C/strong\u003E. The negative feedback occurs specifically at the level of the gonadotrophs in the anterior pituitary, not at the hypothalamic level where gonadotropin releasing hormone is produced.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Inhibin B is produced by gonads and selectively suppresses follicle stimulating hormone production by acting directly on pituitary gonadotrophs","The negative feedback of Inhibin B occurs at the pituitary level, not at the hypothalamic level"],"references":["Makanji Y, Zhu J, Mishra R, Holmquist C, Wong WP, Schwartz NB, Mayo KE, Woodruff TK. Inhibin at 90: from discovery to clinical application, a historical review. Endocr Rev. 2014 Oct;35(5):747-94. doi: 10.1210/er.2014-1003. Epub 2014 Jul 22. PMID: 25051334; PMCID: PMC4167436.","Melmed, S., Polonsky, K. S., Larsen, P. R., \u0026 Kronenberg, H. M. (2015). Williams textbook of endocrinology E-Book. Elsevier Health Sciences","Clark, O. H., Duh, Q. Y., Kebebew, E., Gosnell, J. E., \u0026 Shen, W. T. (Eds.). (2016). Textbook of endocrine surgery. JP Medical Ltd","Young, W. F. (2011). Netter\u0027s Endocrine System: Netter Collection of Medical Illustrations: Endocrine System E-book. Elsevier Health Sciences"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"56988"}},"question":{"data":{"type":"questions","id":"15791"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"56988","links":{"self":"https://app.emedici.com/api/itemRevisions/56988"},"attributes":{"createdAt":"2024-12-18T18:25:03+10:30","updatedAt":"2024-12-18T18:25:53+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8482"}},"content":{"data":{"type":"questionRevisions","id":"71479"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Level II","synonyms":null,"description":"Understand (interpreting and summarizing information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"2994","links":{"self":"https://app.emedici.com/api/tags/2994"},"attributes":{"emoji":"","name":"Hypothalamic-pituitary-adrenal axis","synonyms":["HPA axis"],"description":null,"position":null,"createdAt":"2024-09-16T20:19:29+09:30","updatedAt":"2024-11-21T12:54:18+10:30"},"relationship