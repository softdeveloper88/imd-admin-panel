<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tokens – iMD Admin</title>
  <style>
    :root {
      --bg: #f4efe7; --panel: rgba(255,251,245,0.9); --panel-strong: #fffdf8;
      --ink: #1d2a2f; --muted: #66757e; --line: rgba(35,50,58,0.12);
      --brand: #0f766e; --brand-deep: #0b4f49;
      --danger: #b42318; --danger-bg: #fff0ed;
      --success: #0f7b4d; --success-bg: #edf9f0;
      --warn: #b45309; --warn-bg: #fffbeb;
      --info: #0369a1; --info-bg: #e0f2fe;
      --shadow: 0 22px 50px rgba(31,38,43,0.12); --radius: 22px;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:"Avenir Next","Helvetica Neue","Segoe UI",sans-serif;color:var(--ink);background:radial-gradient(circle at top left,rgba(15,118,110,0.14),transparent 26%),radial-gradient(circle at top right,rgba(217,119,6,0.12),transparent 20%),linear-gradient(180deg,#f8f2e8 0%,var(--bg) 100%);min-height:100vh;display:flex}
    a{color:inherit}

    /* Sidebar */
    .sidebar{width:250px;min-height:100vh;background:linear-gradient(180deg,rgba(12,58,69,0.97),rgba(22,90,84,0.93));color:#f9fafb;padding:0;flex-shrink:0;position:fixed;left:0;top:0;bottom:0;z-index:100;transition:transform .2s}
    .sidebar-header{padding:20px 18px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,0.1)}
    .logo{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:700}
    .logo-icon{font-size:24px}
    .sidebar-toggle{background:none;border:none;color:#f9fafb;font-size:20px;cursor:pointer;padding:4px 8px}
    .sidebar-menu{padding:12px 0}
    .menu-section{margin-bottom:8px}
    .menu-label{padding:8px 20px 4px;font-size:10px;text-transform:uppercase;letter-spacing:.1em;opacity:.5}
    .menu-item{display:flex;align-items:center;gap:10px;padding:10px 20px;text-decoration:none;color:rgba(255,255,255,.7);font-size:14px;transition:all .15s}
    .menu-item:hover{background:rgba(255,255,255,.08);color:#fff}
    .menu-item.active{background:rgba(255,255,255,.12);color:#fff;border-left:3px solid #5eead4}
    .menu-icon{font-size:16px;width:22px;text-align:center}
    .collapsed .sidebar{transform:translateX(-250px)}
    .collapsed .main-content{margin-left:0}

    .main-content{margin-left:250px;flex:1;min-width:0}

    /* Topbar */
    .topbar{display:flex;justify-content:space-between;align-items:center;padding:16px 28px;background:var(--panel);border-bottom:1px solid var(--line)}
    .topbar-left{display:flex;align-items:center;gap:12px}
    .topbar-right{display:flex;align-items:center;gap:16px}
    .breadcrumbs{font-size:14px;color:var(--muted)}
    .breadcrumbs a{color:var(--brand);text-decoration:none}
    .mobile-toggle{display:none;background:none;border:none;font-size:20px;cursor:pointer}
    .btn-logout-sm{background:none;border:1px solid var(--line);padding:6px 14px;border-radius:8px;cursor:pointer;font-size:13px;color:var(--muted)}
    .btn-logout-sm:hover{background:var(--danger-bg);color:var(--danger);border-color:var(--danger)}
    .admin-name{font-size:13px;color:var(--muted)}
    .notif-bell{cursor:pointer;font-size:18px;position:relative}
    .notif-count{position:absolute;top:-6px;right:-8px;background:var(--danger);color:#fff;font-size:10px;padding:1px 5px;border-radius:99px}
    .notif-dropdown{position:absolute;right:80px;top:52px;width:340px;background:#fff;border:1px solid var(--line);border-radius:14px;box-shadow:var(--shadow);z-index:200;max-height:400px;overflow:auto}
    .notif-header{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--line)}
    .notif-mark-all{background:none;border:none;color:var(--brand);cursor:pointer;font-size:12px}
    .notif-item{padding:12px 16px;border-bottom:1px solid rgba(0,0,0,.04);cursor:pointer}
    .notif-item.unread{background:#f0fdf4}
    .notif-title{font-size:13px;font-weight:600}
    .notif-msg{font-size:12px;color:var(--muted);margin-top:2px}
    .notif-time{font-size:11px;color:var(--muted);margin-top:4px}

    .page-content{padding:28px}
    .page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:16px}
    .page-title{font-size:28px;font-weight:700;letter-spacing:-0.02em;margin:0}
    .page-subtitle{color:var(--muted);font-size:14px;margin:4px 0 0}

    /* Stat Cards */
    .stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:14px;margin-bottom:24px}
    .stat-card{background:var(--panel);border:1px solid rgba(255,255,255,0.7);border-radius:16px;box-shadow:0 8px 28px rgba(31,38,43,0.08);padding:18px 20px;position:relative;overflow:hidden}
    .stat-card::before{content:'';position:absolute;top:0;left:0;width:4px;height:100%;border-radius:4px 0 0 4px}
    .stat-card.sc-available::before{background:var(--info)}
    .stat-card.sc-active::before{background:var(--success)}
    .stat-card.sc-expired::before{background:var(--danger)}
    .stat-card.sc-revoked::before{background:#999}
    .stat-card.sc-users::before{background:var(--brand)}
    .stat-card.sc-bundles::before{background:var(--warn)}
    .stat-label{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:600}
    .stat-value{font-size:32px;font-weight:700;margin:6px 0 2px;font-family:Georgia,serif}
    .stat-note{font-size:12px;color:var(--muted)}
    .stat-note.warn{color:var(--warn);font-weight:600}

    /* Alert Banner */
    .alert-banner{display:none;padding:12px 20px;border-radius:12px;margin-bottom:20px;font-size:13px;font-weight:500;align-items:center;gap:8px}
    .alert-banner.show{display:flex}
    .alert-banner.alert-warn{background:var(--warn-bg);color:var(--warn);border:1px solid rgba(180,83,9,0.2)}

    /* Tabs */
    .tabs{display:flex;gap:0;border-bottom:2px solid var(--line);margin-bottom:24px}
    .tab-btn{background:none;border:none;padding:12px 20px;font-size:14px;font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s}
    .tab-btn:hover{color:var(--ink)}
    .tab-btn.active{color:var(--brand);border-bottom-color:var(--brand)}
    .tab-count{display:inline-flex;align-items:center;justify-content:center;min-width:20px;height:20px;padding:0 6px;border-radius:10px;font-size:10px;font-weight:700;margin-left:6px;background:var(--line);color:var(--muted)}
    .tab-btn.active .tab-count{background:rgba(15,118,110,0.12);color:var(--brand)}
    .tab-panel{display:none}
    .tab-panel.active{display:block}

    /* Cards */
    .card{background:var(--panel);border:1px solid rgba(255,255,255,0.7);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:20px}
    .card-header{padding:20px 24px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
    .card-body{padding:20px 24px}
    .card-title{font-size:18px;font-weight:700;margin:0}
    .card-subtitle{font-size:13px;color:var(--muted);margin:2px 0 0}

    /* Form */
    .form-group{margin-bottom:16px}
    .form-group label{display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:var(--ink)}
    .form-group .form-hint{font-size:11px;color:var(--muted);margin-top:4px}
    .form-group input,.form-group select{width:100%;padding:10px 14px;border:1px solid var(--line);border-radius:10px;font-size:14px;outline:none}
    .form-group input:focus,.form-group select:focus{border-color:var(--brand)}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}

    .generated-tokens{background:var(--panel-strong);border:1px solid var(--line);border-radius:14px;padding:16px;margin-top:16px;max-height:400px;overflow-y:auto}
    .gen-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
    .generated-token-item{display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:#fff;border:1px solid var(--line);border-radius:8px;margin-bottom:6px;font-family:"SF Mono","Consolas",monospace;font-size:12px}
    .generated-token-item button{background:var(--brand);color:#fff;border:none;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11px}
    .generated-token-item button:hover{background:var(--brand-deep)}

    /* Filters */
    .filter-bar{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    .search-input{padding:8px 14px;border:1px solid var(--line);border-radius:10px;font-size:14px;min-width:220px;outline:none}
    .search-input:focus{border-color:var(--brand)}
    .filter-select{padding:8px 12px;border:1px solid var(--line);border-radius:10px;font-size:13px;background:#fff;cursor:pointer}

    /* Table */
    table{width:100%;border-collapse:collapse}
    thead th{padding:10px 14px;text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);border-bottom:2px solid var(--line);font-weight:600;white-space:nowrap}
    tbody td{padding:12px 14px;border-bottom:1px solid rgba(29,42,47,0.06);font-size:13px;vertical-align:middle}
    tbody tr:hover td{background:rgba(255,255,255,0.5)}

    .token-code{font-family:"SF Mono","Consolas",monospace;font-size:11px;word-break:break-all;color:var(--ink);background:rgba(0,0,0,0.03);padding:3px 6px;border-radius:4px;display:inline-block;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:pointer}
    .token-code:hover{background:rgba(15,118,110,0.08);color:var(--brand)}

    .badge{display:inline-block;padding:3px 9px;border-radius:999px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.04em}
    .badge-available{background:var(--info-bg);color:var(--info)}
    .badge-active{background:var(--success-bg);color:var(--success)}
    .badge-expired{background:var(--danger-bg);color:var(--danger)}
    .badge-revoked{background:#f0f0f0;color:#777}
    .badge-single{background:#f3e8ff;color:#7c3aed}
    .badge-reseller_bundle{background:#fef3c7;color:var(--warn)}
    .badge-reseller_unit{background:#fff7ed;color:#c2410c}

    .user-info{display:flex;flex-direction:column;gap:1px}
    .user-name{font-weight:600;font-size:13px}
    .user-email{font-size:11px;color:var(--muted)}
    .date-cell{font-size:12px;color:var(--muted);white-space:nowrap}

    /* Buttons */
    .btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s}
    .btn-primary{background:var(--brand);color:#fff}
    .btn-primary:hover{background:var(--brand-deep)}
    .btn-secondary{background:#f0f4f8;color:var(--ink);border:1px solid var(--line)}
    .btn-secondary:hover{background:#e2e8f0}
    .btn-danger{background:var(--danger-bg);color:var(--danger)}
    .btn-danger:hover{background:#fdd;color:#991b1b}
    .btn-sm{padding:4px 10px;font-size:11px;border-radius:6px}
    .btn-group{display:flex;gap:4px}

    .copy-all-btn{background:var(--brand);color:#fff;border:none;padding:8px 16px;border-radius:10px;cursor:pointer;font-size:13px;font-weight:600}
    .copy-all-btn:hover{background:var(--brand-deep)}
    .copy-all-btn.alt{background:#1d4ed8}
    .copy-all-btn.alt:hover{background:#1e40af}

    /* Pagination */
    .pagination{display:flex;gap:6px;justify-content:center;padding:16px;align-items:center}
    .pagination button{padding:6px 12px;border:1px solid var(--line);border-radius:8px;background:#fff;cursor:pointer;font-size:13px}
    .pagination button.active{background:var(--brand);color:#fff;border-color:var(--brand)}
    .pagination button:disabled{opacity:.4;cursor:not-allowed}
    .pagination span{font-size:13px;color:var(--muted)}

    /* Reseller */
    .reseller-bar{height:8px;background:#e5e7eb;border-radius:4px;overflow:hidden;width:100%;max-width:200px}
    .reseller-bar-fill{height:100%;border-radius:4px;transition:width .3s}
    .reseller-stats{display:flex;gap:16px;flex-wrap:wrap}
    .reseller-stat{font-size:11px;display:flex;align-items:center;gap:4px}
    .reseller-dot{width:8px;height:8px;border-radius:50%;display:inline-block}

    /* Modal */
    .modal-mask{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:500;align-items:center;justify-content:center}
    .modal-mask.open{display:flex}
    .modal-box{background:#fff;border-radius:18px;box-shadow:0 40px 80px rgba(0,0,0,0.2);width:640px;max-width:95vw;max-height:90vh;overflow-y:auto}
    .modal-header{padding:20px 24px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}
    .modal-header h3{margin:0;font-size:18px}
    .modal-close{background:none;border:none;font-size:22px;cursor:pointer;color:var(--muted)}
    .modal-body{padding:20px 24px}
    .modal-footer{padding:16px 24px;border-top:1px solid var(--line);display:flex;justify-content:flex-end;gap:10px}

    .detail-section{margin-bottom:20px}
    .detail-section-title{font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:700;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--line)}
    .detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:0}
    .detail-item{padding:8px 0;border-bottom:1px solid rgba(0,0,0,0.04)}
    .detail-item:nth-child(odd){padding-right:16px}
    .detail-item:nth-child(even){padding-left:16px;border-left:1px solid rgba(0,0,0,0.04)}
    .detail-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-bottom:2px}
    .detail-value{font-size:14px;font-weight:500}
    .detail-code{font-family:"SF Mono","Consolas",monospace;font-size:13px;background:rgba(0,0,0,0.04);padding:8px 12px;border-radius:8px;word-break:break-all;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center}
    .detail-code button{flex-shrink:0;margin-left:12px}

    /* Toast */
    .toast{position:fixed;bottom:24px;right:24px;padding:14px 20px;border-radius:12px;color:#fff;font-size:14px;font-weight:500;z-index:999;animation:slideUp .3s ease}
    .toast-success{background:var(--success)}
    .toast-error{background:var(--danger)}
    @keyframes slideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}

    .empty-state{text-align:center;padding:40px;color:var(--muted)}

    @media(max-width:900px){
      .main-content{margin-left:0}
      .stat-grid{grid-template-columns:repeat(2,1fr)}
      .form-row{grid-template-columns:1fr}
      .detail-grid{grid-template-columns:1fr}
      .detail-item:nth-child(even){padding-left:0;border-left:none}
    }
    @media(max-width:600px){
      .stat-grid{grid-template-columns:1fr}
      .page-content{padding:16px}
      .filter-bar{flex-direction:column}
      .search-input{min-width:100%}
    }
  </style>
</head>
<body>
  <%- include('partials/sidebar', { activePage: 'tokens' }) %>
  <div class="main-content">
    <%- include('partials/header', { breadcrumb: 'Tokens', currentAdminUser: typeof currentAdminUser !== 'undefined' ? currentAdminUser : 'Admin' }) %>
    <div class="page-content">

      <div class="page-header">
        <div>
          <h1 class="page-title">Token Management</h1>
          <p class="page-subtitle">Generate, monitor, and manage access tokens for users and resellers</p>
        </div>
      </div>

      <!-- Alert Banner -->
      <div class="alert-banner alert-warn" id="alertBanner">
        <span>&#9888;</span>
        <span id="alertText"></span>
      </div>

      <!-- Stats -->
      <div class="stat-grid" id="statCards">
        <div class="stat-card sc-available">
          <div class="stat-label">Available</div>
          <div class="stat-value" id="sAvailable">&ndash;</div>
          <div class="stat-note">Ready to assign</div>
        </div>
        <div class="stat-card sc-active">
          <div class="stat-label">Active</div>
          <div class="stat-value" id="sActive">&ndash;</div>
          <div class="stat-note">Currently in use</div>
        </div>
        <div class="stat-card sc-users">
          <div class="stat-label">Active Users</div>
          <div class="stat-value" id="sUsers">&ndash;</div>
          <div class="stat-note" id="sExpiring7"></div>
        </div>
        <div class="stat-card sc-expired">
          <div class="stat-label">Expired</div>
          <div class="stat-value" id="sExpired">&ndash;</div>
          <div class="stat-note">Tokens expired</div>
        </div>
        <div class="stat-card sc-revoked">
          <div class="stat-label">Revoked</div>
          <div class="stat-value" id="sRevoked">&ndash;</div>
          <div class="stat-note">Manually revoked</div>
        </div>
        <div class="stat-card sc-bundles">
          <div class="stat-label">Bundles</div>
          <div class="stat-value" id="sBundles">&ndash;</div>
          <div class="stat-note">Reseller bundles</div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="tabs">
        <button class="tab-btn active" data-tab="generator" onclick="switchTab('generator',this)">&#8853; Generate</button>
        <button class="tab-btn" data-tab="tokens" onclick="switchTab('tokens',this)">All Tokens <span class="tab-count" id="tabCountTokens">0</span></button>
        <button class="tab-btn" data-tab="resellers" onclick="switchTab('resellers',this)">Resellers <span class="tab-count" id="tabCountResellers">0</span></button>
      </div>

      <!-- Tab: Token Generator -->
      <div class="tab-panel active" id="tab-generator">
        <div class="card">
          <div class="card-header">
            <div>
              <h2 class="card-title">Generate New Tokens</h2>
              <p class="card-subtitle">Create single-use tokens or reseller bundles</p>
            </div>
          </div>
          <div class="card-body">
            <form id="generateForm" onsubmit="generateTokens(event)">
              <div class="form-row">
                <div class="form-group">
                  <label>Token Type</label>
                  <select id="genType" onchange="toggleResellerFields()">
                    <option value="single">Single User Token</option>
                    <option value="reseller_bundle">Reseller Bundle</option>
                  </select>
                  <div class="form-hint">Single = one code per user. Bundle = batch for a reseller.</div>
                </div>
                <div class="form-group">
                  <label>Subscription Duration</label>
                  <select id="genDuration" onchange="toggleCustomDays()">
                    <option value="monthly">Monthly (30 days)</option>
                    <option value="yearly">Yearly (365 days)</option>
                    <option value="custom">Custom Duration</option>
                  </select>
                  <div class="form-hint">How long the user access lasts once activated.</div>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group" id="customDaysGroup" style="display:none">
                  <label>Custom Duration (days)</label>
                  <input type="number" id="genDays" min="1" max="3650" placeholder="e.g. 90">
                </div>
                <div class="form-group" id="quantityGroup" style="display:none">
                  <label>Number of Tokens</label>
                  <input type="number" id="genQty" min="1" max="1000" value="10" placeholder="How many tokens to generate">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Recipient Name</label>
                  <input type="text" id="genRecipientName" placeholder="e.g. Dr. John Smith, MedStore Cairo" required>
                  <div class="form-hint">Saved with the token so admin can track who the code was generated for.</div>
                </div>
                <div class="form-group">
                  <label>Recipient Email</label>
                  <input type="email" id="genRecipientEmail" placeholder="name@example.com" required>
                  <div class="form-hint">Seller or buyer contact used for tracking and PDF export.</div>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group" id="resellerGroup" style="display:none">
                  <label>Reseller Name</label>
                  <input type="text" id="genReseller" placeholder="Optional reseller label; defaults to recipient name">
                  <div class="form-hint">Used as the internal reseller label for bundle reporting.</div>
                </div>
                <div class="form-group">
                  <label>Activation Policy</label>
                  <input type="text" value="Access duration starts only after first use" disabled>
                  <div class="form-hint">Unused tokens stay redeemable until they are used or manually revoked.</div>
                </div>
              </div>
              <button type="submit" class="btn btn-primary" id="generateBtn">&#8853; Generate Tokens</button>
            </form>

            <div class="generated-tokens" id="generatedOutput" style="display:none">
              <div class="gen-header">
                <strong id="generatedTitle">Generated Tokens</strong>
                <div class="btn-group">
                  <button class="copy-all-btn alt" id="exportPdfBtn" style="display:none" onclick="exportLastGeneratedPdf()">Export PDF</button>
                  <button class="copy-all-btn" onclick="copyAllTokens()">Copy All Codes</button>
                </div>
              </div>
              <div id="generatedList"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab: All Tokens -->
      <div class="tab-panel" id="tab-tokens">
        <div class="card">
          <div class="card-header">
            <h2 class="card-title">All Tokens</h2>
            <div class="filter-bar">
              <input type="text" class="search-input" id="tokenSearch" placeholder="Search by code, recipient, user, or email..." oninput="debouncedLoadTokens()">
              <select class="filter-select" id="filterStatus" onchange="loadTokens()">
                <option value="">All Status</option>
                <option value="available">Available</option>
                <option value="active">Active</option>
                <option value="expired">Expired</option>
                <option value="revoked">Revoked</option>
              </select>
              <select class="filter-select" id="filterType" onchange="loadTokens()">
                <option value="">All Types</option>
                <option value="single">Single</option>
                <option value="reseller_bundle">Bundle</option>
                <option value="reseller_unit">Unit</option>
              </select>
            </div>
          </div>
          <div class="card-body" style="padding:0;overflow-x:auto">
            <table>
              <thead>
                <tr>
                  <th>Token Code</th>
                  <th>Type</th>
                  <th>Duration</th>
                  <th>Status</th>
                  <th>Requested For</th>
                  <th>Activated User</th>
                  <th>User Valid Until</th>
                  <th>Used At</th>
                  <th>Created</th>
                  <th style="text-align:right">Actions</th>
                </tr>
              </thead>
              <tbody id="tokensTableBody">
                <tr><td colspan="10" class="empty-state">Loading tokens...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="pagination" id="tokensPagination"></div>
        </div>
      </div>

      <!-- Tab: Resellers -->
      <div class="tab-panel" id="tab-resellers">
        <div class="card">
          <div class="card-header">
            <div>
              <h2 class="card-title">Reseller Overview</h2>
              <p class="card-subtitle">Usage breakdown per reseller</p>
            </div>
          </div>
          <div class="card-body" style="padding:0;overflow-x:auto">
            <table>
              <thead>
                <tr>
                  <th>Reseller</th>
                  <th>Bundles</th>
                  <th>Total Units</th>
                  <th>Breakdown</th>
                  <th>Usage Rate</th>
                </tr>
              </thead>
              <tbody id="resellersTableBody">
                <tr><td colspan="5" class="empty-state">Loading resellers...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Token Detail Modal -->
  <div class="modal-mask" id="detailModal" onclick="if(event.target===this)closeModal()">
    <div class="modal-box">
      <div class="modal-header">
        <h3 id="modalTitle">Token Details</h3>
        <button class="modal-close" onclick="closeModal()">&times;</button>
      </div>
      <div class="modal-body" id="detailBody">Loading...</div>
      <div class="modal-footer" id="modalFooter">
        <button class="btn btn-secondary" onclick="closeModal()">Close</button>
      </div>
    </div>
  </div>

<script>
/* Helpers */
function escHtml(str) {
  var d = document.createElement('div');
  d.textContent = str || '';
  return d.innerHTML;
}

function fmtDate(dateStr) {
  if (!dateStr) return '\u2014';
  var d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function fmtDateTime(dateStr) {
  if (!dateStr) return '\u2014';
  var d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) +
    ' ' + d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
}

function daysFromNow(dateStr) {
  if (!dateStr) return null;
  return Math.ceil((new Date(dateStr) - Date.now()) / 86400000);
}

function durationLabel(t) {
  if (t.duration_type === 'monthly') return '30 days';
  if (t.duration_type === 'yearly') return '365 days';
  return t.duration_days + ' days';
}

function typeLabel(type) {
  if (type === 'single') return 'Single';
  if (type === 'reseller_bundle') return 'Bundle';
  if (type === 'reseller_unit') return 'Unit';
  return type;
}

/* Toast */
function toast(msg, type) {
  var t = document.createElement('div');
  t.className = 'toast toast-' + type;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(function() { t.remove(); }, 3500);
}

/* Tab Switching */
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  document.getElementById('tab-' + name).classList.add('active');
  if (btn) btn.classList.add('active');
  if (name === 'tokens') loadTokens();
  if (name === 'resellers') loadResellers();
}

/* Form Toggles */
function toggleResellerFields() {
  var isBundle = document.getElementById('genType').value === 'reseller_bundle';
  document.getElementById('quantityGroup').style.display = isBundle ? '' : 'none';
  document.getElementById('resellerGroup').style.display = isBundle ? '' : 'none';
}

function toggleCustomDays() {
  var isCustom = document.getElementById('genDuration').value === 'custom';
  document.getElementById('customDaysGroup').style.display = isCustom ? '' : 'none';
}

/* Sidebar Toggle */
function toggleSidebar() {
  document.body.classList.toggle('collapsed');
  var sb = document.getElementById('sidebar');
  if (sb) sb.classList.toggle('show');
}

/* Load Stats */
async function loadStats() {
  try {
    var resp = await fetch('/api/admin/tokens/stats');
    var d = await resp.json();
    document.getElementById('sAvailable').textContent = (d.available || 0).toLocaleString();
    document.getElementById('sActive').textContent = (d.active || 0).toLocaleString();
    document.getElementById('sExpired').textContent = (d.expired || 0).toLocaleString();
    document.getElementById('sRevoked').textContent = (d.revoked || 0).toLocaleString();
    document.getElementById('sUsers').textContent = (d.active_users || 0).toLocaleString();
    document.getElementById('sBundles').textContent = (d.total_bundles || 0).toLocaleString();
    document.getElementById('tabCountTokens').textContent = (d.total_tokens || 0).toLocaleString();

    var exp7El = document.getElementById('sExpiring7');
    if (d.expiring_7_days > 0) {
      exp7El.textContent = d.expiring_7_days + ' account(s) expiring in 7 days';
      exp7El.className = 'stat-note warn';
    } else {
      exp7El.textContent = 'No upcoming account expiries';
      exp7El.className = 'stat-note';
    }

    var banner = document.getElementById('alertBanner');
    if (d.expiring_7_days > 0) {
      document.getElementById('alertText').textContent =
        d.expiring_7_days + ' token-based account(s) expire within 7 days' +
        (d.expiring_30_days > d.expiring_7_days ? ', ' + d.expiring_30_days + ' within 30 days' : '') + '.';
      banner.classList.add('show');
    } else {
      banner.classList.remove('show');
    }
  } catch (e) {
    console.error('Failed to load stats:', e);
  }
}

/* Generate Tokens */
var lastGeneratedCodes = [];
var lastGeneratedBatch = null;
var currentDetailExportPacket = null;
async function generateTokens(e) {
  e.preventDefault();
  var btn = document.getElementById('generateBtn');
  btn.disabled = true;
  btn.textContent = 'Generating...';

  var body = {
    token_type: document.getElementById('genType').value,
    duration_type: document.getElementById('genDuration').value,
    recipient_name: document.getElementById('genRecipientName').value.trim(),
    recipient_email: document.getElementById('genRecipientEmail').value.trim()
  };
  if (!body.recipient_name || !body.recipient_email) {
    toast('Recipient name and email are required', 'error');
    btn.disabled = false; btn.textContent = '\u2295 Generate Tokens';
    return;
  }
  if (body.duration_type === 'custom') {
    body.duration_days = parseInt(document.getElementById('genDays').value);
    if (!body.duration_days || body.duration_days < 1) {
      toast('Please enter custom duration in days', 'error');
      btn.disabled = false; btn.textContent = '\u2295 Generate Tokens';
      return;
    }
  }
  if (body.token_type === 'reseller_bundle') {
    body.quantity = parseInt(document.getElementById('genQty').value);
    body.reseller_name = document.getElementById('genReseller').value.trim();
    if (!body.quantity || body.quantity < 1) {
      toast('Please enter number of tokens', 'error');
      btn.disabled = false; btn.textContent = '\u2295 Generate Tokens';
      return;
    }
  }

  try {
    var resp = await fetch('/api/admin/tokens/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    var data = await resp.json();
    if (!resp.ok) {
      toast(data.error || 'Failed to generate tokens', 'error');
      return;
    }

    var codes = data.tokens.filter(function(t) { return t.token_type !== 'reseller_bundle'; });
    lastGeneratedCodes = codes.map(function(t) { return t.token_code; });
    lastGeneratedBatch = {
      token_type: body.token_type,
      duration_label: body.duration_type === 'custom' ? body.duration_days + ' days' : durationLabel({ duration_type: body.duration_type, duration_days: body.duration_days || 0 }),
      recipient_name: body.recipient_name,
      recipient_email: body.recipient_email,
      reseller_name: body.reseller_name || body.recipient_name,
      generated_at: new Date().toISOString(),
      created_by: '<%= typeof currentAdminUser !== "undefined" ? currentAdminUser : "Admin" %>',
      tokens: codes
    };
    var output = document.getElementById('generatedOutput');
    var list = document.getElementById('generatedList');
    var title = document.getElementById('generatedTitle');
    var exportBtn = document.getElementById('exportPdfBtn');
    var durStr = body.duration_type === 'custom' ? body.duration_days + ' days' : body.duration_type;
    title.textContent = codes.length + ' Token' + (codes.length !== 1 ? 's' : '') + ' Generated \u00B7 ' + durStr;
    exportBtn.style.display = codes.length > 0 ? '' : 'none';
    list.innerHTML = codes.map(function(t, i) {
      return '<div class="generated-token-item">' +
        '<span style="color:var(--muted);min-width:28px">' + (i + 1) + '.</span>' +
        '<span style="flex:1">' + escHtml(t.token_code) + '</span>' +
        '<button onclick="copyCode(\'' + t.token_code + '\')">Copy</button>' +
      '</div>';
    }).join('');
    output.style.display = '';

    toast('Successfully generated ' + codes.length + ' token(s)', 'success');
    loadStats();
  } catch (err) {
    toast('Network error', 'error');
    console.error(err);
  } finally {
    btn.disabled = false;
    btn.textContent = '\u2295 Generate Tokens';
  }
}

function copyCode(code) {
  navigator.clipboard.writeText(code).then(function() { toast('Token code copied!', 'success'); });
}

function copyAllTokens() {
  if (lastGeneratedCodes.length === 0) return;
  navigator.clipboard.writeText(lastGeneratedCodes.join('\n')).then(function() {
    toast('All ' + lastGeneratedCodes.length + ' codes copied!', 'success');
  });
}

function exportTokenPacketPdf(packet) {
  if (!packet || !packet.tokens || packet.tokens.length === 0) {
    toast('No generated tokens available to export', 'error');
    return;
  }

  var rows = packet.tokens.map(function(t, index) {
    return '<tr>' +
      '<td>' + (index + 1) + '</td>' +
      '<td style="font-family:SFMono-Regular,Consolas,monospace">' + escHtml(t.token_code) + '</td>' +
      '<td>' + escHtml(typeLabel(t.token_type)) + '</td>' +
      '<td>' + escHtml(durationLabel(t)) + '</td>' +
    '</tr>';
  }).join('');

  var popup = window.open('', '_blank', 'width=960,height=760');
  if (!popup) {
    toast('Please allow pop-ups to export PDF', 'error');
    return;
  }

  popup.document.write('<!DOCTYPE html><html><head><meta charset="utf-8"><title>Token Export</title><style>' +
    'body{font-family:"Avenir Next","Helvetica Neue",Arial,sans-serif;color:#1d2a2f;padding:32px;line-height:1.45}' +
    'h1{margin:0 0 6px;font-size:28px} h2{margin:26px 0 10px;font-size:15px;text-transform:uppercase;letter-spacing:.08em;color:#66757e}' +
    '.meta{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px 20px;margin:20px 0 28px}' +
    '.meta-box{padding:12px 14px;border:1px solid #d7e0e5;border-radius:12px;background:#f9fbfb}' +
    '.label{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:#66757e;font-weight:700;margin-bottom:4px}' +
    '.value{font-size:15px;font-weight:600}' +
    'table{width:100%;border-collapse:collapse;margin-top:10px} th,td{border:1px solid #d7e0e5;padding:10px 12px;text-align:left;font-size:13px;vertical-align:top}' +
    'th{background:#eef6f5;font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:#486068}' +
    '.note{margin-top:20px;padding:14px 16px;border-radius:12px;background:#eff6ff;color:#1e3a8a;font-size:13px}' +
    '@media print{body{padding:20px}.print-hide{display:none}}' +
  '</style></head><body>' +
    '<h1>iMD Token Export</h1>' +
    '<div style="color:#66757e;font-size:14px">Prepared for seller delivery and PDF sharing</div>' +
    '<div class="meta">' +
      '<div class="meta-box"><div class="label">Recipient</div><div class="value">' + escHtml(packet.recipient_name || '\u2014') + '</div></div>' +
      '<div class="meta-box"><div class="label">Recipient Email</div><div class="value">' + escHtml(packet.recipient_email || '\u2014') + '</div></div>' +
      '<div class="meta-box"><div class="label">Reseller Label</div><div class="value">' + escHtml(packet.reseller_name || packet.recipient_name || '\u2014') + '</div></div>' +
      '<div class="meta-box"><div class="label">Duration</div><div class="value">' + escHtml(packet.duration_label || '\u2014') + '</div></div>' +
      '<div class="meta-box"><div class="label">Generated At</div><div class="value">' + escHtml(fmtDateTime(packet.generated_at)) + '</div></div>' +
      '<div class="meta-box"><div class="label">Generated By</div><div class="value">' + escHtml(packet.created_by || 'Admin') + '</div></div>' +
    '</div>' +
    '<h2>Token Codes</h2>' +
    '<table><thead><tr><th>#</th><th>Token Code</th><th>Type</th><th>Duration</th></tr></thead><tbody>' + rows + '</tbody></table>' +
    '<div class="note">Access duration starts only when the token is redeemed. Unused tokens remain valid until redeemed or manually revoked by admin.</div>' +
    '<div class="print-hide" style="margin-top:24px"><button onclick="window.print()" style="padding:10px 16px;border:none;border-radius:10px;background:#0f766e;color:#fff;font-weight:700;cursor:pointer">Print / Save as PDF</button></div>' +
  '</body></html>');
  popup.document.close();
}

function exportLastGeneratedPdf() {
  exportTokenPacketPdf(lastGeneratedBatch);
}

function exportCurrentDetailPdf() {
  exportTokenPacketPdf(currentDetailExportPacket);
}

/* Load Tokens Table */
var currentPage = 1;
var _searchTimer = null;
function debouncedLoadTokens() {
  clearTimeout(_searchTimer);
  _searchTimer = setTimeout(function() { loadTokens(); }, 300);
}

async function loadTokens(page) {
  if (page) currentPage = page;
  var search = document.getElementById('tokenSearch').value.trim();
  var status = document.getElementById('filterStatus').value;
  var type = document.getElementById('filterType').value;
  var params = new URLSearchParams({ page: currentPage, limit: 50 });
  if (search) params.set('search', search);
  if (status) params.set('status', status);
  if (type) params.set('type', type);

  try {
    var resp = await fetch('/api/admin/tokens?' + params);
    var data = await resp.json();
    var tbody = document.getElementById('tokensTableBody');

    if (!data.tokens || data.tokens.length === 0) {
      tbody.innerHTML = '<tr><td colspan="10" class="empty-state">No tokens found</td></tr>';
      document.getElementById('tokensPagination').innerHTML = '';
      return;
    }

    tbody.innerHTML = data.tokens.map(function(t) {
      var recipientHtml = '\u2014';
      if (t.recipient_name || t.recipient_email || t.assigned_to_reseller) {
        recipientHtml = '<div class="user-info"><span class="user-name">' +
          escHtml(t.recipient_name || t.assigned_to_reseller || 'Unnamed recipient') + '</span>' +
          (t.recipient_email ? '<span class="user-email">' + escHtml(t.recipient_email) + '</span>' : '') +
          (t.assigned_to_reseller && t.assigned_to_reseller !== t.recipient_name ? '<span class="user-email">Reseller: ' + escHtml(t.assigned_to_reseller) + '</span>' : '') +
          '</div>';
      }

      var assignedHtml = '\u2014';
      if (t.assigned_username) {
        assignedHtml = '<div class="user-info"><span class="user-name">' + escHtml(t.assigned_username) + '</span>' +
          (t.assigned_email ? '<span class="user-email">' + escHtml(t.assigned_email) + '</span>' : '') + '</div>';
      }

      // User valid_until
      var validUntilHtml = '\u2014';
      if (t.status === 'active' && t.user_valid_until) {
        var days = daysFromNow(t.user_valid_until);
        if (days !== null && days <= 7) {
          validUntilHtml = '<span style="color:var(--danger);font-weight:600">' + fmtDate(t.user_valid_until) + '</span><br><span style="font-size:10px;color:var(--danger)">' + days + 'd left</span>';
        } else if (days !== null && days <= 30) {
          validUntilHtml = '<span style="color:var(--warn);font-weight:600">' + fmtDate(t.user_valid_until) + '</span><br><span style="font-size:10px;color:var(--warn)">' + days + 'd left</span>';
        } else {
          validUntilHtml = '<span>' + fmtDate(t.user_valid_until) + '</span>';
        }
      }

      return '<tr>' +
        '<td><span class="token-code" title="Click to copy: ' + escHtml(t.token_code) + '" onclick="copyCode(\'' + t.token_code + '\')">' + escHtml(t.token_code.substring(0, 14)) + '\u2026</span></td>' +
        '<td><span class="badge badge-' + t.token_type + '">' + escHtml(typeLabel(t.token_type)) + '</span></td>' +
        '<td>' + escHtml(durationLabel(t)) + '</td>' +
        '<td><span class="badge badge-' + t.status + '">' + t.status + '</span></td>' +
        '<td>' + recipientHtml + '</td>' +
        '<td>' + assignedHtml + '</td>' +
        '<td class="date-cell">' + validUntilHtml + '</td>' +
        '<td class="date-cell">' + (t.used_at ? fmtDate(t.used_at) : '\u2014') + '</td>' +
        '<td class="date-cell">' + fmtDate(t.created_at) + (t.created_by ? '<br><span style="font-size:10px;color:var(--muted)">' + escHtml(t.created_by) + '</span>' : '') + '</td>' +
        '<td style="text-align:right"><div class="btn-group" style="justify-content:flex-end">' +
          '<button class="btn btn-sm btn-secondary" onclick="viewToken(' + t.id + ')" title="View details">View</button>' +
          (t.status !== 'revoked' ? '<button class="btn btn-sm btn-danger" onclick="revokeToken(' + t.id + ')" title="Revoke token">Revoke</button>' : '') +
        '</div></td>' +
      '</tr>';
    }).join('');

    // Pagination
    var totalPages = Math.ceil(data.total / data.limit);
    var pag = document.getElementById('tokensPagination');
    if (totalPages <= 1) {
      pag.innerHTML = '<span>' + data.total + ' token' + (data.total !== 1 ? 's' : '') + '</span>';
      return;
    }
    var html = '<button ' + (currentPage <= 1 ? 'disabled' : '') + ' onclick="loadTokens(' + (currentPage - 1) + ')">\u2039 Prev</button>';
    html += '<span>Page ' + currentPage + ' of ' + totalPages + ' \u00B7 ' + data.total + ' tokens</span>';
    html += '<button ' + (currentPage >= totalPages ? 'disabled' : '') + ' onclick="loadTokens(' + (currentPage + 1) + ')">Next \u203A</button>';
    pag.innerHTML = html;
  } catch (e) {
    console.error('Failed to load tokens:', e);
  }
}

/* View Token Detail */
async function viewToken(id) {
  var modal = document.getElementById('detailModal');
  var body = document.getElementById('detailBody');
  modal.classList.add('open');
  body.innerHTML = '<p style="color:var(--muted)">Loading...</p>';

  try {
    var resp = await fetch('/api/admin/tokens/' + id);
    var data = await resp.json();
    var t = data.token;
    var html = '';

    // Token code
    html += '<div class="detail-code"><span style="word-break:break-all">' + escHtml(t.token_code) + '</span>' +
      '<button class="btn btn-sm btn-secondary" onclick="copyCode(\'' + t.token_code + '\')">Copy</button></div>';

    // Token Info section
    html += '<div class="detail-section"><div class="detail-section-title">Token Information</div><div class="detail-grid">';
    html += '<div class="detail-item"><div class="detail-label">Type</div><div class="detail-value"><span class="badge badge-' + t.token_type + '">' + escHtml(typeLabel(t.token_type)) + '</span></div></div>';
    html += '<div class="detail-item"><div class="detail-label">Status</div><div class="detail-value"><span class="badge badge-' + t.status + '">' + t.status + '</span></div></div>';
    html += '<div class="detail-item"><div class="detail-label">Duration</div><div class="detail-value">' + escHtml(t.duration_type) + ' (' + t.duration_days + ' days)</div></div>';
    html += '<div class="detail-item"><div class="detail-label">Recipient Name</div><div class="detail-value">' + escHtml(t.recipient_name || t.assigned_to_reseller || '\u2014') + '</div></div>';
    html += '<div class="detail-item"><div class="detail-label">Recipient Email</div><div class="detail-value">' + escHtml(t.recipient_email || '\u2014') + '</div></div>';
    html += '<div class="detail-item"><div class="detail-label">Created</div><div class="detail-value">' + fmtDateTime(t.created_at) + '</div></div>';
    html += '<div class="detail-item"><div class="detail-label">Created By</div><div class="detail-value">' + escHtml(t.created_by || '\u2014') + '</div></div>';
    html += '</div></div>';

    // Assignment section
    if (t.assigned_username || t.assigned_to_reseller || t.used_at) {
      html += '<div class="detail-section"><div class="detail-section-title">Assignment</div><div class="detail-grid">';
      html += '<div class="detail-item"><div class="detail-label">Activated User</div><div class="detail-value">' +
        (t.assigned_username ? escHtml(t.assigned_username) : '\u2014') + '</div></div>';
      html += '<div class="detail-item"><div class="detail-label">User Email</div><div class="detail-value">' +
        (t.assigned_email ? escHtml(t.assigned_email) : '\u2014') + '</div></div>';
      if (t.assigned_to_reseller) {
        html += '<div class="detail-item"><div class="detail-label">Reseller</div><div class="detail-value">' + escHtml(t.assigned_to_reseller) + '</div></div>';
        html += '<div class="detail-item"></div>';
      }
      html += '<div class="detail-item"><div class="detail-label">Used At</div><div class="detail-value">' + fmtDateTime(t.used_at) + '</div></div>';
      if (t.user_valid_until) {
        var days = daysFromNow(t.user_valid_until);
        var color = days !== null && days <= 7 ? 'var(--danger)' : days !== null && days <= 30 ? 'var(--warn)' : 'var(--success)';
        html += '<div class="detail-item"><div class="detail-label">User Valid Until</div><div class="detail-value" style="color:' + color + ';font-weight:600">' +
          fmtDate(t.user_valid_until) + (days !== null ? ' (' + days + ' days left)' : '') + '</div></div>';
      } else {
        html += '<div class="detail-item"></div>';
      }
      html += '</div></div>';
    }

    // Bundle children
    if (data.children && data.children.length > 0) {
      var used = data.children.filter(function(c) { return c.status === 'active'; }).length;
      var avail = data.children.filter(function(c) { return c.status === 'available'; }).length;
      html += '<div class="detail-section"><div class="detail-section-title">Bundle Tokens (' + data.children.length + ' total \u00B7 ' + used + ' used \u00B7 ' + avail + ' available)</div>';
      html += '<div style="max-height:240px;overflow-y:auto">';
      html += data.children.map(function(c, i) {
        return '<div class="generated-token-item" style="font-size:11px">' +
          '<span style="color:var(--muted);min-width:24px">' + (i + 1) + '</span>' +
          '<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + escHtml(c.token_code) + '">' + escHtml(c.token_code.substring(0, 14)) + '\u2026 </span>' +
          '<span class="badge badge-' + c.status + '" style="margin:0 8px">' + c.status + '</span>' +
          (c.assigned_username ? '<span style="font-size:10px;color:var(--muted)">\u2192 ' + escHtml(c.assigned_username) + '</span>' : '') +
          '<button onclick="copyCode(\'' + c.token_code + '\')" style="margin-left:8px">Copy</button>' +
        '</div>';
      }).join('');
      html += '</div></div>';
    }

    // Usage history
    if (data.history && data.history.length > 0) {
      html += '<div class="detail-section"><div class="detail-section-title">Usage History</div>';
      html += '<table style="width:100%;font-size:12px"><thead><tr><th>Action</th><th>User</th><th>Applied</th><th>Valid Until</th></tr></thead><tbody>';
      html += data.history.map(function(h) {
        return '<tr><td style="padding:6px 8px"><span class="badge badge-active">' + escHtml(h.action) + '</span></td>' +
        '<td style="padding:6px 8px">' + escHtml(h.username) + '</td>' +
        '<td style="padding:6px 8px">' + fmtDateTime(h.applied_at) + '</td>' +
        '<td style="padding:6px 8px">' + fmtDate(h.valid_until) + '</td></tr>';
      }).join('');
      html += '</tbody></table></div>';
    }

    body.innerHTML = html;
    document.getElementById('modalTitle').textContent = 'Token: ' + t.token_code.substring(0, 8) + '\u2026';

    currentDetailExportPacket = {
      token_type: t.token_type,
      duration_label: durationLabel(t),
      recipient_name: t.recipient_name,
      recipient_email: t.recipient_email,
      reseller_name: t.assigned_to_reseller,
      generated_at: t.created_at,
      created_by: t.created_by,
      tokens: data.children && data.children.length > 0 ? data.children : [t]
    };

    // Show revoke in footer if applicable
    var footer = document.getElementById('modalFooter');
    if (t.status !== 'revoked') {
      footer.innerHTML = '<button class="btn btn-secondary" onclick="exportCurrentDetailPdf()">Export PDF</button>' +
        '<button class="btn btn-danger" onclick="revokeToken(' + t.id + ');closeModal()">Revoke Token</button>' +
        '<button class="btn btn-secondary" onclick="closeModal()">Close</button>';
    } else {
      footer.innerHTML = '<button class="btn btn-secondary" onclick="exportCurrentDetailPdf()">Export PDF</button>' +
        '<button class="btn btn-secondary" onclick="closeModal()">Close</button>';
    }
  } catch (err) {
    body.innerHTML = '<p style="color:var(--danger)">Failed to load token details</p>';
  }
}

function closeModal() {
  currentDetailExportPacket = null;
  document.getElementById('detailModal').classList.remove('open');
}

/* Revoke Token */
async function revokeToken(id) {
  if (!confirm('Revoke this token? If it is active, the assigned user may lose access.')) return;
  try {
    var resp = await fetch('/api/admin/tokens/' + id + '/revoke', { method: 'POST' });
    var data = await resp.json();
    if (!resp.ok) {
      toast(data.error || 'Failed to revoke token', 'error');
      return;
    }
    toast('Token revoked successfully', 'success');
    loadTokens();
    loadStats();
  } catch (e) {
    toast('Network error', 'error');
  }
}

/* Load Resellers */
async function loadResellers() {
  try {
    var resp = await fetch('/api/admin/tokens/resellers');
    var data = await resp.json();
    var tbody = document.getElementById('resellersTableBody');
    document.getElementById('tabCountResellers').textContent = (data.length || 0).toString();

    if (!data || data.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No resellers found. Create a reseller bundle to get started.</td></tr>';
      return;
    }

    tbody.innerHTML = data.map(function(r) {
      var usagePct = r.total_units > 0 ? Math.round((r.used_units / r.total_units) * 100) : 0;
      var barColor = usagePct >= 80 ? 'var(--success)' : usagePct >= 40 ? 'var(--warn)' : 'var(--info)';
      return '<tr>' +
        '<td><strong>' + escHtml(r.reseller_name || 'Unnamed') + '</strong></td>' +
        '<td>' + r.total_bundles + '</td>' +
        '<td>' + r.total_units + '</td>' +
        '<td><div class="reseller-stats">' +
          '<span class="reseller-stat"><span class="reseller-dot" style="background:var(--info)"></span> ' + r.available_units + ' available</span>' +
          '<span class="reseller-stat"><span class="reseller-dot" style="background:var(--success)"></span> ' + r.used_units + ' used</span>' +
          '<span class="reseller-stat"><span class="reseller-dot" style="background:var(--danger)"></span> ' + r.expired_units + ' expired</span>' +
          (r.revoked_units > 0 ? '<span class="reseller-stat"><span class="reseller-dot" style="background:#999"></span> ' + r.revoked_units + ' revoked</span>' : '') +
        '</div></td>' +
        '<td><div style="display:flex;align-items:center;gap:10px">' +
          '<div class="reseller-bar"><div class="reseller-bar-fill" style="width:' + usagePct + '%;background:' + barColor + '"></div></div>' +
          '<strong style="font-size:13px">' + usagePct + '%</strong>' +
        '</div></td>' +
      '</tr>';
    }).join('');
  } catch (e) {
    console.error('Failed to load resellers:', e);
  }
}

/* Init */
loadStats();
</script>
</body>
</html>