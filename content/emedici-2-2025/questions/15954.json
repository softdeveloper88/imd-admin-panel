{"data":[{"type":"questionAttempts","id":"17607335","links":{"self":"https://app.emedici.com/api/questionAttempts/17607335"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T13:21:21+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T13:21:21+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15954"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15954","links":{"self":"https://app.emedici.com/api/questions/15954"},"attributes":{"optionProportions":[0.08,0.1,0.05,0.05,0.73]},"relationships":{"item":{"data":{"type":"items","id":"8645"}},"activeRevision":{"data":{"type":"questionRevisions","id":"63330"}}}},{"type":"items","id":"8645","links":{"self":"https://app.emedici.com/api/items/8645"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15954"}},"activeRevision":{"data":{"type":"itemRevisions","id":"48781"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4926"},{"type":"tags","id":"4949"},{"type":"tags","id":"5090"},{"type":"tags","id":"8621"}]},"contributions":{"data":[{"type":"contributions","id":"20696"},{"type":"contributions","id":"20699"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"63330","links":{"self":"https://app.emedici.com/api/questionRevisions/63330"},"attributes":{"stem":"\u003Cp\u003EDuring human embryonic development, blood cells are produced at different anatomical sites at different times.\u003C/p\u003E","stemQuestion":"Which one of the following is the first site of blood cell production during human embryonic development?","responseType":"sba","marks":1,"options":["Bone marrow","Liver","Spleen","Allantois","Yolk sac"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Eyolk sac\u003C/strong\u003E is the first site of blood cell production (haematopoiesis) in human embryonic development, beginning in week three. Blood islands form in the yolk sac mesoderm, giving rise to both primitive blood cells and blood vessel endothelium.\u003C/p\u003E\u003Cp\u003EThe incorrect options are:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EThe \u003Cstrong\u003Ebone marrow\u003C/strong\u003E becomes the primary site of haematopoiesis during the second trimester and continues throughout adult life\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EThe \u003Cstrong\u003Eliver\u003C/strong\u003E becomes the major site of haematopoiesis from week six of development until the bone marrow gradually takes over as the primary site\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EThe \u003Cstrong\u003Espleen\u003C/strong\u003E has only a minor role in embryonic haematopoiesis\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EThe \u003Cstrong\u003Eallantois\u003C/strong\u003E is an extraembryonic membrane that forms part of the umbilical cord but does not participate in haematopoiesis.\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E","optionExplanations":["","","","",""],"learningPoints":["Extraembryonic haematopoiesis first occurs in the yolk sac during week three of development","Blood islands in the yolk sac produce primitive erythroid cells and endothelial cells"],"references":["Sadler TW. Langman\u0027s Medical Embryology: Wolters Kluwer; 2015."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"48781"}},"question":{"data":{"type":"questions","id":"15954"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"48781","links":{"self":"https://app.emedici.com/api/itemRevisions/48781"},"attributes":{"createdAt":"2024-11-20T13:21:54+10:30","updatedAt":"2024-11-20T13:22:30+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8645"}},"content":{"data":{"type":"quest