{"data":[{"type":"questionAttempts","id":"17521925","links":{"self":"https://app.emedici.com/api/questionAttempts/17521925"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-29T14:38:51+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T14:38:51+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"13776"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"13776","links":{"self":"https://app.emedici.com/api/questions/13776"},"attributes":{"optionProportions":[0.19,0.44,0.12,0.08,0.17]},"relationships":{"item":{"data":{"type":"items","id":"6395"}},"activeRevision":{"data":{"type":"questionRevisions","id":"107180"}}}},{"type":"items","id":"6395","links":{"self":"https://app.emedici.com/api/items/6395"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"13776"}},"activeRevision":{"data":{"type":"itemRevisions","id":"89635"}},"tags":{"data":[{"type":"tags","id":"7"},{"type":"tags","id":"25"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"1020"},{"type":"tags","id":"1106"},{"type":"tags","id":"4975"},{"type":"tags","id":"4987"},{"type":"tags","id":"11625"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"12507"},{"type":"contributions","id":"31748"},{"type":"contributions","id":"39688"},{"type":"contributions","id":"42928"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"107180","links":{"self":"https://app.emedici.com/api/questionRevisions/107180"},"attributes":{"stem":"\u003Cp\u003EA 42-year-old man presents to a General Practice clinic for follow up after experiencing a confirmed seizure. The seizure occurred after a head injury at soccer four weeks ago and he was discharged from the Emergency Department with outpatient investigations. He has not had any further seizures since then. Neuroimaging and EEG were normal. He has no significant medical history and does not take any regular medications.\u003C/p\u003E\u003Cp\u003EOn examination, he appears well with vital signs within normal limits and a normal neurological examination.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate advice regarding fitness to drive?","responseType":"sba","marks":1,"options":["He must not drive for at least three months until cleared by a doctor and must notify the driving authority","He must not drive for at least six months until cleared by a doctor and must notify the driving authority","He must not drive for at least 12 months until cleared by a doctor and must notify the driving authority","He is able to resume driving immediately as long as he remains seizure-free","He must not drive for 2 weeks as it was a provoked seizure and there is no need to notify the driving authority"],"correctOptions":[1],"correctResponses":[],"explanation":"\u003Cp\u003EAccording to the Austroads Assessing Fitness to Drive guidelines, a private vehicle driver must not drive for a \u003Cstrong\u003Eminimum of six months\u003C/strong\u003E following a first seizure. This is irrespective of the cause of the first seizure. The driver \u003Cstrong\u003Emust notify the driving authority\u003C/strong\u003E of the seizure.\u003C/p\u003E\u003Cp\u003EA \u003Cstrong\u003Ethree month\u003C/strong\u003E restriction would be insufficient according to the Fitness to Drive guidelines.\u003C/p\u003E\u003Cp\u003EThe patient should not \u003Cstrong\u003Eresume driving immediately\u003C/strong\u003E, even if he remains seizure-free, as there is a mandatory non-driving period. He also must notify the driving authority and cannot simply resume driving without notifying them.\u003C/p\u003E\u003Cp\u003EAny patient with a history of seizures will require a medical assessment to assess fitness to hold a conditional license subject to ongoing periodic medical reviews as determined by the Fitness to Drive guidelines.\u003C/p\u003E\u003Cp\u003ECommercial vehicle drivers (e.g. taxi and bus drivers) must abide by more strict rules including requiring specialist neurologist review and requiring up to a 10 year seizure free period before regaining their commercial license. \u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Private vehicle drivers must not drive for a minimum of 6 months following a first seizure.","Drivers must notify the driving authority after a seizure."],"references":["Assessing Fitness to Drive. In: Austroads. 2022. Available at: https://austroads.com.au/publications/assessing-fitness-to-drive/ap-g56/neurological-conditions/seizures-and-epilepsy"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"89635"}},"question":{"data":{"type":"questions","id":"13776"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"89635","links":{"self":"https://app.emedici.com/api/itemRevisions/89635"},"attributes":{"createdAt":"2025-06-25T21:38:42+09:30","updatedAt":"2025-06-25T21:39:49+09:30"},"relationships":{"item":{"data":{"type":"items","id":"6395"}},"content":{"data":{"type":"questionRevisions","id":"107180"}}},"meta":{"canDelete":false}},{"type":"tags","id":"7","links":{"self":"https://app.emedici.com/api/tags/7"},"attributes":{"emoji":"\ud83e\udde0","name":"Neurology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"grou