{"data":[{"type":"questionAttempts","id":"17566646","links":{"self":"https://app.emedici.com/api/questionAttempts/17566646"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-29T23:45:45+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T23:45:45+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18860"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18860","links":{"self":"https://app.emedici.com/api/questions/18860"},"attributes":{"optionProportions":[0.03,0.79,0.14,0.03,0.01]},"relationships":{"item":{"data":{"type":"items","id":"11593"}},"activeRevision":{"data":{"type":"questionRevisions","id":"92802"}}}},{"type":"items","id":"11593","links":{"self":"https://app.emedici.com/api/items/11593"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18860"}},"activeRevision":{"data":{"type":"itemRevisions","id":"76161"}},"tags":{"data":[{"type":"tags","id":"17"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"4987"},{"type":"tags","id":"4989"},{"type":"tags","id":"5631"},{"type":"tags","id":"5641"},{"type":"tags","id":"5644"},{"type":"tags","id":"5745"},{"type":"tags","id":"11260"},{"type":"tags","id":"11282"},{"type":"tags","id":"11650"},{"type":"tags","id":"12867"}]},"contributions":{"data":[{"type":"contributions","id":"27294"},{"type":"contributions","id":"27300"},{"type":"contributions","id":"44849"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"92802","links":{"self":"https://app.emedici.com/api/questionRevisions/92802"},"attributes":{"stem":"\u003Cp\u003EA pharmaceutical company representative offers to provide lunch for clinic staff during a routine clinical meeting for the practice. The representative would also deliver a product presentation about a new diabetes medication. They also offer to pay each attending doctor an honorarium of $200 for their time.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate professional response?","responseType":"sba","marks":1,"options":["Accept the honorarium but decline the lunch","Accept the lunch but decline the honorarium","Accept both but declare them to the clinic manager","Accept both the lunch and honorarium as compensation for time spent","Accept both but limit prescribing of their products"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EPatients trust doctors to provide independent and unbiased care, but conflicts of interest can arise when a doctor\u2019s financial, professional, or personal relationships with third parties influence patient care. Such conflicts, whether actual or perceived, require careful identification, disclosure, and resolution to ensure the doctor\u2019s primary duty to the patient remains uncompromised.\u003C/p\u003E\u003Cp\u003EThe most appropriate response is to \u003Cstrong\u003Eaccept the lunch but decline the honorarium\u003C/strong\u003E. Accepting small hospitality items of trivial value (like a basic lunch during a work meeting) is generally considered to be acceptable, but accepting personal payments for meeting sales representatives creates a conflict of interest and could influence, or be seen to influence. prescribing behaviour.\u003C/p\u003E\u003Cp\u003EHealthcare professionals must maintain independence from commercial interests to ensure clinical decisions are made solely based on patient needs. Sizeable gifts or payments can create unconscious bias in decision-making and therefore must be avoided.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Healthcare professionals must not accept gifts or inducements from medical companies that could influence clinical decision-making.","Accepting payments for meeting sales representatives creates conflicts of interest and is unethical."],"references":["Medical Board of Australia. Good medical practice: a code of conduct for doctors in Australia [online]. 2020 [Cited 2025 Jan 15]. Available at: https://www.medicalboard.gov.au/codes-guidelines-policies/code-of-conduct.aspx."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"76161"}},"question":{"data":{"type":"questions","id":"18860"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"76161","links":{"self":"https://app.emedici.com/api/itemRevisions/76161"},"attributes":{"createdAt":"2025-03-19T13:26:12+10:30","updatedAt":"2025-03-19T13:26:12+10:30"},"relationships":{"item":{"data":{"type":"items","id":"11593"}},"content":{"data":{"type":"questionRevisions","id":"92802"}}},"meta":{"canDelete":false}},{"type":"tags","id":"17","links":{"self":"https://app.emedici.com/api/tags/17"},"attributes":{"emoji":"\ud83d\ude07","name":"Bioethics","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Leve