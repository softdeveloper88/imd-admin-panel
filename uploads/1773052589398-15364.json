{"data":[{"type":"questionAttempts","id":"17595545","links":{"self":"https://app.emedici.com/api/questionAttempts/17595545"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T11:05:29+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T11:05:29+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15364"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15364","links":{"self":"https://app.emedici.com/api/questions/15364"},"attributes":{"optionProportions":[0.1,0.2,0.65,0.03,0.03]},"relationships":{"item":{"data":{"type":"items","id":"8055"}},"activeRevision":{"data":{"type":"questionRevisions","id":"69845"}}}},{"type":"items","id":"8055","links":{"self":"https://app.emedici.com/api/items/8055"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15364"}},"activeRevision":{"data":{"type":"itemRevisions","id":"55301"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"4928"},{"type":"tags","id":"4944"},{"type":"tags","id":"4950"},{"type":"tags","id":"7882"},{"type":"tags","id":"8755"},{"type":"tags","id":"10886"}]},"contributions":{"data":[{"type":"contributions","id":"19557"},{"type":"contributions","id":"19559"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"69845","links":{"self":"https://app.emedici.com/api/questionRevisions/69845"},"attributes":{"stem":"\u003Cp\u003EViral hepatitis infections remain a significant global health concern. Understanding their diagnosis and epidemiology is crucial for effective management.\u003C/p\u003E","stemQuestion":"Which one of the following statements about hepatitis D and hepatitis E viruses is correct?","responseType":"sba","marks":1,"options":["Hepatitis D virus RNA testing alone confirms infection","Hepatitis D virus infects hepatocytes directly","Hepatitis E virus infection is diagnosed using anti-HEV IgM antibodies","Hepatitis D outbreaks occur mainly through pork consumption","Hepatitis E transmission is primarily blood-borne"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EHepatitis D virus RNA testing\u003C/strong\u003E alone is insufficient for diagnosis - hepatitis B surface antigen must also be present since hepatitis D virus requires hepatitis B virus for replication.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHepatitis D virus only infects hepatocytes directly\u003C/strong\u003E is incorrect - it requires the presence of hepatitis B surface antigen as a helper virus for cell entry and replication.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAnti-HEV IgM antibodies\u003C/strong\u003E are indeed the primary diagnostic test for acute hepatitis E virus infection. This test has good sensitivity and specificity.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHepatitis D outbreaks\u003C/strong\u003E are not associated with pork consumption - it is hepatitis E that is associated with consumption of undercooked pork in high-income countries.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHepatitis E transmission\u003C/strong\u003E occurs primarily through the faecal-oral route, particularly through contaminated water in areas with poor sanitation. Blood product transmission is rare.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Hepatitis D virus requires hepatitis B surface antigen for replication and can only infect people with hepatitis B infection","Hepatitis D diagnosis requires both HDV RNA and hepatitis B surface antigen testing","Hepatitis E is diagnosed using anti-HEV IgM antibodies and is primarily transmitted through contaminated water","Hepatitis E in high-income countries is mainly associated with consumption of undercooked pork products"],"references":["Mehta P, Grant LM, Reddivari AKR. Viral Hepatitis. 2024 Mar 10. In: StatPearls [Internet]. Treasure Island (FL): StatPearls Publishing; 2024 Jan\u2013. PMID: 32119436","Lok AS, Pawlotsky JM. Viral hepatitis at a crossroad. Gastroenterology. 2012 May;142(6):1261-3. doi: 10.1053/j.gastro.2012.03.007. PMID: 22537431","Yamada, T., Alpers, D. H., Kalloo, A. N., Kaplowitz, N., Owyang, C., \u0026 Powell, D. W. (Eds.). (2011). Textbook of gastroenterology. John Wiley \u0026 Sons","Kumar, V., Abbas, A. K., \u0026 Aster, J. C. (Eds.). (2012). Robbins basic pathology e-book. Elsevier Health Scienc","Song JE, Kim DY. Diagnosis of hepatitis B. Ann Transl Med. 2016 Sep;4(18):338. doi: 10.21037/atm.2016.09.11. PMID: 27761442; PMCID: PMC5066055"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"55301"}},"question":{"data":{"type":"questions","id":"15364"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"55301","links":{"self":"https://app.emedici.com/api/itemRevisions/55301"},"attributes":{"createdAt":"2024-12-12T20:42:42+10:30","updatedAt":"2024-12-12T20:43:16+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8055"}},"content":{"data":{"type":"questionRevisions","id":"69845"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https: