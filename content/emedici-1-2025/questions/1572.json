{"data":[{"type":"questionAttempts","id":"17499862","links":{"self":"https://app.emedici.com/api/questionAttempts/17499862"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T10:04:48+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T10:04:48+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"1572"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"1572","links":{"self":"https://app.emedici.com/api/questions/1572"},"attributes":{"optionProportions":[0.04,0.04,0.15,0.09,0.68]},"relationships":{"item":{"data":{"type":"items","id":"1572"}},"activeRevision":{"data":{"type":"questionRevisions","id":"33872"}}}},{"type":"items","id":"1572","links":{"self":"https://app.emedici.com/api/items/1572"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1572"}},"activeRevision":{"data":{"type":"itemRevisions","id":"19142"}},"tags":{"data":[{"type":"tags","id":"2"},{"type":"tags","id":"24"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"82"},{"type":"tags","id":"1036"},{"type":"tags","id":"4953"},{"type":"tags","id":"4961"},{"type":"tags","id":"4987"},{"type":"tags","id":"4992"},{"type":"tags","id":"9735"},{"type":"tags","id":"11625"},{"type":"tags","id":"11630"},{"type":"tags","id":"11642"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"8457"},{"type":"contributions","id":"8486"},{"type":"contributions","id":"42343"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"33872","links":{"self":"https://app.emedici.com/api/questionRevisions/33872"},"attributes":{"stem":"\u003Cp\u003EA concerned 29-year-old man presents to the Emergency Department. He anxiously tells you that while on a run he noticed palpitations and that his fitness tracker had been recording his heart rate as high as 220.\u003C/p\u003E\u003Cp\u003EOn examination, he is alert, well perfused, and blood pressure is 130/80mmHg. ECG is shown below.\u003C/p\u003E","stemQuestion":"Which pharmacological management should be given first?","responseType":"sba","marks":1,"options":["Flecainide","Atropine","Amiodarone","Esmolol","Adenosine"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThe ECG in the stem demonstrates a supraventricular tachycardia (narrow QRS tachycardia with no discrete p waves seen). Vagal manoeuvres are first-line and should be attempted before escalating to pharmacological management.\u003C/p\u003E\u003Cp\u003EThe mainstay of treatment of supraventricular tachycardia is intravenous\u003Cstrong\u003E adenosine\u003C/strong\u003E which has been shown to terminate SVT that is due to AVNRT or AVRT in 78-96% of cases. It should be given by a rapid IV push in a large or central vein; the patient should also be warned of the brief chest tightness during the bolus injection.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EFlecainide \u003C/strong\u003Ecan be used to prevent or treat SVT but is not first-line for treatment of acute SVT.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAtropine \u003C/strong\u003Eis not recommended for treatment of SVT. It has a role in the management of symptomatic bradycardia.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAmiodarone \u003C/strong\u003Ehas use in the long-term management of SVT and may be used acutely if other methods have failed but is not the first-line treatment of SVT.\u003C/p\u003E\u003Cp\u003EEvidence for \u003Cstrong\u003Eesmolol \u003C/strong\u003Ein treatment of SVT is limited and trials have demonstrated inferiority to other agents, so it would not be the best first-line management.\u003C/p\u003E","optionExplanations":null,"learningPoints":["First-line treatment of supraventricular tachycardia is adenosine"],"references":["Page R, Joglar J, Caldwell M, et al. 2015 ACC/AHA/HRS Guideline for the Management of Adult Patients With Supraventricular Tachycardia. J Am Coll Cardiol. 2016 Apr, 67 (13) e27\u2013e115. https://doi.org/10.1016/j.jacc.2015.08.856"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"19142"}},"question":{"data":{"type":"questions","id":"1572"}},"stemMedia":{"data":[{"type":"media","id":"19572"}]},"explanationMedia":{"data":[]}}},{"type":"media","id":"19572","links":{"self":"https://app.emedici.com/api/media/19572"},"attributes":{"mimeType":"image/jpeg","url":"https://app.emedici.com/storage/media/a710168d-8255-461e-a4ec-5db12bb3cd8a.jpg","thumbUrl":"https://app.emedici.com/storage/media/a710168d-8255-461e-a4ec-5db12bb3cd8a.jpg","isProcessed":true,"width":600,"height":355}},{"type":"itemRevisions","id":"19142","links":{"self":"https://app.emedici.com/api/itemRevisions/19142"},"attributes":{"createdAt":"2023-03-21T08:04:11+10:30","updatedAt":"2023-03-21T08:04:11+10:30"},"relationships":{"item":{"data":{"type":"items","id":"1572"}},"content":{"data":{"type":"questionRevisions","id":"33872"}}},"meta":{"canDelete":false}},{"type":"tags","id":"2","links":{"self":"https://app.emedici.com/api/tags/2"},"attributes":{"emoji":"\ud83e\udec0","name":"Cardiology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:21+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"24","links":{"self":"https://app.emedici.com/api/tags/24"},"attributes":{"emoji":"\ud83d\ude91","name":"Emergency Medicine","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"5"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":