{"data":[{"type":"questionAttempts","id":"17476199","links":{"self":"https://app.emedici.com/api/questionAttempts/17476199"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-28T22:42:33+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T22:42:33+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"13697"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"13697","links":{"self":"https://app.emedici.com/api/questions/13697"},"attributes":{"optionProportions":[0.06,0.07,0.74,0.07,0.07]},"relationships":{"item":{"data":{"type":"items","id":"6313"}},"activeRevision":{"data":{"type":"questionRevisions","id":"47338"}}}},{"type":"items","id":"6313","links":{"self":"https://app.emedici.com/api/items/6313"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"13697"}},"activeRevision":{"data":{"type":"itemRevisions","id":"32067"}},"tags":{"data":[{"type":"tags","id":"5"},{"type":"tags","id":"9"},{"type":"tags","id":"24"},{"type":"tags","id":"65"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"1039"},{"type":"tags","id":"1151"},{"type":"tags","id":"1153"},{"type":"tags","id":"4954"},{"type":"tags","id":"4961"},{"type":"tags","id":"4964"},{"type":"tags","id":"4987"},{"type":"tags","id":"4992"},{"type":"tags","id":"11625"},{"type":"tags","id":"11630"},{"type":"tags","id":"11638"},{"type":"tags","id":"11642"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"11702"},{"type":"contributions","id":"14802"},{"type":"contributions","id":"39164"},{"type":"contributions","id":"42910"},{"type":"contributions","id":"43913"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"47338","links":{"self":"https://app.emedici.com/api/questionRevisions/47338"},"attributes":{"stem":"\u003Cp\u003EA three-year-old boy presents to the Emergency Department with a history of accidental ingestion of household bleach approximately one hour ago. He is crying and drooling but has not vomited. He has no significant medical history and does not take any regular medications. \u003C/p\u003E\u003Cp\u003EOn examination, he appears distressed with a pulse rate of 110/min, blood pressure 90/60 mmHg, respiratory rate 24/min, SpO2 98% on room air, and temperature 37.0\u00b0C. His oropharynx is erythematous but there are no visible burns or ulcers. He has mild abdominal tenderness but no guarding or rebound tenderness.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate investigation to assess the extent of injury?","responseType":"sba","marks":1,"options":["Chest X-ray","Abdominal ultrasound","Endoscopy","CT scan of the abdomen","Barium swallow"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EIn cases of caustic ingestion, such as household bleach, the primary concern is the extent of injury to the gastrointestinal tract. The most appropriate investigation to assess this is \u003Cstrong\u003Eendoscopy\u003C/strong\u003E. Endoscopy allows direct visualisation of the mucosa and helps determine the severity of the injury, which is crucial for guiding further management.\u003C/p\u003E\u003Cp\u003EA \u003Cstrong\u003Echest X-ray\u003C/strong\u003E may be useful if there is concern for perforation or aspiration, but it does not provide detailed information about mucosal injury.\u003C/p\u003E\u003Cp\u003EAn \u003Cstrong\u003Eabdominal ultrasound\u003C/strong\u003E is not useful for assessing mucosal injury in the context of caustic ingestion.\u003C/p\u003E\u003Cp\u003EA \u003Cstrong\u003ECT scan of the abdomen\u003C/strong\u003E can provide information about perforation or other complications but is not the first-line investigation for assessing mucosal injury.\u003C/p\u003E\u003Cp\u003EA \u003Cstrong\u003Ebarium swallow\u003C/strong\u003E is generally avoided in the acute setting of caustic ingestion due to the risk of exacerbating injury and complications.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Endoscopy is the investigation of choice for assessing the extent of injury in cases of caustic ingestion."],"references":["Methasate A, Lohsiriwat V. Role of endoscopy in caustic injury of the esophagus. World J Gastrointest Endosc. 2018 Oct 16;10(10):274-282. Available at: https://www.ncbi.nlm.nih.gov/pmc/articles/PMC6198306/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"32067"}},"question":{"data":{"type":"questions","id":"13697"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"32067","links":{"self":"https://app.emedici.com/api/itemRevisions/32067"},"attributes":{"createdAt":"2024-06-21T14:26:16+09:30","updatedAt":"2024-08-01T19:25:21+09:30"},"relationships":{"item":{"data":{"type":"items","id":"6313"}},"content":{"data":{"type":"questionRevisions","id":"47338"}}},"meta":{"canDelete":false}},{"type":"tags","id":"5","links":{"self":"https://app.emedici.com/api/tags/5"},"attributes":{"emoji":"\ud83d\udd2d","name":"Gastroenterology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"9","links":{"self":"https://app.emedici.com/api/tags/9"},"attributes":{"emoji":"\ud83d\udc76","name":"Paediatrics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:39:03+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"24","links":{"self":"https://app.emedici.com/api/tags/24"},"attributes":{"emoji":"\ud83d\ude91","name":"Emerg