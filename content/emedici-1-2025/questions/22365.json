{"data":[{"type":"questionAttempts","id":"20889505","links":{"self":"https://app.emedici.com/api/questionAttempts/20889505"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-11-07T13:05:54+10:30","options":[1],"response":null,"finalizedAt":"2025-11-07T13:05:54+10:30"},"relationships":{"user":{"data":{"type":"users","id":"56433"},"links":{"related":"https://app.emedici.com/api/questionAttempts/20889505/user","self":"https://app.emedici.com/api/questionAttempts/20889505/relationships/user"}},"questionSession":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889505/questionSession","self":"https://app.emedici.com/api/questionAttempts/20889505/relationships/questionSession"}},"session":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889505/session","self":"https://app.emedici.com/api/questionAttempts/20889505/relationships/session"}},"question":{"data":{"type":"questions","id":"22365"},"links":{"related":"https://app.emedici.com/api/questionAttempts/20889505/question","self":"https://app.emedici.com/api/questionAttempts/20889505/relationships/question"}},"bookmark":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889505/bookmark","self":"https://app.emedici.com/api/questionAttempts/20889505/relationships/bookmark"}}}}],"included":[{"type":"questions","id":"22365","links":{"self":"https://app.emedici.com/api/questions/22365"},"relationships":{"attempts":{"links":{"related":"https://app.emedici.com/api/questions/22365/attempts","self":"https://app.emedici.com/api/questions/22365/relationships/attempts"}},"item":{"data":{"type":"items","id":"15330"},"links":{"related":"https://app.emedici.com/api/questions/22365/item","self":"https://app.emedici.com/api/questions/22365/relationships/item"}},"activeRevision":{"data":{"type":"questionRevisions","id":"120074"},"links":{"related":"https://app.emedici.com/api/questions/22365/activeRevision","self":"https://app.emedici.com/api/questions/22365/relationships/activeRevision"}}}},{"type":"items","id":"15330","links":{"self":"https://app.emedici.com/api/items/15330"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/15330/packs","self":"https://app.emedici.com/api/items/15330/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/15330/revisions","self":"https://app.emedici.com/api/items/15330/relationships/revisions"}},"content":{"data":{"type":"questions","id":"22365"},"links":{"related":"https://app.emedici.com/api/items/15330/content","self":"https://app.emedici.com/api/items/15330/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/15330/specialtyTags","self":"https://app.emedici.com/api/items/15330/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/15330/primaryTags","self":"https://app.emedici.com/api/items/15330/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/15330/contributionTypes","self":"https://app.emedici.com/api/items/15330/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/15330/contributors","self":"https://app.emedici.com/api/items/15330/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/15330/contribution","self":"https://app.emedici.com/api/items/15330/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/15330/myContribution","self":"https://app.emedici.com/api/items/15330/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"101809"},"links":{"related":"https://app.emedici.com/api/items/15330/activeRevision","self":"https://app.emedici.com/api/items/15330/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"11"},{"type":"tags","id":"24"},{"type":"tags","id":"26"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"78"},{"type":"tags","id":"1991"},{"type":"tags","id":"1994"},{"type":"tags","id":"2030"},{"type":"tags","id":"12919"},{"type":"tags","id":"13209"}],"links":{"related":"https://app.emedici.com/api/items/15330/tags","self":"https://app.emedici.com/api/items/15330/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"40746"},{"type":"contributions","id":"53240"}],"links":{"related":"https://app.emedici.com/api/items/15330/contributions","self":"https://app.emedici.com/api/items/15330/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"120074","links":{"self":"https://app.emedici.com/api/questionRevisions/120074"},"attributes":{"stem":"\u003Cp\u003EA 58-year-old woman presents to the Emergency Department with a two-hour history of coughing up large amounts of bright red blood. She estimates she has expectorated approximately 300 mL. She has a medical history of bronchiectasis diagnosed five years ago following recurrent chest infections. Her regular medications include salbutamol inhaler and azithromycin three times weekly. She is a non-smoker.\u003C/p\u003E\u003Cp\u003EOn examination, she appears anxious and pale with blood staining around her mouth. Her pulse rate is 110/min, blood pressure 120/80 mmHg, respiratory rate 24/min, SpO2 92% on room air, and temperature 37.2\u00b0C. Chest auscultation reveals coarse crackles in the right lower zone with audible gurgling. High-flow oxygen has been commenced and large-bore intravenous access obtained.\u003C/p\u003E\u003Cp\u003EInvestigations reveal: haemoglobin 95 g/L (115-155), white cell count 8.2 \u00d7 10\u2079/L (4.0-11.0), platelet count 40 \u00d7 10\u2079/L (150-400).\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate next step in management?","responseType":"sba","marks":1,"options":["CT pulmonary angiography","Platelet transfusion","Intubation and mechanical ventilation","Bronchial artery embolisation","Bronchoscopy"],"correctOptions":[1],"correctResponses":[],"explanation":"\u003Cp\u003EMassive haemoptysis is a life-threatening emergency defined as expectoration of blood sufficient to cause immediate threat to life through airway obstruction or cardiovascular compromise. While various volume thresholds (100-600 mL within 24 hours) have been proposed, the key feature is that it represents a life-threatening situation. The primary threat from massive haemoptysis is asphyxiation due to blood flooding the airways and alveoli, rather than exsanguination from blood loss.\u003C/p\u003E\u003Cp\u003ECommon causes of massive haemoptysis include:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EBronchiectasis (most common in developed countries)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003ETuberculosis (most common worldwide)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003ELung malignancy (bronchogenic carcinoma)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EAspergilloma (fungal ball in pre-existing cavity)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EPulmonary arteriovenous malformations\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EVasculitis (particularly granulomatosis with polyangiitis)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003ETrauma or iatrogenic causes (post-bronchoscopy, Swan-Ganz catheter)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003ECoagulopathy or anticoagulation\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EIn approximately 90% of cases of massive haemoptysis, the source of bleeding is the bronchial circulation, which arises from the systemic circulation (usually the descending thoracic aorta) and is therefore under systemic pressure. Only about 5% of cases involve bleeding from the pulmonary circulation, which operates at much lower pressures. In patients with bronchiectasis, chronic inflammation leads to hypertrophy and tortuosity of bronchial arteries, making them prone to rupture and causing significant bleeding.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPlatelet transfusion\u003C/strong\u003E is the most appropriate next step. This patient has severe thrombocytopenia (40 \u00d7 10\u2079/L) in the setting of massive haemoptysis. Platelets play a crucial role in primary haemostasis, and a count below 50 \u00d7 10\u2079/L significantly impairs the body\u0027s ability to form an effective platelet plug at sites of vascular injury. In the context of active bleeding, platelet transfusion is indicated to achieve a count above 50 \u00d7 10\u2079/L (or above 100 \u00d7 10\u2079/L for life-threatening bleeding). Correcting the thrombocytopenia is essential before considering invasive procedures and will help reduce ongoing bleeding.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECT pulmonary angiography\u003C/strong\u003E is designed to opacify the pulmonary arterial system and would not adequately visualise the bronchial arteries, which are the source of bleeding in bronchiectasis. A dedicated CT angiography with systemic arterial phase timing would be required to identify bronchial arteries, but this should not delay immediate management of the thrombocytopenia in an actively bleeding patient.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EIntubation and mechanical ventilation\u003C/strong\u003E may be necessary if the patient develops respiratory failure or cannot protect their airway from blood aspiration. However, this patient maintains adequate oxygenation and is managing her secretions, so intubation is not immediately indicated. Intubation in massive haemoptysis carries risks as positive pressure ventilation can worsen bleeding.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EBronchial artery embolisation\u003C/strong\u003E is a definitive treatment for massive haemoptysis from bronchiectasis, with success rates exceeding 90%. However, it requires interventional radiology expertise and time to arrange. More importantly, invasive procedures should be deferred until the severe thrombocytopenia is corrected to minimise procedural bleeding risk.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EBronchoscopy\u003C/strong\u003E can be useful for localising bleeding and providing temporary tamponade with balloon occlusion or ice-cold saline lavage. However, it requires specialised equipment and expertise, and is typically reserved for cases where embolisation has failed or is not feasible. In actively bleeding patients with severe thrombocytopenia, bronchoscopy could worsen bleeding and should be avoided until platelet counts are corrected.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Platelet transfusion is indicated for massive haemoptysis when thrombocytopenia is present, as adequate platelet function is essential for haemostasis.","Bronchial artery embolisation remains the definitive treatment for massive haemoptysis in stable patients with bronchiectasis.","The primary threat from massive haemoptysis is asphyxiation from blood in the airways rather than exsanguination."],"references":["A systematic approach to the management of massive hemoptysis. J Thorac Dis. 2017;9(Suppl 10):S1069-S1086. doi: 10.21037/jtd.2017.06.41. PMID: 28894641; PMCID: PMC5696556. Available at: https://pmc.ncbi.nlm.nih.gov/articles/PMC5696556/","Lordan J, Gascoigne A, Corris P. The pulmonary physician in critical care \u2022 Illustrative case 7: Assessment and management of massive haemoptysis. Thorax. 2003 Sep;58(9):814-9. doi: 10.1136/thorax.58.9.814. PMID: 12947147; PMCID: PMC1746797. Available at: https://pmc.ncbi.nlm.nih.gov/articles/instance/1746797/pdf/v058p00814.pdf"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"101809"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120074/itemRevision","self":"https://app.emedici.com/api/questionRevisions/120074/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"22365"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120074/question","self":"https://app.emedici.com/api/questionRevisions/120074/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/120074/stemMedia","self":"https://app.emedici.com/api/questionRevisions/120074/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/120074/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/120074/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"101809","links":{"self":"https://app.emedici.com/api/itemRevisions/101809"},"attributes":{"createdAt":"2025-10-14T14:12:16+10:30","updatedAt":"2025-10-14T14:13:03+10:30"},"relationships":{"item":{"data":{"type":"items","id":"15330"},"links":{"related":"https://app.emedici.com/api/itemRevisions/101809/item","self":"https://app.emedici.com/api/itemRevisions/101809/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"120074"},"links":{"related":"https://app.emedici.com/api/itemRevisions/101809/content","self":"https://app.emedici.com/api/itemRevisions/101809/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"11","links":{"self":"https://app.emedici.com/api/tags/11"},"attributes":{"emoji":"\ud83e\udec1","name":"Respiratory Medicine","synonyms":["Pulmonology"],"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/11/group","self":"https://app.emedici.com/api/tags/11/relationships/group"}},"heading":{"data":{"type":"tagHeadings","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/11/heading","self":"https://app.emedici.com/api/tags/11/relationships/heading"}},"ancestors":{"links":{"rel