{"data":[{"type":"questionAttempts","id":"17625142","links":{"self":"https://app.emedici.com/api/questionAttempts/17625142"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T16:21:40+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T16:21:40+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17008"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17008","links":{"self":"https://app.emedici.com/api/questions/17008"},"attributes":{"optionProportions":[0.05,0.14,0.77,0,0.05]},"relationships":{"item":{"data":{"type":"items","id":"9698"}},"activeRevision":{"data":{"type":"questionRevisions","id":"68224"}}}},{"type":"items","id":"9698","links":{"self":"https://app.emedici.com/api/items/9698"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17008"}},"activeRevision":{"data":{"type":"itemRevisions","id":"53681"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5409"},{"type":"tags","id":"5457"},{"type":"tags","id":"5500"},{"type":"tags","id":"5528"}]},"contributions":{"data":[{"type":"contributions","id":"22830"},{"type":"contributions","id":"22832"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"68224","links":{"self":"https://app.emedici.com/api/questionRevisions/68224"},"attributes":{"stem":"\u003Cp\u003EDisease prevention strategies are classified into different levels based on when they are implemented in the natural history of disease.\u003C/p\u003E","stemQuestion":"Which one of the following best describes primary prevention?","responseType":"sba","marks":1,"options":["Rehabilitation after disease has occurred","Early detection of disease through screening programmes","Actions taken before disease onset to prevent occurrence","Management of established chronic conditions","Treatment to prevent disease complications"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EPrimary prevention encompasses \u003Cstrong\u003Eactions taken before disease onset to prevent occurrence\u003C/strong\u003E. This includes population-wide interventions like immunisation programs, food fortification, and health promotion campaigns that aim to modify risk factors before disease develops.\u003C/p\u003E\u003Cp\u003EThe other levels of prevention serve different purposes:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003ERehabilitation after disease has occurred\u003C/strong\u003E is tertiary prevention, aimed at restoring function and preventing further deterioration in those with established conditions\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EEarly detection of disease through screening programmes\u003C/strong\u003E defines secondary prevention, which identifies disease in its early, more treatable stages\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EManagement of established chronic conditions\u003C/strong\u003E falls under tertiary prevention, focusing on optimising outcomes for those with existing disease\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003ETreatment to prevent disease complications\u003C/strong\u003E represents tertiary prevention, which aims to minimise the impact of established disease and prevent further deterioration\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EBy intervening before disease occurs, primary prevention represents the most upstream and potentially impactful approach to reducing disease burden at a population level.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Primary prevention aims to prevent disease before it occurs through measures like vaccination and lifestyle modification.","Secondary prevention focuses on early detection and intervention to prevent disease progression.","Tertiary prevention aims to reduce complications and improve quality of life in established disease."],"references":["Shultz JM, Sullivan LM, Galea S. Public Health: An Introduction to the Science and Practice of Population Health. Springer Publishing Company; 2021."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"53681"}},"question":{"data":{"type":"questions","id":"17008"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"53681","links":{"self":"https://app.emedici.com/api/itemRevisions/53681"},"attributes":{"createdAt":"2024-12-09T15:20:34+10:30","updatedAt":"2024-12-09T15:21:28+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9698"}},"content":{"data":{"type":"questionRevisions","id":"68224"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"5326","links":{"self"