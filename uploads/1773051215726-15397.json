{"data":[{"type":"questionAttempts","id":"17596194","links":{"self":"https://app.emedici.com/api/questionAttempts/17596194"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T11:11:02+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T11:11:02+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15397"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15397","links":{"self":"https://app.emedici.com/api/questions/15397"},"relationships":{"item":{"data":{"type":"items","id":"8088"}},"activeRevision":{"data":{"type":"questionRevisions","id":"63696"}}}},{"type":"items","id":"8088","links":{"self":"https://app.emedici.com/api/items/8088"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15397"}},"activeRevision":{"data":{"type":"itemRevisions","id":"49136"}},"tags":{"data":[{"type":"tags","id":"5"},{"type":"tags","id":"19"},{"type":"tags","id":"24"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"1061"},{"type":"tags","id":"1139"},{"type":"tags","id":"1449"},{"type":"tags","id":"3467"},{"type":"tags","id":"4928"},{"type":"tags","id":"4950"},{"type":"tags","id":"5771"},{"type":"tags","id":"8127"},{"type":"tags","id":"8133"}]},"contributions":{"data":[{"type":"contributions","id":"19625"},{"type":"contributions","id":"19628"},{"type":"contributions","id":"20884"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"63696","links":{"self":"https://app.emedici.com/api/questionRevisions/63696"},"attributes":{"stem":"\u003Cp\u003EAn otherwise well 62-year-old woman presents to the emergency department with a two day history of left lower quadrant abdominal pain and fever. On examination her temperature is 37.8\u00b0C and there is mild tenderness in the left iliac fossa. The rest of the physical examination is unremarkable. The clinician suspects acute diverticulitis and assesses the patient as being sufficiently well for her to be managed at home. A number of investigations will be arranged prior to her discharge.\u003C/p\u003E","stemQuestion":"Which one of the following should be avoided during the acute phase of diverticulitis?","responseType":"sba","marks":1,"options":["Abdominal ultrasound","C-reactive protein measurement","Colonoscopy","Complete blood count","Computed tomography of the abdomen"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EDuring acute diverticulitis, \u003Cstrong\u003Ecomputed tomography\u003C/strong\u003E of the abdomen is the preferred initial imaging modality as it can confirm the diagnosis and identify complications. \u003Cstrong\u003EColonoscopy\u003C/strong\u003E should be avoided during the acute phase due to the risk of perforation through the inflamed bowel wall. It may be performed 6-8 weeks after resolution of acute symptoms.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAbdominal ultrasound\u003C/strong\u003E can be used as an alternative imaging modality, particularly in young or pregnant patients to avoid radiation exposure. \u003Cstrong\u003EComplete blood count\u003C/strong\u003E and \u003Cstrong\u003EC-reactive protein\u003C/strong\u003E measurements are important to assess disease severity and monitor response to treatment.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Colonoscopy is contraindicated in acute diverticulitis due to risk of perforation","Imaging studies like computed tomography are essential for diagnosing acute diverticulitis","Initial diagnosis and monitoring of diverticulitis relies on cross-sectional imaging"],"references":["Piscopo N, Ellul P. Diverticular Disease: A Review on Pathophysiology and Recent Evidence. Ulster Med J. 2020 Sep;89(2):83-88. Epub 2020 Oct 21. PMID: 33093692; PMCID: PMC7576390","Feuerstein JD, Falchuk KR. Diverticulosis and Diverticulitis. Mayo Clin Proc. 2016 Aug;91(8):1094-104. doi: 10.1016/j.mayocp.2016.03.012. Epub 2016 May 5. PMID: 27156370","Yamada, T., Alpers, D. H., Kalloo, A. N., Kaplowitz, N., Owyang, C., \u0026 Powell, D. W. (Eds.). (2011). Textbook of gastroenterology. John Wiley \u0026 Sons","Kumar, V., Abbas, A. K., \u0026 Aster, J. C. (Eds.). (2012). Robbins basic pathology e-book. Elsevier Health Science"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"49136"}},"question":{"data":{"type":"questions","id":"15397"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"49136","links":{"self":"https://app.emedici.com/api/itemRevisions/49136"},"attributes":{"createdAt":"2024-11-22T11:12:53+10:30","updatedAt":"2024-11-22T11:13:28+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8088"}},"content":{"data":{"type":"questionRevisions","id":"63696"}}},"meta":{"canDelete":false}},{"type":"tags","id":"5","links":{"self":"https://app.emedici.com/api/tags/5"},"attributes":{"emoji":"\ud83d\udd2d","name":"Gastroenterology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"19","links":{"self":"https://app.emedici.com/api/tags/19"},"attributes":{"emoji":"\ud83d\udd2a","name":"General Surgery","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:20+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"2"}}},"meta":{"itemCount":0}},{"type":"tags","id":"24","links":{"self":"https://app.emedici.com/api/tags/24"},"attributes":{"emoji":"\ud83d\ude91","name":"Emergency Medicine","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relatio