{"data":[{"type":"questionAttempts","id":"17598556","links":{"self":"https://app.emedici.com/api/questionAttempts/17598556"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T11:41:14+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T11:41:14+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15496"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15496","links":{"self":"https://app.emedici.com/api/questions/15496"},"attributes":{"optionProportions":[0.82,0,0.08,0.04,0.06]},"relationships":{"item":{"data":{"type":"items","id":"8187"}},"activeRevision":{"data":{"type":"questionRevisions","id":"61617"}}}},{"type":"items","id":"8187","links":{"self":"https://app.emedici.com/api/items/8187"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15496"}},"activeRevision":{"data":{"type":"itemRevisions","id":"47070"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4927"},{"type":"tags","id":"4942"},{"type":"tags","id":"4950"},{"type":"tags","id":"9906"}]},"contributions":{"data":[{"type":"contributions","id":"19817"},{"type":"contributions","id":"19819"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"61617","links":{"self":"https://app.emedici.com/api/questionRevisions/61617"},"attributes":{"stem":"\u003Cp\u003EGas exchange in the lungs occurs primarily through diffusion across the alveolar-capillary membrane. Various pathological processes can impair this diffusion process.\u003C/p\u003E","stemQuestion":"Which one of the following conditions causes impaired gas diffusion in the lungs?","responseType":"sba","marks":1,"options":["Surfactant dysfunction","Increased cardiac output","Bronchial smooth muscle contraction","Increased ventilation rate","Decreased blood viscosity"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003ESurfactant dysfunction\u003C/strong\u003E directly affects gas diffusion by increasing surface tension in alveoli, leading to decreased alveolar surface area and increased diffusion distance. This makes gas exchange less efficient across the alveolar-capillary membrane.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EIncreased cardiac output\u003C/strong\u003E actually improves gas exchange by enhancing perfusion. \u003Cstrong\u003EBronchial smooth muscle contraction\u003C/strong\u003E affects airflow but not diffusion directly. \u003Cstrong\u003EIncreased ventilation rate\u003C/strong\u003E affects gas delivery to alveoli but not the diffusion process itself. \u003Cstrong\u003EDecreased blood viscosity\u003C/strong\u003E would theoretically improve gas exchange by enhancing blood flow.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Diffusion limitations in the lungs can be caused by thickening of the alveolar-capillary membrane, reduced surface area, or altered surfactant function.","Surfactant dysfunction leads to increased surface tension, alveolar collapse, and impaired gas exchange across the alveolar-capillary membrane."],"references":["Gower WA, Nogee LM. Surfactant dysfunction. Paediatr Respir Rev. 2011 Dec;12(4):223-9. doi: 10.1016/j.prrv.2011.01.005. Epub 2011 Mar 5. PMID: 22018035; PMCID: PMC3201772.","Ramaswamy VV, Abiramalatha T, Bandyopadhyay T, Boyle E, Roehr CC. Surfactant therapy in late preterm and term neonates with respiratory distress syndrome: a systematic review and meta-analysis. Arch Dis Child Fetal Neonatal Ed. 2022 Jul;107(4):393-397. doi: 10.1136/archdischild-2021-322890. Epub 2021 Oct 22. PMID: 34686533.","Han S, Mallampalli RK. The Role of Surfactant in Lung Disease and Host Defense against Pulmonary Infections. Ann Am Thorac Soc. 2015 May;12(5):765-74. doi: 10.1513/AnnalsATS.201411-507FR. PMID: 25742123; PMCID: PMC4418337.","Kumar, V., Abbas, A. K., \u0026 Aster, J. C. (Eds.). (2012). Robbins basic pathology e-book. Elsevier Health Science"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"47070"}},"question":{"data":{"type":"questions","id":"15496"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"47070","links":{"self":"https://app.emedici.com/api/itemRevisions/47070"},"attributes":{"createdAt":"2024-11-15T23:25:51+10:30","updatedAt":"2024-11-15T23:26:19+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8187"}},"content":{"data":{"type":"questionRevisions","id":"61617"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4927","links":{"self":"https://app.emedici.com/api/tags/4927"},"attributes":{"emoji":"\ud83e\udec1","name":"Respiratory","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:14:59+10:30","update