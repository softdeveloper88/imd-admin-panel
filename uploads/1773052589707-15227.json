{"data":[{"type":"questionAttempts","id":"17592182","links":{"self":"https://app.emedici.com/api/questionAttempts/17592182"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T10:11:46+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T10:11:46+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15227"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15227","links":{"self":"https://app.emedici.com/api/questions/15227"},"attributes":{"optionProportions":[0.06,0.03,0.91,0,0]},"relationships":{"item":{"data":{"type":"items","id":"7918"}},"activeRevision":{"data":{"type":"questionRevisions","id":"69360"}}}},{"type":"items","id":"7918","links":{"self":"https://app.emedici.com/api/items/7918"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15227"}},"activeRevision":{"data":{"type":"itemRevisions","id":"54813"}},"tags":{"data":[{"type":"tags","id":"5"},{"type":"tags","id":"31"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"385"},{"type":"tags","id":"1017"},{"type":"tags","id":"1440"},{"type":"tags","id":"4928"},{"type":"tags","id":"4937"},{"type":"tags","id":"4950"},{"type":"tags","id":"8127"},{"type":"tags","id":"8572"},{"type":"tags","id":"9598"}]},"contributions":{"data":[{"type":"contributions","id":"19290"},{"type":"contributions","id":"19294"},{"type":"contributions","id":"22452"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"69360","links":{"self":"https://app.emedici.com/api/questionRevisions/69360"},"attributes":{"stem":"\u003Cp\u003ETreatment options for colorectal neoplasms vary depending on the extent of the disease and the underlying pathology. One treatment option is local endoscopic mucosal resection.\u003C/p\u003E","stemQuestion":"Which one of the following would be most appropriate for this approach?","responseType":"sba","marks":1,"options":["Submucosal invasion","Familial adenomatous polyposis","Carcinoma in situ without submucosal invasion","Metastatic adenocarcinoma","Lynch syndrome"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003ELocal excision techniques like polypectomy or endoscopic mucosal resection are appropriate for \u003Cstrong\u003Ecarcinoma in situ without submucosal invasion\u003C/strong\u003E because the cancer is confined to the mucosa with no risk of lymph node spread.\u003C/p\u003E        \u003Cp\u003E\u003Cstrong\u003ESubmucosal invasion\u003C/strong\u003E requires formal surgical resection due to risk of lymph node metastases. \u003Cstrong\u003EFamilial adenomatous polyposis\u003C/strong\u003E typically requires total colectomy due to the inevitable development of cancer. \u003Cstrong\u003EMetastatic adenocarcinoma\u003C/strong\u003E requires systemic therapy and possible surgical management of both primary and metastatic disease. \u003Cstrong\u003ELynch syndrome\u003C/strong\u003E (hereditary non-polyposis colorectal cancer) usually requires extensive surgical resection due to high risk of synchronous and metachronous cancers.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Carcinoma in situ in colorectal cancer can be treated with local excision via polypectomy or endoscopic mucosal resection if there is no submucosal invasion.","Hereditary conditions like FAP and Lynch syndrome require more extensive surgical management due to high risk of malignant transformation.","Presence of submucosal invasion or metastatic disease requires more extensive surgical resection and systemic therapy."],"references":["Yamada, T., Alpers, D. H., Kalloo, A. N., Kaplowitz, N., Owyang, C., \u0026 Powell, D. W. (Eds.). (2011). Textbook of gastroenterology. John Wiley \u0026 Sons","Kumar, V., Abbas, A. K., \u0026 Aster, J. C. (Eds.). (2012). Robbins basic pathology e-book. Elsevier Health Science","Sandler RS. Epidemiology and risk factors for colorectal cancer. Gastroenterol Clin North Am. 1996 Dec;25(4):717-35. doi: 10.1016/s0889-8553(05)70271-5. PMID: 8960889","Rawla P, Sunkara T, Barsouk A. Epidemiology of colorectal cancer: incidence, mortality, survival, and risk factors. Prz Gastroenterol. 2019;14(2):89-103. doi: 10.5114/pg.2018.81072. Epub 2019 Jan 6. PMID: 31616522; PMCID: PMC6791134"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"54813"}},"question":{"data":{"type":"questions","id":"15227"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"54813","links":{"self":"https://app.emedici.com/api/itemRevisions/54813"},"attributes":{"createdAt":"2024-12-11T20:37:54+10:30","updatedAt":"2024-12-11T20:38:17+10:30"},"relationships":{"item":{"data":{"type":"items","id":"7918"}},"content":{"data":{"type":"questionRevisions","id":"69360"}}},"meta":{"canDelete":false}},{"type":"tags","id":"5","links":{"self":"https://app.emedici.com/api/tags/5"},"attributes":{"emoji":"\ud83d\udd2d","name":"Gastroenterology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"31","links":{"self":"https://app.emedici.com/api/tags/31"},"attributes":{"emoji":"\ud83c\udf97","name":"Oncology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relation