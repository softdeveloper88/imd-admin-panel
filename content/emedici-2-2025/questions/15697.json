{"data":[{"type":"questionAttempts","id":"17602425","links":{"self":"https://app.emedici.com/api/questionAttempts/17602425"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T12:24:49+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T12:24:49+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15697"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15697","links":{"self":"https://app.emedici.com/api/questions/15697"},"attributes":{"optionProportions":[0.69,0.16,0.16,0,0]},"relationships":{"item":{"data":{"type":"items","id":"8388"}},"activeRevision":{"data":{"type":"questionRevisions","id":"62262"}}}},{"type":"items","id":"8388","links":{"self":"https://app.emedici.com/api/items/8388"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15697"}},"activeRevision":{"data":{"type":"itemRevisions","id":"47708"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4929"},{"type":"tags","id":"4935"},{"type":"tags","id":"4942"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"7037"},{"type":"tags","id":"8501"},{"type":"tags","id":"10095"},{"type":"tags","id":"10114"},{"type":"tags","id":"10148"},{"type":"tags","id":"10604"},{"type":"tags","id":"10636"},{"type":"tags","id":"10637"},{"type":"tags","id":"10638"}]},"contributions":{"data":[{"type":"contributions","id":"20213"},{"type":"contributions","id":"20216"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"62262","links":{"self":"https://app.emedici.com/api/questionRevisions/62262"},"attributes":{"stem":"\u003Cp\u003EConsider the hormonal and physiological changes that occur during menopause.\u003C/p\u003E","stemQuestion":"Which one of the following increases during menopause?","responseType":"sba","marks":1,"options":["FSH","Estradiol","Inhibin","Ovulation","Follicular recruitment"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EDuring menopause, \u003Cstrong\u003EFSH\u003C/strong\u003E levels increase markedly due to reduced negative feedback from declining ovarian hormones. This occurs because:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EEstradiol\u003C/strong\u003E production decreases as ovarian follicles become depleted\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EInhibin\u003C/strong\u003E levels fall due to reduced follicular function\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EOvulation\u003C/strong\u003E ceases as follicular development stops\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EFollicular recruitment\u003C/strong\u003E decreases due to depletion of the ovarian follicular pool\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThe loss of negative feedback from estradiol and inhibin results in increased gonadotropin-releasing hormone (GnRH) pulsatility and consequently elevated FSH levels.\u003C/p\u003E","optionExplanations":null,"learningPoints":["During menopause, follicle stimulating hormone (FSH) levels increase due to reduced negative feedback from declining ovarian hormones.","Estradiol, inhibin, ovulation and follicular recruitment all decrease during menopause due to ovarian follicular depletion."],"references":["Okeke T, Anyaehie U, Ezenyeaku C. Premature menopause. Ann Med Health Sci Res. 2013 Jan;3(1):90-5. doi: 10.4103/2141-9248.109458. PMID: 23634337; PMCID: PMC3634232","Magraith K, Jang C. Management of menopause. Aust Prescr. 2023 Oct;46(3):48-53. doi: 10.18773/austprescr.2023.014. PMID: 38053812; PMCID: PMC10665088","Santoro N, Epperson CN, Mathews SB. Menopausal Symptoms and Their Management. Endocrinol Metab Clin North Am. 2015 Sep;44(3):497-515. doi: 10.1016/j.ecl.2015.05.001. PMID: 26316239; PMCID: PMC4890704","Hawkins SM, Matzuk MM. The menstrual cycle: basic biology. Ann N Y Acad Sci. 2008;1135:10-8. doi: 10.1196/annals.1429.018. PMID: 18574203; PMCID: PMC2913133","Evans, T. J., \u0026 Ganjam, V. K. (2017). Reproductive anatomy and physiology. In Reproductive and Developmental Toxicology (pp. 7-37). Academic Press","Melmed, S., Polonsky, K. S., Larsen, P. R., \u0026 Kronenberg, H. M. (2015). Williams textbook of endocrinology E-Book. Elsevier Health Sciences"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"47708"}},"question":{"data":{"type":"questions","id":"15697"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"47708","links":{"self":"https://app.emedici.com/api/itemRevisions/47708"},"attributes":{"createdAt":"2024-11-17T14:35:24+10:30","updatedAt":"2024-11-17T14:36:34+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8388"}},"content":{"data":{"type":"questionRevisions","id":"62262"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},