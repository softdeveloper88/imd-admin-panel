{"data":[{"type":"questionAttempts","id":"17626267","links":{"self":"https://app.emedici.com/api/questionAttempts/17626267"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T16:35:33+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T16:35:33+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17064"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17064","links":{"self":"https://app.emedici.com/api/questions/17064"},"attributes":{"optionProportions":[0.19,0.46,0.19,0.04,0.12]},"relationships":{"item":{"data":{"type":"items","id":"9754"}},"activeRevision":{"data":{"type":"questionRevisions","id":"77009"}}}},{"type":"items","id":"9754","links":{"self":"https://app.emedici.com/api/items/9754"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17064"}},"activeRevision":{"data":{"type":"itemRevisions","id":"62515"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4936"},{"type":"tags","id":"4943"},{"type":"tags","id":"4947"},{"type":"tags","id":"5275"}]},"contributions":{"data":[{"type":"contributions","id":"22932"},{"type":"contributions","id":"23097"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"77009","links":{"self":"https://app.emedici.com/api/questionRevisions/77009"},"attributes":{"stem":"\u003Cp\u003EA 72-year-old woman presents to her general practitioner with three days of fever, dry cough, and fatigue. A rapid antigen test is positive for COVID-19. Her medical history includes type 2 diabetes mellitus and hypertension. She takes metformin 1 g twice daily.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate antiviral treatment?","responseType":"sba","marks":1,"options":["Ribavirin","Nirmatrelvir/ritonavir","Aciclovir","Ganciclovir","Oseltamivir"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003ENirmatrelvir/ritonavir\u003C/strong\u003E is the recommended first-line oral antiviral for treating mild to moderate COVID-19 in patients at high risk of progression to severe disease. It works by inhibiting the main protease of SARS-CoV-2, preventing viral replication.\u003C/p\u003E        \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E        \u003Cul\u003E        \u003Cli\u003E\u003Cstrong\u003ERibavirin\u003C/strong\u003E is used mainly for hepatitis C virus and respiratory syncytial virus infections\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EAciclovir\u003C/strong\u003E is only effective against herpes viruses\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EGanciclovir\u003C/strong\u003E is used primarily for cytomegalovirus infections\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EOseltamivir\u003C/strong\u003E is specific for influenza virus and has no activity against coronaviruses\u003C/li\u003E    \u003C/ul\u003E        \u003Cp\u003ETreatment should be initiated within five days of symptom onset. The patient\u0027s advanced age and diabetes put her at higher risk of severe disease, making her an appropriate candidate for antiviral therapy. Temporary cessation of metformin may be required during treatment due to drug interactions.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Nirmatrelvir/ritonavir is the first-line oral antiviral treatment for mild to moderate COVID-19 in high-risk patients.","Early initiation of antiviral therapy is crucial for optimal treatment outcomes in COVID-19.","Risk factors like diabetes mellitus and advanced age increase the risk of severe COVID-19 disease."],"references":["Therapeutic Guidelines. Melbourne: Therapeutic Guidelines Limited. Available from: https://www.tg.org.au","Ritter J, Flower RJ (Rod J), Henderson G (Graeme), et al.\u00a0Rang and Dale\u2019s Pharmacology. Tenth edition. Elsevier; 2024.","Australian Medicines Handbook\u00a0(online). Adelaide: Australian Medicines Handbook Pty Ltd. Available from:\u00a0https://amhonline.amh.net.au/","Gon\u00e7alves BC, Lopes Barbosa MG, Silva Olak AP, et al. Antiviral therapies: advances and perspectives. Fundam Clin Pharmacol. 2021;35(2):305-320. doi:10.1111/fcp.12609"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"62515"}},"question":{"data":{"type":"questions","id":"17064"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"62515","links":{"self":"https://app.emedici.com/api/itemRevisions/62515"},"attributes":{"createdAt":"2025-01-05T22:17:35+10:30","updatedAt":"2025-01-05T22:17:53+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9754"}},"content":{"data":{"type":"questionRevisions","id":"77009"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta