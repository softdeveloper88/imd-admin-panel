{"data":[{"type":"questionAttempts","id":"17620575","links":{"self":"https://app.emedici.com/api/questionAttempts/17620575"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T15:45:23+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T15:45:23+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16638"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"16638","links":{"self":"https://app.emedici.com/api/questions/16638"},"attributes":{"optionProportions":[0,0.03,0.31,0.64,0.03]},"relationships":{"item":{"data":{"type":"items","id":"9329"}},"activeRevision":{"data":{"type":"questionRevisions","id":"76660"}}}},{"type":"items","id":"9329","links":{"self":"https://app.emedici.com/api/items/9329"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16638"}},"activeRevision":{"data":{"type":"itemRevisions","id":"62157"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4930"},{"type":"tags","id":"4939"},{"type":"tags","id":"4943"},{"type":"tags","id":"4947"},{"type":"tags","id":"5199"}]},"contributions":{"data":[{"type":"contributions","id":"22102"},{"type":"contributions","id":"22380"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"76660","links":{"self":"https://app.emedici.com/api/questionRevisions/76660"},"attributes":{"stem":"\u003Cp\u003EA 42-year-old woman visits her general practitioner seeking assistance with smoking cessation. She reports smoking one pack of cigarettes daily for the past 25 years and describes multiple failed quit attempts. The doctor recommends nicotine replacement therapy.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the primary mechanism of action of nicotine replacement therapy?","responseType":"sba","marks":1,"options":["Inhibits gamma-aminobutyric acid receptors","Decreases nicotine clearance","Antagonises nicotinic acetylcholine receptors","Activates nicotinic acetylcholine receptors","Inhibits dopamine transport"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003ENicotine replacement therapy functions by \u003Cstrong\u003Eactivating nicotinic acetylcholine receptors\u003C/strong\u003E in the central nervous system, helping to minimise withdrawal symptoms by providing controlled amounts of nicotine that would otherwise come from cigarettes.\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EInhibiting gamma-aminobutyric acid receptors\u003C/strong\u003E is not how nicotine exerts its effects.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EDecreasing nicotine clearance\u003C/strong\u003E does not reflect the mechanism - replacement therapy supplies nicotine directly.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EAntagonising nicotinic acetylcholine receptors\u003C/strong\u003E would actually increase withdrawal effects.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EInhibiting dopamine transport\u003C/strong\u003E is not the primary mechanism, although nicotine does lead to increased dopamine signaling.\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EBy providing nicotine through controlled delivery systems, replacement therapy helps manage cravings while avoiding exposure to harmful tobacco smoke constituents.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Nicotine replacement products activate nicotinic acetylcholine receptors to alleviate withdrawal symptoms during smoking cessation.","Nicotine from replacement products is absorbed more gradually and at lower concentrations compared to cigarettes.","Various nicotine delivery systems provide different pharmacokinetic profiles to suit individual needs."],"references":["Therapeutic Guidelines. Melbourne: Therapeutic Guidelines Limited. Available from: https://www.tg.org.au","Ritter J, Flower RJ (Rod J), Henderson G (Graeme), et al.\u00a0Rang and Dale\u2019s Pharmacology. Tenth edition. Elsevier; 2024.","Australian Medicines Handbook\u00a0(online). Adelaide: Australian Medicines Handbook Pty Ltd. Available from:\u00a0https://amhonline.amh.net.au/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"62157"}},"question":{"data":{"type":"questions","id":"16638"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"62157","links":{"self":"https://app.emedici.com/api/itemRevisions/62157"},"attributes":{"createdAt":"2025-01-03T20:32:58+10:30","updatedAt":"2025-01-04T08:00:10+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9329"}},"content":{"data":{"type":"questionRevisions","id":"76660"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"m