{"data":[{"type":"questionAttempts","id":"17492886","links":{"self":"https://app.emedici.com/api/questionAttempts/17492886"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T06:48:48+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T06:48:48+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"1178"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"1178","links":{"self":"https://app.emedici.com/api/questions/1178"},"attributes":{"optionProportions":[0.44,0.21,0.01,0.25,0.08]},"relationships":{"item":{"data":{"type":"items","id":"1178"}},"activeRevision":{"data":{"type":"questionRevisions","id":"41974"}}}},{"type":"items","id":"1178","links":{"self":"https://app.emedici.com/api/items/1178"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1178"}},"activeRevision":{"data":{"type":"itemRevisions","id":"26964"}},"tags":{"data":[{"type":"tags","id":"24"},{"type":"tags","id":"35"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"1046"},{"type":"tags","id":"4959"},{"type":"tags","id":"4961"},{"type":"tags","id":"4987"},{"type":"tags","id":"4992"},{"type":"tags","id":"11630"},{"type":"tags","id":"11642"},{"type":"tags","id":"11644"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"2885"},{"type":"contributions","id":"2905"},{"type":"contributions","id":"18259"},{"type":"contributions","id":"33970"},{"type":"contributions","id":"42239"},{"type":"contributions","id":"44936"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"41974","links":{"self":"https://app.emedici.com/api/questionRevisions/41974"},"attributes":{"stem":"\u003Cp\u003EA 78-year-old woman presents to the Emergency Department with a left sided nosebleed which started one hour ago. She has used most of a box of tissues and fresh blood is still coming out. Her medical history includes atrial fibrillation for which she takes apixaban. She is highly anxious given the amount of perceived bleeding. On examination her blood pressure is 145/85 mmHg, pulse 100/min and temperature 36.5 C.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate next step in management?","responseType":"sba","marks":1,"options":["Ice and external compression to the nose","Silver nitrate cautery to the offending vessel","Referral for radiologic embolisation","Assessment of her airway and insert of large bore cannula","Referral to ENT"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EEpistaxis is a common presenting complaint to GP\u0027s and emergency departments. The majority of episodes cease with simple nasal compression, however, the clinician must be aware of the potential for catastrophic bleeding. Appropriate assessment is needed in this patient as she is on anticoagulation and is elderly. As such a Primary Survey approach is most suitable, starting with \u003Cstrong\u003Eairway assessment,\u003C/strong\u003E as blood clots can occlude the airway. Insertion of a wide-bore cannula is a standard practice in resuscitation; in this case, although the patient is currently haemodynamically stable, she may quickly decompensate and require aggressive volume expansion. \u003Cstrong\u003ECompression of the nose\u003C/strong\u003E can be useful but the bleeding has been going for an hour and there is more pressing management. \u003Cstrong\u003ESilver nitrate cauterisation\u003C/strong\u003E may be beneficial if there is a clear identify anterior bleeding vessel but AFTER a primary survey assessment. \u003Cstrong\u003EENT\u003C/strong\u003E are the experts in managing these scenarios and should be called after initial management is commenced. \u003Cstrong\u003ERadiological embolisation\u003C/strong\u003E is a management option after considering the above.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Epistaxis can be an emergency and requires A-E assessment"],"references":["Yau S. An update on epistaxis. AFP. 2015; 44(9): 653-656."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"26964"}},"question":{"data":{"type":"questions","id":"1178"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"26964","links":{"self":"https://app.emedici.com/api/itemRevisions/26964"},"attributes":{"createdAt":"2024-01-28T18:57:35+10:30","updatedAt":"2024-08-07T08:21:56+09:30"},"relationships":{"item":{"data":{"type":"items","id":"1178"}},"content":{"data":{"type":"questionRevisions","id":"41974"}}},"meta":{"canDelete":false}},{"type":"tags","id":"24","links":{"self":"https://app.emedici.com/api/tags/24"},"attributes":{"emoji":"\ud83d\ude91","name":"Emergency Medicine","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"5"}}},"meta":{"itemCount":0}},{"type":"tags","id":"35","links":{"self":"https://app.emedici.com/api/tags/35"},"attributes":{"emoji":"\ud83d\udc43","name":"Otorhinolaryngology","synonyms":["ENT","HEENT"],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:40:48+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"2"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":"Management","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"72","links":{"self":"https://app.emedici.com/api/tags/72"},"attributes":{"emoji":"","name":"Graduating","synony