{"data":[{"type":"questionAttempts","id":"17480172","links":{"self":"https://app.emedici.com/api/questionAttempts/17480172"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-28T23:38:34+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T23:38:34+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"21"}},"bookmark":{"data":null}}},{"type":"questionAttempts","id":"17582388","links":{"self":"https://app.emedici.com/api/questionAttempts/17582388"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T06:41:03+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T06:41:03+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"21"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"21","links":{"self":"https://app.emedici.com/api/questions/21"},"attributes":{"optionProportions":[0.05,0.78,0.06,0.09,0.02]},"relationships":{"item":{"data":{"type":"items","id":"21"}},"activeRevision":{"data":{"type":"questionRevisions","id":"52889"}}}},{"type":"items","id":"21","links":{"self":"https://app.emedici.com/api/items/21"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"21"}},"activeRevision":{"data":{"type":"itemRevisions","id":"38275"}},"tags":{"data":[{"type":"tags","id":"2"},{"type":"tags","id":"25"},{"type":"tags","id":"42"},{"type":"tags","id":"64"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"99"},{"type":"tags","id":"1196"},{"type":"tags","id":"2664"},{"type":"tags","id":"4947"},{"type":"tags","id":"5002"}]},"contributions":{"data":[{"type":"contributions","id":"15481"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"52889","links":{"self":"https://app.emedici.com/api/questionRevisions/52889"},"attributes":{"stem":"\u003Cp\u003EA 35-year-old man presents for a routine health check and on examination is found to have a pan-systolic murmur, heard best at the 5th\u00a0intercostal space, mid-clavicular line. He is otherwise a tall, thin and healthy man, although he does have a history of several spontaneous pneumothoracies.\u003C/p\u003E","stemQuestion":"Which one of the following valvular pathologies is the most likely cause of this murmur?","responseType":"sba","marks":1,"options":["Aortic regurgitation","Mitral regurgitation","Mitral stenosis","Ventricular septal defect","Aortic stenosis"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient almost certainly has Marfan syndrome, which is most commonly associated with \u003Cstrong\u003Emitral valve prolapse and regurgitation\u003C/strong\u003E. Marfan syndrome is an autosomal dominant, multi-system connective tissue disease. The typical patient with Marfan syndrome is young, tall and thin with long limbs, arachnodactyly (long, \u2018spider\u2019 fingers) as well as skeletal deformities such as scoliosis.\u00a0\u003C/p\u003E\u003Cp\u003EThe cardiac manifestations of Marfan syndrome include valvular pathology, sudden cardiac death as well as aortic aneurysms or dissection. The most common valvular pathologies include aortic root dilatation and resultant regurgitation as well as mitral valve prolapse with or without regurgitation. While aortic root dilatation and risk of dissection is the major cause of cardiac mortality in patients with Marfan syndrome, significant mitral valve disease remains the most common finding in these patients. Mitral valve prolapse and resultant regurgitation is the most common cardiac manifestation of Marfan syndrome with an estimated incidence of 80% compared to 2-3% in the general population.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Mitral regurgitation is associated with a pan-systolic murmur."],"references":["Plichta RP, Glower DD, Hughes GC. Valvular Disease in Marfan Syndrome: Surgical Considerations and Management. Current Cardiology Reports. 2019;21(4):23."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"38275"}},"question":{"data":{"type":"questions","id":"21"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"38275","links":{"self":"https://app.emedici.com/api/itemRevisions/38275"},"attributes":{"createdAt":"2024-09-11T13:16:37+09:30","updatedAt":"2024-09-11T13:18:27+09:30"},"relationships":{"item":{"data":{"type":"items","id":"21"}},"content":{"data":{"type":"questionRevisions","id":"52889"}}},"meta":{"canDelete":false}},{"type":"tags","id":"2","links":{"self":"https://app.emedici.com/api/tags/2"},"attributes":{"emoji":"\ud83e\udec0","name":"Cardiology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:21+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"42","links":{"self":"https://app.emedici.com/api/tags/42"},"attributes":{"emoji":"\ud83e\uddec","name":"Genetics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"4"}}},"meta":{"itemCount":0}},{"type":"tags","id":"64","links":{"self":"https://app.emedici.com/api/tags/64"},"attri