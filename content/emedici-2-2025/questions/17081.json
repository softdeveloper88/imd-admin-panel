{"data":[{"type":"questionAttempts","id":"17626570","links":{"self":"https://app.emedici.com/api/questionAttempts/17626570"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T16:39:17+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T16:39:17+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17081"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17081","links":{"self":"https://app.emedici.com/api/questions/17081"},"attributes":{"optionProportions":[0.05,0.1,0.68,0.18,0]},"relationships":{"item":{"data":{"type":"items","id":"9771"}},"activeRevision":{"data":{"type":"questionRevisions","id":"69142"}}}},{"type":"items","id":"9771","links":{"self":"https://app.emedici.com/api/items/9771"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17081"}},"activeRevision":{"data":{"type":"itemRevisions","id":"54599"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"4936"},{"type":"tags","id":"4943"},{"type":"tags","id":"4944"},{"type":"tags","id":"5254"},{"type":"tags","id":"5257"}]},"contributions":{"data":[{"type":"contributions","id":"22949"},{"type":"contributions","id":"23164"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"69142","links":{"self":"https://app.emedici.com/api/questionRevisions/69142"},"attributes":{"stem":"\u003Cp\u003ECephalosporins are commonly prescribed antibiotics that belong to the beta-lactam family. They are classified into different generations based on their antimicrobial spectrum.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the antimicrobial spectrum of first-generation cephalosporins?","responseType":"sba","marks":1,"options":["Primarily active against anaerobic bacteria","Equal activity against gram-positive and gram-negative organisms","Primarily active against gram-positive organisms","Primarily active against gram-negative organisms","Primarily active against atypical organisms"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EFirst-generation cephalosporins are \u003Cstrong\u003Eprimarily active against gram-positive organisms\u003C/strong\u003E, particularly Staphylococcus and Streptococcus species. They have limited activity against gram-negative organisms.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EEqual activity against gram-positive and gram-negative organisms\u003C/strong\u003E - First-generation cephalosporins have much stronger gram-positive than gram-negative activity\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EPrimarily active against gram-negative organisms\u003C/strong\u003E - This better describes later generations of cephalosporins\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EPrimarily active against anaerobic bacteria\u003C/strong\u003E - Cephalosporins generally have poor anaerobic coverage\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EPrimarily active against atypical organisms\u003C/strong\u003E - Cephalosporins are not effective against atypical organisms like \u003Cem\u003EMycoplasma\u003C/em\u003E or \u003Cem\u003EChlamydia\u003C/em\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EExamples of first-generation cephalosporins include cefazolin and cephalexin. Their spectrum of activity makes them useful for treating skin and soft tissue infections caused by susceptible gram-positive organisms.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Cephalosporins are beta-lactam antibiotics that work by inhibiting bacterial cell wall synthesis.","First-generation cephalosporins have good activity against gram-positive organisms but limited gram-negative coverage.","Later generations of cephalosporins have increased gram-negative coverage but decreased gram-positive activity."],"references":["Therapeutic Guidelines. Melbourne: Therapeutic Guidelines Limited. Available from: https://www.tg.org.au","Ritter J, Flower RJ (Rod J), Henderson G (Graeme), et al.\u00a0Rang and Dale\u2019s Pharmacology. Tenth edition. Elsevier; 2024.","Australian Medicines Handbook\u00a0(online). Adelaide: Australian Medicines Handbook Pty Ltd. Available from:\u00a0https://amhonline.amh.net.au/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"54599"}},"question":{"data":{"type":"questions","id":"17081"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"54599","links":{"self":"https://app.emedici.com/api/itemRevisions/54599"},"attributes":{"createdAt":"2024-12-11T11:11:24+10:30","updatedAt":"2024-12-11T11:12:11+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9771"}},"content":{"data":{"type":"questionRevisions","id":"69142"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Level II","synonyms":null,"description":"Understand (interpreting and summarizing information)","position":null,"createdAt":null,"updatedAt":null},"relationships":