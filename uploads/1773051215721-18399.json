{"data":[{"type":"questionAttempts","id":"17650238","links":{"self":"https://app.emedici.com/api/questionAttempts/17650238"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T21:10:48+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T21:10:48+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18399"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18399","links":{"self":"https://app.emedici.com/api/questions/18399"},"relationships":{"item":{"data":{"type":"items","id":"11117"}},"activeRevision":{"data":{"type":"questionRevisions","id":"114264"}}}},{"type":"items","id":"11117","links":{"self":"https://app.emedici.com/api/items/11117"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18399"}},"activeRevision":{"data":{"type":"itemRevisions","id":"96264"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4930"},{"type":"tags","id":"4941"},{"type":"tags","id":"4942"},{"type":"tags","id":"10356"}]},"contributions":{"data":[{"type":"contributions","id":"25772"},{"type":"contributions","id":"25775"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"114264","links":{"self":"https://app.emedici.com/api/questionRevisions/114264"},"attributes":{"stem":"\u003Cp\u003E\u003C/p\u003E","stemQuestion":"Which one of the following parts of the brain is primarily responsible for the programming of complex movements?","responseType":"sba","marks":1,"options":["Premotor and supplementary motor areas","Primary motor cortex","Basal ganglia","Cerebellum","Somatosensory cortex"],"correctOptions":[0],"correctResponses":[],"explanation":"\u003Cp\u003EThe brain is responsible for controlling and coordinating voluntary movements. Different regions of the brain contribute to various aspects of movement, including planning, initiation, and execution. The \u003Cstrong\u003Epremotor and supplementary motor areas\u003C/strong\u003E are primarily responsible for the programming of complex movements, being involved in the planning and coordination of movements before they are executed by the primary motor cortex.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Eprimary motor cortex\u003C/strong\u003E is responsible for the execution of voluntary movements rather than their programming. The \u003Cstrong\u003Ebasal ganglia\u003C/strong\u003E are involved in the modulation and regulation of movement, not the initial programming. The \u003Cstrong\u003Ecerebellum\u003C/strong\u003E is crucial for coordination and precision of movements, but not for programming. The \u003Cstrong\u003Esomatosensory cortex\u003C/strong\u003E processes sensory information from the body and is not directly involved in movement programming.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["The premotor and supplementary motor areas are involved in the planning and programming of complex movements.","The primary motor cortex is responsible for the execution of voluntary movements.","The basal ganglia and cerebellum play roles in movement coordination and modulation."],"references":["Patton KT, Thibodeau GA. Anthony\u0027s Textbook of Anatomy \u0026 Physiology-E-Book: Anthony\u0027s Textbook of Anatomy \u0026 Physiology-E-Book. Elsevier Health Sciences; 2018.","Hutson M, Ward A, editors. Oxford textbook of musculoskeletal medicine. Oxford University Press; 2015.","Longo UG, Denaro V, editors. Textbook of musculoskeletal disorders. Springer Nature; 2023.","Hughes SH. The Musculoskeletal System: The Musculoskeletal System-E-Book. Elsevier Health Sciences; 2022.","Frontera WR, Ochala J. Skeletal muscle: a brief review of structure and function. Calcif Tissue Int. 2015 Mar;96(3):183-95.","Morrison BM. Neuromuscular Diseases. Semin Neurol. 2016 Oct;36(5):409-418.","Hall JE. Guyton and Hall Textbook of Medical Physiology. 14th ed. Philadelphia: Elsevier; 2021. Chapter 56; pg. 698"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"96264"}},"question":{"data":{"type":"questions","id":"18399"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"96264","links":{"self":"https://app.emedici.com/api/itemRevisions/96264"},"attributes":{"createdAt":"2025-09-15T14:30:23+09:30","updatedAt":"2025-09-15T14:30:23+09:30"},"relationships":{"item":{"data":{"type":"items","id":"11117"}},"content":{"data":{"type":"questionRevisions","id":"114264"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4930","links":{"self":"https://app.emedici.com/api/tags/4930"},"attributes":{"emoji":"\ud83e\udde0","name":"Nervous System","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"202