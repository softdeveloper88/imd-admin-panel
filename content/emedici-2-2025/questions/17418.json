{"data":[{"type":"questionAttempts","id":"17632140","links":{"self":"https://app.emedici.com/api/questionAttempts/17632140"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T17:36:52+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T17:36:52+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17418"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17418","links":{"self":"https://app.emedici.com/api/questions/17418"},"relationships":{"item":{"data":{"type":"items","id":"10108"}},"activeRevision":{"data":{"type":"questionRevisions","id":"82570"}}}},{"type":"items","id":"10108","links":{"self":"https://app.emedici.com/api/items/10108"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17418"}},"activeRevision":{"data":{"type":"itemRevisions","id":"67735"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5455"}]},"contributions":{"data":[{"type":"contributions","id":"23681"},{"type":"contributions","id":"23685"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"82570","links":{"self":"https://app.emedici.com/api/questionRevisions/82570"},"attributes":{"stem":"\u003Cp\u003ESocial determinants of health significantly influence population health outcomes and health inequities.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the social determinants of health?","responseType":"sba","marks":1,"options":["Healthcare system accessibility and medical resources","Environmental and socioeconomic conditions throughout life","Personal choices regarding diet and exercise","Inherited traits and physiological characteristics","Societal perspectives on wellness and disease"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Eenvironmental and socioeconomic conditions throughout life\u003C/strong\u003E encompass the social determinants of health, which include factors such as economic resources, educational opportunities, occupational circumstances, living conditions, and community support systems.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EHealthcare system accessibility and medical resources\u003C/strong\u003E represents only a small portion of what influences health outcomes, contributing roughly 20% to overall health status\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EPersonal choices regarding diet and exercise\u003C/strong\u003E are themselves shaped by social determinants rather than being primary determinants\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EInherited traits and physiological characteristics\u003C/strong\u003E fall under biological rather than social influences on health\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ESocietal perspectives on wellness and disease\u003C/strong\u003E represent just one aspect of the broader social determinants framework\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003ERecognition of these social determinants is essential for developing effective public health interventions and policies that address underlying causes of health disparities.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Social determinants of health are the conditions in which people are born, grow, live, work and age that affect health outcomes.","The five main categories of social determinants are economic stability, education, healthcare access, neighbourhood environment, and social context.","Social determinants account for approximately 80% of health outcomes, while medical care accounts for about 20%."],"references":["Shultz JM, Sullivan LM, Galea S. Public Health: An Introduction to the Science and Practice of Population Health. Springer Publishing Company; 2021."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"67735"}},"question":{"data":{"type":"questions","id":"17418"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"67735","links":{"self":"https://app.emedici.com/api/itemRevisions/67735"},"attributes":{"createdAt":"2025-01-29T23:14:08+10:30","updatedAt":"2025-01-29T23:15:03+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10108"}},"content":{"data":{"type":"questionRevisions","id":"82570"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"5326","links":{"self":"https://app.emedici.com/api/tags/5326"},"attributes":{"emoji":"\ud83c\udf0f","name":"Public Health","synonyms":null,"description":null,"position":null,"createdAt":"2024-10-24T05:44:22+10:30","updatedAt":"2024-10-24T05:44:22+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1