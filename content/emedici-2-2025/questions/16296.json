{"data":[{"type":"questionAttempts","id":"17613050","links":{"self":"https://app.emedici.com/api/questionAttempts/17613050"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T14:29:47+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T14:29:47+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16296"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"16296","links":{"self":"https://app.emedici.com/api/questions/16296"},"attributes":{"optionProportions":[0.79,0,0.14,0.04,0.04]},"relationships":{"item":{"data":{"type":"items","id":"8987"}},"activeRevision":{"data":{"type":"questionRevisions","id":"116079"}}}},{"type":"items","id":"8987","links":{"self":"https://app.emedici.com/api/items/8987"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16296"}},"activeRevision":{"data":{"type":"itemRevisions","id":"98075"}},"tags":{"data":[{"type":"tags","id":"8"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"1992"},{"type":"tags","id":"4930"},{"type":"tags","id":"4941"},{"type":"tags","id":"4942"},{"type":"tags","id":"5586"},{"type":"tags","id":"7519"},{"type":"tags","id":"7520"},{"type":"tags","id":"7521"},{"type":"tags","id":"10416"}]},"contributions":{"data":[{"type":"contributions","id":"21380"},{"type":"contributions","id":"21382"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"116079","links":{"self":"https://app.emedici.com/api/questionRevisions/116079"},"attributes":{"stem":"\u003Cp\u003ELight entering the eye must pass through several structures before reaching the retina to form a focused image.\u003C/p\u003E","stemQuestion":"Which one of the following pairs of structures must light pass through to form an image on the retina?","responseType":"sba","marks":1,"options":["Cornea and lens","Pupil and iris","Pupil and lens","Lens and iris","Macula and cornea"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003ELight must pass through the \u003Cstrong\u003Ecornea and lens\u003C/strong\u003E to be properly focused on the retina. The cornea provides about two-thirds of the eye\u0027s total refractive power, while the lens provides the remaining one-third and allows for accommodation through shape changes.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Epupil and iris\u003C/strong\u003E are not refractive structures as the pupil is simply the opening in the iris that regulates light entry. The \u003Cstrong\u003Epupil and lens\u003C/strong\u003E omits the cornea which is essential for refraction. The \u003Cstrong\u003Elens and iris\u003C/strong\u003E again omits the cornea, and the iris is not a refractive structure. The \u003Cstrong\u003Emacula and cornea\u003C/strong\u003E pairing is incorrect as the macula is part of the retina where light is detected, not a structure light passes through.\u003C/p\u003E\u003Cp\u003ETogether, the cornea and lens focus light rays to form a clear inverted image on the retina.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Light must pass through both the cornea and lens to be properly focused on the retina.","The cornea provides approximately two-thirds of the eye\u0027s refractive power, while the lens provides the remaining one-third and allows for accommodation."],"references":["Hejtmancik JF, Shiels A. Overview of the Lens. Prog Mol Biol Transl Sci. 2015;134:119-27. doi: 10.1016/bs.pmbts.2015.04.006. Epub 2015 May 27. PMID: 26310153; PMCID: PMC5656279.","Nguyen KH, Patel BC, Tadi P. Anatomy, Head and Neck: Eye Retina. [Updated 2023 Aug 8]. In: StatPearls [Internet]. Treasure Island (FL): StatPearls Publishing; 2024 Jan-. Available from: https://www.ncbi.nlm.nih.gov/books/NBK542332/","Singh, V. (2024). Textbook of Clinical Neuroanatomy-E-Book. Elsevier Health Sciences.","Michael-Titus, A. T., \u0026 Shortland, P. (2022). The Nervous System, E-Book: The Nervous System, E-Book. Elsevier Health Sciences."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"98075"}},"question":{"data":{"type":"questions","id":"16296"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"98075","links":{"self":"https://app.emedici.com/api/itemRevisions/98075"},"attributes":{"createdAt":"2025-09-27T13:47:29+09:30","updatedAt":"2025-09-27T13:48:19+09:30"},"relationships":{"item":{"data":{"type":"items","id":"8987"}},"content":{"data":{"type":"questionRevisions","id":"116079"}}},"meta":{"canDelete":false}},{"type":"tags","id":"8","links":{"self":"https://app.emedici.com/api/tags/8"},"attributes":{"emoji":"\ud83d\udc41","name":"Ophthalmology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position"