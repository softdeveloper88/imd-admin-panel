{"data":[{"type":"questionAttempts","id":"17639562","links":{"self":"https://app.emedici.com/api/questionAttempts/17639562"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T19:06:44+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T19:06:44+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17779"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17779","links":{"self":"https://app.emedici.com/api/questions/17779"},"relationships":{"item":{"data":{"type":"items","id":"10493"}},"activeRevision":{"data":{"type":"questionRevisions","id":"116742"}}}},{"type":"items","id":"10493","links":{"self":"https://app.emedici.com/api/items/10493"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17779"}},"activeRevision":{"data":{"type":"itemRevisions","id":"98729"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4932"},{"type":"tags","id":"4942"},{"type":"tags","id":"10177"}]},"contributions":{"data":[{"type":"contributions","id":"24494"},{"type":"contributions","id":"24564"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"116742","links":{"self":"https://app.emedici.com/api/questionRevisions/116742"},"attributes":{"stem":"\u003Cp\u003ESebum is an oily substance produced by sebaceous glands in human skin that serves several important physiological functions.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the primary composition of human sebum?","responseType":"sba","marks":1,"options":["Cholesterol and phospholipids","Ceramides and sphingolipids","Glycoproteins and proteoglycans","Triglycerides, wax esters, and squalene","Keratin and filaggrin"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EHuman sebum is primarily composed of \u003Cstrong\u003Etriglycerides, wax esters, and squalene\u003C/strong\u003E. These lipids are synthesised by sebaceous glands and secreted onto the skin surface where they contribute to the skin barrier function and provide waterproofing.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECholesterol and phospholipids\u003C/strong\u003E are primarily found in cell membranes and do not constitute major components of sebum. \u003Cstrong\u003ECeramides and sphingolipids\u003C/strong\u003E are important components of the stratum corneum but are not major constituents of sebum. \u003Cstrong\u003EGlycoproteins and proteoglycans\u003C/strong\u003E are structural components of the dermis and are not found in significant quantities in sebum. \u003Cstrong\u003EKeratin and filaggrin\u003C/strong\u003E are proteins found within keratinocytes and do not form part of sebum composition.\u003C/p\u003E\u003Cp\u003ESebum production is controlled by androgens and increases significantly during puberty. Excessive sebum production can contribute to acne development, while insufficient production can lead to dry skin conditions.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Sebum is produced by sebaceous glands and consists primarily of triglycerides, wax esters, squalene, and free fatty acids.","Sebum production is stimulated by androgens and helps maintain skin barrier function and waterproofing.","Sebaceous glands are found throughout the skin except on the palms and soles."],"references":["Hall JE, Hall ME. Guyton and Hall Textbook of Medical Physiology. 14th ed. Philadelphia, PA: Elsevier; 2020.","Tortora GJ, Mellifont R, Derrickson B, Burkett B, Peoples G, D D. Principles of Anatomy and Physiology, Asia-Pacific Edition. 2nd ed. John Wiley \u0026 Sons Australia; 2019."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"98729"}},"question":{"data":{"type":"questions","id":"17779"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"98729","links":{"self":"https://app.emedici.com/api/itemRevisions/98729"},"attributes":{"createdAt":"2025-09-30T14:53:55+09:30","updatedAt":"2025-09-30T14:54:15+09:30"},"relationships":{"item":{"data":{"type":"items","id":"10493"}},"content":{"data":{"type":"questionRevisions","id":"116742"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4932","links":{"self":"https://app.emedici.com/api/tags/4932"},"attributes":{"emoji":"\ud83e\uddf4","name":"Skin and Associated Structures","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-11-21T12:54:20+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"13"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4942","links":{"self":"https://app.emedici.com/api/tags/4942"},"attributes":{"emoji":"\u2699\ufe0f","name":"Physiology","synonyms":[],