{"data":[{"type":"questionAttempts","id":"20889282","links":{"self":"https://app.emedici.com/api/questionAttempts/20889282"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-11-07T13:05:38+10:30","options":[1],"response":null,"finalizedAt":"2025-11-07T13:05:38+10:30"},"relationships":{"user":{"data":{"type":"users","id":"56433"},"links":{"related":"https://app.emedici.com/api/questionAttempts/20889282/user","self":"https://app.emedici.com/api/questionAttempts/20889282/relationships/user"}},"questionSession":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889282/questionSession","self":"https://app.emedici.com/api/questionAttempts/20889282/relationships/questionSession"}},"session":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889282/session","self":"https://app.emedici.com/api/questionAttempts/20889282/relationships/session"}},"question":{"data":{"type":"questions","id":"21439"},"links":{"related":"https://app.emedici.com/api/questionAttempts/20889282/question","self":"https://app.emedici.com/api/questionAttempts/20889282/relationships/question"}},"bookmark":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889282/bookmark","self":"https://app.emedici.com/api/questionAttempts/20889282/relationships/bookmark"}}}}],"included":[{"type":"questions","id":"21439","links":{"self":"https://app.emedici.com/api/questions/21439"},"relationships":{"attempts":{"links":{"related":"https://app.emedici.com/api/questions/21439/attempts","self":"https://app.emedici.com/api/questions/21439/relationships/attempts"}},"item":{"data":{"type":"items","id":"14308"},"links":{"related":"https://app.emedici.com/api/questions/21439/item","self":"https://app.emedici.com/api/questions/21439/relationships/item"}},"activeRevision":{"data":{"type":"questionRevisions","id":"101916"},"links":{"related":"https://app.emedici.com/api/questions/21439/activeRevision","self":"https://app.emedici.com/api/questions/21439/relationships/activeRevision"}}}},{"type":"items","id":"14308","links":{"self":"https://app.emedici.com/api/items/14308"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/14308/packs","self":"https://app.emedici.com/api/items/14308/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/14308/revisions","self":"https://app.emedici.com/api/items/14308/relationships/revisions"}},"content":{"data":{"type":"questions","id":"21439"},"links":{"related":"https://app.emedici.com/api/items/14308/content","self":"https://app.emedici.com/api/items/14308/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/14308/specialtyTags","self":"https://app.emedici.com/api/items/14308/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/14308/primaryTags","self":"https://app.emedici.com/api/items/14308/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/14308/contributionTypes","self":"https://app.emedici.com/api/items/14308/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/14308/contributors","self":"https://app.emedici.com/api/items/14308/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/14308/contribution","self":"https://app.emedici.com/api/items/14308/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/14308/myContribution","self":"https://app.emedici.com/api/items/14308/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"84372"},"links":{"related":"https://app.emedici.com/api/items/14308/activeRevision","self":"https://app.emedici.com/api/items/14308/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"5"},{"type":"tags","id":"24"},{"type":"tags","id":"25"},{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"539"},{"type":"tags","id":"4578"},{"type":"tags","id":"5771"},{"type":"tags","id":"9598"}],"links":{"related":"https://app.emedici.com/api/items/14308/tags","self":"https://app.emedici.com/api/items/14308/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"35421"},{"type":"contributions","id":"35422"}],"links":{"related":"https://app.emedici.com/api/items/14308/contributions","self":"https://app.emedici.com/api/items/14308/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"101916","links":{"self":"https://app.emedici.com/api/questionRevisions/101916"},"attributes":{"stem":"\u003Cp\u003EA 42-year-old woman presents to the Emergency Department with a 60-minute history of severe right upper quadrant pain. The pain came on suddenly after dinner, is constant in nature, and radiates to her right shoulder. She reports two similar episodes in the past month, both occurring after eating fatty meals. She has no fever, vomiting, or jaundice. Her medical history includes hypertension and gestational diabetes during her last pregnancy five years ago. Her medications include amlodipine. She does not drink alcohol and has never smoked.\u003C/p\u003E\u003Cp\u003EOn examination, she appears uncomfortable but not distressed. Her pulse rate is 88/min, blood pressure 142/88 mmHg, respiratory rate 18/min, SpO2 98% on room air, and temperature 37.1\u00b0C. Her abdomen is soft with some minimal tenderness in the right upper quadrant but no guarding or rebound tenderness. There is no increase in pain when she takes a deep breath during palpation of the right upper quadrant.\u003C/p\u003E\u003Cp\u003EInvestigations reveal:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EWhite cell count: 9.2 \u00d7 10^9/L (4.0-11.0)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EC-reactive protein: 8 mg/L (\u0026lt;10)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EBilirubin: 15 \u03bcmol/L (3-20)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EAlkaline phosphatase: 95 U/L (30-110)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EGamma-glutamyl transferase: 45 U/L (5-50)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EAlanine aminotransferase: 32 U/L (5-40)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003ELipase: 65 U/L (13-60)\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Acute pancreatitis","Acute hepatitis","Perforated peptic ulcer","Biliary colic","Acute cholecystitis"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient presents with classic features of biliary colic: sudden-onset right upper quadrant pain that radiates to the right shoulder, occurring after a fatty meal, with previous similar episodes. The absence of fever, normal inflammatory markers, and lack of pain on inspiration during right upper quadrant palpation help differentiate this from other conditions.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EBiliary colic\u003C/strong\u003E occurs when a gallstone temporarily obstructs the cystic duct, causing distension of the gallbladder and pain. It typically presents with sudden-onset, severe right upper quadrant or epigastric pain that may radiate to the back or right shoulder. The pain usually lasts 30 minutes to several hours and often follows fatty meals. Laboratory tests are typically normal or show only mild abnormalities. This patient\u0027s presentation is highly consistent with biliary colic, with normal inflammatory markers and liver function tests.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAcute cholecystitis\u003C/strong\u003E involves inflammation of the gallbladder, usually due to persistent obstruction of the cystic duct by a gallstone. It typically presents with right upper quadrant pain lasting longer than six hours, fever, and pain on inspiration during palpation of the right upper quadrant. Laboratory tests often show leukocytosis and elevated C-reactive protein. This patient lacks these inflammatory features, making acute cholecystitis less likely.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAcute pancreatitis\u003C/strong\u003E typically presents with severe epigastric pain radiating to the back, often accompanied by nausea and vomiting. Serum amylase and lipase are usually elevated to at least three times the upper limit of normal. While this patient\u0027s lipase is slightly elevated, it is not at the level typically seen in acute pancreatitis (at least three times upper limit). Additionally, the pain is primarily in the right upper quadrant rather than epigastric, making pancreatitis unlikely.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPerforated peptic ulcer\u003C/strong\u003E typically presents with sudden, severe, and diffuse abdominal pain. Examination usually reveals a rigid abdomen with generalised guarding and rebound tenderness due to peritonitis. This patient\u0027s localised tenderness without peritoneal signs makes a perforated ulcer unlikely.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAcute hepatitis\u003C/strong\u003E typically presents with malaise, fatigue, anorexia, and right upper quadrant pain. Jaundice is common, and liver enzymes, particularly aminotransferases, are markedly elevated. This patient\u0027s normal liver function tests and the episodic nature of her pain make acute hepatitis unlikely.\u003C/p\u003E\u003Cp\u003EThe next step in management would be an ultrasound of the right upper quadrant to confirm the presence of gallstones. Management of uncomplicated biliary colic includes pain control with non-steroidal anti-inflammatory drugs or opioids, dietary modification to avoid fatty foods, and consideration of elective laparoscopic cholecystectomy to prevent recurrent episodes and complications.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Biliary colic typically presents as episodic right upper quadrant pain that may radiate to the right shoulder or back, often triggered by fatty meals.","Ultrasound is the first-line investigation for suspected biliary colic, with high sensitivity for detecting gallstones.","Management of uncomplicated biliary colic includes pain control, dietary modification, and consideration of elective cholecystectomy."],"references":["Gurusamy KS, Davidson BR. Gallstones. BMJ 2014; 348:g2669"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"84372"},"links":{"related":"https://app.emedici.com/api/questionRevisions/101916/itemRevision","self":"https://app.emedici.com/api/questionRevisions/101916/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"21439"},"links":{"related":"https://app.emedici.com/api/questionRevisions/101916/question","self":"https://app.emedici.com/api/questionRevisions/101916/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/101916/stemMedia","self":"https://app.emedici.com/api/questionRevisions/101916/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/101916/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/101916/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"84372","links":{"self":"https://app.emedici.com/api/itemRevisions/84372"},"attributes":{"createdAt":"2025-05-05T09:12:09+09:30","updatedAt":"2025-05-05T09:13:12+09:30"},"relationships":{"item":{"data":{"type":"items","id":"14308"},"links":{"related":"https://app.emedici.com/api/itemRevisions/84372/item","self":"https://app.emedici.com/api/itemRevisions/84372/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"101916"},"li