{"data":[{"type":"questionAttempts","id":"17632138","links":{"self":"https://app.emedici.com/api/questionAttempts/17632138"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T17:36:51+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T17:36:51+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17417"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17417","links":{"self":"https://app.emedici.com/api/questions/17417"},"relationships":{"item":{"data":{"type":"items","id":"10107"}},"activeRevision":{"data":{"type":"questionRevisions","id":"70562"}}}},{"type":"items","id":"10107","links":{"self":"https://app.emedici.com/api/items/10107"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17417"}},"activeRevision":{"data":{"type":"itemRevisions","id":"56026"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5362"}]},"contributions":{"data":[{"type":"contributions","id":"23680"},{"type":"contributions","id":"23688"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"70562","links":{"self":"https://app.emedici.com/api/questionRevisions/70562"},"attributes":{"stem":"\u003Cp\u003ERural health outcomes in Australia show consistent disparities when compared with metropolitan areas.\u003C/p\u003E","stemQuestion":"Which one of the following best describes a characteristic feature of rural health in Australia?","responseType":"sba","marks":1,"options":["Lower prevalence of mental health conditions","Greater access to specialist medical services","Higher burden of chronic disease and injury","Higher life expectancy than metropolitan areas","Lower rates of preventable hospitalisations"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EThe correct answer is that rural areas have a \u003Cstrong\u003Ehigher burden of chronic disease and injury\u003C/strong\u003E. This is due to multiple factors including occupational hazards in farming and mining, greater distances to travel, delayed access to healthcare, and higher rates of risk factors such as smoking and obesity.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003ELower prevalence of mental health conditions\u003C/strong\u003E - Rural populations experience higher rates of mental health conditions and suicide, particularly among farmers and Indigenous communities.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EGreater access to specialist medical services\u003C/strong\u003E - Rural and remote communities face significant challenges accessing specialist care, often requiring lengthy travel to metropolitan centres.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EHigher life expectancy than metropolitan areas\u003C/strong\u003E - Life expectancy decreases with increasing remoteness from major cities in Australia.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ELower rates of preventable hospitalisations\u003C/strong\u003E - Preventable hospitalisations occur more frequently in rural areas due to delayed access to primary care and preventive health services.\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThese health disparities are influenced by factors including geographical isolation, socioeconomic disadvantage, workforce shortages, and limited access to healthcare services.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Rural populations generally have poorer health outcomes compared to metropolitan populations due to multiple socioeconomic and healthcare access factors.","Key health challenges in rural areas include higher rates of chronic disease, injury, and mental health conditions.","Rural communities often face barriers to healthcare including distance, limited specialist services, and workforce shortages."],"references":["Shultz JM, Sullivan LM, Galea S. Public Health: An Introduction to the Science and Practice of Population Health. Springer Publishing Company; 2021.","Rural and remote health. Australian Institute of Health and Welfare. Available from: https://www.aihw.gov.au/reports/rural-remote-australians/rural-and-remote-health"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"56026"}},"question":{"data":{"type":"questions","id":"17417"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"56026","links":{"self":"https://app.emedici.com/api/itemRevisions/56026"},"attributes":{"createdAt":"2024-12-15T19:19:39+10:30","updatedAt":"2025-01-04T00:09:14+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10107"}},"content":{"data":{"type":"questionRevisions","id":"70562"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"dat