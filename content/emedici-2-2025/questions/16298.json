{"data":[{"type":"questionAttempts","id":"17613052","links":{"self":"https://app.emedici.com/api/questionAttempts/17613052"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T14:29:49+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T14:29:49+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16298"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"16298","links":{"self":"https://app.emedici.com/api/questions/16298"},"attributes":{"optionProportions":[0.8,0.16,0,0.04,0]},"relationships":{"item":{"data":{"type":"items","id":"8989"}},"activeRevision":{"data":{"type":"questionRevisions","id":"116098"}}}},{"type":"items","id":"8989","links":{"self":"https://app.emedici.com/api/items/8989"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16298"}},"activeRevision":{"data":{"type":"itemRevisions","id":"98094"}},"tags":{"data":[{"type":"tags","id":"7"},{"type":"tags","id":"8"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"1992"},{"type":"tags","id":"4930"},{"type":"tags","id":"4941"},{"type":"tags","id":"4942"},{"type":"tags","id":"5586"},{"type":"tags","id":"7132"},{"type":"tags","id":"7556"},{"type":"tags","id":"7558"},{"type":"tags","id":"10434"}]},"contributions":{"data":[{"type":"contributions","id":"21384"},{"type":"contributions","id":"21388"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"116098","links":{"self":"https://app.emedici.com/api/questionRevisions/116098"},"attributes":{"stem":"\u003Cp\u003EThe optic tract contains visual information from the contralateral visual field after partial decussation of retinal ganglion cell axons at the optic chiasm.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the primary thalamic target of the optic tract?","responseType":"sba","marks":1,"options":["Lateral geniculate nucleus","Medial geniculate nucleus","Pulvinar nucleus","Ventral lateral nucleus","Ventral anterior nucleus"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Elateral geniculate nucleus\u003C/strong\u003E is the primary thalamic relay nucleus for visual information. It receives input from retinal ganglion cells via the optic tract and projects to the primary visual cortex via the optic radiation.\u003C/p\u003E\u003Cp\u003EThe other thalamic nuclei have different functions. The \u003Cstrong\u003Emedial geniculate nucleus\u003C/strong\u003E processes auditory information, while the \u003Cstrong\u003Epulvinar nucleus\u003C/strong\u003E is involved in visual attention but is not the primary relay for the optic tract. The \u003Cstrong\u003Eventral lateral nucleus\u003C/strong\u003E processes motor information from the cerebellum, and the \u003Cstrong\u003Eventral anterior nucleus\u003C/strong\u003E processes motor information from the basal ganglia. The lateral geniculate nucleus has a precise retinotopic organisation, maintaining the spatial relationships of visual information as it is relayed to the cortex.\u003C/p\u003E","optionExplanations":null,"learningPoints":["The lateral geniculate nucleus of the thalamus is the primary relay centre for visual information from the retina to the visual cortex.","The optic tract carries visual information from the contralateral visual field due to partial decussation at the optic chiasm."],"references":["Cohen-Sinai N, Man-Peles I, Zahavi A, Luckman J, Goldenberg-Cohen N. Simplifying the diagnosis of optic tract lesions. Front Med (Lausanne). 2022 Oct 25;9:1029829. doi: 10.3389/fmed.2022.1029829. PMID: 36388882; PMCID: PMC9642808.","Reese BE. Development of the retina and optic pathway. Vision Res. 2011 Apr 13;51(7):613-32. doi: 10.1016/j.visres.2010.07.010. Epub 2010 Jul 18. PMID: 20647017; PMCID: PMC2974959.","Singh, V. (2024). Textbook of Clinical Neuroanatomy-E-Book. Elsevier Health Sciences.","Michael-Titus, A. T., \u0026 Shortland, P. (2022). The Nervous System, E-Book: The Nervous System, E-Book. Elsevier Health Sciences."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"98094"}},"question":{"data":{"type":"questions","id":"16298"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"98094","links":{"self":"https://app.emedici.com/api/itemRevisions/98094"},"attributes":{"createdAt":"2025-09-27T14:41:12+09:30","updatedAt":"2025-09-27T14:47:06+09:30"},"relationships":{"item":{"data":{"type":"items","id":"8989"}},"content":{"data":{"type":"questionRevisions","id":"116098"}}},"meta":{"canDelete":false}},{"type":"tags","id":"7","links":{"self":"https://app.emedici.com/api/tags/7"},"attributes":{"emoji":"\ud83e\udde0","name":"Neurology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"8","links":{"self":"https://app.emedici.com/api/tags/8"},"attributes":{"emoji":"\ud83d\udc41","name":"Ophthalmology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"J