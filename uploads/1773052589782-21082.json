com/api/questions/21082/relationships/activeRevision"}}}},{"type":"items","id":"13957","links":{"self":"https://app.emedici.com/api/items/13957"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/13957/packs","self":"https://app.emedici.com/api/items/13957/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/13957/revisions","self":"https://app.emedici.com/api/items/13957/relationships/revisions"}},"content":{"data":{"type":"questions","id":"21082"},"links":{"related":"https://app.emedici.com/api/items/13957/content","self":"https://app.emedici.com/api/items/13957/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/13957/specialtyTags","self":"https://app.emedici.com/api/items/13957/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/13957/primaryTags","self":"https://app.emedici.com/api/items/13957/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/13957/contributionTypes","self":"https://app.emedici.com/api/items/13957/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/13957/contributors","self":"https://app.emedici.com/api/items/13957/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/13957/contribution","self":"https://app.emedici.com/api/items/13957/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/13957/myContribution","self":"https://app.emedici.com/api/items/13957/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"102395"},"links":{"related":"https://app.emedici.com/api/items/13957/activeRevision","self":"https://app.emedici.com/api/items/13957/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4946"}],"links":{"related":"https://app.emedici.com/api/items/13957/tags","self":"https://app.emedici.com/api/items/13957/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"33677"},{"type":"contributions","id":"53207"}],"links":{"related":"https://app.emedici.com/api/items/13957/contributions","self":"https://app.emedici.com/api/items/13957/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"120798","links":{"self":"https://app.emedici.com/api/questionRevisions/120798"},"attributes":{"stem":"\u003Cp\u003EThe following image shows a cross-section of skeletal muscle tissue under light microscopy with haematoxylin and eosin staining.\u003C/p\u003E","stemQuestion":"Which one of the following structures is correctly identified in skeletal muscle tissue?","responseType":"sba","marks":1,"options":["Perimysium is the connective tissue surrounding fascicles","Epimysium is the connective tissue surrounding blood vessels only","Sarcolemma is the connective tissue between adjacent fascicles","Perimysium is the connective tissue surrounding individual muscle fibres","Endomysium is the thick connective tissue surrounding the entire muscle"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EIn skeletal muscle tissue, \u003Cstrong\u003Eperimysium is the connective tissue surrounding fascicles\u003C/strong\u003E (groups of muscle fibres). This is a key identifying feature in cross-sectional views of skeletal muscle. The perimysium is composed of collagen fibres that appear pink in haematoxylin and eosin staining and forms distinct boundaries around bundles of muscle fibres.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EEndomysium is the thick connective tissue surrounding the entire muscle\u003C/strong\u003E - This is incorrect. Endomysium is actually the delicate connective tissue that surrounds individual muscle fibres, not the entire muscle. The thick connective tissue surrounding the entire muscle is the epimysium.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EPerimysium is the connective tissue surrounding individual muscle fibres\u003C/strong\u003E - This is incorrect. The connective tissue surrounding individual muscle fibres is the endomysium, not the perimysium.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EEpimysium is the connective tissue surrounding blood vessels only\u003C/strong\u003E - This is incorrect. Epimysium is the dense irregular connective tissue that surrounds the entire muscle, not just blood vessels.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ESarcolemma is the connective tissue between adjacent fascicles\u003C/strong\u003E - This is incorrect. Sarcolemma is the cell membrane of muscle fibres, not connective tissue. The connective tissue between adjacent fascicles would be perimysium.\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EIn a cross-section of skeletal muscle, three layers of connective tissue can be identified: epimysium (surrounding the entire muscle), perimysium (surrounding fascicles), and endomysium (surrounding individual muscle fibres).\u003C/p\u003E","optionExplanations":null,"learningPoints":["Skeletal muscle tissue is characterised by striated, multinucleated muscle fibres arranged in fascicles surrounded by connective tissue layers.","Perimysium is the connective tissue layer that surrounds groups of muscle fibres (fascicles) in skeletal muscle.","Endomysium is the delicate connective tissue layer that surrounds individual muscle fibres in skeletal muscle."],"references":["Muscle Tissue: Cross Section Whole Skeletal Muscle. Flikr. Image accessed under CC0 1.0 license: https://creativecommons.org/publicdomain/zero/1.0/. Accessed at: https://www.flickr.com/photos/146824358@N03/28089115828/","Sule N. Histology-skeletal muscle. PathologyOutlines.com website. https://www.pathologyoutlines.com/topic/softtissueskeletalnormal.html. Accessed October 16th, 2025."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"102395"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120798/itemRevision","self":"https://app.emedici.com/api/questionRevisions/120798/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"21082"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120798/question","self":"https://app.emedici.com/api/questionRevisions/120798/relationships/question"}},"stemMedia":{"data":[{"type":"media","id":"21817"}],"links":{"related":"https://app.emedici.com/api/questionRevisions/120798/stemMedia","self":"https://app.emedici.com/api/questionRevisions/120798/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/120798/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/120798/relationships/explanationMedia"}}}},{"type":"media","id":"21817","links":{"self":"https://app.emedici.com/api/media/21817"},"attributes":{"mimeType":"image/jpeg","url":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/IhIs3VulJmwdO4yMHQEAd2RR6nFf1B.jpg","thumbUrl":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/IhIs3VulJmwdO4yMHQEAd2RR6nFf1B.jpg","isProcessed":true,"width":1500,"height":846}},{"type":"itemRevisions","id":"102395","links":{"self":"https://app.emedici.com/api/itemRevisions/102395"},"attributes":{"createdAt":"2025-10-17T12:22:31+10:30","updatedAt":"2025-10-17T12:25:40+10:30"},"relationships":{"item":{"data":{"type":"items","id":"13957"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102395/item","self":"https://app.emedici.com/api/itemRevisions/102395/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"120798"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102395/con