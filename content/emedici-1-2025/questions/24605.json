{"data":[{"type":"questionAttempts","id":"20889714","links":{"self":"https://app.emedici.com/api/questionAttempts/20889714"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-11-07T13:07:32+10:30","options":[1],"response":null,"finalizedAt":"2025-11-07T13:07:32+10:30"},"relationships":{"user":{"data":{"type":"users","id":"56433"},"links":{"related":"https://app.emedici.com/api/questionAttempts/20889714/user","self":"https://app.emedici.com/api/questionAttempts/20889714/relationships/user"}},"questionSession":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889714/questionSession","self":"https://app.emedici.com/api/questionAttempts/20889714/relationships/questionSession"}},"session":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889714/session","self":"https://app.emedici.com/api/questionAttempts/20889714/relationships/session"}},"question":{"data":{"type":"questions","id":"24605"},"links":{"related":"https://app.emedici.com/api/questionAttempts/20889714/question","self":"https://app.emedici.com/api/questionAttempts/20889714/relationships/question"}},"bookmark":{"data":null,"links":{"related":"https://app.emedici.com/api/questionAttempts/20889714/bookmark","self":"https://app.emedici.com/api/questionAttempts/20889714/relationships/bookmark"}}}}],"included":[{"type":"questions","id":"24605","links":{"self":"https://app.emedici.com/api/questions/24605"},"relationships":{"attempts":{"links":{"related":"https://app.emedici.com/api/questions/24605/attempts","self":"https://app.emedici.com/api/questions/24605/relationships/attempts"}},"item":{"data":{"type":"items","id":"17432"},"links":{"related":"https://app.emedici.com/api/questions/24605/item","self":"https://app.emedici.com/api/questions/24605/relationships/item"}},"activeRevision":{"data":{"type":"questionRevisions","id":"119757"},"links":{"related":"https://app.emedici.com/api/questions/24605/activeRevision","self":"https://app.emedici.com/api/questions/24605/relationships/activeRevision"}}}},{"type":"items","id":"17432","links":{"self":"https://app.emedici.com/api/items/17432"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/17432/packs","self":"https://app.emedici.com/api/items/17432/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/17432/revisions","self":"https://app.emedici.com/api/items/17432/relationships/revisions"}},"content":{"data":{"type":"questions","id":"24605"},"links":{"related":"https://app.emedici.com/api/items/17432/content","self":"https://app.emedici.com/api/items/17432/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/17432/specialtyTags","self":"https://app.emedici.com/api/items/17432/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/17432/primaryTags","self":"https://app.emedici.com/api/items/17432/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/17432/contributionTypes","self":"https://app.emedici.com/api/items/17432/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/17432/contributors","self":"https://app.emedici.com/api/items/17432/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/17432/contribution","self":"https://app.emedici.com/api/items/17432/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/17432/myContribution","self":"https://app.emedici.com/api/items/17432/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"101537"},"links":{"related":"https://app.emedici.com/api/items/17432/activeRevision","self":"https://app.emedici.com/api/items/17432/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"24"},{"type":"tags","id":"30"},{"type":"tags","id":"34"},{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"78"},{"type":"tags","id":"1216"},{"type":"tags","id":"1989"},{"type":"tags","id":"1993"},{"type":"tags","id":"4487"},{"type":"tags","id":"4961"},{"type":"tags","id":"4974"},{"type":"tags","id":"4987"},{"type":"tags","id":"5841"},{"type":"tags","id":"6022"},{"type":"tags","id":"12919"}],"links":{"related":"https://app.emedici.com/api/items/17432/tags","self":"https://app.emedici.com/api/items/17432/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"51721"},{"type":"contributions","id":"52677"}],"links":{"related":"https://app.emedici.com/api/items/17432/contributions","self":"https://app.emedici.com/api/items/17432/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"119757","links":{"self":"https://app.emedici.com/api/questionRevisions/119757"},"attributes":{"stem":"\u003Cp\u003EA 14-year-old boy presents to the Emergency Department with a three-hour history of left hand pain after catching a basketball awkwardly during a game. He felt immediate pain and then fell to the ground but does not remember how he landed. He has been unable to make a full fist since the injury. He has no significant medical history and does not take any regular medications.\u003C/p\u003E\u003Cp\u003EOn examination, he appears well with vital signs within normal limits. There is diffuse swelling over the dorsum of the left hand with tenderness along the ulnar aspect. He has difficulty with active flexion of multiple fingers due to pain, and active wrist flexion also reproduces pain. Neurovascular examination is intact.\u003C/p\u003E\u003Cp\u003EA left hand radiograph is obtained (Image).\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Scaphoid fracture","Extensor tendon rupture","Fifth metacarpal neck fracture","Distal radius fracture","Fourth middle phalanx volar plate avulsion fracture"],"correctOptions":[4],"correctResponses":[],"explanation":"\u003Cp\u003EThis patient presents following a basketball injury with hand pain and difficulty making a fist. The radiograph demonstrates a subtle cortical fracture at the volar base of the middle phalanx of the fourth finger with minimal displacement. This type of injury, often called a volar plate avulsion fracture, commonly occurs when the finger is forcefully hyperextended or subjected to axial loading during ball-catching sports. The subsequent fall may have contributed to the diffuse hand swelling and wrist symptoms.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EFourth middle phalanx volar plate avulsion fracture\u003C/strong\u003E is the correct diagnosis. These fractures can be subtle and are often missed on initial assessment, particularly when there is diffuse hand swelling that may distract from the specific site of injury. The pain with wrist flexion likely represents referred pain or secondary soft tissue injury from the fall.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EScaphoid fracture\u003C/strong\u003E is an important differential in any patient with hand pain after a fall or impact. However, the radiograph does not show any cortical disruption or trabecular irregularity in the scaphoid bone. Additionally, scaphoid fractures typically present with anatomical snuffbox tenderness rather than ulnar-sided hand pain.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EFifth metacarpal neck fracture\u003C/strong\u003E (boxer\u0027s fracture) commonly occurs from punching injuries and would present with more localised swelling and tenderness over the fifth metacarpal. The radiograph shows normal alignment and cortical integrity of all metacarpals.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EDistal radius fracture\u003C/strong\u003E is a common paediatric injury that can occur from falls onto an outstretched hand. However, the radiograph shows a normal distal radius with an intact cortex. The lucent line visible at the distal radius represents the normal growth plate (physis) in this 14-year-old patient, not a fracture. Growth plates appear as radiolucent lines on radiographs and should not be mistaken for fractures.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EExtensor tendon rupture\u003C/strong\u003E would not be visible on plain radiographs and typically presents with an inability to actively extend the affected finger at the metacarpophalangeal joint. While the patient has difficulty with flexion due to pain, this is different from the mechanical inability to extend seen with tendon rupture.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Volar plate avulsion fractures at the base of the middle phalanx are commonly missed on initial radiographs, highlighting the importance of having 2 projections at right angles to each other.","These injuries typically occur from hyperextension or axial loading mechanisms during ball sports."],"references":["Radiopaedia. Volar plate avulsion injury. Available at: https://radiopaedia.org/articles/volar-plate-avulsion-injury","RCH. Phalangeal Finger Fractures. Royal Children\u0027s Hospital Clinical Practice Guidelines. Available at: https://www.rch.org.au/clinicalguide/guideline_index/fractures/Phalangeal_Finger_Fractures/","Eddy M. \u0022Hands, fingers, thumbs \u2014 assessment and management of common hand injuries in general practice.\u0022 Australian Family Physician, vol. 41, no. 4, April 2012. Available at: https://www.racgp.org.au/afp/2012/april/hands-fingers-thumbs"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"101537"},"links":{"related":"https://app.emedici.com/api/questionRevisions/119757/itemRevision","self":"https://app.emedici.com/api/questionRevisions/119757/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"24605"},"links":{"related":"https://app.emedici.com/api/questionRevisions/119757/question","self":"https://app.emedici.com/api/questionRevisions/119757/relationships/question"}},"stemMedia":{"data":[{"type":"media","id":"22220"},{"type":"media","id":"22221"},{"type":"media","id":"22222"}],"links":{"related":"https://app.emedici.com/api/questionRevisions/119757/stemMedia","self":"https://app.emedici.com/api/questionRevisions/119757/relationships/stemMedia"}},"explanationMedia":{"data":[{"type":"media","id":"22224"}],"links":{"related":"https://app.emedici.com/api/questionRevisions/119757/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/119757/relationships/explanationMedia"}}}},{"type":"media","id":"22220","links":{"self":"https://app.emedici.com/api/media/22220"},"attributes":{"mimeType":"image/jpeg","url":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/eZK3rOJZ2zS9VTdiFMfk2sYU4s7w3Y.jpg","thumbUrl":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/eZK3rOJZ2zS9VTdiFMfk2sYU4s7w3Y.jpg","isProcessed":true,"width":574,"height":856}},{"type":"media","id":"22221","links":{"self":"https://app.emedici.com/api/media/22221"},"attributes":{"mimeType":"image/jpeg","url":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/cZoIRLCd7uWaeRGINUaHLNrUHYWPwR.jpg","thumbUrl":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/cZoIRLCd7uWaeRGINUaHLNrUHYWPwR.jpg","isProcessed":true,"width":608,"height":850}},{"type":"media","id":"22222","links":{"self":"https://app.emedici.com/api/media/22222"},"attributes":{"mimeType":"image/jpeg","url":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/lzdaK1TtuCS09xnhqkkHymNl0ytiqk.jpg","thumbUrl":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/lzdaK1TtuCS09xnhqkkHymNl0ytiqk.jpg","isProcessed":true,"width":584,"height":864}},{"type":"media","id":"22224","links":{"self":"https://app.emedici.com/api/media/22224"},"attributes":{"mimeType":"image/jpeg","