{"data":[{"type":"questionAttempts","id":"17611140","links":{"self":"https://app.emedici.com/api/questionAttempts/17611140"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T14:08:07+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T14:08:07+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16202"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"16202","links":{"self":"https://app.emedici.com/api/questions/16202"},"relationships":{"item":{"data":{"type":"items","id":"8893"}},"activeRevision":{"data":{"type":"questionRevisions","id":"71522"}}}},{"type":"items","id":"8893","links":{"self":"https://app.emedici.com/api/items/8893"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16202"}},"activeRevision":{"data":{"type":"itemRevisions","id":"57031"}},"tags":{"data":[{"type":"tags","id":"23"},{"type":"tags","id":"25"},{"type":"tags","id":"31"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"152"},{"type":"tags","id":"595"},{"type":"tags","id":"4943"},{"type":"tags","id":"4947"},{"type":"tags","id":"7670"}]},"contributions":{"data":[{"type":"contributions","id":"21164"},{"type":"contributions","id":"21166"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"71522","links":{"self":"https://app.emedici.com/api/questionRevisions/71522"},"attributes":{"stem":"\u003Cp\u003EHealthcare providers often receive questions about when breastfeeding should be discontinued. While breastfeeding is generally encouraged whenever possible, there are some specific medical situations that require cessation.\u003C/p\u003E","stemQuestion":"Which one of the following is an absolute contraindication to breastfeeding?","responseType":"sba","marks":1,"options":["Active chemotherapy treatment","Maternal urinary tract infection","Maternal use of paracetamol","Maternal mastitis infection","Maternal consumption of caffeine"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EActive chemotherapy treatment\u003C/strong\u003E is an absolute contraindication to breastfeeding as these agents can be transferred to the infant through breast milk and cause serious harm. Chemotherapy drugs are designed to kill rapidly dividing cells and could severely affect the developing infant.\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EMaternal urinary tract infection\u003C/strong\u003E can be safely treated with appropriate antibiotics while continuing to breastfeed\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EMaternal use of paracetamol\u003C/strong\u003E is considered safe during breastfeeding\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EMaternal mastitis infection\u003C/strong\u003E should be treated but continuing to breastfeed is recommended to help resolve the infection\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EMaternal consumption of caffeine\u003C/strong\u003E in moderate amounts is compatible with breastfeeding\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EOther absolute contraindications to breastfeeding include maternal HIV infection in developed countries, active tuberculosis until treated, human T-cell lymphotropic virus, and maternal substance abuse.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Most medications are compatible with breastfeeding, but chemotherapy, radioactive compounds, and drugs of abuse are absolute contraindications.","Common infections like mastitis or nipple thrush can be treated while continuing breastfeeding.","Maternal dietary restrictions or common medications rarely require cessation of breastfeeding."],"references":["Whitburn S. Breastfeeding: Expressing and supplementing. Australian Journal of General Practice. 2022 Mar 1;51(3):112\u20135."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"57031"}},"question":{"data":{"type":"questions","id":"16202"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"57031","links":{"self":"https://app.emedici.com/api/itemRevisions/57031"},"attributes":{"createdAt":"2024-12-19T04:27:37+10:30","updatedAt":"2025-01-04T08:41:09+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8893"}},"content":{"data":{"type":"questionRevisions","id":"71522"}}},"meta":{"canDelete":false}},{"type":"tags","id":"23","links":{"self":"https://app.emedici.com/api/tags/23"},"attributes":{"emoji":"\ud83e\udd30","name":"Obstetrics","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"3"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"31","links":{"self":"https://app.emedici.com/api/tags/31"},"attributes":{"emoji":"\ud83c\udf97","name":"Oncology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":