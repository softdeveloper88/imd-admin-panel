ype":"sba","marks":1,"options":["Clinical hyperandrogenism and obesity","Clinical hyperandrogenism and ovulatory dysfunction","Biochemical hyperandrogenism and insulin resistance","Ovulatory dysfunction and obesity","Clinical hyperandrogenism and acanthosis nigricans"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EThe Rotterdam criteria for diagnosing polycystic ovarian syndrome require two of three features:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003EOvulatory dysfunction (oligo-ovulation or anovulation)\u003C/li\u003E\u003Cli\u003EClinical or biochemical evidence of hyperandrogenism\u003C/li\u003E\u003Cli\u003EPolycystic ovaries on ultrasound\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003E\u003Cstrong\u003EClinical hyperandrogenism\u003C/strong\u003E and \u003Cstrong\u003Eovulatory dysfunction\u003C/strong\u003E represent two of these diagnostic criteria. \u003Cstrong\u003EBiochemical hyperandrogenism\u003C/strong\u003E is an alternative to clinical signs but not an additional criterion. While \u003Cstrong\u003Eobesity\u003C/strong\u003E and \u003Cstrong\u003Eacanthosis nigricans\u003C/strong\u003E are common in PCOS, they are not part of the diagnostic criteria. Insulin resistance, while common, is also not a diagnostic criterion.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Polycystic ovarian syndrome is diagnosed using the Rotterdam criteria: ovulatory dysfunction, clinical or biochemical hyperandrogenism, and polycystic ovaries on ultrasound (2 of 3 required)","Clinical hyperandrogenism manifests as hirsutism, acne, and androgenic alopecia"],"references":["Arulkumaran, S., Ledger, W., Denny, L., \u0026 Doumouchtsis, S. (Eds.). (2019). Oxford Textbook of Obstetrics and Gynaecology. Oxford University Press","Witchel SF, Oberfield SE, Pe\u00f1a AS. Polycystic Ovary Syndrome: Pathophysiology, Presentation, and Treatment With Emphasis on Adolescent Girls. J Endocr Soc. 2019 Jun 14;3(8):1545-1573. doi: 10.1210/js.2019-00078. PMID: 31384717; PMCID: PMC6676075","Padubidri, V. G., \u0026 Daftary, S. N. (Eds.). (2014). Shaw\u0027s Textbook of Gynecology E-book. Elsevier health sciences","Singh S, Pal N, Shubham S, Sarma DK, Verma V, Marotta F, Kumar M. Polycystic Ovary Syndrome: Etiology, Current Management, and Future Therapeutics. J Clin Med. 2023 Feb 11;12(4):1454. doi: 10.3390/jcm12041454. PMID: 36835989; PMCID: PMC9964744"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"48334"}},"question":{"data":{"type":"questions","id":"15726"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"48334","links":{"self":"https://app.emedici.com/api/itemRevisions/48334"},"attributes":{"createdAt":"2024-11-19T08:28:09+10:30","updatedAt":"2024-11-19T08:29:07+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8417"}},"content":{"data":{"type":"questionRevisions","id":"62884"}}},"meta":{"canDelete":false}},{"type":"tags","id":"4","links":{"self":"https://app.emedici.com/api/tags/4"},"attributes":{"emoji":"\ud83c\udf6c","name":"Endocrinology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"22","links":{"self":"https://app.emedici.com/api/tags/22"},"attributes":{"emoji":"\ud83c\udf53","name":"Gynaecology","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"3"}}},"meta":{"itemCount":0}},{"type":"tags","id":"64","links":{"self":"https://app.emedici.com/api/tags/64"},"attributes":{"emoji":"","name":"Diagnosis","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":nul