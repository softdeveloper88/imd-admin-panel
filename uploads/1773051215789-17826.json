{"data":[{"type":"questionAttempts","id":"17640385","links":{"self":"https://app.emedici.com/api/questionAttempts/17640385"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T19:16:58+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T19:16:58+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17826"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17826","links":{"self":"https://app.emedici.com/api/questions/17826"},"attributes":{"optionProportions":[0.83,0.04,0.04,0.09,0]},"relationships":{"item":{"data":{"type":"items","id":"10540"}},"activeRevision":{"data":{"type":"questionRevisions","id":"75178"}}}},{"type":"items","id":"10540","links":{"self":"https://app.emedici.com/api/items/10540"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17826"}},"activeRevision":{"data":{"type":"itemRevisions","id":"60686"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4947"},{"type":"tags","id":"5631"},{"type":"tags","id":"5749"}]},"contributions":{"data":[{"type":"contributions","id":"24584"},{"type":"contributions","id":"25020"},{"type":"contributions","id":"26001"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"75178","links":{"self":"https://app.emedici.com/api/questionRevisions/75178"},"attributes":{"stem":"\u003Cp\u003EOpen disclosure is an important ethical and professional responsibility in healthcare that promotes transparency and maintains trust between healthcare providers and patients.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the essential first step in this process?","responseType":"sba","marks":1,"options":["Acknowledgment of the adverse event and expression of regret","Investigation of root causes","Consultation with medical defence organisation","Development of a detailed action plan","Documentation in medical records"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThe essential first step in open disclosure is \u003Cstrong\u003Eacknowledgment of the adverse event and expression of regret\u003C/strong\u003E. This demonstrates respect for the patient\u0027s right to know about their healthcare and helps maintain trust in the therapeutic relationship.\u003C/p\u003E    \u003Cp\u003EThe incorrect options represent important but secondary steps:\u003C/p\u003E    \u003Cul\u003E        \u003Cli\u003E\u003Cstrong\u003EInvestigation of root causes\u003C/strong\u003E occurs after the initial disclosure and involves a systematic analysis to understand how the event occurred.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EConsultation with medical defence organisation\u003C/strong\u003E may be necessary for serious events but should not delay the immediate acknowledgment to the patient.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EDevelopment of a detailed action plan\u003C/strong\u003E follows the initial discussion and focuses on preventing similar events in the future.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EDocumentation in medical records\u003C/strong\u003E is crucial but should occur alongside rather than before the disclosure conversation.\u003C/li\u003E    \u003C/ul\u003E    \u003Cp\u003EOpen disclosure should occur as soon as possible after an adverse event is identified. The process includes expressing regret, providing a factual explanation of what occurred, describing the potential consequences, and outlining steps to prevent recurrence.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Open disclosure is the process of open discussion with patients about adverse events that occurred during their healthcare.","Key elements of open disclosure include an apology, factual explanation, consequences, and planned improvements.","Open disclosure should occur as soon as possible after an adverse event is identified."],"references":["Open disclosure. Australian Commission on Safety and Quality in Healthcare. Available from: https://www.safetyandquality.gov.au/our-work/clinical-governance/open-disclosure#:~:text=Open%20disclosure%20is%20the%20open,\u0027%20or%20\u0027we%20are%20sorry\u0027"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"60686"}},"question":{"data":{"type":"questions","id":"17826"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"60686","links":{"self":"https://app.emedici.com/api/itemRevisions/60686"},"attributes":{"createdAt":"2024-12-29T09:20:53+10:30","updatedAt":"2024-12-29T09:21:29+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10540"}},"content":{"data":{"type":"questionRevisions","id":"75178"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"