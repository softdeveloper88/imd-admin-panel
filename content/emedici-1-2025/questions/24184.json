com/api/questions/24184/relationships/activeRevision"}}}},{"type":"items","id":"17039","links":{"self":"https://app.emedici.com/api/items/17039"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/17039/packs","self":"https://app.emedici.com/api/items/17039/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/17039/revisions","self":"https://app.emedici.com/api/items/17039/relationships/revisions"}},"content":{"data":{"type":"questions","id":"24184"},"links":{"related":"https://app.emedici.com/api/items/17039/content","self":"https://app.emedici.com/api/items/17039/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/17039/specialtyTags","self":"https://app.emedici.com/api/items/17039/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/17039/primaryTags","self":"https://app.emedici.com/api/items/17039/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/17039/contributionTypes","self":"https://app.emedici.com/api/items/17039/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/17039/contributors","self":"https://app.emedici.com/api/items/17039/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/17039/contribution","self":"https://app.emedici.com/api/items/17039/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/17039/myContribution","self":"https://app.emedici.com/api/items/17039/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"98842"},"links":{"related":"https://app.emedici.com/api/items/17039/activeRevision","self":"https://app.emedici.com/api/items/17039/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"9"},{"type":"tags","id":"24"},{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"1288"},{"type":"tags","id":"1993"},{"type":"tags","id":"2341"},{"type":"tags","id":"2356"},{"type":"tags","id":"2706"},{"type":"tags","id":"3062"},{"type":"tags","id":"3343"},{"type":"tags","id":"8848"},{"type":"tags","id":"11539"},{"type":"tags","id":"12919"},{"type":"tags","id":"13209"}],"links":{"related":"https://app.emedici.com/api/items/17039/tags","self":"https://app.emedici.com/api/items/17039/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"50474"},{"type":"contributions","id":"53215"}],"links":{"related":"https://app.emedici.com/api/items/17039/contributions","self":"https://app.emedici.com/api/items/17039/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"116854","links":{"self":"https://app.emedici.com/api/questionRevisions/116854"},"attributes":{"stem":"\u003Cp\u003EA 16-year-old girl presents to the Emergency Department with her parents with a three-hour history of confusion and seeing things that are not there. She was at a party earlier in the evening and her friends report she may have taken an unknown substance. She has no significant medical history and does not take any regular medications. She is in year 11 at high school.\u003C/p\u003E\u003Cp\u003EOn examination, she appears anxious and is describing vivid visual hallucinations of colours and patterns. Her pulse rate is 115/min, blood pressure 145/90 mmHg, respiratory rate 22/min, SpO2 99% on room air, and temperature 37.9\u00b0C. Her pupils are 7 mm bilaterally and reactive to light. She is oriented to person but not to time or place. Cardiovascular and respiratory examinations are otherwise normal. There are no focal neurological signs.\u003C/p\u003E","stemQuestion":"Which one of the following toxidromes is most consistent with this presentation?","responseType":"sba","marks":1,"options":["Anticholinergic toxidrome","Sympathomimetic toxidrome","Hallucinogen toxidrome","Serotonin syndrome","Opioid toxidrome"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient presents with a constellation of signs and symptoms consistent with hallucinogen intoxication. The key features that point to this diagnosis include mydriasis (dilated pupils), mild tachycardia and hypertension, slight temperature elevation, and most characteristically, vivid visual hallucinations with altered mental state. Hallucinogens such as lysergic acid diethylamide (LSD), psilocybin, and synthetic compounds are unfortunately encountered in adolescent populations, particularly in party settings.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EHallucinogen toxidrome\u003C/strong\u003E is characterised by the combination of sympathetic activation (tachycardia, hypertension, mydriasis, mild hyperthermia) along with perceptual disturbances including visual hallucinations, synaesthesia, and altered sense of time. Patients typically remain conscious but may be disoriented. The visual hallucinations are often described as geometric patterns, bright colours, or visual distortions.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAnticholinergic toxidrome\u003C/strong\u003E shares some features with hallucinogen toxidrome, including mydriasis, tachycardia, and confusion. However, anticholinergic toxicity typically presents with dry, flushed skin, urinary retention, decreased bowel sounds, and delirium rather than formed visual hallucinations. The classic mnemonic is \u0022hot as a hare, blind as a bat, dry as a bone, red as a beet, mad as a hatter.\u0022\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESympathomimetic toxidrome\u003C/strong\u003E can present with similar vital sign abnormalities (tachycardia, hypertension, hyperthermia, mydriasis) but is typically associated with agitation, diaphoresis, and tremor rather than the prominent visual hallucinations seen in this case. Substances causing this toxidrome include amphetamines and cocaine.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESerotonin syndrome\u003C/strong\u003E presents with the triad of altered mental state, autonomic dysfunction, and neuromuscular abnormalities. Key distinguishing features include hyperreflexia, clonus, and muscle rigidity, which are not present in this patient. Additionally, serotonin syndrome typically occurs in the context of serotonergic medication use.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EOpioid toxidrome\u003C/strong\u003E presents with the classic triad of decreased consciousness, respiratory depression, and miosis (constricted pupils). This is clearly inconsistent with this patient\u0027s presentation of mydriasis, normal respiratory rate, and visual hallucinations.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Hallucinogen toxidrome is characterised by mydriasis, tachycardia, hypertension, hyperthermia, and altered mental state with hallucinations.","Benzodiazepines are the first-line treatment for agitation in hallucinogen intoxication in children."],"references":["The Royal Children\u0027s Hospital Melbourne. Toxidromes and poisoning. Clinical Practice Guidelines. Available at: https://www.rch.org.au/clinicalguide/guideline_index/Toxidromes_poisoning/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"98842"},"links":{"related":"https://app.emedici.com/api/questionRevisions/116854/itemRevision","self":"https://app.emedici.com/api/questionRevisions/116854/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"24184"},"links":{"related":"https://app.emedici.com/api/questionRevisions/116854/question","self":"https://app.emedici.com/api/questionRevisions/116854/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/116854/stemMedia","self":"https://app.emedici.com/api/questionRevisions/116854/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/116854/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/116854/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"98842","links":{"self":"https://app.emedici.com/api/itemRevisions/98842"},"attributes":{"createdAt":"2025-09-30T20:38:25+09:30","updatedAt":"2025-09-30T20:41:56+09:30"},"relationships":{"item":{"data":{"type":"items","id":"17039"},"links":{"related":"https://app.emedici.com/api/itemRevisions/98842/item","self":"https://app.emedici.com/api/itemRevisions/98842/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"116854"},"links":{"related":"https://app.emedici.com/api/itemRevisions/98842/content","self":"https://app.emedici.com/api/itemRevisions/98842/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"9","links":{"self":"https://app.emedici.com/api/tags/9"},"attributes":{"emoji":"\ud83d\udc76","name":"Paediatrics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:39:03+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/9/group","self":"https://app.emedici.com/api/tags/9/relationships/group"}},"heading":{"data":{"type":"tagHeadings","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/9/heading","self":"https://app.emedici.com/api/tags/9/relationships/heading"}},"ancestors":{"links":{"related":"https://app.emedici.com/api/tags/9/ancestors","self":"https://app.emedici.com/api/tags/9/relationships/ancestors"}},"parents":{"links":{"related":"https://app.emedici.com/api/tags/9/parents","self":"https://app.emedici.com/api/tags/9/relationships/parents"}},"children":{"links":{"related":"https://app.emedici.com/api/tags/9/children","self":"https://app.emedici.com/api/tags/9/relationships/children"}},"descendants":{"links":{"related":"https://app.emedici.com