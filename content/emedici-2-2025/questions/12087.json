{"data":[{"type":"questionAttempts","id":"17513366","links":{"self":"https://app.emedici.com/api/questionAttempts/17513366"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T13:08:48+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T13:08:48+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"12087"}},"bookmark":{"data":null}}},{"type":"questionAttempts","id":"17583633","links":{"self":"https://app.emedici.com/api/questionAttempts/17583633"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T07:22:10+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T07:22:10+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"12087"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"12087","links":{"self":"https://app.emedici.com/api/questions/12087"},"attributes":{"optionProportions":[0.11,0.07,0.12,0.07,0.64]},"relationships":{"item":{"data":{"type":"items","id":"4640"}},"activeRevision":{"data":{"type":"questionRevisions","id":"86561"}}}},{"type":"items","id":"4640","links":{"self":"https://app.emedici.com/api/items/4640"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"12087"}},"activeRevision":{"data":{"type":"itemRevisions","id":"70843"}},"tags":{"data":[{"type":"tags","id":"14"},{"type":"tags","id":"23"},{"type":"tags","id":"25"},{"type":"tags","id":"29"},{"type":"tags","id":"66"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"152"},{"type":"tags","id":"2967"},{"type":"tags","id":"4943"},{"type":"tags","id":"4947"},{"type":"tags","id":"4966"},{"type":"tags","id":"4969"},{"type":"tags","id":"4980"},{"type":"tags","id":"4985"},{"type":"tags","id":"5771"},{"type":"tags","id":"6442"},{"type":"tags","id":"11625"},{"type":"tags","id":"11634"},{"type":"tags","id":"11644"}]},"contributions":{"data":[{"type":"contributions","id":"7049"},{"type":"contributions","id":"7098"},{"type":"contributions","id":"10782"},{"type":"contributions","id":"11150"},{"type":"contributions","id":"13415"},{"type":"contributions","id":"28927"},{"type":"contributions","id":"29756"},{"type":"contributions","id":"33417"},{"type":"contributions","id":"43291"},{"type":"contributions","id":"44372"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"86561","links":{"self":"https://app.emedici.com/api/questionRevisions/86561"},"attributes":{"stem":"\u003Cp\u003EA 24-year-old woman presents to the General Practice clinic with a two-day history of burning when passing urine and urinary frequency. She reports mild suprapubic pain. She is nine weeks pregnant. She has no significant medical history and takes only pregnancy multivitamins.\u003C/p\u003E\u003Cp\u003EOn examination, she appears well. Her pulse rate is 88/min, blood pressure 120/70 mmHg, respiratory rate 14/min, SpO2 99% on room air, and temperature 37.5\u00b0C. There is mild suprapubic tenderness but no costovertebral angle tenderness. Urinalysis shows leukocytes and nitrites.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate empirical antibiotic?","responseType":"sba","marks":1,"options":["Trimethoprim","Amoxicillin","Amoxicillin with clavulanic acid","Trimethoprim with sulfamethoxazole","Nitrofurantoin"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient presents with symptoms and signs consistent with an uncomplicated urinary tract infection (cystitis) in early pregnancy. The presence of leukocytes and nitrites on urinalysis supports this diagnosis.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ENitrofurantoin\u003C/strong\u003E is the first-line empirical antibiotic for uncomplicated urinary tract infections in pregnancy before 37 weeks gestation. It has good coverage against common uropathogens including \u003Cem\u003EEscherichia coli\u003C/em\u003E. It should be avoided at term (\u226537 weeks) due to the risk of neonatal haemolysis and jaundice.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ETrimethoprim\u003C/strong\u003E is contraindicated in the first trimester of pregnancy due to its association with neural tube defects and other congenital anomalies. While it is an appropriate choice in non-pregnant women, the risks outweigh the benefits in early pregnancy.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAmoxicillin\u003C/strong\u003E can be used for urinary tract infections in pregnancy, but only after culture confirms susceptibility. The high prevalence of amoxicillin resistance makes it unsuitable for empirical therapy.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ETrimethoprim with sulfamethoxazole\u003C/strong\u003E is contraindicated throughout pregnancy due to the risk of neural tube defects from trimethoprim and the risk of kernicterus from sulfamethoxazole near term.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAmoxicillin with clavulanic acid\u003C/strong\u003E is unnecessarily broad-spectrum for uncomplicated urinary tract infections. While safe in pregnancy, it should be reserved for culture-directed therapy or complicated infections.\u003C/p\u003E\u003Cp\u003ECefalexin is an alternative first-line option for urinary tract infections in pregnancy when nitrofurantoin is contraindicated or not tolerated.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Nitrofurantoin is first-line empirical therapy for uncomplicated urinary tract infection in pregnancy before 37 weeks gestation","Trimethoprim should be avoided in first trimester pregnancy due to risk of congenital anomalies","Amoxicillin is an appropriate option once culture susceptibility is confirmed"],"references":["Flores-Mireles AL, Walker JN, Caparon M, Hultgren SJ. Urinary tract infections: epidemiology, mechanisms of infection and treatment options. Nature Reviews Microbiology. 2015;13(5):269-84. Available at: https://www.nature.com/articles/nrmicro3432#citeas","Jarvis TR, Chan L, Gottlieb T. Assessment and management of lower urinary tract infection in adults. Aust Prescr 2014;37:7-9. Available at: https://doi.org/10.18773/austprescr.2014.002","Urinary tract infection and bacteriuria in pregnancy. In: Therapeutic Guidelines. Melbourne: Therapeutic Guidelines Limited; accessed {22 Feb 2025}. Available at: https://tgldcdp.tg.org.au/etgcomplete"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"70843"}},"question":{"data":{"type":"questions","id":"12087"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"70843","links":{"self":"https://app.emedici.com/api/itemRevisions/70843"},"attributes":{"createdAt":"2025-02-22T14:26:34+10:30","updatedAt":"2025-02-22T14:27:27+10:30"},"relationships":{"item":{"data":{"type":"items","id":"4640"}},"content":{"data":{"type":"questionRevisions","id":"86561"}}},"meta":{"canDelete":false}},{"type":"tags","id":"14","links":{"self":"https://app.emedici.com/api/tags/14"},"attributes":{"emoji":"\ud83e\udda0","name":"Infectious Diseases","synonyms":["ID"],"description":null,"position":null,"createdAt":null,"updatedAt":"2021-05-21T07:51:58+09:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"23","links":{"self":"https://app.emedici.com/api/tags/23"},"attributes":{"emoji":"\ud83e\udd30","name":"Obstetrics","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"3"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u