{"data":[{"type":"questionAttempts","id":"17599085","links":{"self":"https://app.emedici.com/api/questionAttempts/17599085"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T11:49:01+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T11:49:01+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15523"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15523","links":{"self":"https://app.emedici.com/api/questions/15523"},"attributes":{"optionProportions":[0.23,0.11,0.11,0.51,0.03]},"relationships":{"item":{"data":{"type":"items","id":"8214"}},"activeRevision":{"data":{"type":"questionRevisions","id":"61726"}}}},{"type":"items","id":"8214","links":{"self":"https://app.emedici.com/api/items/8214"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15523"}},"activeRevision":{"data":{"type":"itemRevisions","id":"47172"}},"tags":{"data":[{"type":"tags","id":"2"},{"type":"tags","id":"11"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"1880"},{"type":"tags","id":"2282"},{"type":"tags","id":"2593"},{"type":"tags","id":"2598"},{"type":"tags","id":"2602"},{"type":"tags","id":"4927"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"8133"}]},"contributions":{"data":[{"type":"contributions","id":"19870"},{"type":"contributions","id":"19873"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"61726","links":{"self":"https://app.emedici.com/api/questionRevisions/61726"},"attributes":{"stem":"\u003Cp\u003EPulmonary hypertension is defined as elevated pressure in the pulmonary circulation. Various diagnostic tests can be used to evaluate this condition.\u003C/p\u003E","stemQuestion":"Which one of the following is the gold standard investigation to confirm the diagnosis of pulmonary hypertension?","responseType":"sba","marks":1,"options":["Ventilation-perfusion scan","Computed tomography pulmonary angiogram","Transthoracic echocardiography","Right heart catheterisation","Polysomnography"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003ERight heart catheterisation\u003C/strong\u003E is the gold standard diagnostic test for pulmonary hypertension. It provides direct measurement of pulmonary arterial pressure, with a mean pulmonary arterial pressure \u0026gt;20 mmHg at rest confirming the diagnosis.\u003C/p\u003E        \u003Cp\u003EWhile \u003Cstrong\u003Etransthoracic echocardiography\u003C/strong\u003E can estimate pulmonary pressures and is an excellent screening tool, it may be inaccurate in some cases. \u003Cstrong\u003EComputed tomography pulmonary angiogram\u003C/strong\u003E and \u003Cstrong\u003Eventilation-perfusion scan\u003C/strong\u003E are useful to identify chronic thromboembolic pulmonary hypertension but cannot confirm the diagnosis. \u003Cstrong\u003EPolysomnography\u003C/strong\u003E may identify sleep-disordered breathing as a contributing factor but does not diagnose pulmonary hypertension directly.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Right heart catheterisation is the gold standard diagnostic test for pulmonary hypertension, defined as mean pulmonary arterial pressure \u003E20 mmHg at rest.","Right heart catheterisation allows direct measurement of pulmonary pressures and helps classify the type of pulmonary hypertension."],"references":["D\u0027Alto M, Dimopoulos K, Coghlan JG, Kovacs G, Rosenkranz S, Naeije R. Right Heart Catheterization for the Diagnosis of Pulmonary Hypertension: Controversies and Practical Issues. Heart Fail Clin. 2018 Jul;14(3):467-477. doi: 10.1016/j.hfc.2018.03.011. PMID: 29966642.","Chokkalingam Mani B, Chaudhari SS. Right Heart Cardiac Catheterization. [Updated 2023 Apr 7]. In: StatPearls [Internet]. Treasure Island (FL): StatPearls Publishing; 2024 Jan-. Available from: https://www.ncbi.nlm.nih.gov/books/NBK557404/","Rosenkranz S, Preston IR. Right heart catheterisation: best practice and pitfalls in pulmonary hypertension. Eur Respir Rev. 2015 Dec;24(138):642-52. doi: 10.1183/16000617.0062-2015. PMID: 26621978; PMCID: PMC9487613.","Mason, R. J., Broaddus, V. C., Martin, T. R., King, T. E., Schraufnagel, D., Murray, J. F., \u0026 Nadel, J. A. (2010). Murray and Nadel\u0027s textbook of respiratory medicine E-book: 2-volume set. Elsevier Health Sciences."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"47172"}},"question":{"data":{"type":"questions","id":"15523"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"47172","links":{"self":"https://app.emedici.com/api/itemRevisions/47172"},"attributes":{"createdAt":"2024-11-16T11:38:53+10:30","updatedAt":"2024-11-16T11:39:42+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8214"}},"content":{"data":{"type":"questionRevisions","id":"61726"}}},"meta":{"canDelete":false}},{"type":"tags","id":"2","links":{"self":"https://app.emedici.com/api/tags/2"},"attributes":{"emoji":"\ud83e\udec0","name":"Cardiology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:21+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"11","links":{"self":"https://app.emedici.com/api/tags/11"},"attributes":{"emoji":"\ud83e\udec1","name":"Respiratory Medicine","synonyms":["Pulmonology"],"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji"