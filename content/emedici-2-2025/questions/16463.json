{"data":[{"type":"questionAttempts","id":"17617257","links":{"self":"https://app.emedici.com/api/questionAttempts/17617257"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T15:11:57+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T15:11:57+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16463"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"16463","links":{"self":"https://app.emedici.com/api/questions/16463"},"attributes":{"optionProportions":[0.05,0.05,0.05,0.72,0.13]},"relationships":{"item":{"data":{"type":"items","id":"9154"}},"activeRevision":{"data":{"type":"questionRevisions","id":"66190"}}}},{"type":"items","id":"9154","links":{"self":"https://app.emedici.com/api/items/9154"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16463"}},"activeRevision":{"data":{"type":"itemRevisions","id":"51639"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4929"},{"type":"tags","id":"4934"},{"type":"tags","id":"4942"},{"type":"tags","id":"4943"},{"type":"tags","id":"4946"},{"type":"tags","id":"5119"},{"type":"tags","id":"8498"}]},"contributions":{"data":[{"type":"contributions","id":"21736"},{"type":"contributions","id":"21756"},{"type":"contributions","id":"22139"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"66190","links":{"self":"https://app.emedici.com/api/questionRevisions/66190"},"attributes":{"stem":"\u003Cp\u003ETestosterone is the primary male sex hormone responsible for development and maintenance of male sexual characteristics.\u003C/p\u003E","stemQuestion":"Which one of the following is the primary site of testosterone synthesis in men?","responseType":"sba","marks":1,"options":["Prostate gland","Seminiferous tubules","Adrenal cortex","Leydig cells of testes","Sertoli cells of testes"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003ELeydig cells of the testes\u003C/strong\u003E are the primary site of testosterone synthesis in men, producing about 95% of circulating testosterone. These cells respond to luteinising hormone from the anterior pituitary to produce testosterone.\u003C/p\u003E\u003Cp\u003EThe other options are incorrect, and explained below:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EThe \u003Cstrong\u003Eprostate gland\u003C/strong\u003E is a target organ for testosterone action but does not synthesise it.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EThe \u003Cstrong\u003Eseminiferous tubules\u003C/strong\u003E are involved in sperm production but not testosterone synthesis.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EThe \u003Cstrong\u003Eadrenal cortex\u003C/strong\u003E produces small amounts of androgens, but is not the primary source of testosterone.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EThe \u003Cstrong\u003ESertoli cells\u003C/strong\u003E support spermatogenesis but do not produce significant amounts of testosterone.\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003ETestosterone production is regulated by the hypothalamic-pituitary-gonadal axis. Once synthesised, testosterone can act directly or be converted to dihydrotestosterone by 5-alpha reductase in target tissues.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Testosterone is primarily synthesised in Leydig cells of the testes under control of luteinising hormone.","Testosterone acts through nuclear androgen receptors to promote male sexual development and maintain secondary sex characteristics.","Dihydrotestosterone is formed from testosterone by 5-alpha reductase and is more potent at androgen receptors."],"references":["Ritter J, Flower RJ (Rod J), Henderson G (Graeme), et al.\u00a0Rang and Dale\u2019s Pharmacology. Tenth edition. Elsevier; 2024."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"51639"}},"question":{"data":{"type":"questions","id":"16463"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"51639","links":{"self":"https://app.emedici.com/api/itemRevisions/51639"},"attributes":{"createdAt":"2024-11-29T14:38:47+10:30","updatedAt":"2024-11-29T14:39:01+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9154"}},"content":{"data":{"type":"questionRevisions","id":"66190"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4929","links":{"self":"https://app.emedici.com/api/tags/4929"},"attributes":{"emoji":"\ud83c\udf6d","name":"Endocrine","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-10-31T09:50:27+10:30"},"relationships":{"group":{"data":{"type":"t