{"data":[{"type":"questionAttempts","id":"17633501","links":{"self":"https://app.emedici.com/api/questionAttempts/17633501"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T17:54:06+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T17:54:06+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17483"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17483","links":{"self":"https://app.emedici.com/api/questions/17483"},"attributes":{"optionProportions":[0.95,0,0,0.05,0]},"relationships":{"item":{"data":{"type":"items","id":"10173"}},"activeRevision":{"data":{"type":"questionRevisions","id":"70725"}}}},{"type":"items","id":"10173","links":{"self":"https://app.emedici.com/api/items/10173"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17483"}},"activeRevision":{"data":{"type":"itemRevisions","id":"56191"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5536"}]},"contributions":{"data":[{"type":"contributions","id":"23776"},{"type":"contributions","id":"23784"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"70725","links":{"self":"https://app.emedici.com/api/questionRevisions/70725"},"attributes":{"stem":"\u003Cp\u003EHealthcare funding in Australia involves multiple systems working together to provide universal coverage for citizens and permanent residents.\u003C/p\u003E","stemQuestion":"Which one of the following best describes Medicare in Australia?","responseType":"sba","marks":1,"options":["A universal public health insurance system","A healthcare system only for pensioners","A voluntary contribution scheme","A private health insurance scheme","A scheme exclusively for hospital services"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EMedicare is a \u003Cstrong\u003Euniversal public health insurance system\u003C/strong\u003E that provides access to essential healthcare services for all Australian citizens and permanent residents. It is funded through general taxation and a Medicare levy.\u003C/p\u003E    \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E    \u003Cul\u003E        \u003Cli\u003EMedicare is not \u003Cstrong\u003Ea healthcare system only for pensioners\u003C/strong\u003E, as it provides universal coverage to all eligible residents regardless of age or pension status.\u003C/li\u003E        \u003Cli\u003EMedicare is not \u003Cstrong\u003Ea voluntary contribution scheme\u003C/strong\u003E, as it is a compulsory system that automatically covers eligible residents.\u003C/li\u003E        \u003Cli\u003EMedicare is not \u003Cstrong\u003Ea private health insurance scheme\u003C/strong\u003E, but rather a public system that operates separately from private health insurance.\u003C/li\u003E        \u003Cli\u003EMedicare is not \u003Cstrong\u003Ea scheme exclusively for hospital services\u003C/strong\u003E, as it covers a broad range of healthcare services including general practice visits, specialist consultations and diagnostic tests.\u003C/li\u003E    \u003C/ul\u003E    \u003Cp\u003EMedicare provides benefits for medical services listed in the Medicare Benefits Schedule (MBS) and subsidised medications through the Pharmaceutical Benefits Scheme (PBS). It ensures universal access to essential healthcare regardless of ability to pay.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Medicare is Australia\u0027s universal public health insurance scheme that provides free or subsidised healthcare to all citizens and permanent residents.","The Medicare Benefits Schedule (MBS) lists medical services that are subsidised by the Australian Government.","The Pharmaceutical Benefits Scheme (PBS) provides subsidised prescription medications to Medicare card holders."],"references":["Duckett S. Expanding the breadth of Medicare: learning from Australia. Health Econ Policy Law. 2018;13(3-4):344-368. doi:10.1017/S1744133117000421"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"56191"}},"question":{"data":{"type":"questions","id":"17483"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"56191","links":{"self":"https://app.emedici.com/api/itemRevisions/56191"},"attributes":{"createdAt":"2024-12-16T13:33:23+10:30","updatedAt":"2024-12-16T13:34:41+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10173"}},"content":{"data":{"type":"questionRevisions","id":"70725"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"5326","links":{"self":"https://app.emedici.com/api/tags/5326"},"attributes":{"emoji":"\ud83c\udf0f","name":"Public Health","synonyms":null,"description":nu