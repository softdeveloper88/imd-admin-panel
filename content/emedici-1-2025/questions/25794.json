com/api/questions/25794/relationships/activeRevision"}}}},{"type":"items","id":"18629","links":{"self":"https://app.emedici.com/api/items/18629"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/18629/packs","self":"https://app.emedici.com/api/items/18629/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/18629/revisions","self":"https://app.emedici.com/api/items/18629/relationships/revisions"}},"content":{"data":{"type":"questions","id":"25794"},"links":{"related":"https://app.emedici.com/api/items/18629/content","self":"https://app.emedici.com/api/items/18629/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/18629/specialtyTags","self":"https://app.emedici.com/api/items/18629/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/18629/primaryTags","self":"https://app.emedici.com/api/items/18629/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/18629/contributionTypes","self":"https://app.emedici.com/api/items/18629/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/18629/contributors","self":"https://app.emedici.com/api/items/18629/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/18629/contribution","self":"https://app.emedici.com/api/items/18629/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/18629/myContribution","self":"https://app.emedici.com/api/items/18629/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"105104"},"links":{"related":"https://app.emedici.com/api/items/18629/activeRevision","self":"https://app.emedici.com/api/items/18629/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"23"},{"type":"tags","id":"64"},{"type":"tags","id":"73"},{"type":"tags","id":"78"},{"type":"tags","id":"160"},{"type":"tags","id":"489"},{"type":"tags","id":"503"},{"type":"tags","id":"12956"}],"links":{"related":"https://app.emedici.com/api/items/18629/tags","self":"https://app.emedici.com/api/items/18629/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"55897"}],"links":{"related":"https://app.emedici.com/api/items/18629/contributions","self":"https://app.emedici.com/api/items/18629/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"123671","links":{"self":"https://app.emedici.com/api/questionRevisions/123671"},"attributes":{"stem":"\u003Cp\u003EA 38-year-old woman presents to the antenatal clinic at 16 weeks gestation in her fifth pregnancy. She has had four previous uncomplicated pregnancies with spontaneous vaginal deliveries at term. She has no significant medical history and does not take any regular medications. She mentions that she has developed prominent varicose veins in both legs over the past five years, which have become more noticeable during this pregnancy. Her BMI is 31 kg/m\u00b2. On examination, she appears well with vital signs within normal limits. Bilateral extensive varicose veins are visible from the groin to the ankles with associated mild ankle oedema.\u003C/p\u003E","stemQuestion":"Which one of the following represents the most appropriate next step in managing this patient\u0027s venous thromboembolism risk?","responseType":"sba","marks":1,"options":["Prescribe graduated compression stockings and review at 28 weeks","Commence prophylactic low molecular weight heparin immediately","Perform thrombophilia screening before deciding on prophylaxis","Defer thromboprophylaxis until the third trimester"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EVenous thromboembolism (VTE) remains a leading cause of maternal mortality, and pregnancy itself increases the risk of VTE six-fold. Risk assessment should be performed at booking, during each admission, and postpartum to identify women who may benefit from thromboprophylaxis.\u003C/p\u003E\u003Cp\u003EThe correct answer is to \u003Cstrong\u003Ecommence prophylactic low molecular weight heparin immediately\u003C/strong\u003E. This patient has three significant risk factors for VTE: gross varicose veins (adjusted odds ratio 2.4), obesity with BMI \u003E30 kg/m\u00b2 (adjusted odds ratio 1.7-2.5), and parity \u22653 (adjusted odds ratio 1.0-2.2). According to Queensland Health guidelines, the presence of multiple moderate risk factors indicates the need for antenatal prophylaxis with low molecular weight heparin from the first trimester. The combination of these factors places her at sufficiently high risk that prophylaxis should not be delayed.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPrescribing graduated compression stockings and reviewing at 28 weeks\u003C/strong\u003E would be inadequate management. While compression stockings may help with symptoms and provide some additional protection, they are insufficient as sole therapy when pharmacological prophylaxis is indicated based on risk assessment.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPerforming thrombophilia screening before deciding on prophylaxis\u003C/strong\u003E is inappropriate. Thrombophilia screening is not routinely recommended in pregnancy and would not change management in this case, as she already meets criteria for prophylaxis based on clinical risk factors alone. Additionally, many thrombophilia tests are unreliable during pregnancy.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EDeferring thromboprophylaxis until the third trimester\u003C/strong\u003E would leave this patient unprotected during a significant portion of her pregnancy. While VTE risk does increase as pregnancy progresses, women with multiple risk factors require prophylaxis from early pregnancy to provide optimal protection.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Gross varicose veins are an independent risk factor for venous thromboembolism in pregnancy, requiring formal risk assessment.","VTE risk stratification should incorporate multiple factors including pre-existing conditions, obstetric factors, and transient risk factors to guide thromboprophylaxis decisions."],"references":["Queensland Health. Queensland Clinical Guidelines: Venous thromboembolism (VTE) prophylaxis in pregnancy and the puerperium. 2021. Available from: https://www.health.qld.gov.au/__data/assets/pdf_file/0011/140024/g-vte.pdf"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"105104"},"links":{"related":"https://app.emedici.com/api/questionRevisions/123671/itemRevision","self":"https://app.emedici.com/api/questionRevisions/123671/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"25794"},"links":{"related":"https://app.emedici.com/api/questionRevisions/123671/question","self":"https://app.emedici.com/api/questionRevisions/123671/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/123671/stemMedia","self":"https://app.emedici.com/api/questionRevisions/123671/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/123671/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/123671/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"105104","links":{"self":"https://app.emedici.com/api/itemRevisions/105104"},"attributes":{"createdAt":"2025-10-31T10:52:00+10:30","updatedAt":"2025-10-31T11:05:49+10:30"},"relationships":{"item":{"data":{"type":"items","id":"18629"},"links":{"related":"https://app.emedici.com/api/itemRevisions/105104/item","self":"https://app.emedici.com/api/itemRevisions/105104/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"1236