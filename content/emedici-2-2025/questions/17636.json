{"data":[{"type":"questionAttempts","id":"17637168","links":{"self":"https://app.emedici.com/api/questionAttempts/17637168"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T18:39:59+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T18:39:59+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17636"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17636","links":{"self":"https://app.emedici.com/api/questions/17636"},"relationships":{"item":{"data":{"type":"items","id":"10350"}},"activeRevision":{"data":{"type":"questionRevisions","id":"71746"}}}},{"type":"items","id":"10350","links":{"self":"https://app.emedici.com/api/items/10350"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17636"}},"activeRevision":{"data":{"type":"itemRevisions","id":"57235"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"4948"},{"type":"tags","id":"7756"}]},"contributions":{"data":[{"type":"contributions","id":"24210"},{"type":"contributions","id":"24217"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"71746","links":{"self":"https://app.emedici.com/api/questionRevisions/71746"},"attributes":{"stem":"\u003Cp\u003EA researcher is investigating whether playing classical music affects the growth rate of garden peas compared to silence. \u003C/p\u003E","stemQuestion":"Which one of the following statistical approaches is most appropriate for this analysis?","responseType":"sba","marks":1,"options":["One-tailed test looking only for growth rate decrease","One-tailed test looking only for growth rate increase","Two-tailed test examining both increase and decrease","Sequential one-tailed tests in both directions","One-tailed test with doubled significance level"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EA \u003Cstrong\u003Etwo-tailed test examining both increase and decrease\u003C/strong\u003E is most appropriate when there is no theoretical basis for predicting the direction of an effect. This approach allows detection of significant changes in either direction while maintaining appropriate control of Type I error rate.\u003C/p\u003E\u003Cp\u003ETwo-tailed tests are generally preferred in research unless there is strong theoretical justification for examining only one direction. While one-tailed tests provide more statistical power, they can miss important effects in the unexpected direction.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["One-tailed tests examine statistical significance in only one direction, while two-tailed tests examine both directions.","Two-tailed tests are more conservative and generally preferred unless there is strong theoretical justification for a one-tailed test.","The significance level (alpha) is split between both tails in a two-tailed test, requiring a more extreme test statistic for significance."],"references":["Sullivan LM. Essentials of biostatistics in public health. 3rd ed. Burlington (MA): Jones \u0026 Bartlett Learning; 2018.","Dawson B, Trapp RG. Basic \u0026 clinical biostatistics. 4th ed. New York: McGraw-Hill; 2004."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"57235"}},"question":{"data":{"type":"questions","id":"17636"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"57235","links":{"self":"https://app.emedici.com/api/itemRevisions/57235"},"attributes":{"createdAt":"2024-12-20T15:18:33+10:30","updatedAt":"2024-12-20T15:19:08+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10350"}},"content":{"data":{"type":"questionRevisions","id":"71746"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.co