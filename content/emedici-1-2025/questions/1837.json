butes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1837"}},"activeRevision":{"data":{"type":"itemRevisions","id":"39498"}},"tags":{"data":[{"type":"tags","id":"31"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"78"},{"type":"tags","id":"247"},{"type":"tags","id":"377"},{"type":"tags","id":"3809"},{"type":"tags","id":"3884"},{"type":"tags","id":"8088"}]},"contributions":{"data":[{"type":"contributions","id":"6380"},{"type":"contributions","id":"7688"},{"type":"contributions","id":"16291"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"54026","links":{"self":"https://app.emedici.com/api/questionRevisions/54026"},"attributes":{"stem":"\u003Cp\u003EA 40-year-old woman presents to the outpatient department with a lump in her right breast, which she noticed two months ago and is gradually increasing in size. It is not associated with pain, discharge, or redness. She is otherwise well. Her mother died from breast cancer 20 years ago. On examination, there is a 3 cm immobile lump in the right breast. There is also nipple inversion, and her right axillary nodes are palpable. A core biopsy shows ductal carcinoma, which is hormone receptor-negative and HER2-negative. An MRI shows locally advanced malignancy involving the axillary nodes only, with no other metastasis. Consideration is given for possible neoadjuvant chemotherapy.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate treatment?","responseType":"sba","marks":1,"options":["Surgical resection without neoadjuvant therapy","Neoadjuvant chemotherapy followed by surgical resection","Surgical resection followed by adjuvant tamoxifen","Surgical resection followed by adjuvant trastuzumab","Neoadjuvant pertuzumab followed by surgical resection"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EThe patient has presented with ductal carcinoma which is hormone receptor-negative and HER2-negative (triple negative) and is only involving the adjacent lymph nodes. \u003Cstrong\u003ENeoadjuvant chemotherapy followed by surgery\u003C/strong\u003E would be the best option for this patient with locally advanced disease, as it has the potential to decrease tumour size prior to surgical intervention and decrease the risk of recurrence. Neoadjuvant chemotherapy is indicated in patients with locally advanced breast cancer and also those breast cancer patients who may benefit from size reduction before conservation therapy. Neoadjuvant therapy can also help convert non-operable tumours to operable tumours.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESurgical resection without neoadjuvant therapy\u003C/strong\u003E would not be a good option in this patient because this is a locally advanced breast cancer and neoadjuvant therapy has the potential to decrease tumour size, thus leading to more conservative surgery and a better prognosis.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESurgical resection followed by adjuvant tamoxifen\u003C/strong\u003E is a potential option for patients with low-risk localised ER-positive breast cancers. But given this patient\u0027s tumour is ER-negative, there is no role for tamoxifen.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ETrastuzumab\u003C/strong\u003E is a biological antineoplastic drug that is indicated for the treatment of HER2-positive breast cancer, while this patient has presented with HER2-negative breast cancer.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPertuzumab\u003C/strong\u003E is a humanised monoclonal antibody to the human epidermal growth factor receptor 2 (HER2) which is used in combination with other antineoplastic agents in the therapy of refractory, advanced breast cancer which is HER2-positive.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Neoadjuvant chemotherapy is used for locally advanced triple negative breast cancer."],"references":["Baranova A, Krasnoselskyi M, Starikov V, et al. Triple-negative breast cancer: current treatment strategies and factors of negative prognosis. J Med Life. 2022 Feb;15(2):153-161. Available at: https://www.ncbi.nlm.nih.gov/pmc/articles/PMC8999097/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"39498"}},"question":{"data":{"type":"questions","id":"1837"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"39498","links":{"self":"https://app.emedici.com/api/itemRevisions/39498"},"attributes":{"createdAt":"2024-09-29T00:32:08+09:30","updatedAt":"2024-09-29T00:32:31+09:30"},"relationships":{"item":{"data":{"type":"items","id":"1837"}},"content":{"data":{"type":"questionRevisions","id":"54026"}}},"meta":{"canDelete":false}},{"type":"tags","id":"31","links":{"self":"https://app.emedici.com/api/tags/31"},"attributes":{"emoji":"\ud83c\udf97","name":"Oncology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":"Management","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"72","links":{"self":"https://app.emedici.com/api/tags/72"},"attributes":{"emoji":"","name":"Graduating","synonyms":null,"description":"Only suitable for a graduating medical student at the end of their degree","position":1,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"78","links":{"self":"https://app.emedici.com/api/tags/78"},"attributes":{"emoji":"","name":"Le