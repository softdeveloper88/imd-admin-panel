:"tags","id":"4947"}]},"contributions":{"data":[{"type":"contributions","id":"31563"},{"type":"contributions","id":"31564"}]},"lastContribution":{"data":null},"lastRevision":{"data":{"type":"itemRevisions","id":"75696"}},"lastActivity":{"data":null},"lastFeedback":{"data":null}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"92391","links":{"self":"https://app.emedici.com/api/questionRevisions/92391"},"attributes":{"stem":"\u003Cp\u003EA 68-year-old woman presents with a painless swelling on the side of her face (Image). This has been present for four months and has shown little evidence of change in size. She has no other health issues.\u003C/p\u003E\u003Cp\u003EOn examination the swelling is clearly defined, smooth-surfaced and firm to palpation. The skin can be moved over the swelling.\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Epidermoid cyst","Enlarged lymph node","Enlarged submandibular gland","Parotid tumour","Lipoma"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThe swelling is in the region of the \u003Cstrong\u003Eparotid gland\u003C/strong\u003E. In such circumstances it is prudent to assume that the swelling arises from the parotid gland - until proven otherwise. Masses within the parotid gland are usually benign tumours, the most common being a pleomorphic adenoma.\u003C/p\u003E\u003Cp\u003EWhilst it could be a \u003Cstrong\u003Elipoma\u003C/strong\u003E, these lesions are usually found on the trunk or limbs and the face is an uncommon site.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EEpidermoid cysts \u003C/strong\u003Eare not usually found on the face. They are usually smaller than this lesion and well circumscribed, with a punctum at the apex.\u003C/p\u003E\u003Cp\u003EThe mass is unlikely to be a \u003Cstrong\u003Elymph node\u003C/strong\u003E, as this out of the anatomical territory of the cervical nodes.\u003C/p\u003E\u003Cp\u003ELikewise, it would not be a \u003Cstrong\u003Esubmandibular gland\u003C/strong\u003E - which, by definition, is under the mandible.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Most parotid tumours are pleomorphic adenomas."],"references":["Kim KS, Yang HS. Unusual locations of lipoma: Differential diagnosis of head and neck mass. Australian Family Physician. 2014;43(12):867\u201370.","Tan E. An approach to neck masses in adults [Internet]. 2020 [cited 2024 Jan 27]. Available from: https://www1.racgp.org.au/ajgp/2020/may/an-approach-to-neck-masses-in-adults"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"75696"}},"question":{"data":{"type":"questions","id":"287"}},"stemMedia":{"data":[{"type":"media","id":"19919"}]},"explanationMedia":{"data":[]}}},{"type":"media","id":"19919","links":{"self":"https://app.emedici.com/api/media/19919"},"attributes":{"mimeType":"image/jpeg","url":"https://app.emedici.com/storage/media/e7d3841e-669f-4bc4-9792-118953f6bc3c.jpg","thumbUrl":"https://app.emedici.com/storage/media/e7d3841e-669f-4bc4-9792-118953f6bc3c.jpg","isProcessed":true,"width":340,"height":440}},{"type":"itemRevisions","id":"75696","links":{"self":"https://app.emedici.com/api/itemRevisions/75696"},"attributes":{"createdAt":"2025-03-17T15:58:17+10:30","updatedAt":"2025-03-17T15:58:18+10:30","number":8,"notes":"","plagiarismCheckedAt":null,"plagiarismScore":null,"plagiarismReportUrl":null},"relationships":{"item":{"data":{"type":"items","id":"287"}},"content":{"data":{"type":"questionRevisions","id":"92391"}},"author":{"data":{"type":"users","id":"9"}},"generation":{"data":null}},"meta":{"canDelete":false}},{"type":"tags","id":"35","links":{"self":"https://app.emedici.com/api/tags/35"},"attributes":{"emoji":"\ud83d\udc43","name":"Otorhinolaryngology","synonyms":["ENT","HEENT"],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:40:48+10:30"},"re