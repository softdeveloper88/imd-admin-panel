{"data":[{"type":"questionAttempts","id":"17600655","links":{"self":"https://app.emedici.com/api/questionAttempts/17600655"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T12:06:24+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T12:06:24+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15628"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15628","links":{"self":"https://app.emedici.com/api/questions/15628"},"attributes":{"optionProportions":[0,0,0.7,0.22,0.07]},"relationships":{"item":{"data":{"type":"items","id":"8319"}},"activeRevision":{"data":{"type":"questionRevisions","id":"66706"}}}},{"type":"items","id":"8319","links":{"self":"https://app.emedici.com/api/items/8319"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15628"}},"activeRevision":{"data":{"type":"itemRevisions","id":"52159"}},"tags":{"data":[{"type":"tags","id":"4"},{"type":"tags","id":"32"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"1773"},{"type":"tags","id":"3320"},{"type":"tags","id":"4929"},{"type":"tags","id":"4943"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"5122"}]},"contributions":{"data":[{"type":"contributions","id":"20074"},{"type":"contributions","id":"20078"},{"type":"contributions","id":"22239"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"66706","links":{"self":"https://app.emedici.com/api/questionRevisions/66706"},"attributes":{"stem":"\u003Cp\u003EA 42-year-old man presents with gradual enlargement of his hands (Image 1), feet, and facial features (Image 2) over several years. Magnetic resonance imaging reveals a pituitary macroadenoma.\u003C/p\u003E","stemQuestion":"Which one of the following is the first-line treatment for this condition?","responseType":"sba","marks":1,"options":["Dopamine agonists","External beam radiation","Growth hormone receptor antagonists","Somatostatin analogues","Transsphenoidal surgery"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient has acromegaly. \u003Cstrong\u003ETranssphenoidal surgery\u003C/strong\u003E is the first-line treatment for most patients with acromegaly, particularly those with smaller and well-circumscribed tumours. Surgery offers the possibility of rapid cure and normalisation of growth hormone levels.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESomatostatin analogues\u003C/strong\u003E like octreotide are typically used as second-line therapy or in patients who are poor surgical candidates. \u003Cstrong\u003EDopamine agonists\u003C/strong\u003E have limited efficacy and are mainly used in mixed growth hormone/prolactin-secreting tumours. \u003Cstrong\u003EGrowth hormone receptor antagonists\u003C/strong\u003E like pegvisomant are usually reserved for patients who have failed other treatments. \u003Cstrong\u003EExternal beam radiation\u003C/strong\u003E is generally used as adjuvant therapy due to its slow onset of action and risk of hypopituitarism.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Transsphenoidal surgery is the first-line treatment for most patients with acromegaly.","Growth hormone secreting pituitary adenomas are the most common cause of acromegaly.","Medical therapy with somatostatin analogues is typically reserved for patients who are poor surgical candidates or have residual disease."],"references":["Fleseriu M, Langlois F, Lim DST, Varlamov EV, Melmed S. Acromegaly: pathogenesis, diagnosis, and management. Lancet Diabetes Endocrinol. 2022 Nov;10(11):804-826. doi: 10.1016/S2213-8587(22)00244-3. Epub 2022 Oct 6. PMID: 36209758.","Ben-Shlomo A, Melmed S. Acromegaly. Endocrinol Metab Clin North Am. 2008 Mar;37(1):101-22, viii. doi: 10.1016/j.ecl.2007.10.002. PMID: 18226732; PMCID: PMC2697616.","Chanson P, Salenave S. Acromegaly. Orphanet J Rare Dis. 2008 Jun 25;3:17. doi: 10.1186/1750-1172-3-17. PMID: 18578866; PMCID: PMC2459162.","Clark, O. H., Duh, Q. Y., Kebebew, E., Gosnell, J. E., \u0026 Shen, W. T. (Eds.). (2016). Textbook of endocrine surgery. JP Medical Ltd"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"52159"}},"question":{"data":{"type":"questions","id":"15628"}},"stemMedia":{"data":[{"type":"media","id":"21276"},{"type":"media","id":"21277"}]},"explanationMedia":{"data":[]}}},{"type":"media","id":"21276","links":{"self":"https://app.emedici.com/api/media/21276"},"attributes":{"mimeType":"image/jpeg","url":"https://app.emedici.com/storage/media/Z4WiDoxgIwZZx0cdrdA1AjlqvPXBvd.jpg","thumbUrl":"https://app.emedici.com/storage/media/Z4WiDoxgIwZZx0cdrdA1AjlqvPXBvd.jpg","isProcessed":true,"width":587,"height":429}},{"type":"media","id":"21277","links":{"self":"https://app.emedici.com/api/media/21277"},"attributes":{"mimeType":"image/jpeg","url":"https://app.emedici.com/storage/media/0ru3XUhPNdSzhwA5CFmulf4VbukaYD.jpg","thumbUrl":"https://app.emedici.com/storage/media/0ru3XUhPNdSzhwA5CFmulf4VbukaYD.jpg","isProcessed":true,"width":398,"height":440}},{"type":"itemRevisions","id":"52159","links":{"self":"https://app.emedici.com/api/itemRevisions/52159"},"attributes":{"createdAt":"2024-12-01T19:57:43+10:30","updatedAt":"2024-12-01T19:58:26+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8319"}},"content":{"data":{"type":"questionRevisions","id":"66706"}}},"meta":{"canDelete":false}},{"type":"tags","id":"4","links":{"self":"https://app.emedici.com/api/tags/4"},"attributes":{"emoji":"\ud83c\udf6c","name":"Endocrinology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},