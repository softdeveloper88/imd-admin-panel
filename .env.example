# Copy this file to .env and fill in your values
# Hostinger sets PORT automatically - do not change it
PORT=3000

# Admin credentials (change these before going live!)
IMD_ADMIN_USERNAME=admin
IMD_ADMIN_PASSWORD=admin123
IMD_ADMIN_COOKIE_SECRET=change-this-to-a-random-64-char-string

# Set to production on the server
NODE_ENV=production
