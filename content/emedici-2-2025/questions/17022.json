{"data":[{"type":"questionAttempts","id":"17625401","links":{"self":"https://app.emedici.com/api/questionAttempts/17625401"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T16:24:03+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T16:24:03+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17022"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17022","links":{"self":"https://app.emedici.com/api/questions/17022"},"attributes":{"optionProportions":[0.08,0.1,0.13,0.67,0.03]},"relationships":{"item":{"data":{"type":"items","id":"9712"}},"activeRevision":{"data":{"type":"questionRevisions","id":"73521"}}}},{"type":"items","id":"9712","links":{"self":"https://app.emedici.com/api/items/9712"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17022"}},"activeRevision":{"data":{"type":"itemRevisions","id":"58990"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"4936"},{"type":"tags","id":"4944"},{"type":"tags","id":"5326"},{"type":"tags","id":"5438"},{"type":"tags","id":"5447"}]},"contributions":{"data":[{"type":"contributions","id":"22854"},{"type":"contributions","id":"23120"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"73521","links":{"self":"https://app.emedici.com/api/questionRevisions/73521"},"attributes":{"stem":"\u003Cp\u003EA woman received all recommended childhood vaccines except for measles, mumps, and rubella (MMR), a live attenuated vaccine. The general practitioner explains the different types of vaccines and their safety profiles.\u003C/p\u003E","stemQuestion":"Which one of the following best describes live attenuated vaccines?","responseType":"sba","marks":1,"options":["Contain inactivated bacterial toxins","Contain killed pathogens that cannot replicate","Contain only specific proteins from pathogens","Contain weakened pathogens that can replicate","Contain synthetic copies of pathogen DNA"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003ELive attenuated vaccines contain weakened forms of pathogens that can still replicate\u003C/strong\u003E in the host but have been modified so they cannot cause serious disease in people with healthy immune systems. These vaccines typically produce strong and long-lasting immunity because they closely mimic natural infection.\u003C/p\u003E    \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E    \u003Cul\u003E        \u003Cli\u003E\u003Cstrong\u003EInactivated bacterial toxins\u003C/strong\u003E are used in toxoid vaccines, which provide immunity against bacterial toxins rather than the whole organism.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EKilled pathogens that cannot replicate\u003C/strong\u003E are used in inactivated vaccines, which provide immunity without any risk of replication.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EOnly specific proteins from pathogens\u003C/strong\u003E are used in subunit vaccines, which contain purified parts of the pathogen rather than the whole organism.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003ESynthetic copies of pathogen DNA\u003C/strong\u003E are used in nucleic acid vaccines, which instruct cells to produce specific viral proteins.\u003C/li\u003E    \u003C/ul\u003E    \u003Cp\u003EExamples of live attenuated vaccines include measles, mumps, rubella (MMR), varicella, and oral polio vaccines. These vaccines are generally contraindicated in immunocompromised individuals due to the theoretical risk of the attenuated pathogen causing disease.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Live attenuated vaccines contain weakened pathogens that can replicate but not cause disease in immunocompetent individuals.","Inactivated vaccines contain killed pathogens that cannot replicate but still stimulate an immune response.","Subunit vaccines contain specific parts of pathogens like proteins or polysaccharides rather than whole organisms."],"references":["Shultz JM, Sullivan LM, Galea S. Public Health: An Introduction to the Science and Practice of Population Health. Springer Publishing Company; 2021."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"58990"}},"question":{"data":{"type":"questions","id":"17022"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"58990","links":{"self":"https://app.emedici.com/api/itemRevisions/58990"},"attributes":{"createdAt":"2024-12-23T22:29:16+10:30","updatedAt":"2024-12-23T23:13:50+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9712"}},"content":{"data":{"type":"questionRevisions","id":"73521"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Level II","synonyms":null,"description":"Understand (interpreting and summarizing information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"dat