{"data":[{"type":"questionAttempts","id":"17657265","links":{"self":"https://app.emedici.com/api/questionAttempts/17657265"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T22:25:44+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T22:25:44+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"19165"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"19165","links":{"self":"https://app.emedici.com/api/questions/19165"},"attributes":{"optionProportions":[0.16,0.16,0.05,0.16,0.47]},"relationships":{"item":{"data":{"type":"items","id":"11899"}},"activeRevision":{"data":{"type":"questionRevisions","id":"81558"}}}},{"type":"items","id":"11899","links":{"self":"https://app.emedici.com/api/items/11899"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"19165"}},"activeRevision":{"data":{"type":"itemRevisions","id":"66912"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4942"},{"type":"tags","id":"4947"},{"type":"tags","id":"5326"},{"type":"tags","id":"5586"}]},"contributions":{"data":[{"type":"contributions","id":"27878"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"81558","links":{"self":"https://app.emedici.com/api/questionRevisions/81558"},"attributes":{"stem":"\u003Cp\u003EMedical imaging procedures use varying amounts of ionising radiation. The average person receives approximately 2.0 millisieverts per year from natural background radiation sources including cosmic rays, soil, building materials and food.\u003C/p\u003E","stemQuestion":"Which one of the following imaging procedures delivers the highest radiation dose?","responseType":"sba","marks":1,"options":["Computed tomography abdomen and pelvis","Computed tomography coronary angiography","Computed tomography spine","Magnetic resonance imaging abdomen","Positron emission tomography whole body scan"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EA \u003Cstrong\u003Epositron emission tomography whole body scan\u003C/strong\u003E delivers approximately 22.7 millisieverts (mSv) of radiation, which is equivalent to 7.6 years of natural background radiation. This is due to the radioactive tracers used and the long scanning time required.\u003C/p\u003E\u003Cp\u003EThe other options deliver lower radiation doses:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EComputed tomography abdomen and pelvis\u003C/strong\u003E delivers approximately 10 mSv\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EComputed tomography coronary angiography\u003C/strong\u003E delivers approximately 12 mSv\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EComputed tomography spine\u003C/strong\u003E delivers approximately 6 mSv\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EMagnetic resonance imaging abdomen\u003C/strong\u003E uses magnetic fields rather than ionising radiation and therefore delivers no radiation dose\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EUnderstanding radiation doses helps clinicians make informed decisions about imaging choices and enables appropriate counselling of patients regarding radiation risks.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Positron emission tomography whole body scanning delivers approximately 22.7 millisieverts of radiation, equivalent to 7.6 years of background radiation.","Computed tomography procedures typically deliver between 5-15 millisieverts of radiation depending on the body region scanned.","Magnetic resonance imaging does not use ionising radiation and therefore delivers no radiation dose."],"references":["Rehani MM, Nacouzi D. Higher patient doses through X-ray imaging procedures. Physica Medica 2020; 79:80\u201386","https://www.radiologyinfo.org/en/info/safety-xray"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"66912"}},"question":{"data":{"type":"questions","id":"19165"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"66912","links":{"self":"https://app.emedici.com/api/itemRevisions/66912"},"attributes":{"createdAt":"2025-01-26T12:16:13+10:30","updatedAt":"2025-01-26T12:21:00+10:30"},"relationships":{"item":{"data":{"type":"items","id":"11899"}},"content":{"data":{"type":"questionRevisions","id":"81558"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4942","links":{"self":"https://app.emedici.com/api/tags/4942"},"attributes":{"emoji":"\u2699\ufe0f","name":"Physiology","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-11-21T12:54:08+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"14"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"typ