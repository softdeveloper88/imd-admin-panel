com/api/questions/21092/relationships/activeRevision"}}}},{"type":"items","id":"13967","links":{"self":"https://app.emedici.com/api/items/13967"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/13967/packs","self":"https://app.emedici.com/api/items/13967/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/13967/revisions","self":"https://app.emedici.com/api/items/13967/relationships/revisions"}},"content":{"data":{"type":"questions","id":"21092"},"links":{"related":"https://app.emedici.com/api/items/13967/content","self":"https://app.emedici.com/api/items/13967/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/13967/specialtyTags","self":"https://app.emedici.com/api/items/13967/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/13967/primaryTags","self":"https://app.emedici.com/api/items/13967/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/13967/contributionTypes","self":"https://app.emedici.com/api/items/13967/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/13967/contributors","self":"https://app.emedici.com/api/items/13967/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/13967/contribution","self":"https://app.emedici.com/api/items/13967/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/13967/myContribution","self":"https://app.emedici.com/api/items/13967/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"102751"},"links":{"related":"https://app.emedici.com/api/items/13967/activeRevision","self":"https://app.emedici.com/api/items/13967/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"5"},{"type":"tags","id":"14"},{"type":"tags","id":"25"},{"type":"tags","id":"29"},{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"1051"},{"type":"tags","id":"1151"},{"type":"tags","id":"1258"},{"type":"tags","id":"1412"},{"type":"tags","id":"4928"},{"type":"tags","id":"12795"}],"links":{"related":"https://app.emedici.com/api/items/13967/tags","self":"https://app.emedici.com/api/items/13967/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"33697"},{"type":"contributions","id":"53203"}],"links":{"related":"https://app.emedici.com/api/items/13967/contributions","self":"https://app.emedici.com/api/items/13967/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"121142","links":{"self":"https://app.emedici.com/api/questionRevisions/121142"},"attributes":{"stem":"\u003Cp\u003EA 42-year-old woman presents to her general practice with a three-month history of intermittent epigastric discomfort, nausea, and early satiety. She reports no vomiting, weight loss, or change in bowel habits. She has no significant medical history and does not take any regular medications. She works as a veterinary nurse and lives with two cats and a dog. On examination, she appears well with vital signs within normal limits. Abdominal examination reveals mild epigastric tenderness without guarding or rebound. Upper gastrointestinal endoscopy shows patchy erythema in the gastric antrum. Histopathological examination of gastric biopsies is shown below:\u003C/p\u003E","stemQuestion":"Which one of the following is the most important risk factor for this infection?","responseType":"sba","marks":1,"options":["Consumption of contaminated water","Poor socioeconomic conditions","Previous gastric surgery","Chronic proton pump inhibitor use","Contact with domestic animals"],"correctOptions":[4],"correctResponses":[],"explanation":"\u003Cp\u003E\u003Cem\u003EHelicobacter heilmannii\u003C/em\u003E is a non-pylori Helicobacter species that causes chronic gastritis in humans. The histopathological examination shows the characteristic tightly coiled spiral organisms of \u003Cem\u003EH. heilmannii\u003C/em\u003E, which are morphologically distinct from the more common \u003Cem\u003EH. pylori\u003C/em\u003E. \u003Cem\u003EH. heilmannii\u003C/em\u003E is significantly longer (5-10 \u03bcm) than \u003Cem\u003EH. pylori\u003C/em\u003E (2-4 \u03bcm) and displays a characteristic corkscrew-like morphology with 4-10 tight spiral turns. In contrast, \u003Cem\u003EH. pylori\u003C/em\u003E appears as shorter, gently curved or S-shaped bacteria with only 1-3 loose spirals. Unlike \u003Cem\u003EH. pylori\u003C/em\u003E, which is transmitted person-to-person, \u003Cem\u003EH. heilmannii\u003C/em\u003E is a zoonotic infection with distinct epidemiological characteristics.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EContact with domestic animals\u003C/strong\u003E is the primary risk factor for \u003Cem\u003EH. heilmannii\u003C/em\u003E infection. The organism naturally colonises the gastric mucosa of various animals, including cats, dogs, pigs, and non-human primates. Transmission occurs through close contact with infected animals, particularly their saliva. Veterinarians, veterinary nurses, pet owners, and others with occupational or frequent exposure to animals are at increased risk. The patient\u0027s occupation as a veterinary nurse and ownership of multiple pets represent classic risk factors.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EConsumption of contaminated water\u003C/strong\u003E is a well-established risk factor for \u003Cem\u003EH. pylori\u003C/em\u003E infection, particularly in developing countries. However, this is not a recognised transmission route for \u003Cem\u003EH. heilmannii\u003C/em\u003E, which requires animal-to-human transmission.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPoor socioeconomic conditions\u003C/strong\u003E are associated with increased prevalence of \u003Cem\u003EH. pylori\u003C/em\u003E infection due to overcrowding, poor sanitation, and limited access to clean water. \u003Cem\u003EH. heilmannii\u003C/em\u003E infection shows no clear association with socioeconomic status and is more related to animal exposure.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPrevious gastric surgery\u003C/strong\u003E can alter gastric physiology and predispose to various complications, including bile reflux gastropathy and bacterial overgrowth, but it is not a risk factor for \u003Cem\u003EH. heilmannii\u003C/em\u003E infection. The organism requires transmission from an animal host.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EChronic proton pump inhibitor use\u003C/strong\u003E can lead to gastric acid suppression and may predispose to certain infections, such as \u003Cem\u003EClostridium difficile\u003C/em\u003E and small intestinal bacterial overgrowth. However, it is not a risk factor for \u003Cem\u003EH. heilmannii\u003C/em\u003E infection, which is acquired through zoonotic transmission.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Helicobacter heilmannii is a zoonotic infection transmitted from domestic animals, particularly cats and dogs, to humans.","H. heilmannii appears as tightly coiled spiral organisms (5-10 \u03bcm long) on histology, distinct from the shorter, less coiled H. pylori (2-4 \u03bcm)."],"references":["Uthman, Ed. Helicobacter heilmannii in gastric mucosa. Flickr. Accessed under license CC By 2.0: https://creativecommons.org/licenses/by/2.0/deed.en. Accessed at: https://www.flickr.com/photos/euthman/49093650322/in/pool-labmed/","Weisenberg E. Helicobacter heilmannii. PathologyOutlines.com website. https://www.pathologyoutlines.com/topic/stomachhh.html. Accessed October 16th, 2025."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"102751"},"links":{"related":"https://app.emedici.com/api/questionRevisions/121142/itemRevision","self":"https://app.emedici.com/api/questionRevisions/121142/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"21092"},"links":{"related":"https://app.emedici.com/api/questionRevisions/121142/question","self":"https://app.emedici.com/api/questionRevisions/121142/relationships/question"}},"stemMedia":{"data":[{"type":"media","id":"21827"}],"links":{"related":"https://app.emedici.com/api/questionRevisions/121142/stemMedia","self":"https://app.emedici.com/api/questionRevisions/121142/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/121142/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/121142/relationships/explanationMedia"}}}},{"type":"media","id":"21827","links":{"self":"https://app.emedici.com/api/media/21827"},"attributes":{"mimeType":"image/jpeg","url":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/MWvQlcIPvqCVdigIIjpotztEDJI6fe.jpg","thumbUrl":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/MWvQlcIPvqCVdigIIjpotztEDJI6fe.jpg","isProcessed":true,"width":1336,"height":1500}},{"type":"itemRevisions","id":"102751","links":{"self":"https://app.emedici.com/api/itemRevisions/102751"},"attributes":{"createdAt":"2025-10-19T17:17:37+10:30","updatedAt":"2025-10-19T17:20:26+10:30"},"relationships":{"item":{"data":{"type":"items","id":"13967"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102751/item","self":"https://app.emedici.com/api/itemRevisions/102751/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"121142"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102751/content","self":"https://app.emedici.com/api/itemRevisions/102751/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"5","links":{"self":"https://app.emedici.com/api/tags/5"},"attributes":{"emoji":"\ud83d\udd2d","name":"Gastroenterology","synonyms":[],"