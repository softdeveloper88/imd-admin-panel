{"data":[{"type":"questionAttempts","id":"17638207","links":{"self":"https://app.emedici.com/api/questionAttempts/17638207"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T18:52:33+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T18:52:33+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17699"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17699","links":{"self":"https://app.emedici.com/api/questions/17699"},"relationships":{"item":{"data":{"type":"items","id":"10413"}},"activeRevision":{"data":{"type":"questionRevisions","id":"72112"}}}},{"type":"items","id":"10413","links":{"self":"https://app.emedici.com/api/items/10413"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17699"}},"activeRevision":{"data":{"type":"itemRevisions","id":"57582"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4942"},{"type":"tags","id":"5586"},{"type":"tags","id":"10414"}]},"contributions":{"data":[{"type":"contributions","id":"24324"},{"type":"contributions","id":"24360"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"72112","links":{"self":"https://app.emedici.com/api/questionRevisions/72112"},"attributes":{"stem":"\u003Cp\u003ETaste sensations from the tongue and oral cavity are transmitted through multiple cranial nerves to reach specific regions of the brain.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the primary central relay station for taste information in the brainstem?","responseType":"sba","marks":1,"options":["Nucleus of the solitary tract","Inferior olivary nucleus","Trigeminal sensory nucleus","Vestibular nucleus","Superior salivatory nucleus"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Enucleus of the solitary tract\u003C/strong\u003E is the primary brainstem relay centre for taste information. It receives input from cranial nerves VII (facial), IX (glossopharyngeal) and X (vagus), which carry taste sensations from different regions of the tongue and oral cavity. From here, projections travel to the ventral posteromedial nucleus of the thalamus and then to the primary gustatory cortex.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003EThe \u003Cstrong\u003Esuperior salivatory nucleus\u003C/strong\u003E is involved in parasympathetic control of salivary glands rather than taste sensation processing.\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Etrigeminal sensory nucleus\u003C/strong\u003E processes general sensory information from the face and oral cavity but not taste sensations.\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Einferior olivary nucleus\u003C/strong\u003E is involved in cerebellar function and motor learning rather than taste processing.\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Evestibular nucleus\u003C/strong\u003E processes information about balance and spatial orientation rather than taste sensations.\u003C/li\u003E\u003C/ul\u003E","optionExplanations":["","","","",""],"learningPoints":["The taste pathway involves cranial nerves VII, IX and X carrying sensory information from taste buds to the nucleus of the solitary tract.","The nucleus of the solitary tract projects to the ventral posteromedial nucleus of the thalamus.","Taste information ultimately reaches the primary gustatory cortex in the insula and frontal operculum."],"references":["Hall JE, Hall ME. Guyton and Hall Textbook of Medical Physiology. 14th ed. Philadelphia, PA: Elsevier; 2020.","Tortora, G. J., Mellifont, R., Derrickson, B., Burkett, B., Peoples, G., D, D. Principles of Anatomy and Physiology, Asia-Pacific Edition,  2nd Edition. John Wiley \u0026 Sons Australia; 2019."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"57582"}},"question":{"data":{"type":"questions","id":"17699"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"57582","links":{"self":"https://app.emedici.com/api/itemRevisions/57582"},"attributes":{"createdAt":"2024-12-20T22:41:38+10:30","updatedAt":"2024-12-20T22:42:02+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10413"}},"content":{"data":{"type":"questionRevisions","id":"72112"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4942","links":{"self":"https://app.emedici.com/api/tags/4942"},"attributes":{"emoji":"\u2699\ufe0f","name":"Physiology","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-11-21T12:54:08+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"14"}},"heading":{"data":null}},"meta"