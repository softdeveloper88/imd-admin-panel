{"data":[{"type":"questionAttempts","id":"17656010","links":{"self":"https://app.emedici.com/api/questionAttempts/17656010"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T22:08:37+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T22:08:37+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18708"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18708","links":{"self":"https://app.emedici.com/api/questions/18708"},"attributes":{"optionProportions":[0.14,0.23,0,0.09,0.55]},"relationships":{"item":{"data":{"type":"items","id":"11440"}},"activeRevision":{"data":{"type":"questionRevisions","id":"76947"}}}},{"type":"items","id":"11440","links":{"self":"https://app.emedici.com/api/items/11440"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18708"}},"activeRevision":{"data":{"type":"itemRevisions","id":"62452"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4935"},{"type":"tags","id":"4942"},{"type":"tags","id":"10649"}]},"contributions":{"data":[{"type":"contributions","id":"26487"},{"type":"contributions","id":"26492"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"76947","links":{"self":"https://app.emedici.com/api/questionRevisions/76947"},"attributes":{"stem":"\u003Cp\u003EColostrum is the first milk produced by mothers in the initial days after childbirth. It differs significantly in composition from mature breast milk.\u003C/p\u003E","stemQuestion":"Which one of the following best describes a characteristic of colostrum compared to mature breast milk?","responseType":"sba","marks":1,"options":["Higher lactose content","Higher fat content","Lower mineral content","Lower protein content","Higher concentration of immunoglobulins"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EColostrum contains a \u003Cstrong\u003Ehigher concentration of immunoglobulins\u003C/strong\u003E, particularly IgA, compared to mature breast milk. This provides essential passive immunity to protect the newborn against infections in the first few days of life. Colostrum also contains higher levels of protein, minerals, and leukocytes but lower levels of fat and lactose than mature breast milk.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003ELower protein content\u003C/strong\u003E - Colostrum has approximately twice the protein content of mature breast milk\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EHigher fat content\u003C/strong\u003E - Colostrum actually has lower fat content than mature breast milk\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ELower mineral content\u003C/strong\u003E - Colostrum has higher levels of minerals, particularly sodium, potassium and chloride\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EHigher lactose content\u003C/strong\u003E - Colostrum contains less lactose than mature breast milk\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThe unique composition of colostrum is specifically adapted to meet the immediate needs of the newborn, providing immune protection and supporting early development.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Colostrum contains high concentrations of immunoglobulins, particularly IgA, which provides passive immunity to the newborn.","Colostrum has higher protein and lower fat content compared to mature breast milk.","Colostrum contains growth factors and leukocytes that support infant immune system development."],"references":["Tortora GJ, Derrickson BH, Burkett B, Peoples G, Dye D, Cooke J, et al. Principles of Anatomy and Physiology, 2nd Asia-Pacific Edition: John Wiley \u0026 Sons, Limited; 2019","Hall J. Guyton and Hall Textbook of Medical Physiology. 14th ed. Elsevier Health Sciences; 2021."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"62452"}},"question":{"data":{"type":"questions","id":"18708"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"62452","links":{"self":"https://app.emedici.com/api/itemRevisions/62452"},"attributes":{"createdAt":"2025-01-05T20:46:23+10:30","updatedAt":"2025-01-05T20:46:56+10:30"},"relationships":{"item":{"data":{"type":"items","id":"11440"}},"content":{"data":{"type":"questionRevisions","id":"76947"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4935","links":{"self":"https://app.emedici.com/api/tags/4935"},"attributes":{"emoji":"\ud83e\udd5a","name":"Reproductive System (Female)","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-11-21T12:54:35+10:30"},"relationships":{"group":{"da