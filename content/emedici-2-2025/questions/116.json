d":"1456"},{"type":"contributions","id":"17701"},{"type":"contributions","id":"41993"},{"type":"contributions","id":"42970"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"42354","links":{"self":"https://app.emedici.com/api/questionRevisions/42354"},"attributes":{"stem":"\u003Cp\u003EA 72-year-old man has recently been diagnosed with symptomatic congestive cardiac failure. His echocardiogram showed a left ventricular ejection fraction of 34%. To treat his heart failure he is to be commenced on an ACE inhibitor and a beta-blocker.\u003C/p\u003E","stemQuestion":"Which one of the following beta-blockers would be most appropriate?","responseType":"sba","marks":1,"options":["Atenolol","Nebivolol","Sotalol","Labetalol","Propranolol"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EThe four beta-blockers with evidence for use in congestive cardiac failure in terms of providing a mortality benefit are\u003Cstrong\u003E nebivolol\u003C/strong\u003E, carvedilol, bisoprolol, and metoprolol. These agents can reduce the mortality rate by about 30% over one year. Nebivolol has been studied for use in the elderly population with heart failure (SENIORS study). The other three beta-blockers (ie, carvedilol, bisoprolol, metoprolol) provide significant mortality benefit but have not been studied extensively for use in the elderly population.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAtenolol\u003C/strong\u003E and \u003Cstrong\u003Esotalol\u003C/strong\u003E are associated with increased mortality in patients with congestive heart failure.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ELabetalol\u003C/strong\u003E is labeled for use in the acute management of severe hypertension or in hypertension during pregnancy. It is not indicated for use in congestive heart failure.\u003C/p\u003E\u003Cp\u003EAlthough several studies have shown the mortality benefit of \u003Cstrong\u003Epropranolol\u003C/strong\u003E, it is not extensively studied enough to be considered a recommended choice of beta-blocker for heart failure.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Nebivolol has proven efficacy in the management of congestive cardiac failure."],"references":["Flather M, Shibata M, Coats A, Van Veldhuisen D, Parkhomenko A, Borbola J et al. Randomized trial to determine the effect of nebivolol on mortality and cardiovascular hospital admission in elderly patients with heart failure (SENIORS). European Heart Journal. 2005;26(3):215-225."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"27375"}},"question":{"data":{"type":"questions","id":"116"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"27375","links":{"self":"https://app.emedici.com/api/itemRevisions/27375"},"attributes":{"createdAt":"2024-02-08T06:56:22+10:30","updatedAt":"2024-10-13T08:05:46+10:30"},"relationships":{"item":{"data":{"type":"items","id":"116"}},"content":{"data":{"type":"questionRevisions","id":"42354"}}},"meta":{"canDelete":false}},{"type":"tags","id":"2","links":{"self":"https://app.emedici.com/api/tags/2"},"attributes":{"emoji":"\ud83e\udec0","name":"Cardiology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:21+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"6","links":{"self":"https://app.emedici.com/api/tags/6"},"attributes":{"emoji":"\ud83d\udc75","name":"Geriatrics","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"43","links":{"self":"https://app.emedici.com/api/tags/43"},"attributes":{"emoji":"\ud83d\udc8a","name":"Pharmacology","synonyms":null,"description":nul