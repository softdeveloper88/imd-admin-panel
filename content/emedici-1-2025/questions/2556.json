{"data":[{"type":"questionAttempts","id":"17473600","links":{"self":"https://app.emedici.com/api/questionAttempts/17473600"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-28T22:11:03+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T22:11:03+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"2556"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"2556","links":{"self":"https://app.emedici.com/api/questions/2556"},"attributes":{"optionProportions":[0.69,0.08,0.06,0.09,0.09]},"relationships":{"item":{"data":{"type":"items","id":"2556"}},"activeRevision":{"data":{"type":"questionRevisions","id":"81967"}}}},{"type":"items","id":"2556","links":{"self":"https://app.emedici.com/api/items/2556"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"2556"}},"activeRevision":{"data":{"type":"itemRevisions","id":"67232"}},"tags":{"data":[{"type":"tags","id":"9"},{"type":"tags","id":"11"},{"type":"tags","id":"13"},{"type":"tags","id":"14"},{"type":"tags","id":"67"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"88"},{"type":"tags","id":"1061"},{"type":"tags","id":"2701"},{"type":"tags","id":"3749"},{"type":"tags","id":"4174"},{"type":"tags","id":"8118"}]},"contributions":{"data":[{"type":"contributions","id":"2622"},{"type":"contributions","id":"2650"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"81967","links":{"self":"https://app.emedici.com/api/questionRevisions/81967"},"attributes":{"stem":"\u003Cp\u003EA 15-year-old boy is brought to the Emergency Department by his parents. He has had a fever for the past two days, a new onset yellow productive cough, and difficulty breathing. His medical history includes sickle cell anaemia. He immigrated to Australia with his parents two years ago. A chest X-ray is ordered and shows focal right middle lobe consolidation.\u0026nbsp;\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely causative organism?","responseType":"sba","marks":1,"options":["Streptococcus pneumoniae","Salmonella typhi","Staphylococcus aureus","Moraxella catarrhalis","Legionella pneumophila"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EIn patients with sickle cell disease, \u003Cstrong\u003EStreptococcus pneumoniae\u003C/strong\u003E is the most likely causative organism for pneumonia. This is due to functional asplenism, which increases susceptibility to infections by encapsulated organisms. Other encapsulated bacteria such as \u003Cem\u003EHaemophilus influenzae\u003C/em\u003E and \u003Cem\u003ENeisseria meningitidis\u003C/em\u003E also pose a risk, but \u003Cem\u003EStreptococcus pneumoniae\u003C/em\u003E is the most common cause of pneumonia in these patients.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESalmonella typhi\u003C/strong\u003E is more commonly associated with osteomyelitis in sickle cell disease rather than pneumonia.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EStaphylococcus aureus\u003C/strong\u003E, \u003Cstrong\u003EMoraxella catarrhalis\u003C/strong\u003E, and \u003Cstrong\u003ELegionella pneumophila\u003C/strong\u003E are less commonly associated with pneumonia in sickle cell disease compared to \u003Cem\u003EStreptococcus pneumoniae\u003C/em\u003E.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Patients with sickle cell disease are at increased risk of infections due to functional asplenism.","Streptococcus pneumoniae is a common cause of pneumonia in individuals with sickle cell disease.","Encapsulated bacteria pose a significant risk to patients with sickle cell disease due to impaired immune function."],"references":["Marti-Carvajal AJ, Conterno LO. Antibiotics for treating community-acquired pneumonia in people with sickle cell disease. Cochrane; 2016: (11)."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"67232"}},"question":{"data":{"type":"questions","id":"2556"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"67232","links":{"self":"https://app.emedici.com/api/itemRevisions/67232"},"attributes":{"createdAt":"2025-01-27T14:00:49+10:30","updatedAt":"2025-01-27T14:03:16+10:30"},"relationships":{"item":{"data":{"type":"items","id":"2556"}},"content":{"data":{"type":"questionRevisions","id":"81967"}}},"meta":{"canDelete":false}},{"type":"tags","id":"9","links":{"self":"https://app.emedici.com/api/tags/9"},"attributes":{"emoji":"\ud83d\udc76","name":"Paediatrics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:39:03+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"11","links":{"self":"https://app.emedici.com/api/tags/11"},"attributes":{"emoji":"\ud83e\udec1","name":"Respiratory Medicine","synonyms":["Pulmonology"],"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"13","links":{"self":"https://app.emedici.com/api/tags/13"},"attributes":{"emoji":"\ud83e\ude78","name":"Haematology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:44+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"14","links":{"self":"https://app.emedici.com/api/tags/14"},"attributes":{"emoji":"\ud83e\udda0","name":"Infectious Diseases","synonyms":["ID"],"description":null,"position":null,"createdAt":null,"updatedAt":"2021-05-21T07:51:58+09:30"},"relationships":{"group":{"