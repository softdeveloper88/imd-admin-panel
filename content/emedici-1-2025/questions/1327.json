uestions/1327/relationships/activeRevision"}}}},{"type":"items","id":"1327","links":{"self":"https://app.emedici.com/api/items/1327"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/1327/packs","self":"https://app.emedici.com/api/items/1327/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/1327/revisions","self":"https://app.emedici.com/api/items/1327/relationships/revisions"}},"content":{"data":{"type":"questions","id":"1327"},"links":{"related":"https://app.emedici.com/api/items/1327/content","self":"https://app.emedici.com/api/items/1327/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/1327/specialtyTags","self":"https://app.emedici.com/api/items/1327/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/1327/primaryTags","self":"https://app.emedici.com/api/items/1327/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/1327/contributionTypes","self":"https://app.emedici.com/api/items/1327/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/1327/contributors","self":"https://app.emedici.com/api/items/1327/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/1327/contribution","self":"https://app.emedici.com/api/items/1327/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/1327/myContribution","self":"https://app.emedici.com/api/items/1327/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"100533"},"links":{"related":"https://app.emedici.com/api/items/1327/activeRevision","self":"https://app.emedici.com/api/items/1327/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"17"},{"type":"tags","id":"66"},{"type":"tags","id":"71"},{"type":"tags","id":"525"},{"type":"tags","id":"4947"},{"type":"tags","id":"5631"},{"type":"tags","id":"5769"}],"links":{"related":"https://app.emedici.com/api/items/1327/tags","self":"https://app.emedici.com/api/items/1327/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"2055"},{"type":"contributions","id":"2058"},{"type":"contributions","id":"16238"},{"type":"contributions","id":"35066"},{"type":"contributions","id":"35188"},{"type":"contributions","id":"35498"},{"type":"contributions","id":"36994"},{"type":"contributions","id":"37727"},{"type":"contributions","id":"50019"},{"type":"contributions","id":"51985"},{"type":"contributions","id":"51986"},{"type":"contributions","id":"51987"}],"links":{"related":"https://app.emedici.com/api/items/1327/contributions","self":"https://app.emedici.com/api/items/1327/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"118722","links":{"self":"https://app.emedici.com/api/questionRevisions/118722"},"attributes":{"stem":"\u003Cp\u003EA 73-year-old woman presents to hospital with a three-week history of progressive dysphagia and unintentional weight loss of 5 kg. She has no significant medical history and does not take any regular medications. She emigrated from China 20 years ago and has limited English proficiency. Her daughter, who speaks fluent English, has been translating during the admission and the patient has expressed she is happy for her family to translate.\u003C/p\u003E\u003Cp\u003EOn examination, she appears cachectic but alert. Her vital signs are within normal limits. She is orientated to person, place and time, showing no signs of cognitive deficits. She has been able to understand everything involved in her medical care thus far.\u003C/p\u003E\u003Cp\u003EInvestigations including endoscopy and biopsy have confirmed oesophageal adenocarcinoma. The medical team wish to discuss the diagnosis and its implications with the patient. The family has privately told staff they do not want the patient to know the diagnosis and would prefer their mother to be kept comfortable. The patient\u0027s daughter offers to translate for the discussion.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate next step?","responseType":"sba","marks":1,"options":["Agree to the daughter\u0027s wishes","Agree to the daughter\u0027s wishes, provided other family members are present","Arrange for an interpreter to be present with the family","Arrange to see the patient with an interpreter alone","Leave it to the daughter to discuss things further with the patient"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThis scenario presents an ethical dilemma involving patient autonomy, family dynamics, and cultural considerations. The patient has mental capacity and the right to be informed about her diagnosis. However, the family\u0027s desire to withhold this information creates a conflict that must be handled sensitively.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EArrange to see the patient with an interpreter alone\u003C/strong\u003E is the most appropriate approach. This ensures the patient receives accurate information without family interference, while respecting her autonomy. During this private consultation, the clinician can follow the SPIKES protocol, particularly the \u0027I\u0027 step - invitation - to establish what the patient wants to know about her condition and who she would like present for future discussions. Some patients may prefer not to know their diagnosis but are happy for family to know and make decisions on their behalf, though this is uncommon.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAgree to the daughter\u0027s wishes\u003C/strong\u003E would be unethical as it violates the principle of patient autonomy. A competent patient has the right to receive information about their diagnosis and treatment options. Allowing the daughter to control information flow could result in the patient being unable to make informed decisions about her care.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAgree to the daughter\u0027s wishes, provided other family members are present\u003C/strong\u003E does not address the fundamental ethical issue. Having more family members present does not justify withholding information from a competent patient.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EArrange for an interpreter to be present with the family\u003C/strong\u003E was previously considered appropriate to provide support during difficult news. However, given the family\u0027s stated intention to withhold information, it is more appropriate to first meet with the patient alone to establish her preferences regarding information disclosure and family involvement.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ELeave it to the daughter to discuss things further with the patient\u003C/strong\u003E abdicates the medical practitioner\u0027s responsibility to ensure the patient is properly informed. Given the daughter\u0027s desire to withhold the diagnosis, this approach would likely result in the patient remaining uninformed.\u003C/p\u003E\u003Cp\u003EThese situations require careful navigation of cultural values while maintaining ethical medical practice. After establishing the patient\u0027s wishes in a private consultation with an independent interpreter, the clinician can then proceed according to the patient\u0027s preferences, which may include having family present for subsequent discussions if she desires.\u003C/p\u003E","optionExplanations":null,"learningPoints":["In patients who have mental capacity, it is unethical to withhold information, and it is the medical practitioner\u0027s role to ensure they understand and are involved in decision making of their own medical treatment.","When delivering a serious diagnosis, patient autonomy requires first establishing what the patient wants to know and who they want present during the discussion."],"references":["Juckett G, Unger K. Appropriate Use of Medical Interpreters. Am Fam Physician. 2014; 90:476-80."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"100533"},"links":{"related":"https://app.emedici.com/api/questionRevisions/118722/itemRevision","self":"https://app.emedici.com/api/questionRevisions/118722/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"1327"},"links":{"related":"https://app.emedici.com/api/questionRevisions/118722/question","self":"https://app.emedici.com/api/questionRevisions/118722/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/118722/stemMedia","self":"https://app.emedici.com/api/questionRevisions/118722/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/118722/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/118722/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"100533","links":{"self":"https://app.emedici.com/api/itemRevisions/100533"},"attributes":{"createdAt":"2025-10-08T12:45:23+10:30","updatedAt":"2025-10-08T12:48:42+10:30"},"relationships":{"item":{"data":{"type":"items","id":"1327"},"links":{"related":"https://app.emedici.com/api/itemRevisions/100533/item","self":"https://app.emedici.com/api/itemRevisions/100533/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"118722"},"links":{"related":"https://app.emedici.com/api/itemRevisions/100533/content","self":"https://app.emedici.com/api/itemRevisions/100533/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"17","links":{"self":"https://app.emedici.com/api/tags/17"},"attributes":{"emoji":"\ud83d\ude07","name":"Bioethics","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups",