<mediaMap>
<mediaPoint id="fig01_17" type="IMG" mediaType="TID1" mediaSize="3" order="20" href="chap01.html#fig01_17"><desc><![CDATA[<b>Figure 1-17</b> Landmarks of the external eye. <span style="font-size:0.8em"><i>(Illustration by Christine Gralapp.)</i></span>]]></desc><mediaPath src="images/img_p18.jpg" thumbSrc="images/img_p18.jpg"/></mediaPoint>
