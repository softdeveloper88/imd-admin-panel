{"data":[{"type":"questionAttempts","id":"17616520","links":{"self":"https://app.emedici.com/api/questionAttempts/17616520"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T15:04:20+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T15:04:20+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16396"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"16396","links":{"self":"https://app.emedici.com/api/questions/16396"},"relationships":{"item":{"data":{"type":"items","id":"9087"}},"activeRevision":{"data":{"type":"questionRevisions","id":"116519"}}}},{"type":"items","id":"9087","links":{"self":"https://app.emedici.com/api/items/9087"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16396"}},"activeRevision":{"data":{"type":"itemRevisions","id":"98512"}},"tags":{"data":[{"type":"tags","id":"7"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4930"},{"type":"tags","id":"4941"},{"type":"tags","id":"4950"},{"type":"tags","id":"5937"},{"type":"tags","id":"7114"},{"type":"tags","id":"10389"}]},"contributions":{"data":[{"type":"contributions","id":"21590"},{"type":"contributions","id":"21591"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"116519","links":{"self":"https://app.emedici.com/api/questionRevisions/116519"},"attributes":{"stem":"\u003Cp\u003EA 56-year-old woman presents to the emergency department with difficulty speaking. She appears frustrated as she can only produce short, laboured phrases despite appearing to understand everything being said to her. Neurological examination reveals mild right-sided facial weakness.\u003C/p\u003E","stemQuestion":"Which one of the following brain regions is most closely associated with this language deficit?","responseType":"sba","marks":1,"options":["Wernicke\u0027s area in temporal lobe","Angular gyrus in parietal lobe","Inferior frontal gyrus","Superior temporal gyrus","Supramarginal gyrus"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EThe patient\u0027s presentation is consistent with Broca\u0027s (non-fluent) aphasia. The \u003Cstrong\u003Einferior frontal gyrus\u003C/strong\u003E of the dominant hemisphere contains Broca\u0027s area, which is crucial for speech production. Damage to this area results in difficulty producing fluent speech while maintaining language comprehension.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EWernicke\u0027s area in temporal lobe\u003C/strong\u003E damage causes receptive aphasia with impaired comprehension but preserved fluency. \u003Cstrong\u003EAngular gyrus in parietal lobe\u003C/strong\u003E damage causes difficulty with reading comprehension (alexia) and writing (agraphia). \u003Cstrong\u003ESuperior temporal gyrus\u003C/strong\u003E contains primary auditory cortex and is involved in auditory processing. \u003Cstrong\u003ESupramarginal gyrus\u003C/strong\u003E is involved in phonological processing but not primarily in speech production. The associated right facial weakness is explained by the close proximity of Broca\u0027s area to the primary motor cortex controlling the face.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Broca\u0027s area is located in the inferior frontal gyrus of the dominant (usually left) hemisphere and is crucial for speech production.","Damage to Broca\u0027s area results in non-fluent aphasia, characterised by impaired speech production with preserved comprehension.","Broca\u0027s area lies immediately anterior to the primary motor cortex region controlling face and tongue movements."],"references":["Watari T, Shimizu T, Tokuda Y. Broca aphasia. BMJ Case Rep. 2014 Dec 19;2014:bcr2014208214. doi: 10.1136/bcr-2014-208214. PMID: 25527689; PMCID: PMC4275730.","Wang R, Wiley C. Confusion vs Broca Aphasia: A Case Report. Perm J. 2020;24:19-061. doi: 10.7812/TPP/19-061. Epub 2019 Dec 3. PMID: 31852049; PMCID: PMC6907899.","Acharya AB, Wroten M. Broca Aphasia. 2023 Feb 13. In: StatPearls [Internet]. Treasure Island (FL): StatPearls Publishing; 2024 Jan\u2013. PMID: 28613781."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"98512"}},"question":{"data":{"type":"questions","id":"16396"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"98512","links":{"self":"https://app.emedici.com/api/itemRevisions/98512"},"attributes":{"createdAt":"2025-09-29T16:14:22+09:30","updatedAt":"2025-09-29T16:17:04+09:30"},"relationships":{"item":{"data":{"type":"items","id":"9087"}},"content":{"data":{"type":"questionRevisions","id":"116519"}}},"meta":{"canDelete":false}},{"type":"tags","id":"7","links":{"self":"https://app.emedici.com/api/tags/7"},"attributes":{"emoji":"\ud83e\udde0","name":"Neurology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:45+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.