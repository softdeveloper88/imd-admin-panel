{"data":[{"type":"questionAttempts","id":"17566473","links":{"self":"https://app.emedici.com/api/questionAttempts/17566473"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T23:42:22+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T23:42:22+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18833"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18833","links":{"self":"https://app.emedici.com/api/questions/18833"},"attributes":{"optionProportions":[0.94,0.01,0.03,0.02,0.01]},"relationships":{"item":{"data":{"type":"items","id":"11566"}},"activeRevision":{"data":{"type":"questionRevisions","id":"79615"}}}},{"type":"items","id":"11566","links":{"self":"https://app.emedici.com/api/items/11566"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18833"}},"activeRevision":{"data":{"type":"itemRevisions","id":"64919"}},"tags":{"data":[{"type":"tags","id":"17"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4987"},{"type":"tags","id":"4989"},{"type":"tags","id":"4990"},{"type":"tags","id":"11260"},{"type":"tags","id":"11282"},{"type":"tags","id":"11291"},{"type":"tags","id":"11650"},{"type":"tags","id":"12867"}]},"contributions":{"data":[{"type":"contributions","id":"27223"},{"type":"contributions","id":"27227"},{"type":"contributions","id":"44848"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"79615","links":{"self":"https://app.emedici.com/api/questionRevisions/79615"},"attributes":{"stem":"\u003Cp\u003EA General Practitioner is planning to advertise their new medical practice on social media. They want to ensure their advertising complies with the Medical Board of Australia Guidelines for advertising regulated health services.\u003C/p\u003E","stemQuestion":"Which one of the following would be an appropriate advertising approach?","responseType":"sba","marks":1,"options":["Publishing factual information about available services","Offering discount vouchers for first-time consultations","Including patient testimonials about successful treatments","Comparing cure rates with other local practices","Using before and after treatment photographs"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThe correct approach is \u003Cstrong\u003Epublishing factual information about available services\u003C/strong\u003E. This aligns with the Medical Board of Australia guidelines which require that information published about medical services must be factual and verifiable.\u003C/p\u003E\u003Cp\u003EThe incorrect approaches are problematic because:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EOffering discount vouchers\u003C/strong\u003E - Providing inducements or incentives is not permitted in medical advertising\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EIncluding patient testimonials\u003C/strong\u003E - The use of testimonials in medical advertising is explicitly prohibited\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EComparing cure rates with other local practices\u003C/strong\u003E - Making comparisons between services and those of colleagues is considered unfair and inappropriate\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EUsing before and after treatment photographs\u003C/strong\u003E - Using before and after photos can be misleading and create unrealistic expectations about treatment outcomes\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EMedical advertising must prioritise patient interests and avoid exploitation of vulnerabilities. Information should be presented in a way that helps patients make informed decisions about their healthcare without creating unrealistic expectations or compromising professional standards.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Medical advertising must be factual, verifiable and comply with relevant legislation and guidelines.","Medical professionals must not use testimonials, offer inducements, or make unfair comparisons in advertising.","Medical advertisements must not exploit patient vulnerabilities or create unrealistic expectations."],"references":["Medical Board of Australia. Good medical practice: a code of conduct for doctors in Australia [online]. 2020 [Cited 2025 Jan 15]. Available at: https://www.medicalboard.gov.au/codes-guidelines-policies/code-of-conduct.aspx."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"64919"}},"question":{"data":{"type":"questions","id":"18833"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"64919","links":{"self":"https://app.emedici.com/api/itemRevisions/64919"},"attributes":{"createdAt":"2025-01-15T11:00:34+10:30","updatedAt":"2025-01-15T11:01:03+10:30"},"relationships":{"item":{"data":{"type":"items","id":"11566"}},"content":{"data":{"type":"questionRevisions","id":"79615"}}},"meta":{"canDelete":false}},{"type":"tags","id":"17","links":{"self":"https://app.emedici.com/api/tags/17"},"attributes":{"emoji":"\ud83d\ude07","name":"Bioethics","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical med