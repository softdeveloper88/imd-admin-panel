{"data":[{"type":"questionAttempts","id":"17487560","links":{"self":"https://app.emedici.com/api/questionAttempts/17487560"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T03:14:50+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T03:14:50+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"389"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"389","links":{"self":"https://app.emedici.com/api/questions/389"},"attributes":{"optionProportions":[0.81,0.03,0.02,0.03,0.11]},"relationships":{"item":{"data":{"type":"items","id":"389"}},"activeRevision":{"data":{"type":"questionRevisions","id":"30407"}}}},{"type":"items","id":"389","links":{"self":"https://app.emedici.com/api/items/389"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"389"}},"activeRevision":{"data":{"type":"itemRevisions","id":"16349"}},"tags":{"data":[{"type":"tags","id":"34"},{"type":"tags","id":"64"},{"type":"tags","id":"72"},{"type":"tags","id":"1984"}]},"contributions":{"data":[{"type":"contributions","id":"945"},{"type":"contributions","id":"31039"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"30407","links":{"self":"https://app.emedici.com/api/questionRevisions/30407"},"attributes":{"stem":"\u003Cp\u003EA 30-year-old man presents with a six hour history of sudden onset of joint pain and swelling in his left knee. He denies any history of trauma. His medical history includes haemophilia A and asthma. On examination, his pulse rate is 98/min, blood pressure 130/70mmHg, respiratory rate 18/min, oxygen saturation 96% on room air, and temperature 37.8C. The left knee is diffusely swollen, but not tender. The range of motion is approximately 20 degrees flexion. Anterior drawer test and McMurray\u0027s tests are negative.\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Haemarthrosis","Osgood-Schlatters syndrome","Spontaneous anterior cruciate ligament rupture","Gout","Septic arthritis"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EIn the absence of trauma, a cruciate ligament injury is unlikely and the physical findings bear that out. The patient is in the wrong age group for Osgood-Schlatters disease. Gout typically occurs in older patients and presents with severe, acute pain and is often in the setting of heavy, continued alcohol consumption. With septic arthritis, the joint would be tender and the patient may also have evidence of systemic infection. With his history of haemophilia A, a \u003Cstrong\u003Ehaemarthrosis \u003C/strong\u003Ebecomes the most likely diagnosis.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Haemarthrosis is a common cause of non-traumatic joint pain in patients with haemophilia"],"references":["Knobe K, Berntorp E. Haemophilia and joint disease: pathophysiology, evaluation, and management.\u00a0J Comorb. 2011;1:51\u201359. Published 2011 Dec 27. doi:10.15256/joc.2011.1.2."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"16349"}},"question":{"data":{"type":"questions","id":"389"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"16349","links":{"self":"https://app.emedici.com/api/itemRevisions/16349"},"attributes":{"createdAt":"2022-11-29T06:37:03+10:30","updatedAt":"2022-11-29T06:37:03+10:30"},"relationships":{"item":{"data":{"type":"items","id":"389"}},"content":{"data":{"type":"questionRevisions","id":"30407"}}},"meta":{"canDelete":false}},{"type":"tags","id":"34","links":{"self":"https://app.emedici.com/api/tags/34"},"attributes":{"emoji":"\ud83e\uddb4","name":"Orthopaedics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47: