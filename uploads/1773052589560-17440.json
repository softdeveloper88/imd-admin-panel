{"data":[{"type":"questionAttempts","id":"17632810","links":{"self":"https://app.emedici.com/api/questionAttempts/17632810"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T17:44:45+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T17:44:45+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17440"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17440","links":{"self":"https://app.emedici.com/api/questions/17440"},"attributes":{"optionProportions":[0,0,0.64,0.32,0.05]},"relationships":{"item":{"data":{"type":"items","id":"10130"}},"activeRevision":{"data":{"type":"questionRevisions","id":"70922"}}}},{"type":"items","id":"10130","links":{"self":"https://app.emedici.com/api/items/10130"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17440"}},"activeRevision":{"data":{"type":"itemRevisions","id":"56389"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5531"},{"type":"tags","id":"5532"}]},"contributions":{"data":[{"type":"contributions","id":"23730"},{"type":"contributions","id":"23833"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"70922","links":{"self":"https://app.emedici.com/api/questionRevisions/70922"},"attributes":{"stem":"\u003Cp\u003EHealthcare systems around the world use different approaches to fund and deliver medical services to their populations.\u003C/p\u003E","stemQuestion":"Which one of the following best describes Australia\u0027s primary healthcare funding model?","responseType":"sba","marks":1,"options":["Charity-based system","Out-of-pocket payment system","Tax-based universal system","Social insurance system","Private insurance only system"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EAustralia uses a \u003Cstrong\u003Etax-based universal system\u003C/strong\u003E called Medicare, which is primarily funded through general taxation and a specific Medicare levy. This provides universal coverage for all Australian citizens and permanent residents.\u003C/p\u003E    \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E    \u003Cul\u003E        \u003Cli\u003EA \u003Cstrong\u003Echarity-based system\u003C/strong\u003E would rely on charitable organisations to provide healthcare services, whereas Australia\u0027s system is funded through government taxation.\u003C/li\u003E        \u003Cli\u003EAn \u003Cstrong\u003Eout-of-pocket payment system\u003C/strong\u003E would require patients to pay directly for healthcare services at the point of delivery, which is not Australia\u0027s primary model.\u003C/li\u003E        \u003Cli\u003EA \u003Cstrong\u003Esocial insurance system\u003C/strong\u003E involves mandatory employment-based insurance contributions, which is used in countries like Germany but not in Australia.\u003C/li\u003E        \u003Cli\u003EA \u003Cstrong\u003Eprivate insurance only system\u003C/strong\u003E would rely solely on private health insurance, whereas Australia uses this as a complement to the public system.\u003C/li\u003E    \u003C/ul\u003E    \u003Cp\u003EThe tax-based system ensures universal access to healthcare regardless of ability to pay, with additional private options available for those who choose them.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Healthcare funding models can be classified as tax-based, social insurance, private insurance, or out-of-pocket systems.","Tax-based healthcare systems like Australia\u0027s Medicare are funded through general taxation and provide universal coverage.","Social insurance systems require mandatory contributions from workers and employers to fund healthcare."],"references":["Angeles MR, Crosland P, Hensher M. Challenges for Medicare and universal health care in Australia since 2000. Med J Aust. 2023;218(7):322-329. doi:10.5694/mja2.51844"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"56389"}},"question":{"data":{"type":"questions","id":"17440"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"56389","links":{"self":"https://app.emedici.com/api/itemRevisions/56389"},"attributes":{"createdAt":"2024-12-16T15:18:16+10:30","updatedAt":"2024-12-16T15:19:32+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10130"}},"content":{"data":{"type":"questionRevisions","id":"70922"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"5326","links":{"self":"https://app.emedici.com/api/tags/5326"},"attributes":{"emoji":"\ud83c\udf0f","name":"Public Health","synonyms":null,"description":null,"position":null,"createdAt":"2024-10-24T05:44:22+10:30","updatedAt":"2024-10-24T05:44:22+10:30