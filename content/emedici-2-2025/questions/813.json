tags","id":"9598"},{"type":"tags","id":"11625"},{"type":"tags","id":"11630"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"727"},{"type":"contributions","id":"42155"},{"type":"contributions","id":"43818"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"67931","links":{"self":"https://app.emedici.com/api/questionRevisions/67931"},"attributes":{"stem":"\u003Cp\u003EAn 83-year-old woman with known gallstones presents with a two day history of fever, chills and right upper quadrant pain. She looks unwell, with a temperature of 38.6C, blood pressure of 110/60 mmHg and pulse rate of 100/min. Her sclera are tinged yellow and her abdomen is soft, with no localised tenderness.\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Acute cholecystitis","Bilary colic","Cholangitis","Acute pancreatitis","Acute hepatitis"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient has \u003Cstrong\u003Echolangitis\u003C/strong\u003E, as defined by Charcot\u0027s triad:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EFever (rigors)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003ERight upper quadrant pain\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EJaundice\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThe fact that the patient is known to have gallstones makes it most likely that her current problem is stone-related. The presence of upper abdominal pain does not imply localised tenderness. If upper abdominal tenderness is present, the patient may well have an inflammatory process (\u003Cstrong\u003Echolecystitis\u003C/strong\u003E) rather than bile duct sepsis. Sometimes abdominal tenderness is evident in patients with cholangitis, but its presence is not a prerequisite for the diagnosis of cholangitis.\u003C/p\u003E\u003Cp\u003EThe pain associated with \u003Cstrong\u003Ebiliary colic\u003C/strong\u003E is constant in nature and usually only last minutes or a few hours. \u003Cstrong\u003EAcute pancreatitis\u003C/strong\u003E tends to be associated with epigastric pain, often going through to the back. Fever and chills would be unusual with this condition and jaundice is not a typical feature. \u003Cstrong\u003EAcute hepatitis\u003C/strong\u003E could produce a similar picture, but chills and a fever of this degree would not be typical.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Charcot\u0027s triad points to cholangitis."],"references":["Wah DLC, Christophi C, Muralidharan V. Acute cholangitis: current concepts. ANZ J Surg 2017; 87:554-59. Available from: https://pubmed.ncbi.nlm.nih.gov/28337833/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"53396"}},"question":{"data":{"type":"questions","id":"813"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"53396","links":{"self":"https://app.emedici.com/api/itemRevisions/53396"},"attributes":{"createdAt":"2024-12-07T23:01:25+10:30","updatedAt":"2024-12-07T23:01:25+10:30"},"relationships":{"item":{"data":{"type":"items","id":"813"}},"content":{"data":{"type":"questionRevisions","id":"67931"}}},"meta":{"canDelete":false}},{"type":"tags","id":"5","links":{"self":"https://app.emedici.com/api/tags/5"},"attributes":{"emoji":"\ud83d\udd2d","name":"Gastroenterology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"19","links":{"self":"https://app.emedici.com/api/tags/19"},"attributes":{"emoji":"\ud83d\udd2a","name":"General Surgery","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:20+10:30"},"relationships":{"group":{"data":{