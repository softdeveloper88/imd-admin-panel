{"data":[{"type":"questionAttempts","id":"17639226","links":{"self":"https://app.emedici.com/api/questionAttempts/17639226"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T19:04:19+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T19:04:19+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17765"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17765","links":{"self":"https://app.emedici.com/api/questions/17765"},"attributes":{"optionProportions":[0.07,0.76,0.04,0.09,0.04]},"relationships":{"item":{"data":{"type":"items","id":"10479"}},"activeRevision":{"data":{"type":"questionRevisions","id":"72390"}}}},{"type":"items","id":"10479","links":{"self":"https://app.emedici.com/api/items/10479"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17765"}},"activeRevision":{"data":{"type":"itemRevisions","id":"57860"}},"tags":{"data":[{"type":"tags","id":"2"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"1036"},{"type":"tags","id":"2602"},{"type":"tags","id":"4926"},{"type":"tags","id":"4947"},{"type":"tags","id":"8133"},{"type":"tags","id":"9787"},{"type":"tags","id":"10964"}]},"contributions":{"data":[{"type":"contributions","id":"24458"},{"type":"contributions","id":"24461"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"72390","links":{"self":"https://app.emedici.com/api/questionRevisions/72390"},"attributes":{"stem":"\u003Cp\u003EA patient has suspected heart failure. An ECG shows left ventricular hypertrophy. Blood tests reveal elevated B-type natriuretic peptide (BNP) levels. \u003C/p\u003E","stemQuestion":"Which one of the following is the gold-standard investigation for diagnosing heart failure?","responseType":"sba","marks":1,"options":["Electrocardiogram","Echocardiography","Chest X-ray","Coronary angiography","Cardiac MRI"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EEchocardiography\u003C/strong\u003E is the gold-standard investigation for diagnosing heart failure. It provides comprehensive information about cardiac structure and function, including ejection fraction, wall motion abnormalities, and valvular function. This information is crucial for confirming the diagnosis of heart failure and guiding management.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EChest X-rays\u003C/strong\u003E can show signs of heart failure such as cardiomegaly and pulmonary congestion, but it does not provide detailed information about cardiac function.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EElectrocardiograms\u003C/strong\u003E can show features associated with heart failure, such as left ventricular hypertrophy or arrhythmias, but are not diagnostic of heart failure. \u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECardiac MRI\u003C/strong\u003E offers detailed imaging of cardiac structures and is useful in specific cases, such as assessing myocardial viability, but it is not routinely used as the first-line investigation for heart failure.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECoronary angiography\u003C/strong\u003E is used to assess coronary artery disease, which can be a cause of heart failure, but it does not directly assess cardiac function or diagnose heart failure.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Echocardiography is the gold-standard investigation for diagnosing heart failure.","Echocardiography provides detailed information about cardiac structure and function, including ejection fraction."],"references":["Modin D, Andersen DM, Biering-S\u00f8rensen T. Echo and heart failure: when do people need an echo, and when do they need natriuretic peptides?. Echo Res Pract. 2018;5(2):R65-R79. doi:10.1530/ERP-18-0004","Inamdar AA, Inamdar AC. Heart Failure: Diagnosis, Management and Utilization. J Clin Med. 2016 Jun 29;5(7):62. doi: 10.3390/jcm5070062. PMID: 27367736; PMCID: PMC4961993.","King M, Kingery J, Casey B. Diagnosis and evaluation of heart failure. Am Fam Physician. 2012 Jun 15;85(12):1161-8. PMID: 22962896."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"57860"}},"question":{"data":{"type":"questions","id":"17765"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"57860","links":{"self":"https://app.emedici.com/api/itemRevisions/57860"},"attributes":{"createdAt":"2024-12-21T11:51:25+10:30","updatedAt":"2024-12-21T11:51:59+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10479"}},"content":{"data":{"type":"questionRevisions","id":"72390"}}},"meta":{"canDelete":false}},{"type":"tags","id":"2","links":{"self":"https://app.emedici.com/api/tags/2"},"attributes":{"emoji":"\ud83e\udec0","name":"Cardiology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:21+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74