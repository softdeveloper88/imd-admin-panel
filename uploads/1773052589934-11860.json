{"data":[{"type":"questionAttempts","id":"17583585","links":{"self":"https://app.emedici.com/api/questionAttempts/17583585"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T07:20:04+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T07:20:04+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"11860"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"11860","links":{"self":"https://app.emedici.com/api/questions/11860"},"attributes":{"optionProportions":[0.37,0.24,0.06,0.11,0.21]},"relationships":{"item":{"data":{"type":"items","id":"4460"}},"activeRevision":{"data":{"type":"questionRevisions","id":"84795"}}}},{"type":"items","id":"4460","links":{"self":"https://app.emedici.com/api/items/4460"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"11860"}},"activeRevision":{"data":{"type":"itemRevisions","id":"69091"}},"tags":{"data":[{"type":"tags","id":"29"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"1114"},{"type":"tags","id":"2765"},{"type":"tags","id":"4926"},{"type":"tags","id":"4950"},{"type":"tags","id":"9787"}]},"contributions":{"data":[{"type":"contributions","id":"6449"},{"type":"contributions","id":"6492"},{"type":"contributions","id":"28849"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"84795","links":{"self":"https://app.emedici.com/api/questionRevisions/84795"},"attributes":{"stem":"\u003Cp\u003EA 65-year-old man presents to the Emergency Department with chest pain, nausea, sweating, and shortness of breath. His symptoms began 30 minutes ago with sudden-onset left-sided chest pain radiating to his neck and jaw. His blood pressure is 110/60 mmHg, pulse rate 80/min, and respiratory rate 20/min. An electrocardiogram shows ST segment elevation in the anterior leads.\u003C/p\u003E","stemQuestion":"Which one of the following markers is expected to be elevated if measured within one hour of symptom onset?","responseType":"sba","marks":1,"options":["Troponin I","Troponin T","Lactate dehydrogenase","Creatine kinase","Myoglobin"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EMyoglobin\u003C/strong\u003E is the earliest biomarker to rise following myocardial injury, becoming detectable within 30 minutes of onset. While it lacks cardiac specificity, its rapid kinetics make it useful for early detection of muscle injury.\u003C/p\u003E\u003Cp\u003EThe other markers rise later:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003ETroponin I\u003C/strong\u003E and \u003Cstrong\u003ETroponin T\u003C/strong\u003E begin rising 2-4 hours after injury and peak at 24 hours\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ELactate dehydrogenase\u003C/strong\u003E rises 6-12 hours after injury, peaks at 24-72 hours, and normalises in 8-14 days\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ECreatine kinase\u003C/strong\u003E rises 3-6 hours after injury and peaks between 16-30 hours\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EWhile myoglobin would be elevated earliest in this scenario, it is not routinely used clinically due to its lack of cardiac specificity. Modern practice relies primarily on serial troponin measurements along with clinical assessment and electrocardiogram findings.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Myoglobin is the earliest cardiac biomarker to rise, detectable within 30 minutes of myocardial injury","Troponins begin rising 2-4 hours after myocardial injury and peak at 24 hours","Creatine kinase and lactate dehydrogenase rise later than troponin following myocardial injury, after 3-6 hours and 6-12 hours respectively"],"references":["Aydin S, Ugur K, Aydin S, Sahin \u0130, Yardim M. Biomarkers in acute myocardial infarction: current perspectives. Vasc Health Risk Manag. 2019;15:1-10. Available at: https://pmc.ncbi.nlm.nih.gov/articles/PMC6340361/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"69091"}},"question":{"data":{"type":"questions","id":"11860"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"69091","links":{"self":"https://app.emedici.com/api/itemRevisions/69091"},"attributes":{"createdAt":"2025-02-11T12:55:23+10:30","updatedAt":"2025-06-19T13:19:05+09:30"},"relationships":{"item":{"data":{"type":"items","id":"4460"}},"content":{"data":{"type":"questionRevisions","id":"84795"}}},"meta":{"canDelete":false}},{"type":"tags","id":"29","links":{"self":"https://app.emedici.com/api/tags/29"},"attributes":{"emoji":"\ud83d\udd2c","name":"Pathology","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"4"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Level II","synonyms":null,"description":"Understand (interpreting and summarizing information)","position":null,"createdAt":null,"updatedAt":null},"re