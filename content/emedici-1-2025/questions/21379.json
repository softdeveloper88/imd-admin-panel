{"data":[{"type":"questionAttempts","id":"17413890","links":{"self":"https://app.emedici.com/api/questionAttempts/17413890"},"attributes":{"position":28,"marks":1,"score":0,"answeredAt":"2025-09-28T08:32:07+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T08:32:07+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":{"type":"questionSessions","id":"1261100"}},"session":{"data":{"type":"questionSessions","id":"1261100"}},"question":{"data":{"type":"questions","id":"21379"}},"bookmark":{"data":null}}},{"type":"questionAttempts","id":"17568762","links":{"self":"https://app.emedici.com/api/questionAttempts/17568762"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T00:21:58+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T00:21:58+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"21379"}},"bookmark":{"data":null}}}],"included":[{"type":"questionSessions","id":"1261100","links":{"self":"https://app.emedici.com/api/questionSessions/1261100"},"attributes":{"startedAt":"2025-09-28T07:52:04+09:30","updatedAt":"2025-09-28T10:28:52+09:30","sessionType":"qbank","questionStatus":"all","difficulty":[],"timeLimit":null,"questionCount":62,"questionsAnswered":61,"marksTotal":61,"marksAttainable":61,"marksAttempted":61,"finishedAt":"2025-09-28T09:15:31+09:30","resultsAvailable":true,"score":0.2,"questionsCorrect":12,"marksCorrect":12},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"pack":{"data":{"type":"packs","id":"5"}},"exam":{"data":null}}},{"type":"questions","id":"21379","links":{"self":"https://app.emedici.com/api/questions/21379"},"attributes":{"optionProportions":[0.04,0.02,0.3,0.48,0.16]},"relationships":{"item":{"data":{"type":"items","id":"14252"}},"activeRevision":{"data":{"type":"questionRevisions","id":"101103"}}}},{"type":"items","id":"14252","links":{"self":"https://app.emedici.com/api/items/14252"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"21379"}},"activeRevision":{"data":{"type":"itemRevisions","id":"83537"}},"tags":{"data":[{"type":"tags","id":"11"},{"type":"tags","id":"23"},{"type":"tags","id":"25"},{"type":"tags","id":"64"},{"type":"tags","id":"73"},{"type":"tags","id":"78"},{"type":"tags","id":"147"},{"type":"tags","id":"1374"},{"type":"tags","id":"2166"},{"type":"tags","id":"4927"},{"type":"tags","id":"4982"},{"type":"tags","id":"11625"},{"type":"tags","id":"12799"},{"type":"tags","id":"12804"}]},"contributions":{"data":[{"type":"contributions","id":"34764"},{"type":"contributions","id":"43746"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"101103","links":{"self":"https://app.emedici.com/api/questionRevisions/101103"},"attributes":{"stem":"\u003Cp\u003EA 28-year-old woman presents to the antenatal clinic at 36 weeks gestation for routine care. She has moderate asthma which has been managed with regular inhaled corticosteroids and as-needed salbutamol throughout her pregnancy. She required a short course of oral prednisolone at 20 weeks gestation for an exacerbation. She has no other significant medical history and takes only her asthma medications and pregnancy vitamins. She works as a primary school teacher and has continued working throughout her pregnancy.\u003C/p\u003E\u003Cp\u003EOn examination, she appears well with vital signs within normal limits. Her fundal height is appropriate for gestational age and fetal movements are normal. Her chest is clear on auscultation with good air entry bilaterally.\u003C/p\u003E\u003Cp\u003EShe expresses concern about the possibility of having an acute asthma attack during labour and asks about the likelihood of this occurring.\u003C/p\u003E","stemQuestion":"Which one of the following statements regarding asthma during labour is most accurate?","responseType":"sba","marks":1,"options":["Epidural analgesia is contraindicated due to increased risk of respiratory depression","All asthma medications should be withheld during active labour","Acute asthma exacerbations occur in approximately 20% of women with asthma during labour","Acute asthma in labour is unlikely because of increased endogenous corticosteroids at this time","Prophylactic oral corticosteroids should be administered at the onset of labour"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThis scenario addresses the management and expectations of asthma during pregnancy and labour. Asthma affects approximately 7% of pregnant women in Australia and appropriate management is essential for maternal and fetal wellbeing.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAcute asthma in labour is unlikely because of increased endogenous corticosteroids at this time\u003C/strong\u003E is correct. During labour, there is a natural surge in endogenous corticosteroids, which have anti-inflammatory properties similar to those of pharmacological corticosteroids used to treat asthma. This physiological response helps protect against bronchospasm and reduces the likelihood of asthma exacerbations during labour. \u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAll asthma medications should be withheld during active labour\u003C/strong\u003E is incorrect and potentially dangerous. Current guidelines recommend continuation of regular asthma medications throughout pregnancy and labour. Withholding medications could lead to loss of asthma control, which poses greater risks to both mother and fetus than the medications themselves. Poorly controlled asthma during pregnancy and labour is associated with increased risks of preeclampsia, preterm birth, low birth weight, and perinatal mortality.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EProphylactic oral corticosteroids should be administered at the onset of labour\u003C/strong\u003E is incorrect. There is no evidence supporting the routine use of prophylactic oral corticosteroids for women with asthma during labour. Such an approach would expose the mother and fetus to unnecessary medication. However, women who have been taking oral corticosteroids during pregnancy should receive stress-dose steroids during labour.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EEpidural analgesia is contraindicated due to increased risk of respiratory depression\u003C/strong\u003E is incorrect. Epidural analgesia is actually preferred for pain management during labour in women with asthma, as it provides effective pain relief without the respiratory depressant effects associated with some systemic opioids. Good pain control is important as pain and stress can trigger asthma symptoms.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAcute asthma exacerbations occur in approximately 20% of women with asthma during labour\u003C/strong\u003E is incorrect. The actual rate of asthma exacerbations during labour is much lower, estimated at less than 2% of women with asthma. This low rate is attributed to the protective effect of increased endogenous corticosteroids during labour and the tendency for asthma to improve in the later stages of pregnancy.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Endogenous corticosteroids increase during labour, reducing the risk of acute asthma exacerbations.","Asthma severity often improves during pregnancy, particularly in the third trimester.","Continuation of regular asthma medications during pregnancy and labour is recommended to maintain optimal control."],"references":["Nelson-Piercy C. Handbook of obstetric medicine. 6th ed. Boca Raton: CRC Press; 2021."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"83537"}},"question":{"data":{"type":"questions","id":"21379"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"83537","links":{"self":"https://app.emedici.com/api/itemRevisions/83537"},"attributes":{"createdAt":"2025-04-30T06:56:26+09:30","updatedAt":"2025-04-30T06:57:13+09:30"},"relationships":{"item":{"data":{"type":"items","id":"14252"}},"content":{"data":{"type":"questionRevisions","id":"101103"}}},"meta":{"canDelete":false}},{"type":"tags","id":"11","links":{"self":"https://app.emedici.com/api/tags/11"},"attributes":{"emoji":"\ud83e\udec1","name":"Respiratory Medicine","synonyms":["Pulmonology"],"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"23","links":{"self":"https://app.emedici.com/api/tags/23"},"attributes":{"emoji":"\ud83e\udd30","name":"Obstetrics","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"3"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"64","links":{"self":"https://app.emedici.com/api/tags/64"},"attributes":{"emoji":"","name":"Diagnosis","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"73","links":{"self":"https://app.emedici.com/api/tags/73"},"attributes":{"emoji":"","name":"Post-graduate","synonyms":null,"description":"Not suitable for a medical student","position":2,"createdAt":null,"updatedAt":null},"relatio