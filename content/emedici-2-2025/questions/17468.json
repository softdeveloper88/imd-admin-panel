{"data":[{"type":"questionAttempts","id":"17633175","links":{"self":"https://app.emedici.com/api/questionAttempts/17633175"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T17:49:34+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T17:49:34+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17468"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17468","links":{"self":"https://app.emedici.com/api/questions/17468"},"relationships":{"item":{"data":{"type":"items","id":"10158"}},"activeRevision":{"data":{"type":"questionRevisions","id":"70812"}}}},{"type":"items","id":"10158","links":{"self":"https://app.emedici.com/api/items/10158"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17468"}},"activeRevision":{"data":{"type":"itemRevisions","id":"56278"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5496"}]},"contributions":{"data":[{"type":"contributions","id":"23758"},{"type":"contributions","id":"23807"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"70812","links":{"self":"https://app.emedici.com/api/questionRevisions/70812"},"attributes":{"stem":"\u003Cp\u003EPublic health measures are essential for controlling the spread of infectious diseases in populations.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the public health practice of quarantine?","responseType":"sba","marks":1,"options":["Treating infected individuals with antibiotics","Decontaminating infected environments","Vaccinating exposed individuals prophylactically","Separating exposed individuals to monitor for illness","Isolating individuals with confirmed infection"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003ESeparating exposed individuals to monitor for illness\u003C/strong\u003E is the definition of quarantine. This practice helps prevent disease transmission by restricting the movement of people who may have been exposed to an infectious disease but are not yet showing symptoms.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003ETreating infected individuals with antibiotics\u003C/strong\u003E represents a therapeutic intervention for managing individual cases rather than a population-level control measure.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EDecontaminating infected environments\u003C/strong\u003E refers to environmental cleaning and sanitisation procedures which aim to eliminate pathogens from surfaces and spaces.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EVaccinating exposed individuals prophylactically\u003C/strong\u003E describes post-exposure prophylaxis, which is a specific preventive intervention for individuals after exposure.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EIsolating individuals with confirmed infection\u003C/strong\u003E describes isolation, a distinct practice from quarantine that involves separating people with known infections from the general population.\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EQuarantine remains an important public health tool, particularly for emerging infectious diseases where other control measures may not yet be available.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Quarantine separates and restricts movement of people who were exposed to a contagious disease to see if they become sick.","Isolation differs from quarantine as it separates people who are already known to be infected.","The term quarantine originated from the 40-day period ships were required to anchor before allowing crew to disembark during plague outbreaks."],"references":["Shultz JM, Sullivan LM, Galea S. Public Health: An Introduction to the Science and Practice of Population Health. Springer Publishing Company; 2021."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"56278"}},"question":{"data":{"type":"questions","id":"17468"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"56278","links":{"self":"https://app.emedici.com/api/itemRevisions/56278"},"attributes":{"createdAt":"2024-12-16T14:13:46+10:30","updatedAt":"2024-12-16T14:14:23+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10158"}},"content":{"data":{"type":"questionRevisions","id":"70812"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"5326","links":{"self":"https://app.emedici.com/api/tags/5326"},"attributes":{"emoji":"\ud83c\udf0f","name":"Public Health","synonyms":null,"description":null,"position":null,"createdAt":"2024-10-24T05:44:22+10:30","updatedAt":"2024-1