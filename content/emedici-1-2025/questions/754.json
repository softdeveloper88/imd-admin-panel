{"data":[{"type":"questionAttempts","id":"17489833","links":{"self":"https://app.emedici.com/api/questionAttempts/17489833"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T04:32:18+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T04:32:18+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"754"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"754","links":{"self":"https://app.emedici.com/api/questions/754"},"attributes":{"optionProportions":[0.36,0.48,0.04,0.05,0.06]},"relationships":{"item":{"data":{"type":"items","id":"754"}},"activeRevision":{"data":{"type":"questionRevisions","id":"92382"}}}},{"type":"items","id":"754","links":{"self":"https://app.emedici.com/api/items/754"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"754"}},"activeRevision":{"data":{"type":"itemRevisions","id":"75687"}},"tags":{"data":[{"type":"tags","id":"11"},{"type":"tags","id":"24"},{"type":"tags","id":"25"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"272"},{"type":"tags","id":"1114"},{"type":"tags","id":"2280"},{"type":"tags","id":"4174"},{"type":"tags","id":"4961"},{"type":"tags","id":"4982"},{"type":"tags","id":"4987"},{"type":"tags","id":"4992"},{"type":"tags","id":"8118"},{"type":"tags","id":"11625"},{"type":"tags","id":"11630"},{"type":"tags","id":"11642"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"31543"},{"type":"contributions","id":"31544"},{"type":"contributions","id":"35807"},{"type":"contributions","id":"37844"},{"type":"contributions","id":"41901"},{"type":"contributions","id":"42139"},{"type":"contributions","id":"43035"},{"type":"contributions","id":"47014"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"92382","links":{"self":"https://app.emedici.com/api/questionRevisions/92382"},"attributes":{"stem":"\u003Cp\u003EA previously well 32-year-old man presents to the Emergency Department following an episode of pleuritic chest pain and shortness of breath which occurred after a bout of coughing. He initially went to see his General Practitioner who organised a chest X-ray (Image). When the practitioner saw the X-ray he suggested that the patient attend the Emergency Department. The pain had occurred twelve hours earlier and the patient is now symptom-free.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate next step in management?","responseType":"sba","marks":1,"options":["Review the following day","Admit for observation","Aspiration","Insertion of a Heimlich valve","Underwater sealed drain"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThe chest X-ray shows a small \u0026lt;15% left sided pneumothorax and some subcutaneous emphysema (Image). Any asymptomatic small pneumothorax in an otherwise fit and healthy patient can be safely left alone. The British Thoracic Society defines a small pneumothorax as one where there is less than a 2 cm rim between the outer lung margin and the chest wall at the level of the hilum. Whilst a short (hours) period of observation may be appropriate, there is no need to admit this patient to hospital.\u003C/p\u003E\u003Cp\u003EIt will still be prudent to \u003Cstrong\u003Ereview the patient the following day\u003C/strong\u003E to ensure the pneumothorax has resolved. A larger pneumothorax should be drained and one that is smaller should be aspirated if it is causing symptoms. Pleurodesis is reserved for recurrent pneumothoraces.\u003C/p\u003E\u003Cp\u003E\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["The small, asymptomatic pneumothorax in a young, fit individual with no respiratory problems can safely be managed on an outpatient basis."],"references":["MacDuff A, Arnold A \u0026 Harvey J (2010). Management of spontaneous pneumothorax: British Thoracic Society pleural disease guideline 2010. Thorax 65, ii18-ii31."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"75687"}},"question":{"data":{"type":"questions","id":"754"}},"stemMedia":{"data":[{"type":"media","id":"19650"}]},"explanationMedia":{"data":[{"type":"media","id":"20418"}]}}},{"type":"media","id":"19650","links":{"self":"https://app.emedici.com/api/media/19650"},"attributes":{"mimeType":"image/jpeg","url":"https://app.emedici.com/storage/media/9d15443f-1200-44ca-a77b-e7cf90ddb993.jpg","thumbUrl":"https://app.emedici.com/storage/media/9d15443f-1200-44ca-a77b-e7cf90ddb993.jpg","isProcessed":true,"width":496,"height":600}},{"type":"media","id":"20418","links":{"self":"https://app.emedici.com/api/media/20418"},"attributes":{"mimeType":"image/jpeg","url":"https://app.emedici.com/storage/media/Wip5OsJ7AKq7NEBEIcXIhX3LV5AOqS.jpg","thumbUrl":"https://app.emedici.com/storage/media/Wip5OsJ7AKq7NEBEIcXIhX3LV5AOqS.jpg","isProcessed":true,"width":500,"height":600}},{"type":"itemRevisions","id":"75687","links":{"self":"https://app.emedici.com/api/itemRevisions/75687"},"attributes":{"createdAt":"2025-03-17T14:50:40+10:30","updatedAt":"2025-05-12T15:14:57+09:30"},"relationships":{"item":{"data":{"type":"items","id":"754"}},"content":{"data":{"type":"questionRevisions","id":"92382"}}},"meta":{"canDelete":false}},{"type":"tags","id":"11","links":{"self":"https://app.emedici.com/api/tags/11"},"attributes":{"emoji":"\ud83e\udec1","name":"Respiratory Medicine","synonyms":["Pulmonology"],"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"24","links":{"self":"https://app.emedici.com/api/tags/24"},"attributes":{"emoji":"\ud83d\ude91","name":"Emergency Medicine","synonyms":