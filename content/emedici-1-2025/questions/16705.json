{"data":[{"type":"questionAttempts","id":"17414289","links":{"self":"https://app.emedici.com/api/questionAttempts/17414289"},"attributes":{"position":34,"marks":1,"score":0,"answeredAt":"2025-09-28T08:45:09+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T08:44:44+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":{"type":"questionSessions","id":"1261100"}},"session":{"data":{"type":"questionSessions","id":"1261100"}},"question":{"data":{"type":"questions","id":"16705"}},"bookmark":{"data":null}}},{"type":"questionAttempts","id":"17539845","links":{"self":"https://app.emedici.com/api/questionAttempts/17539845"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T17:46:57+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T17:46:57+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16705"}},"bookmark":{"data":null}}}],"included":[{"type":"questionSessions","id":"1261100","links":{"self":"https://app.emedici.com/api/questionSessions/1261100"},"attributes":{"startedAt":"2025-09-28T07:52:04+09:30","updatedAt":"2025-09-28T10:28:52+09:30","sessionType":"qbank","questionStatus":"all","difficulty":[],"timeLimit":null,"questionCount":62,"questionsAnswered":61,"marksTotal":61,"marksAttainable":61,"marksAttempted":61,"finishedAt":"2025-09-28T09:15:31+09:30","resultsAvailable":true,"score":0.2,"questionsCorrect":12,"marksCorrect":12},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"pack":{"data":{"type":"packs","id":"5"}},"exam":{"data":null}}},{"type":"questions","id":"16705","links":{"self":"https://app.emedici.com/api/questions/16705"},"attributes":{"optionProportions":[0.25,0.33,0.19,0.23,0.01]},"relationships":{"item":{"data":{"type":"items","id":"9396"}},"activeRevision":{"data":{"type":"questionRevisions","id":"103868"}}}},{"type":"items","id":"9396","links":{"self":"https://app.emedici.com/api/items/9396"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16705"}},"activeRevision":{"data":{"type":"itemRevisions","id":"86285"}},"tags":{"data":[{"type":"tags","id":"3"},{"type":"tags","id":"22"},{"type":"tags","id":"37"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"4097"},{"type":"tags","id":"4652"},{"type":"tags","id":"4776"},{"type":"tags","id":"4970"},{"type":"tags","id":"4983"},{"type":"tags","id":"11643"},{"type":"tags","id":"11644"},{"type":"tags","id":"12801"}]},"contributions":{"data":[{"type":"contributions","id":"22214"},{"type":"contributions","id":"35021"},{"type":"contributions","id":"35023"},{"type":"contributions","id":"43643"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"103868","links":{"self":"https://app.emedici.com/api/questionRevisions/103868"},"attributes":{"stem":"\u003Cp\u003EA 24-year-old woman presents to the Sexual Health clinic with a five-day history of painful genital ulcers. She reports unprotected sexual intercourse with a new partner two weeks ago. She has no significant medical history and takes no regular medications. She works as a retail assistant.\u003C/p\u003E\u003Cp\u003EOn examination, she appears well with vital signs within normal limits. There are three tender, soft ulcers with undermined edges on the labia majora. The base of the ulcers appears grey and purulent. There is tender unilateral inguinal lymphadenopathy. The remainder of the examination is unremarkable.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate antimicrobial treatment?","responseType":"sba","marks":1,"options":["Azithromycin","Acyclovir","Doxycycline","Benzathine penicillin","Fluconazole"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient presents with clinical features typical of chancroid, caused by \u003Cem\u003EHaemophilus ducreyi\u003C/em\u003E. The characteristic features include painful genital ulcers with undermined edges, a grey or purulent base, and tender inguinal lymphadenopathy (usually unilateral). The incubation period is typically 4-7 days.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAzithromycin\u003C/strong\u003E 1g as a single oral dose is the first-line treatment for chancroid. Alternative regimens include ceftriaxone or ciprofloxacin. Treatment should be accompanied by counselling about safer sex practices and contact tracing.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAcyclovir\u003C/strong\u003E would be appropriate for herpes simplex virus infections, which typically present with multiple vesicles that rupture to form shallow ulcers. The absence of vesicles and the presence of undermined edges make HSV less likely.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EBenzathine penicillin\u003C/strong\u003E is the treatment of choice for syphilis. Primary syphilis presents with a painless chancre, which differs from the painful ulcers seen in chancroid.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EDoxycycline\u003C/strong\u003E is used to treat various sexually transmitted infections including chlamydia, but is not the first-line treatment for chancroid. However, it can be used as an alternative if azithromycin is contraindicated.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EFluconazole\u003C/strong\u003E is an antifungal medication used to treat candidiasis, which typically presents with vaginal discharge and irritation rather than ulcers.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Chancroid is caused by Haemophilus ducreyi and presents with painful genital ulcers and tender inguinal lymphadenopathy.","First-line treatment for chancroid is azithromycin as a single dose.","All patients with chancroid should be tested for other sexually transmitted infections including HIV."],"references":["Ngan V, Renaud N, Oakley A. Chancroid: Symptoms, Diagnosis, and Treatment. DermNet New Zealand. April 2018. Available at: https://dermnetnz.org/topics/chancroid"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"86285"}},"question":{"data":{"type":"questions","id":"16705"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"86285","links":{"self":"https://app.emedici.com/api/itemRevisions/86285"},"attributes":{"createdAt":"2025-05-27T18:46:12+09:30","updatedAt":"2025-05-27T18:47:37+09:30"},"relationships":{"item":{"data":{"type":"items","id":"9396"}},"content":{"data":{"type":"questionRevisions","id":"103868"}}},"meta":{"canDelete":false}},{"type":"tags","id":"3","links":{"self":"https://app.emedici.com/api/tags/3"},"attributes":{"emoji":"\ud83e\uddf4","name":"Dermatology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:42+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"22","links":{"self":"https://app.emedici.com/api/tags/22"},"attributes":{"emoji":"\ud83c\udf53","name":"Gynaecology","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"3"}}},"meta":{"itemCount":0}},{"type":"tags","id":"37","links":{"self":"https://app.emedici.com/api/tags/37"},"attributes":{"emoji":"\ud83c\udf46","name":"Sexual Health","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":"Management","synonyms":null,"description":null,"position":null,"create