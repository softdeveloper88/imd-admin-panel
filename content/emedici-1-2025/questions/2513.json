{"data":[{"type":"questionAttempts","id":"17418558","links":{"self":"https://app.emedici.com/api/questionAttempts/17418558"},"attributes":{"position":4,"marks":1,"score":1,"answeredAt":"2025-09-28T10:37:56+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T10:37:56+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":{"type":"questionSessions","id":"1261521"}},"session":{"data":{"type":"questionSessions","id":"1261521"}},"question":{"data":{"type":"questions","id":"2513"}},"bookmark":{"data":null}}},{"type":"questionAttempts","id":"17473543","links":{"self":"https://app.emedici.com/api/questionAttempts/17473543"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-28T22:10:08+09:30","options":[1],"response":null,"finalizedAt":"2025-09-28T22:10:08+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"2513"}},"bookmark":{"data":null}}}],"included":[{"type":"questionSessions","id":"1261521","links":{"self":"https://app.emedici.com/api/questionSessions/1261521"},"attributes":{"startedAt":"2025-09-28T10:36:42+09:30","updatedAt":"2025-09-28T10:37:56+09:30","sessionType":"qbank","questionStatus":"all","difficulty":[],"timeLimit":null,"questionCount":5,"questionsAnswered":5,"marksTotal":5,"marksAttainable":5,"marksAttempted":5,"finishedAt":null,"resultsAvailable":true,"score":0.4,"questionsCorrect":2,"marksCorrect":2},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"pack":{"data":{"type":"packs","id":"5"}},"exam":{"data":null}}},{"type":"questions","id":"2513","links":{"self":"https://app.emedici.com/api/questions/2513"},"attributes":{"optionProportions":[0.27,0.49,0.02,0.07,0.14]},"relationships":{"item":{"data":{"type":"items","id":"2513"}},"activeRevision":{"data":{"type":"questionRevisions","id":"84222"}}}},{"type":"items","id":"2513","links":{"self":"https://app.emedici.com/api/items/2513"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"2513"}},"activeRevision":{"data":{"type":"itemRevisions","id":"68764"}},"tags":{"data":[{"type":"tags","id":"9"},{"type":"tags","id":"25"},{"type":"tags","id":"36"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"763"},{"type":"tags","id":"1196"},{"type":"tags","id":"1295"},{"type":"tags","id":"4954"},{"type":"tags","id":"4969"},{"type":"tags","id":"4970"},{"type":"tags","id":"11638"},{"type":"tags","id":"11644"}]},"contributions":{"data":[{"type":"contributions","id":"2330"},{"type":"contributions","id":"2376"},{"type":"contributions","id":"38927"},{"type":"contributions","id":"44081"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"84222","links":{"self":"https://app.emedici.com/api/questionRevisions/84222"},"attributes":{"stem":"\u003Cp\u003EA three-week-old boy is brought to the General Practice clinic for a routine newborn health check. He was born at 36 weeks gestation via spontaneous vaginal delivery. His parent recently migrated from Sudan and has no prenatal records. He has no significant medical history and takes no regular medications.\u003C/p\u003E\u003Cp\u003EOn examination, he appears well with vital signs within normal limits. Abdominal examination reveals a reducible pea-sized swelling in the right inguinal region superior and lateral to the testicle. The penis has a urethral opening on the ventral surface proximal to the glans. The foreskin is asymmetric with deficient ventral tissue.\u003C/p\u003E","stemQuestion":"Which one of the following is contraindicated in the management of this condition?","responseType":"sba","marks":1,"options":["Indwelling urinary catheter","Circumcision","Prophylactic antibiotics","Laparoscopic hernia repair","Urethroplasty"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EThis infant presents with hypospadias, characterised by an abnormal urethral opening on the ventral surface of the penis, and an associated inguinal hernia. The condition results from incomplete fusion of the urethral folds during embryological development.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECircumcision\u003C/strong\u003E is contraindicated in infants with hypospadias because the foreskin tissue may be required for surgical repair. The ventral foreskin is often deficient in these cases, making circumcision technically difficult and potentially compromising future surgical options.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EUrethroplasty\u003C/strong\u003E is the surgical repair of hypospadias and is indicated when there is significant displacement of the urethral meatus or symptoms affecting micturition. The timing of surgery is typically between 6-18 months of age.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ELaparoscopic hernia repair\u003C/strong\u003E may be required for the associated inguinal hernia. The presence of hypospadias increases the risk of inguinal hernias, and repair prevents complications such as incarceration or strangulation.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EIndwelling urinary catheter\u003C/strong\u003E placement may be necessary following surgical repair or in cases of severe hypospadias affecting urination. It is not contraindicated in these patients.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EProphylactic antibiotics\u003C/strong\u003E are often prescribed perioperatively to prevent urinary tract infections and wound complications following surgical repair. They are an important component of surgical management.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Hypospadias is a contraindication to circumcision in infancy as the foreskin may be required for surgical repair.","Hypospadias commonly co-exists with inguinal hernia and requires surgical evaluation.","Surgical repair of hypospadias (urethroplasty) is indicated for significant displacement or symptomatic micturition."],"references":["Baskin LS, Ebbers MB. Hypospadias: anatomy, etiology, and technique. J Pediatr Surg 2006;41:463. Available at: https://pubmed.ncbi.nlm.nih.gov/16516617/","Snodgrass WT, Koyle MA, Baskin LS, Caldamone AA. Foreskin preservation in penile surgery. J Urol 2006;176:711. Available at: https://pubmed.ncbi.nlm.nih.gov/16813925/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"68764"}},"question":{"data":{"type":"questions","id":"2513"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"68764","links":{"self":"https://app.emedici.com/api/itemRevisions/68764"},"attributes":{"createdAt":"2025-02-08T20:16:25+10:30","updatedAt":"2025-02-08T20:55:30+10:30"},"relationships":{"item":{"data":{"type":"items","id":"2513"}},"content":{"data":{"type":"questionRevisions","id":"84222"}}},"meta":{"canDelete":false}},{"type":"tags","id":"9","links":{"self":"https://app.emedici.com/api/tags/9"},"attributes":{"emoji":"\ud83d\udc76","name":"Paediatrics","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:39:03+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"36","links":{"self":"https://app.emedici.com/api/tags/36"},"attributes":{"emoji":"\ud83e\udd43","name":"Urology","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type"