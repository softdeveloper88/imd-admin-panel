224/relationships/activeRevision"}}}},{"type":"items","id":"224","links":{"self":"https://app.emedici.com/api/items/224"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/224/packs","self":"https://app.emedici.com/api/items/224/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/224/revisions","self":"https://app.emedici.com/api/items/224/relationships/revisions"}},"content":{"data":{"type":"questions","id":"224"},"links":{"related":"https://app.emedici.com/api/items/224/content","self":"https://app.emedici.com/api/items/224/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/224/specialtyTags","self":"https://app.emedici.com/api/items/224/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/224/primaryTags","self":"https://app.emedici.com/api/items/224/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/224/contributionTypes","self":"https://app.emedici.com/api/items/224/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/224/contributors","self":"https://app.emedici.com/api/items/224/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/224/contribution","self":"https://app.emedici.com/api/items/224/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/224/myContribution","self":"https://app.emedici.com/api/items/224/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"100514"},"links":{"related":"https://app.emedici.com/api/items/224/activeRevision","self":"https://app.emedici.com/api/items/224/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"19"},{"type":"tags","id":"25"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"247"},{"type":"tags","id":"262"},{"type":"tags","id":"1217"},{"type":"tags","id":"1432"},{"type":"tags","id":"1501"},{"type":"tags","id":"8088"},{"type":"tags","id":"11063"}],"links":{"related":"https://app.emedici.com/api/items/224/tags","self":"https://app.emedici.com/api/items/224/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"1772"},{"type":"contributions","id":"2740"},{"type":"contributions","id":"45479"},{"type":"contributions","id":"47826"},{"type":"contributions","id":"49110"}],"links":{"related":"https://app.emedici.com/api/items/224/contributions","self":"https://app.emedici.com/api/items/224/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"118703","links":{"self":"https://app.emedici.com/api/questionRevisions/118703"},"attributes":{"stem":"\u003Cp\u003EA 26-year-old woman presents to the General Practice clinic with a five-month history of a painless swelling in her right breast that she notices more around her periods. She has no significant medical history. She does not take any regular medications. She does not smoke and drinks alcohol socially within recommended limits. There is no recent travel.\u003C/p\u003E\u003Cp\u003EOn examination, she appears well with vital signs within normal limits. There is a 15 mm mobile, rubbery, well-circumscribed swelling in the upper outer quadrant of the right breast without overlying skin changes, nipple discharge, or axillary lymphadenopathy. The remainder of the breast examination is unremarkable.\u003C/p\u003E\u003Cp\u003EInvestigations reveal an ultrasound showing a low-density, well-defined ovoid mass without posterior acoustic shadowing, and fine needle aspiration cytology demonstrating a hypercellular sample with monolayer sheets of benign-appearing epithelial cells admixed with myoepithelial cells.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate plan of management?","responseType":"sba","marks":1,"options":["Reassurance with clinical review in three months","Repeat targeted ultrasound in three months","Core needle biopsy","Repeat targeted ultrasound in one year","Surgical excision"],"correctOptions":[1],"correctResponses":[],"explanation":"\u003Cp\u003EThe clinical, ultrasonographic and cytological features of this swelling support a diagnosis of fibroadenoma. Fibroadenoma is a common benign breast lesion in young adults. When clinical examination, breast imaging, and tissue sampling (the triple assessment) are concordant for a benign lesion, conservative management is appropriate. Short-interval clinical follow-up provides safety netting for the small false-negative rate of cytology and reassures the person.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EReassurance with clinical review in three months\u003C/strong\u003E is insufficient as a more detailed assessment with ultrasonography is recommended.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ERepeat targeted ultrasound in three months\u003C/strong\u003E is recommended to assess the mass for growth. If the fibroadenoma remains unchanged, no further follow-up is required. The patient should then be reassured and asked to return for review if any change in the size of the mass is noted.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ECore needle biopsy\u003C/strong\u003E is indicated if there is discordance between clinical, imaging, and cytology findings, if the lesion is enlarging, or if cytology is inadequate or indeterminate. In this scenario, cytology and imaging are typical of fibroadenoma and concordant with examination.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ERepeat targeted ultrasound in one year\u003C/strong\u003E is not in the recent recommendations, as a more recent review and ultrasonic assessment is recommended.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESurgical excision\u003C/strong\u003E is reserved for lesions that are large, painful, increasing in size, cosmetically concerning, or have indeterminate or suspicious pathology. None of these apply here.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Small, asymptomatic fibroadenomas with concordant triple assessment can be managed with reassurance and short-interval clinical and ultrasound review.","Core biopsy is preferred when imaging and cytology are discordant or when there are suspicious clinical features.","Excision is reserved for lesions that are large, painful, growing, or have indeterminate or concerning pathology."],"references":["https://www.breastsurgeons.org/docs/statements/Management-of-Fibroadenomas.pdf","Yu J, Kansal K. Management of Stromal Lesions. Surg Clin N Am 2022; 102:1017\u20131030"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"100514"},"links":{"related":"https://app.emedici.com/api/questionRevisions/118703/itemRevision","self":"https://app.emedici.com/api/questionRevisions/118703/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"224"},"links":{"related":"https://app.emedici.com/api/questionRevisions/118703/question","self":"https://app.emedici.com/api/questionRevisions/118703/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/118703/stemMedia","self":"https://app.emedici.com/api/questionRevisions/118703/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/118703/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/118703/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"100514","links":{"self":"https://app.emedici.com/api/itemRevisions/100514"},"attributes":{"createdAt":"2025-10-08T11:04:34+10:30","updatedAt":"2025-10-08T11:05:50+10:30"},"relationships":{"item":{"data":{"type":"items","id":"224"},"links":{"related":"https://app.emedici.com/api/itemRevisions/100514/item","self":"https://app.emedici.com/api/itemRevisions/100514/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"118703"},"links":{"related":"https://app.emedici.com/api/itemRevisions/100514/content","self":"https://app.emedici.com/api/itemRevisions/100514/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"19","links":{"self":"https://app.emedici.com/api/tags/19"},"attributes":{"emoji":"\ud83d\udd2a","name":"General Surgery","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:20+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/19/group","self":"https://app.emedici.com/api/tags/19/relationships/group"}},"heading":{"data":{"type":"tagHeadings","id":"2"},"links":{"related":"https://app.emedici.com/api/tags/19/heading","self":"https://app.emedici.com/api/tags/19/relationships/heading"}},"ancestors":{"links":{"related":"https://app.emedici.com/api/tags/19/ancestors","self":"https://app.emedici.com/api/tags/19/relationships/ancestors"}},"parents":{"links":{"related":"https://app.emedici.com/api/tags/19/parents","self":"https://app.emedici.com/api/tags/19/relationships/parents"}},"children":{"links":{"related":"https://app.emedici.com/api/tags/19/children","self":"https://app.emedici.com/api/tags/19/relationships/children"}},"descendants":{"links":{"related":"https://app.emedici.com/api/tags/19/descendants","self":"https://app.emedici.com/api/tags/19/relationships/descendants"}},"curricula":{"links":{"related":"https://app.emedici.com/api/tags/19/curricula","self":"https://app.emedici.com/api/tags/19/relationships/curricula"}}},"meta":{"itemCount":0}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updat