{"data":[{"type":"questionAttempts","id":"17637341","links":{"self":"https://app.emedici.com/api/questionAttempts/17637341"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T18:41:17+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T18:41:17+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17654"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17654","links":{"self":"https://app.emedici.com/api/questions/17654"},"attributes":{"optionProportions":[0.04,0.63,0.07,0.22,0.04]},"relationships":{"item":{"data":{"type":"items","id":"10368"}},"activeRevision":{"data":{"type":"questionRevisions","id":"71797"}}}},{"type":"items","id":"10368","links":{"self":"https://app.emedici.com/api/items/10368"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17654"}},"activeRevision":{"data":{"type":"itemRevisions","id":"57286"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"4948"},{"type":"tags","id":"7700"},{"type":"tags","id":"7702"},{"type":"tags","id":"11724"}]},"contributions":{"data":[{"type":"contributions","id":"24243"},{"type":"contributions","id":"24252"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"71797","links":{"self":"https://app.emedici.com/api/questionRevisions/71797"},"attributes":{"stem":"\u003Cp\u003EA researcher is collecting data about patient satisfaction with hospital care. Patients are asked to rate their overall experience as \u0027Very Dissatisfied\u0027, \u0027Dissatisfied\u0027, \u0027Neutral\u0027, \u0027Satisfied\u0027, or \u0027Very Satisfied\u0027.\u003C/p\u003E","stemQuestion":"Which one of the following best describes this type of data?","responseType":"sba","marks":1,"options":["Interval continuous data","Ordinal categorical data","Ratio continuous data","Nominal categorical data","Binary categorical data"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EThis is an example of \u003Cstrong\u003Eordinal categorical data\u003C/strong\u003E. The responses have a clear natural order from very dissatisfied to very satisfied, but the magnitude of difference between each category cannot be assumed to be equal.\u003C/p\u003E        \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E        \u003Cul\u003E        \u003Cli\u003E\u003Cstrong\u003ENominal categorical data\u003C/strong\u003E - Nominal data has categories with no natural order (e.g. blood types, eye colour)\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EInterval continuous data\u003C/strong\u003E - Interval data has equal intervals between values and can be measured on a continuous scale, but lacks a true zero point (e.g. temperature in Celsius)\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003ERatio continuous data\u003C/strong\u003E - Ratio data has equal intervals and a true zero point (e.g. height, weight)\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EBinary categorical data\u003C/strong\u003E - Binary data has only two possible categories (e.g. yes/no, alive/dead)\u003C/li\u003E    \u003C/ul\u003E        \u003Cp\u003EOrdinal data is commonly used in medical research for scales that have ordered categories, such as pain scores, disease staging, and educational levels. While we can say that \u0027Satisfied\u0027 represents greater satisfaction than \u0027Neutral\u0027, we cannot quantify how much greater the satisfaction is.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Ordinal data consists of categories that have a natural order or ranking but the intervals between values may not be equal.","Examples of ordinal data include pain scales, disease staging, and educational levels.","Ordinal data can be compared using greater/less than relationships but differences between values cannot be quantified."],"references":["Sullivan LM. Essentials of biostatistics in public health. 3rd ed. Burlington (MA): Jones \u0026 Bartlett Learning; 2018.","Dawson B, Trapp RG. Basic \u0026 clinical biostatistics. 4th ed. New York: McGraw-Hill; 2004."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"57286"}},"question":{"data":{"type":"questions","id":"17654"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"57286","links":{"self":"https://app.emedici.com/api/itemRevisions/57286"},"attributes":{"createdAt":"2024-12-20T15:48:10+10:30","updatedAt":"2024-12-20T15:51:56+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10368"}},"content":{"data":{"type":"questionRevisions","id":"71797"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Level II","synonyms":null,"description":"Understand (interpreting and summarizing information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4948","links":{"self":"https://app.emedici.com/api/tags/4