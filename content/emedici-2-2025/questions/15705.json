{"data":[{"type":"questionAttempts","id":"17602973","links":{"self":"https://app.emedici.com/api/questionAttempts/17602973"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T12:30:33+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T12:30:33+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15705"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15705","links":{"self":"https://app.emedici.com/api/questions/15705"},"attributes":{"optionProportions":[0.64,0,0.23,0.09,0.05]},"relationships":{"item":{"data":{"type":"items","id":"8396"}},"activeRevision":{"data":{"type":"questionRevisions","id":"71488"}}}},{"type":"items","id":"8396","links":{"self":"https://app.emedici.com/api/items/8396"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15705"}},"activeRevision":{"data":{"type":"itemRevisions","id":"56997"}},"tags":{"data":[{"type":"tags","id":"22"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4935"},{"type":"tags","id":"4946"},{"type":"tags","id":"4947"},{"type":"tags","id":"4950"},{"type":"tags","id":"7021"},{"type":"tags","id":"8397"},{"type":"tags","id":"8503"},{"type":"tags","id":"11067"},{"type":"tags","id":"11068"}]},"contributions":{"data":[{"type":"contributions","id":"20230"},{"type":"contributions","id":"20233"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"71488","links":{"self":"https://app.emedici.com/api/questionRevisions/71488"},"attributes":{"stem":"\u003Cp\u003EA histological section from a uterine mass is shown. The specimen demonstrates interlacing bundles of elongated cells with cigar-shaped nuclei. There is minimal cellular atypia and no mitotic figures are seen.\u003C/p\u003E","stemQuestion":"Which one of the following is the most likely diagnosis?","responseType":"sba","marks":1,"options":["Leiomyoma","Leiomyosarcoma","Endometrial polyp","Adenomyosis","Endometrial hyperplasia"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EThe histological appearance is characteristic of a \u003Cstrong\u003Eleiomyoma\u003C/strong\u003E (fibroid), showing well-differentiated smooth muscle cells arranged in fascicles with minimal cellular atypia. Unlike a \u003Cstrong\u003Eleiomyosarcoma\u003C/strong\u003E, there is no significant nuclear atypia or mitotic activity.\u003C/p\u003E\u003Cp\u003EAn \u003Cstrong\u003Eendometrial polyp\u003C/strong\u003E would show endometrial glands and stroma protruding into the uterine cavity. \u003Cstrong\u003EAdenomyosis\u003C/strong\u003E is characterised by endometrial glands and stroma within the myometrium. \u003Cstrong\u003EEndometrial hyperplasia\u003C/strong\u003E shows proliferation of endometrial glands with varying degrees of architectural complexity.\u003C/p\u003E\u003Cp\u003ELeiomyomas are benign neoplasms composed of smooth muscle cells and varying amounts of fibrous connective tissue. They are the most common benign tumours of the female reproductive tract, occurring in up to 70% of women by age 50.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Uterine fibroids are benign smooth muscle tumours composed of whorled bundles of smooth muscle cells with varying amounts of fibrous tissue","Fibroids are the most common benign tumour in women of reproductive age","Histologically, fibroids show characteristic interlacing bundles of smooth muscle cells without cellular atypia"],"references":["Evans, T. J., \u0026 Ganjam, V. K. (2017). Reproductive anatomy and physiology. In Reproductive and Developmental Toxicology (pp. 7-37). Academic Press","\u0022Lipoleiomyoma2\u0022 by Nephron is licensed under Creative Commons Attribution-Share Alike 3.0 Unported license. https://commons.wikimedia.org/wiki/File:Lipoleiomyoma2.jpg","da Silva AP, Mello Lde A, Dos Santos ER, Paz ST, Cavalcanti CL, de Melo-Junior MR. Histopathological and Digital Morphometrical Evaluation of Uterine Leiomyoma in Brazilian Women. Obstet Gynecol Int. 2016;2016:2968410. doi: 10.1155/2016/2968410. Epub 2016 May 15. PMID: 27293441; PMCID: PMC4884588.","Sohn GS, Cho S, Kim YM, Cho CH, Kim MR, Lee SR; Working Group of Society of Uterine Leiomyoma. Current medical treatment of uterine fibroids. Obstet Gynecol Sci. 2018 Mar;61(2):192-201. doi: 10.5468/ogs.2018.61.2.192. Epub 2018 Feb 13. PMID: 29564309; PMCID: PMC5854898."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"56997"}},"question":{"data":{"type":"questions","id":"15705"}},"stemMedia":{"data":[{"type":"media","id":"21177"}]},"explanationMedia":{"data":[]}}},{"type":"media","id":"21177","links":{"self":"https://app.emedici.com/api/media/21177"},"attributes":{"mimeType":"image/jpeg","url":"https://app.emedici.com/storage/media/SN833rsKNbUS4fsXnkx5FlUsc7cfS0.jpg","thumbUrl":"https://app.emedici.com/storage/media/SN833rsKNbUS4fsXnkx5FlUsc7cfS0.jpg","isProcessed":true,"width":1500,"height":1125}},{"type":"itemRevisions","id":"56997","links":{"self":"https://app.emedici.com/api/itemRevisions/56997"},"attributes":{"createdAt":"2024-12-18T18:52:58+10:30","updatedAt":"2024-12-18T18:53:29+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8396"}},"content":{"data":{"type":"questionRevisions","id":"71488"}}},"meta":{"canDelete":false}},{"type":"tags","id":"22","links":{"self":"https://app.emedici.com/api/tags/22"},"attributes":{"emoji":"\ud83c\udf53","name":"Gynaecology","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"3"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synon