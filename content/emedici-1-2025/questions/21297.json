com/api/questions/21297/relationships/activeRevision"}}}},{"type":"items","id":"14170","links":{"self":"https://app.emedici.com/api/items/14170"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/14170/packs","self":"https://app.emedici.com/api/items/14170/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/14170/revisions","self":"https://app.emedici.com/api/items/14170/relationships/revisions"}},"content":{"data":{"type":"questions","id":"21297"},"links":{"related":"https://app.emedici.com/api/items/14170/content","self":"https://app.emedici.com/api/items/14170/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/14170/specialtyTags","self":"https://app.emedici.com/api/items/14170/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/14170/primaryTags","self":"https://app.emedici.com/api/items/14170/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/14170/contributionTypes","self":"https://app.emedici.com/api/items/14170/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/14170/contributors","self":"https://app.emedici.com/api/items/14170/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/14170/contribution","self":"https://app.emedici.com/api/items/14170/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/14170/myContribution","self":"https://app.emedici.com/api/items/14170/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"102466"},"links":{"related":"https://app.emedici.com/api/items/14170/activeRevision","self":"https://app.emedici.com/api/items/14170/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"2"},{"type":"tags","id":"33"},{"type":"tags","id":"72"},{"type":"tags","id":"1481"},{"type":"tags","id":"4174"}],"links":{"related":"https://app.emedici.com/api/items/14170/tags","self":"https://app.emedici.com/api/items/14170/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"34368"},{"type":"contributions","id":"53202"}],"links":{"related":"https://app.emedici.com/api/items/14170/contributions","self":"https://app.emedici.com/api/items/14170/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"120865","links":{"self":"https://app.emedici.com/api/questionRevisions/120865"},"attributes":{"stem":"\u003Cp\u003EA 50-year-old woman presents to the General Practice clinic with breathlessness on minor exertion. She has no significant medical history and does not take any regular medications.\u003C/p\u003E\u003Cp\u003EOn examination, she appears well. Her pulse rate is 88/min, blood pressure is 140/60 mmHg, respiratory rate is 16/min, SpO2 is 98% on room air, and temperature is 36.7\u00b0C. She has a wide pulse pressure. Cardiac auscultation reveals an early diastolic, decrescendo murmur best heard over the second right intercostal space on expiration. Echocardiography reveals a left ventricular ejection fraction of 38% (50-70%).\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate therapeutic intervention?","responseType":"sba","marks":1,"options":["Aortic valve replacement","Annual clinical assessment","Six-monthly echocardiography","Nifedipine","Ramipril"],"correctOptions":[0],"correctResponses":[],"explanation":"\u003Cp\u003E\u003Cstrong\u003EAortic valve replacement\u003C/strong\u003E is indicated in this patient because she has symptomatic severe aortic regurgitation with evidence of left ventricular systolic dysfunction (ejection fraction below 50%). Surgery is recommended to prevent further irreversible left ventricular damage and to improve symptoms and long-term survival. The presence of exertional dyspnoea and a reduced ejection fraction are both clear indications for surgical intervention, as medical therapy alone cannot correct the underlying mechanical problem of the regurgitant valve.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EAnnual clinical assessment\u003C/strong\u003E is appropriate for people with mild or moderate aortic regurgitation who are asymptomatic and have preserved left ventricular function. In this case, the patient is symptomatic and has reduced ejection fraction, so observation alone is not appropriate.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESix-monthly echocardiography\u003C/strong\u003E may be considered for monitoring in asymptomatic patients with severe aortic regurgitation and normal left ventricular function, or in those with mild symptoms and preserved ejection fraction. However, this patient already has symptoms and left ventricular dysfunction, so delaying surgery for further monitoring would risk further deterioration.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ENifedipine\u003C/strong\u003E is a vasodilator that can reduce afterload and may be used in people with severe aortic regurgitation who are not surgical candidates or as a temporising measure in asymptomatic patients. However, it does not address the underlying valve pathology and is not appropriate as definitive therapy in symptomatic patients with reduced ejection fraction.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ERamipril\u003C/strong\u003E is an angiotensin-converting enzyme inhibitor that may be used to manage heart failure symptoms, but it does not treat the mechanical cause of aortic regurgitation. In this scenario, medical therapy alone is insufficient, and surgery is required to prevent further left ventricular deterioration.\u003C/p\u003E\u003Cp\u003ESevere aortic regurgitation leads to volume overload of the left ventricle, which can result in progressive dilation and systolic dysfunction. Once symptoms develop or left ventricular function declines, prompt surgical intervention is necessary to optimise outcomes.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Symptomatic severe aortic regurgitation with reduced ejection fraction requires prompt aortic valve replacement to prevent irreversible left ventricular dysfunction.","Medical therapy does not address the underlying mechanical problem in severe aortic regurgitation with left ventricular dysfunction.","Symptomatic severe aortic regurgitation carries a poor prognosis without early intervention."],"references":["Alec Vahanian, Friedhelm Beyersdorf, Fabien Praz, Milan Milojevic, Stephan Baldus, Johann Bauersachs, Davide Capodanno, Lenard Conradi, Michele De Bonis, Ruggero De Paulis, Victoria Delgado, Nick Freemantle, Martine Gilard, Kristina H Haugaa, Anders Jeppsson, Peter J\u00fcni, Luc Pierard, Bernard D Prendergast, J Rafael S\u00e1daba, Christophe Tribouilloy, Wojtek Wojakowski, ESC/EACTS Scientific Document Group , ESC National Cardiac Societies , 2021 ESC/EACTS Guidelines for the management of valvular heart disease: Developed by the Task Force for the management of valvular heart disease of the European Society of Cardiology (ESC) and the European Association for Cardio-Thoracic Surgery (EACTS), European Heart Journal, Volume 43, Issue 7, 14 February 2022, Pages 561\u2013632, https://doi.org/10.1093/eurheartj/ehab395"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"102466"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120865/itemRevision","self":"https://app.emedici.com/api/questionRevisions/120865/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"21297"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120865/question","self":"https://app.emedici.com/api/questionRevisions/120865/relationships/question"}},"stemMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/120865/stemMedia","self":"https://app.emedici.com/api/questionRevisions/120865/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/120865/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/120865/relationships/explanationMedia"}}}},{"type":"itemRevisions","id":"102466","links":{"self":"https://app.emedici.com/api/itemRevisions/102466"},"attributes":{"createdAt":"2025-10-18T07:54:02+10:30","updatedAt":"2025-10-18T07:54:09+10:30"},"relationships":{"item":{"data":{"type":"items","id":"14170"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102466/item","self":"https://app.emedici.com/api/itemRevisions/102466/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"120865"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102466/content","self":"https://app.emedici.com/api/itemRevisions/102466/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"2","links":{"self":"https://app.emedici.com/api/tags/2"},"attributes":{"emoji":"\ud83e\udec0","name":"Cardiology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:47:21+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/2/group","self":"https://app.emedici.com/api/tags/2/relationships/group"}},"heading":{"data":{"type":"tagHeadings","id":"1"},"links":{"related":"https://app.emedici.com/api/tags/2/heading","self":"https://app.emedici.com/api/tags/2/relationships/heading"}},"ancestors":{"links":{"related":"https://app.emedici.com/api/tags/2/ancestors","self":"https://app.emedici.com/api/tags/2/relationships/ancestors"}},"parents":{"links":{"related":"https://app.emedici.com/api/tags/2/parents","self":"https://app.emedici.com/api/tags/2/relationships/parents"}},"children":{"links":{"related":"https://app.emedici.com/api/tags/2/children","self":"https://app.e