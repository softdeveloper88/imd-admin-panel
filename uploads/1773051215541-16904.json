{"data":[{"type":"questionAttempts","id":"17624449","links":{"self":"https://app.emedici.com/api/questionAttempts/17624449"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T16:18:07+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T16:18:07+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"16904"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"16904","links":{"self":"https://app.emedici.com/api/questions/16904"},"attributes":{"optionProportions":[0.05,0,0.05,0.86,0.05]},"relationships":{"item":{"data":{"type":"items","id":"9594"}},"activeRevision":{"data":{"type":"questionRevisions","id":"68883"}}}},{"type":"items","id":"9594","links":{"self":"https://app.emedici.com/api/items/9594"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"16904"}},"activeRevision":{"data":{"type":"itemRevisions","id":"54341"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"4945"},{"type":"tags","id":"10725"},{"type":"tags","id":"10792"}]},"contributions":{"data":[{"type":"contributions","id":"22655"},{"type":"contributions","id":"22656"},{"type":"contributions","id":"23098"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"68883","links":{"self":"https://app.emedici.com/api/questionRevisions/68883"},"attributes":{"stem":"\u003Cp\u003EA couple seeks genetic counseling. Both are healthy but carry one copy of a mutation for an autosomal recessive disorder. They have no children but want to understand their reproductive risks.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the probability that their child will be affected by this disorder?","responseType":"sba","marks":1,"options":["100%","75%","50%","25%","0%"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EFor an autosomal recessive condition, both parents must contribute a mutated copy of the gene for a child to be affected. When both parents are carriers (heterozygous), each pregnancy has a \u003Cstrong\u003E25%\u003C/strong\u003E chance of producing an affected child. This follows Mendelian inheritance patterns where each parent has a 50% chance of passing on either their normal or mutated allele and therefore the probability of receiving both mutated copies is 1 in 4 or 25%.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Autosomal recessive inheritance requires two mutated copies of a gene for disease expression.","When both parents are carriers of an autosomal recessive condition, each child has a 25% chance of being affected.","Genetic counseling uses probability calculations to help families understand inheritance risks."],"references":["Turnpenny PD, Ellard S. Emery\u0027s Elements of Medical Genetics E-Book: Elsevier Health Sciences; 2011."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"54341"}},"question":{"data":{"type":"questions","id":"16904"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"54341","links":{"self":"https://app.emedici.com/api/itemRevisions/54341"},"attributes":{"createdAt":"2024-12-10T16:43:00+10:30","updatedAt":"2024-12-10T16:43:51+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9594"}},"content":{"data":{"type":"questionRevisions","id":"68883"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"