com/api/questions/21083/relationships/activeRevision"}}}},{"type":"items","id":"13958","links":{"self":"https://app.emedici.com/api/items/13958"},"attributes":{"contentType":"question"},"relationships":{"packs":{"links":{"related":"https://app.emedici.com/api/items/13958/packs","self":"https://app.emedici.com/api/items/13958/relationships/packs"}},"revisions":{"links":{"related":"https://app.emedici.com/api/items/13958/revisions","self":"https://app.emedici.com/api/items/13958/relationships/revisions"}},"content":{"data":{"type":"questions","id":"21083"},"links":{"related":"https://app.emedici.com/api/items/13958/content","self":"https://app.emedici.com/api/items/13958/relationships/content"}},"specialtyTags":{"links":{"related":"https://app.emedici.com/api/items/13958/specialtyTags","self":"https://app.emedici.com/api/items/13958/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/13958/primaryTags","self":"https://app.emedici.com/api/items/13958/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/13958/contributionTypes","self":"https://app.emedici.com/api/items/13958/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/13958/contributors","self":"https://app.emedici.com/api/items/13958/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/13958/contribution","self":"https://app.emedici.com/api/items/13958/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/13958/myContribution","self":"https://app.emedici.com/api/items/13958/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"102380"},"links":{"related":"https://app.emedici.com/api/items/13958/activeRevision","self":"https://app.emedici.com/api/items/13958/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4946"}],"links":{"related":"https://app.emedici.com/api/items/13958/tags","self":"https://app.emedici.com/api/items/13958/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"33678"},{"type":"contributions","id":"53205"}],"links":{"related":"https://app.emedici.com/api/items/13958/contributions","self":"https://app.emedici.com/api/items/13958/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"120783","links":{"self":"https://app.emedici.com/api/questionRevisions/120783"},"attributes":{"stem":"\u003Cp\u003EA histological section of muscle tissue is examined under light microscopy. The tissue shows elongated, cylindrical fibres with multiple nuclei located at the periphery of each fibre. Cross-striations are clearly visible throughout the fibres, and the tissue lacks centrally located nuclei or intercalated discs.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the tissue shown in this histological section?","responseType":"sba","marks":1,"options":["Pseudostratified columnar epithelium","Transitional epithelium","Cardiac muscle tissue","Smooth muscle tissue","Skeletal muscle tissue"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThe histological section described shows \u003Cstrong\u003Eskeletal muscle tissue\u003C/strong\u003E. The key identifying features of skeletal muscle include:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003EElongated, cylindrical fibres (cells)\u003C/li\u003E\u003Cli\u003EMultiple nuclei positioned at the periphery of each fibre\u003C/li\u003E\u003Cli\u003EProminent cross-striations (banding pattern)\u003C/li\u003E\u003Cli\u003EAbsence of intercalated discs\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003E\u003Cstrong\u003ECardiac muscle tissue\u003C/strong\u003E differs from skeletal muscle in several important ways. Cardiac muscle cells have centrally located nuclei (usually one per cell), are branched rather than cylindrical, and contain intercalated discs that allow for electrical coupling between adjacent cells.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESmooth muscle tissue\u003C/strong\u003E lacks cross-striations and contains spindle-shaped cells with a single, centrally located nucleus. Smooth muscle does not show the banding pattern characteristic of skeletal muscle.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ETransitional epithelium\u003C/strong\u003E is a specialised type of epithelial tissue found lining the urinary tract. It consists of multiple layers of cells that can change shape to accommodate stretching, but does not contain elongated fibres or cross-striations.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003EPseudostratified columnar epithelium\u003C/strong\u003E appears to have multiple layers but actually consists of a single layer of cells of varying heights, all of which reach the basement membrane. This epithelial tissue is found in the respiratory tract and lacks the features of muscle tissue described in the stem.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Skeletal muscle fibres are characterised by peripheral nuclei, cross-striations, and a multinucleated appearance.","Skeletal muscle has a distinctive banding pattern due to the arrangement of actin and myosin filaments.","Skeletal muscle can be distinguished from cardiac and smooth muscle by its histological features."],"references":["Muscle Tissue: Skeletal Muscle Fibers. Flikr. Image accessed under CC0 1.0 license: https://creativecommons.org/publicdomain/zero/1.0/. Accessed at: https://www.flickr.com/photos/146824358@N03/40153601630/","Sule N. Histology-skeletal muscle. PathologyOutlines.com website. https://www.pathologyoutlines.com/topic/softtissueskeletalnormal.html. Accessed October 16th, 2025."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"102380"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120783/itemRevision","self":"https://app.emedici.com/api/questionRevisions/120783/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"21083"},"links":{"related":"https://app.emedici.com/api/questionRevisions/120783/question","self":"https://app.emedici.com/api/questionRevisions/120783/relationships/question"}},"stemMedia":{"data":[{"type":"media","id":"21818"}],"links":{"related":"https://app.emedici.com/api/questionRevisions/120783/stemMedia","self":"https://app.emedici.com/api/questionRevisions/120783/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/120783/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/120783/relationships/explanationMedia"}}}},{"type":"media","id":"21818","links":{"self":"https://app.emedici.com/api/media/21818"},"attributes":{"mimeType":"image/jpeg","url":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/aMdvw8uFDc8XEKpSzPVkbrCG1c2sDz.jpg","thumbUrl":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/aMdvw8uFDc8XEKpSzPVkbrCG1c2sDz.jpg","isProcessed":true,"width":1500,"height":846}},{"type":"itemRevisions","id":"102380","links":{"self":"https://app.emedici.com/api/itemRevisions/102380"},"attributes":{"createdAt":"2025-10-17T11:45:53+10:30","updatedAt":"2025-10-17T11:50:38+10:30"},"relationships":{"item":{"data":{"type":"items","id":"13958"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102380/item","self":"https://app.emedici.com/api/itemRevisions/102380/relationships/item"}},"content":{"data":{"type":"questionRevisions","id":"120783"},"links":{"related":"https://app.emedici.com/api/itemRevisions/102380/content","self":"https://app.emedici.com/api/itemRevisions/102380/relationships/content"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"