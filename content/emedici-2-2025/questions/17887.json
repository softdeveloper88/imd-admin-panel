{"data":[{"type":"questionAttempts","id":"17641584","links":{"self":"https://app.emedici.com/api/questionAttempts/17641584"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T19:28:40+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T19:28:40+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17887"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17887","links":{"self":"https://app.emedici.com/api/questions/17887"},"attributes":{"optionProportions":[0,0.57,0.3,0.1,0.03]},"relationships":{"item":{"data":{"type":"items","id":"10601"}},"activeRevision":{"data":{"type":"questionRevisions","id":"114669"}}}},{"type":"items","id":"10601","links":{"self":"https://app.emedici.com/api/items/10601"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17887"}},"activeRevision":{"data":{"type":"itemRevisions","id":"96672"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4928"},{"type":"tags","id":"4933"},{"type":"tags","id":"4942"},{"type":"tags","id":"10053"},{"type":"tags","id":"10068"}]},"contributions":{"data":[{"type":"contributions","id":"24707"},{"type":"contributions","id":"24711"},{"type":"contributions","id":"24809"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"114669","links":{"self":"https://app.emedici.com/api/questionRevisions/114669"},"attributes":{"stem":"\u003Cp\u003EGluconeogenesis is the metabolic pathway that results in the generation of glucose from certain non-carbohydrate carbon substrates. While the liver is the primary site for this process, another organ also possesses a complete gluconeogenesis pathway.\u003C/p\u003E","stemQuestion":"Which one of the following is this particular other organ?","responseType":"sba","marks":1,"options":["Gall bladder","Kidney","Pancreas","Spleen","Stomach"],"correctOptions":[1],"correctResponses":[],"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Ekidney\u003C/strong\u003E is the other organ, besides the liver, that has a complete gluconeogenesis pathway. This process primarily occurs in the renal cortex. The kidney contributes to maintaining blood glucose levels, especially during prolonged fasting.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Egall bladder\u003C/strong\u003E is involved in bile storage and does not participate in gluconeogenesis. The \u003Cstrong\u003Espleen\u003C/strong\u003E is involved in immune function and blood filtration, not gluconeogenesis. The \u003Cstrong\u003Estomach\u003C/strong\u003E is primarily involved in digestion, not glucose production. The \u003Cstrong\u003Epancreas\u003C/strong\u003E produces digestive enzymes and hormones like insulin and glucagon, but does not perform gluconeogenesis.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["The kidney is capable of performing gluconeogenesis, particularly in the renal cortex.","Gluconeogenesis is the process of synthesising glucose from non-carbohydrate precursors.","The liver and kidney are the primary organs involved in gluconeogenesis."],"references":["Bender DA, Cunningham SM. Introduction to nutrition and metabolism. CRC Press; 2021.","Salway JG. Metabolism at a Glance. John Wiley \u0026 Sons; 2016.","Judge A, Dodd MS. Metabolism. Essays Biochem. 2020 Oct 8;64(4):607-647.","Wang Y, Wu R. The Effect of Fasting on Human Metabolism and Psychological Health. Dis Markers. 2022 Jan 5;2022:5653739.","Nakrani MN, Wineland RH, Anjum F. Physiology, Glucose Metabolism. In: StatPearls [Internet]. Treasure Island (FL): StatPearls Publishing; 2023 Jul 17.","Chandel NS. Carbohydrate Metabolism. Cold Spring Harb Perspect Biol. 2021 Jan 4;13(1):a040568.","Hall JE. Guyton and Hall Textbook of Medical Physiology. 14th ed. Philadelphia: Elsevier; 2021. Chapter 26; pg. 322."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"96672"}},"question":{"data":{"type":"questions","id":"17887"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"96672","links":{"self":"https://app.emedici.com/api/itemRevisions/96672"},"attributes":{"createdAt":"2025-09-18T14:58:40+09:30","updatedAt":"2025-09-18T14:58:40+09:30"},"relationships":{"item":{"data":{"type":"items","id":"10601"}},"content":{"data":{"type":"questionRevisions","id":"114669"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4928","links":{"self":"https://app.emedici.com/api/tags/4928"},"attributes":{"emoji":"\ud83d\udca9","name":"Gastrointestinal","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-10-31T09:50:24+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"13"}},"heading":{"data":null