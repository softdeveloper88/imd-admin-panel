<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Choose Your Plan — iMedicalDoctor</title>
  <style>
    :root {
      --bg: #f0f4f8; --ink: #1a202c; --muted: #718096;
      --brand: #0f766e; --brand-deep: #0b4f49; --brand-light: #ccfbf1;
      --accent: #f59e0b; --white: #fff; --line: #e2e8f0;
      --shadow: 0 20px 60px rgba(0,0,0,0.1);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh; font-family: "Avenir Next","Segoe UI",system-ui,sans-serif;
      color: var(--ink);
      background: linear-gradient(135deg, #f0f9ff 0%, #f0f4f8 50%, #fdf4ff 100%);
    }
    .header {
      text-align: center; padding: 48px 24px 24px;
    }
    .header h1 { font-size: 36px; font-weight: 800; margin-bottom: 8px; }
    .header p { font-size: 18px; color: var(--muted); max-width: 600px; margin: 0 auto; }

    .toggle-wrap { text-align: center; margin: 24px 0; }
    .toggle-wrap .toggle {
      display: inline-flex; background: var(--line); border-radius: 30px; padding: 4px;
    }
    .toggle-wrap .toggle button {
      padding: 10px 28px; border: none; border-radius: 26px; font-size: 14px; font-weight: 600;
      cursor: pointer; background: transparent; color: var(--muted); transition: all 0.3s;
    }
    .toggle-wrap .toggle button.active {
      background: var(--brand); color: var(--white); box-shadow: 0 4px 12px rgba(15,118,110,0.3);
    }
    .save-badge {
      display: inline-block; margin-left: 8px; padding: 2px 10px; border-radius: 12px;
      background: rgba(245,158,11,0.15); color: #d97706; font-size: 12px; font-weight: 700;
    }

    .plans {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px; max-width: 1100px; margin: 0 auto; padding: 24px;
    }
    .plan-card {
      background: var(--white); border-radius: 20px; padding: 32px 28px;
      border: 2px solid var(--line); position: relative; transition: transform 0.2s, box-shadow 0.2s;
      display: flex; flex-direction: column;
    }
    .plan-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
    .plan-card.recommended {
      border-color: var(--brand); box-shadow: 0 0 0 3px rgba(15,118,110,0.15), var(--shadow);
    }
    .plan-card.recommended::before {
      content: "BEST VALUE"; position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
      background: var(--brand); color: var(--white); padding: 4px 16px; border-radius: 20px;
      font-size: 11px; font-weight: 800; letter-spacing: 1px;
    }
    .plan-name { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
    .plan-price { font-size: 42px; font-weight: 800; color: var(--brand); margin-bottom: 4px; }
    .plan-price span { font-size: 16px; font-weight: 500; color: var(--muted); }
    .plan-desc { font-size: 14px; color: var(--muted); margin-bottom: 24px; }
    .plan-features { list-style: none; margin-bottom: 28px; flex: 1; }
    .plan-features li {
      padding: 8px 0; font-size: 14px; display: flex; align-items: center; gap: 10px;
      border-bottom: 1px solid var(--line);
    }
    .plan-features li:last-child { border: none; }
    .plan-features li::before { content: "✓"; color: var(--brand); font-weight: 700; font-size: 16px; }

    .plan-btn {
      width: 100%; padding: 14px; border: none; border-radius: 12px;
      font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.2s;
    }
    .plan-btn-primary {
      background: linear-gradient(135deg, var(--brand-deep), var(--brand));
      color: var(--white);
    }
    .plan-btn-primary:hover { box-shadow: 0 8px 24px rgba(15,118,110,0.3); transform: translateY(-1px); }
    .plan-btn-outline {
      background: transparent; border: 2px solid var(--brand); color: var(--brand);
    }
    .plan-btn-outline:hover { background: var(--brand-light); }

    .plan-card.free-card .plan-price { color: var(--muted); }

    .footer { text-align: center; padding: 32px; color: var(--muted); font-size: 13px; }
    .footer a { color: var(--brand); text-decoration: none; }

    @media (max-width: 768px) {
      .plans { grid-template-columns: 1fr; max-width: 400px; }
      .header h1 { font-size: 28px; }
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Choose Your Plan</h1>
    <p>Complete subscription payment to activate your account and login in the app</p>
  </div>

  <% if (error) { %>
    <div style="max-width:760px;margin:0 auto 12px;padding:12px 14px;border-radius:12px;background:#fff1f2;color:#9f1239;border:1px solid #fecdd3;text-align:center;font-weight:600;">
      <%= error %>
    </div>
  <% } %>

  <div class="toggle-wrap">
    <div class="toggle">
      <button class="active" id="monthlyBtn" onclick="showMonthly()">Monthly</button>
      <button id="yearlyBtn" onclick="showYearly()">Yearly <span class="save-badge">Save 33%</span></button>
    </div>
  </div>

  <div class="plans" id="plansGrid">
    <% plans.forEach((plan, i) => { %>
      <div class="plan-card <%= plan.duration_days >= 365 ? 'recommended' : '' %>"
           data-plan-type="<%= plan.duration_days >= 365 ? 'yearly' : 'monthly' %>"
           data-plan-id="<%= plan.id %>">
        <div class="plan-name"><%= plan.name %></div>
        <div class="plan-price">
          <% if (plan.price > 0) { %>
            $<%= plan.price %><span>/<%= plan.duration_days <= 30 ? 'mo' : (plan.duration_days <= 365 ? 'yr' : 'once') %></span>
          <% } else { %>
            Free
          <% } %>
        </div>
        <div class="plan-desc"><%= plan.description || '' %></div>
        <ul class="plan-features">
          <% (plan.features || []).forEach(f => { %>
            <li><%= f %></li>
          <% }) %>
        </ul>
        <button class="plan-btn plan-btn-primary" onclick="selectPlan(<%= plan.id %>)">Pay & Activate</button>
      </div>
    <% }) %>
  </div>

  <div class="footer">
    <p>Secure payment powered by Stripe. Cancel anytime.</p>
    <p style="margin-top:8px"><a href="/signup">Back to Signup</a></p>
  </div>

  <script>
    // Show monthly plans by default on load
    document.addEventListener('DOMContentLoaded', () => {
      const hasMonthly = document.querySelectorAll('[data-plan-type="monthly"]').length > 0;
      const hasYearly = document.querySelectorAll('[data-plan-type="yearly"]').length > 0;
      if (hasMonthly && hasYearly) showMonthly();
    });

    function showMonthly() {
      document.getElementById('monthlyBtn').classList.add('active');
      document.getElementById('yearlyBtn').classList.remove('active');
      document.querySelectorAll('[data-plan-type="yearly"]').forEach(el => el.style.display = 'none');
      document.querySelectorAll('[data-plan-type="monthly"]').forEach(el => el.style.display = '');
    }
    function showYearly() {
      document.getElementById('yearlyBtn').classList.add('active');
      document.getElementById('monthlyBtn').classList.remove('active');
      document.querySelectorAll('[data-plan-type="monthly"]').forEach(el => el.style.display = 'none');
      document.querySelectorAll('[data-plan-type="yearly"]').forEach(el => el.style.display = '');
    }

    async function selectPlan(planId) {
      <% if (!user) { %>
        window.location.href = '/signup?error=Please+create+an+account+first';
        return;
      <% } %>
      try {
        const resp = await fetch('/api/payments/create-checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan_id: planId }),
        });
        const data = await resp.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert(data.error || 'Failed to start checkout');
        }
      } catch (err) {
        alert('Network error. Please try again.');
      }
    }
  </script>
</body>
</html>
