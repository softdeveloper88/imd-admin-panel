nseType":"sba","marks":1,"options":["Age-related cochlear degeneration","Noise-induced hearing damage","Otitis externa caused by Group A Streptococcus","Congenital rubella infection","Acoustic neuroma"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EOtitis externa caused by Group A Streptococcus\u003C/strong\u003E leads to inflammation and swelling of the external ear canal, which can physically block sound transmission to the middle ear, causing conductive hearing loss.\u003C/p\u003E\u003Cp\u003EThe incorrect options represent causes of sensorineural rather than conductive hearing loss. \u003Cstrong\u003EAge-related cochlear degeneration\u003C/strong\u003E (presbycusis) affects the inner ear hair cells, whilst \u003Cstrong\u003Enoise-induced hearing damage\u003C/strong\u003E causes destruction of cochlear hair cells. \u003Cstrong\u003ECongenital rubella infection\u003C/strong\u003E typically damages the cochlea during development, and \u003Cstrong\u003Eacoustic neuroma\u003C/strong\u003E affects the vestibulocochlear nerve. Conductive hearing loss occurs when sound waves cannot efficiently travel through the external auditory canal or middle ear structures. This is typically caused by physical blockage, fluid accumulation, or problems with the ossicles.\u003C/p\u003E","optionExplanations":null,"learningPoints":["Conductive hearing loss occurs when sound waves cannot efficiently travel through the external ear canal or middle ear.","Otitis externa (swimmer\u0027s ear) can cause temporary conductive hearing loss by blocking the external ear canal.","Group A Streptococcus can cause otitis externa, leading to ear canal swelling and obstruction."],"references":["Wiegand S, Berner R, Schneider A, Lundershausen E, Dietz A. Otitis Externa. Dtsch Arztebl Int. 2019 Mar 29;116(13):224-234. doi: 10.3238/arztebl.2019.0224. PMID: 31064650; PMCID: PMC6522672.","Schilder AG, Chonmaitree T, Cripps AW, Rosenfeld RM, Casselbrant ML, Haggard MP, Venekamp RP. Otitis media. Nat Rev Dis Primers. 2016 Sep 8;2(1):16063. doi: 10.1038/nrdp.2016.63. PMID: 27604644; PMCID: PMC7097351.","Plum AW, Wong M. An Overview of Acute Otitis Externa. Otolaryngol Clin North Am. 2023 Oct;56(5):891-896. doi: 10.1016/j.otc.2023.06.006. Epub 2023 Jul 27. PMID: 37516653.","Michael-Titus, A. T., \u0026 Shortland, P. (2022). The Nervous System, E-Book: The Nervous System, E-Book. Elsevier Health Sciences."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"98103"}},"question":{"data":{"type":"questions","id":"16300"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"98103","links":{"self":"https://app.emedici.com/api/itemRevisions/98103"},"attributes":{"createdAt":"2025-09-27T15:00:55+09:30","updatedAt":"2025-09-27T15:02:44+09:30"},"relationships":{"item":{"data":{"type":"items","id":"8991"}},"content":{"data":{"type":"questionRevisions","id":"116107"}}},"meta":{"canDelete":false}},{"type":"tags","id":"35","links":{"self":"https://app.emedici.com/api/tags/35"},"attributes":{"emoji":"\ud83d\udc43","name":"Otorhinolaryngology","synonyms":["ENT","HEENT"],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:40:48+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"2"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group