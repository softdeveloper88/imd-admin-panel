{"data":[{"type":"questionAttempts","id":"17486557","links":{"self":"https://app.emedici.com/api/questionAttempts/17486557"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T02:37:24+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T02:37:24+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"135"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"135","links":{"self":"https://app.emedici.com/api/questions/135"},"attributes":{"optionProportions":[0.35,0.11,0.13,0.38,0.02]},"relationships":{"item":{"data":{"type":"items","id":"135"}},"activeRevision":{"data":{"type":"questionRevisions","id":"92919"}}}},{"type":"items","id":"135","links":{"self":"https://app.emedici.com/api/items/135"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"135"}},"activeRevision":{"data":{"type":"itemRevisions","id":"76271"}},"tags":{"data":[{"type":"tags","id":"35"},{"type":"tags","id":"66"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"199"},{"type":"tags","id":"1984"},{"type":"tags","id":"2553"},{"type":"tags","id":"4959"},{"type":"tags","id":"4987"},{"type":"tags","id":"11644"},{"type":"tags","id":"11650"}]},"contributions":{"data":[{"type":"contributions","id":"4427"},{"type":"contributions","id":"31878"},{"type":"contributions","id":"37167"},{"type":"contributions","id":"44916"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"92919","links":{"self":"https://app.emedici.com/api/questionRevisions/92919"},"attributes":{"stem":"\u003Cp\u003EA 28-year-old man presents with a four month history of an intermittent nasal discharge. The material is clear and there are no other associated symptoms. The discharge is worse during his early morning runs, particularly when the weather is cold. He is otherwise in good health, does not take any medications and has no known allergies.\u003C/p\u003E\u003Cp\u003EPhysical examination and anterior rhinoscopy is normal.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate next step?","responseType":"sba","marks":1,"options":["Oral decongestant","Intermittent face mask","Beta-2-transferrin testing","Intranasal ipratropium","Salbutamol via spacer"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThis patient presents with symptoms suggestive of chronic non-allergic rhinitis (formerly called vasomotor rhinitis; renamed due to lack of evidence of vascular aetiology). His triggers of cold air and exertion suggest the most common subtype, termed non-allergic rhinopathy.\u003C/p\u003E\u003Cp\u003EIn addition to trigger avoidance, management is symptom-directed:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EFor patients with predominant \u003Cstrong\u003Erhinorrhoea\u003C/strong\u003E (as in this case), intranasal ipratropium is first-line. It has a local action on the cells onto which it is sprayed and works by inhibiting the secretion of mucus, with onset within 15 minutes. If symptoms persist, intranasal corticosteroids or antihistamines can be added.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EFor patients with predominant \u003Cstrong\u003Econgestion\u003C/strong\u003E, intranasal corticosteroids and/or antihistamines are first-line, with \u003Cstrong\u003Eoral decongestants\u003C/strong\u003E added if symptoms persist.\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EIf symptoms persist despite the above, allergy testing should be considered.\u003Cbr /\u003E\u003Cbr /\u003E\u003Cstrong\u003EBeta-2-transferrin testing\u003C/strong\u003E is indicated with suspicion of cerebrospinal fluid (CSF) leak; suspicion is low in the absence of previous facial trauma, intranasal surgery, or persistent leak worsened by leaning forward. \u003Cstrong\u003ESalbutamol\u003C/strong\u003E would be indicated as \u0027reliever\u0027 treatment of asthma, which is not consistent with the clinical picture here.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Intranasal ipratropium is first-line treatment in patients whose main symptom is rhinorrhoea"],"references":["Sur DKC, Plesa ML. Chronic Nonallergic Rhinitis. Am Fam Physician. 2018 Aug 1;98(3):171-176."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"76271"}},"question":{"data":{"type":"questions","id":"135"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"76271","links":{"self":"https://app.emedici.com/api/itemRevisions/76271"},"attributes":{"createdAt":"2025-03-19T21:20:08+10:30","updatedAt":"2025-05-29T08:47:24+09:30"},"relationships":{"item":{"data":{"type":"items","id":"135"}},"content":{"data":{"type":"questionRevisions","id":"92919"}}},"meta":{"canDelete":false}},{"type":"tags","id":"35","links":{"self":"https://app.emedici.com/api/tags/35"},"attributes":{"emoji":"\ud83d\udc43","name":"Otorhinolaryngology","synonyms":["ENT","HEENT"],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-01-16T08:40:48+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"2"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":"Management","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"72","links":{"self":"https://app.emedici.com/api/tags/72"},"attributes":{"emoji":"","name":"Graduating","synonyms":null,"description":"Only suitable for a graduating medical student at the end of their degree","position":1,"createdAt":null,"updatedAt":null},"relationships":{"group":{