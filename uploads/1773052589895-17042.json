{"data":[{"type":"questionAttempts","id":"17625824","links":{"self":"https://app.emedici.com/api/questionAttempts/17625824"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T16:29:37+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T16:29:37+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17042"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17042","links":{"self":"https://app.emedici.com/api/questions/17042"},"relationships":{"item":{"data":{"type":"items","id":"9732"}},"activeRevision":{"data":{"type":"questionRevisions","id":"78002"}}}},{"type":"items","id":"9732","links":{"self":"https://app.emedici.com/api/items/9732"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17042"}},"activeRevision":{"data":{"type":"itemRevisions","id":"63424"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4930"},{"type":"tags","id":"4936"},{"type":"tags","id":"4942"},{"type":"tags","id":"4943"},{"type":"tags","id":"5287"},{"type":"tags","id":"8511"},{"type":"tags","id":"10293"},{"type":"tags","id":"11223"}]},"contributions":{"data":[{"type":"contributions","id":"22910"},{"type":"contributions","id":"23055"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"78002","links":{"self":"https://app.emedici.com/api/questionRevisions/78002"},"attributes":{"stem":"\u003Cp\u003EMacrocyclic lactones are a class of antiparasitic drugs widely used in both human and veterinary medicine for treating various parasitic infections.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the primary mechanism of action of macrocyclic lactones?","responseType":"sba","marks":1,"options":["Binds to glutamate-gated chloride channels causing paralysis","Disrupts parasite cell membrane integrity","Blocks acetylcholinesterase in parasites","Inhibits parasite protein synthesis","Interferes with parasite microtubule formation"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EMacrocyclic lactones primarily work by \u003Cstrong\u003Ebinding to glutamate-gated chloride channels\u003C/strong\u003E in invertebrate nerve and pharyngeal muscle cells. This binding causes largely irreversible channel opening and chloride ion influx, leading to hyperpolarisation, paralysis, and eventual death of the parasite.\u003C/p\u003E\u003Cp\u003EThe incorrect mechanisms can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EDisrupts parasite cell membrane integrity\u003C/strong\u003E is a mechanism more commonly associated with certain antiseptics and antifungals.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EInterferes with parasite microtubule formation\u003C/strong\u003E is the mechanism of benzimidazole antiparasitic drugs\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EBlocks acetylcholinesterase in parasites \u003C/strong\u003E- MOA of organophosphates. \u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003EInhibits parasite protein synthesis\u003C/strong\u003E - mechanism of doxycycline. \u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThe selective toxicity of macrocyclic lactones comes from their poor penetration of the mammalian blood-brain barrier and their specificity for invertebrate glutamate-gated chloride channels. \u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Macrocyclic lactones like ivermectin work by binding to glutamate-gated chloride channels in invertebrate nerve and pharyngeal muscle cells.","Macrocyclic lactones cause hyperpolarisation of invertebrate nerve and pharyngeal muscle cells leading to paralysis and death of parasites.","Macrocyclic lactones have minimal effects on mammalian cells due to poor penetration of the blood-brain barrier."],"references":["Therapeutic Guidelines. Melbourne: Therapeutic Guidelines Limited. Available from: https://www.tg.org.au","Ritter J, Flower RJ (Rod J), Henderson G (Graeme), et al.\u00a0Rang and Dale\u2019s Pharmacology. Tenth edition. Elsevier; 2024.","Australian Medicines Handbook\u00a0(online). Adelaide: Australian Medicines Handbook Pty Ltd. Available from:\u00a0https://amhonline.amh.net.au/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"63424"}},"question":{"data":{"type":"questions","id":"17042"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"63424","links":{"self":"https://app.emedici.com/api/itemRevisions/63424"},"attributes":{"createdAt":"2025-01-08T22:24:42+10:30","updatedAt":"2025-01-08T22:25:08+10:30"},"relationships":{"item":{"data":{"type":"items","id":"9732"}},"content":{"data":{"type":"questionRevisions","id":"78002"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relat