{"data":[{"type":"questionAttempts","id":"17584766","links":{"self":"https://app.emedici.com/api/questionAttempts/17584766"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T07:56:16+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T07:56:16+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"14801"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"14801","links":{"self":"https://app.emedici.com/api/questions/14801"},"attributes":{"optionProportions":[0,0.82,0.09,0.03,0.06]},"relationships":{"item":{"data":{"type":"items","id":"7492"}},"activeRevision":{"data":{"type":"questionRevisions","id":"83506"}}}},{"type":"items","id":"7492","links":{"self":"https://app.emedici.com/api/items/7492"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"14801"}},"activeRevision":{"data":{"type":"itemRevisions","id":"68379"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4930"},{"type":"tags","id":"4931"},{"type":"tags","id":"4942"},{"type":"tags","id":"4943"},{"type":"tags","id":"5177"},{"type":"tags","id":"8512"},{"type":"tags","id":"10293"},{"type":"tags","id":"10315"}]},"contributions":{"data":[{"type":"contributions","id":"18331"},{"type":"contributions","id":"18333"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"83506","links":{"self":"https://app.emedici.com/api/questionRevisions/83506"},"attributes":{"stem":"\u003Cp\u003EA 25-year-old woman presents with fluctuating muscle weakness that worsens throughout the day. She is diagnosed with myasthenia gravis and started on medication.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the mechanism of action of pyridostigmine in treating myasthenia gravis?","responseType":"sba","marks":1,"options":["Blocks voltage-gated calcium channels","Inhibits acetylcholinesterase at the neuromuscular junction","Increases acetylcholine receptor expression","Stimulates acetylcholine synthesis","Suppresses autoantibody production"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EIn myasthenia gravis, \u003Cstrong\u003Einhibition of acetylcholinesterase\u003C/strong\u003E by pyridostigmine prevents the breakdown of acetylcholine at the neuromuscular junction. This increases the concentration and duration of acetylcholine in the synaptic cleft, helping to treat symptoms of myasthenia gravis.\u003C/p\u003E\u003Cp\u003EThe medication does not \u003Cstrong\u003Eblock voltage-gated calcium channels\u003C/strong\u003E, which would actually impair neurotransmitter release. This describes the action of calcium channel blockers.\u003C/p\u003E\u003Cp\u003EIt also does not directly \u003Cstrong\u003Estimulate acetylcholine synthesis\u003C/strong\u003E or \u003Cstrong\u003Eincrease acetylcholine receptor expression\u003C/strong\u003E.\u003C/p\u003E\u003Cp\u003EWhile immunosuppressive treatments are used in myasthenia gravis, pyridostigmine does not \u003Cstrong\u003Esuppress autoantibody production\u003C/strong\u003E.\u003C/p\u003E\u003Cp\u003ECommon side effects of pyridostigmine include increased secretions (sweating, salivation, lacrimation), abdominal cramps, and diarrhoea due to increased cholinergic activity.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Acetylcholinesterase inhibitors like pyridostigmine are first-line treatments for myasthenia gravis","Acetylcholinesterase inhibitors work by preventing the breakdown of acetylcholine at the neuromuscular junction","Side effects of acetylcholinesterase inhibitors include increased secretions and gastrointestinal symptoms"],"references":["Therapeutic Guidelines. Melbourne: Therapeutic Guidelines Limited. Available from: https://www.tg.org.au","Australian Medicines Handbook\u00a0(online). Adelaide: Australian Medicines Handbook Pty Ltd. Available from:\u00a0https://amhonline.amh.net.au/","Ritter J, Flower RJ (Rod J), Henderson G (Graeme), et al.\u00a0Rang and Dale\u2019s Pharmacology. Tenth edition. Elsevier; 2024."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"68379"}},"question":{"data":{"type":"questions","id":"14801"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"68379","links":{"self":"https://app.emedici.com/api/itemRevisions/68379"},"attributes":{"createdAt":"2025-02-04T20:42:18+10:30","updatedAt":"2025-02-04T20:42:50+10:30"},"relationships":{"item":{"data":{"type":"items","id":"7492"}},"content":{"data":{"type":"questionRevisions","id":"83506"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4930","links":{"self":"https://app.emedici.com/api/tags/4930"},"attributes":{"emoji":"\ud83e\udde0","na