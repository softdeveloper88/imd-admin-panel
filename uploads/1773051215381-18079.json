{"data":[{"type":"questionAttempts","id":"17645027","links":{"self":"https://app.emedici.com/api/questionAttempts/17645027"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T20:11:23+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T20:11:23+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18079"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18079","links":{"self":"https://app.emedici.com/api/questions/18079"},"attributes":{"optionProportions":[0,0,0.95,0.05,0]},"relationships":{"item":{"data":{"type":"items","id":"10793"}},"activeRevision":{"data":{"type":"questionRevisions","id":"74988"}}}},{"type":"items","id":"10793","links":{"self":"https://app.emedici.com/api/items/10793"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18079"}},"activeRevision":{"data":{"type":"itemRevisions","id":"60494"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4947"},{"type":"tags","id":"5631"},{"type":"tags","id":"5706"}]},"contributions":{"data":[{"type":"contributions","id":"25147"},{"type":"contributions","id":"25949"},{"type":"contributions","id":"25963"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"74988","links":{"self":"https://app.emedici.com/api/questionRevisions/74988"},"attributes":{"stem":"\u003Cp\u003EIn Australia, certain categories of death require mandatory reporting to the coroner for investigation and review. These deaths may occur in various settings including hospitals, aged care facilities, private homes, or public places.\u003C/p\u003E","stemQuestion":"Which one of the following deaths would most likely be considered reviewable?","responseType":"sba","marks":1,"options":["Death from end-stage renal disease on dialysis","Death from expected progression of heart failure","Death during gastrectomy under general anaesthesia","Death from pneumonia in a five-year-old with cystic fibrosis","Death from advanced metastatic cancer in palliative care"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EA \u003Cstrong\u003Edeath during gastrectomy under general anaesthesia\u003C/strong\u003E is automatically considered a reviewable death as it occurred during a surgical procedure under anaesthesia. All deaths that occur during or as a result of anaesthesia or surgical procedures must be reported to the coroner.\u003C/p\u003E\u003Cp\u003EThe other options describe natural deaths that would typically not require coronial review:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EA \u003Cstrong\u003Edeath from end-stage renal disease on dialysis\u003C/strong\u003E represents a natural progression of a documented chronic medical condition.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EA \u003Cstrong\u003Edeath from expected progression of heart failure\u003C/strong\u003E occurs as part of the natural course of a known cardiovascular condition.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EA \u003Cstrong\u003Edeath from pneumonia in a five-year-old with cystic fibrosis\u003C/strong\u003E represents a known complication of an underlying genetic condition.\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EA \u003Cstrong\u003Edeath from advanced metastatic cancer in palliative care\u003C/strong\u003E represents an anticipated outcome in a patient receiving end-of-life care.\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EOther categories of reviewable deaths include unexpected deaths, deaths from violence or injury, deaths in custody, deaths of unknown cause, and healthcare-associated deaths that may have been preventable.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Reviewable deaths must be reported to the coroner and include deaths that are unexpected, unnatural, violent, or result from accident or injury.","Healthcare-associated deaths that are unexpected or potentially preventable are considered reviewable deaths.","Deaths occurring during or following anaesthesia or surgical procedures are automatically considered reviewable deaths."],"references":["Clinical practice guidelines: death of a child. Royal Children\u0027s Hospital. Updated September 2022. Available from: https://www.rch.org.au/clinicalguide/guideline_index/Death_of_a_child/"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"60494"}},"question":{"data":{"type":"questions","id":"18079"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"60494","links":{"self":"https://app.emedici.com/api/itemRevisions/60494"},"attributes":{"createdAt":"2024-12-28T16:43:15+10:30","updatedAt":"2024-12-28T16:43:49+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10793"}},"content":{"data":{"type":"questionRevisions","id":"74988"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":n