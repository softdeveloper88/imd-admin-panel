{"data":[{"type":"questionAttempts","id":"17640863","links":{"self":"https://app.emedici.com/api/questionAttempts/17640863"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T19:19:21+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T19:19:21+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17841"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17841","links":{"self":"https://app.emedici.com/api/questions/17841"},"relationships":{"item":{"data":{"type":"items","id":"10555"}},"activeRevision":{"data":{"type":"questionRevisions","id":"78242"}}}},{"type":"items","id":"10555","links":{"self":"https://app.emedici.com/api/items/10555"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17841"}},"activeRevision":{"data":{"type":"itemRevisions","id":"63651"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4929"},{"type":"tags","id":"4942"}]},"contributions":{"data":[{"type":"contributions","id":"24612"},{"type":"contributions","id":"24616"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"78242","links":{"self":"https://app.emedici.com/api/questionRevisions/78242"},"attributes":{"stem":"\u003Cp\u003EAfter a meal containing carbohydrates, glucose is distributed to various tissues in the body. Different tissues have varying capacities for glucose uptake based on their metabolic needs and insulin sensitivity.\u003C/p\u003E","stemQuestion":"Which one of the following tissues receives the second highest proportion of ingested glucose after feeding?","responseType":"sba","marks":1,"options":["Skeletal muscle","Brain","Liver","Adipose tissue","Kidney"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Eliver\u003C/strong\u003E receives approximately 30% of ingested glucose after feeding, second only to the brain. The liver plays a crucial role in glucose homeostasis by storing glucose as glycogen and regulating blood glucose levels through glycogenolysis and gluconeogenesis.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Ebrain\u003C/strong\u003E receives the highest proportion (approximately 40%) as it relies almost exclusively on glucose for energy and requires a constant supply.\u003C/p\u003E\u003Cp\u003EThe other options receive smaller proportions:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003ESkeletal muscle\u003C/strong\u003E takes up glucose in an insulin-dependent manner, primarily for immediate energy use or glycogen storage\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EAdipose tissue\u003C/strong\u003E takes up glucose for conversion to triglycerides, but in smaller amounts than the liver\u003C/li\u003E\u003Cli\u003EThe \u003Cstrong\u003Ekidney\u003C/strong\u003E uses glucose for energy but accounts for only a small percentage of total glucose uptake\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThe distribution pattern reflects both the metabolic priorities of the body and the insulin sensitivity of different tissues.\u003C/p\u003E","optionExplanations":null,"learningPoints":["After feeding, the liver receives approximately 30% of ingested glucose due to its role in glycogen storage and glucose homeostasis","The brain receives approximately 40% of ingested glucose as it relies almost exclusively on glucose for energy","Insulin-dependent glucose uptake occurs primarily in muscle, liver and adipose tissue"],"references":["Bender, D. A., \u0026 Cunningham, S. M. (2021). Introduction to nutrition and metabolism. CRC Press","Salway, J. G. (2016). Metabolism at a Glance. John Wiley \u0026 Sons","Chandel NS. Carbohydrate Metabolism. Cold Spring Harb Perspect Biol. 2021 Jan 4;13(1):a040568. doi: 10.1101/cshperspect.a040568. PMID: 33397651; PMCID: PMC7778149"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"63651"}},"question":{"data":{"type":"questions","id":"17841"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"63651","links":{"self":"https://app.emedici.com/api/itemRevisions/63651"},"attributes":{"createdAt":"2025-01-09T22:47:01+10:30","updatedAt":"2025-01-09T23:46:49+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10555"}},"content":{"data":{"type":"questionRevisions","id":"78242"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4929","links":{"self":"https://app.emedici.com/api/tags/4929"},"attributes":{"emoji":"\ud83c\udf6d","name":"Endocrine","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-10-31T09:50:27+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"13"}},"heading":{"data":null}},"meta":{"itemCount":