links":{"self":"https://app.emedici.com/api/items/1269"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"1269"}},"activeRevision":{"data":{"type":"itemRevisions","id":"85099"}},"tags":{"data":[{"type":"tags","id":"4"},{"type":"tags","id":"65"},{"type":"tags","id":"72"},{"type":"tags","id":"76"},{"type":"tags","id":"3542"},{"type":"tags","id":"4962"},{"type":"tags","id":"4987"},{"type":"tags","id":"4988"},{"type":"tags","id":"4992"},{"type":"tags","id":"11625"},{"type":"tags","id":"11640"},{"type":"tags","id":"11642"},{"type":"tags","id":"11650"},{"type":"tags","id":"12912"},{"type":"tags","id":"12921"}]},"contributions":{"data":[{"type":"contributions","id":"2625"},{"type":"contributions","id":"2637"},{"type":"contributions","id":"35949"},{"type":"contributions","id":"42270"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"102620","links":{"self":"https://app.emedici.com/api/questionRevisions/102620"},"attributes":{"stem":"\u003Cp\u003EA 25-year-old woman presents with a painful, swollen neck. She also reports new onset sleeplessness, a sensation of anxiety and loose stools with increased appetite. Apart from a recent sore throat and dry cough, she has been well. Her medical history is unremarkable. She is on the oral contraceptive pill but no other regular medications. On examination, she is afebrile and has sinus tachycardia of 102/min. Her thyroid is asymmetrically enlarged, firm, tender and warm to touch.\u003C/p\u003E","stemQuestion":"Which one of the following investigations is most appropriate to perform next to establish the diagnosis?","responseType":"sba","marks":1,"options":["Thyroid function tests (TFTs)","Radioactive iodine uptake scan","Nil further investigation","Epstein Barr Virus (EBV) serology","Thyroid ultrasonography"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003ESubacute granulomatous thyroiditis, also known as de Quervain\u0027s thyroiditis, is the diagnosis, with a recent viral upper respiratory tract infection, tender thyroid and symptoms and signs suggestive of clinical hyperthyroidism. To confirm the diagnosis, \u003Cstrong\u003Ethyroid function tests\u003C/strong\u003E (TFTs) should be performed. Whilst the additional investigations could confer additional diagnostic value and identify which stage the disease is at, these are not essential.\u003C/p\u003E\u003Cp\u003ESubacute granulomatous thyroiditis often follows a defined course: with initial inflammation, there is excessive release of free thyroxine resulting in clinical hyperthyroidism, suppressed TSH and reduced radioactive iodine uptake; next, there is clinical euthyroidism; gradually, circulating thyroxine diminishes resulting in clinical hypothyroidism, elevated TSH and recovery of radioactive iodine uptake; eventually, the patient returns to clinical euthyroidism. Its management remains symptomatic, with anti-inflammatories and beta blockers forming the mainstay of treatment.\u003C/p\u003E","optionExplanations":null,"learningPoints":["A painful thyroid swelling after a recent viral infection is virtually diagnostic of thyroiditis."],"references":["Slatosky, J, Shipton, B \u0026 Haney Wahba 2013, \u2018Thyroiditis: Differential Diagnosis and Management\u2019, American Family Physician, vol. 61, no. 4, pp. 1047\u20131052."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"85099"}},"question":{"data":{"type":"questions","id":"1269"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"85099","links":{"self":"https://app.emedici.com/api/itemRevisions/85099"},"attributes":{"createdAt":"2025-05-13T14:05:25+09:30","updatedAt":"2025-05-13T14:06:15+09:30"},"relationships":{"item":{"data":{"type":"items","id":"1269"}},"content":{"data":{"type":"questionRevisions","id":"102620"}}},"meta":{"canDelete":false}},{"type":"tags","id":"4","links":{"self":"https://app.emedici.com/api/tags/4"},"attributes":{"emoji":"\ud83c\udf6c","name":"Endocrinology","synonyms":[],"description":null,"position":null,"createdAt":null,"updatedAt":"2024-11-21T09:49:43+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"65","links":{"self":"https://app.emedici.com/api/tags/65"},"attributes":{"emoji":"","name":"Investigations","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"72","links":{"self":"https://app.emedici.com/api/tags/72"},"attributes":{"emoji":"","name":"Graduating","synonyms":null,"description":"Only suitable for a graduating medical student at the end of their degree","position":1,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"76","links":{"self":"https://app.emedici.com/api/tags/76"},"attributes":{"emoji":"","name":"Level II","synonyms":null,"description":"Understand (interpreting and summarizing information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"3542","links":{"self":"https://app.emedici.com/api/tags/3542"},"attributes":{"emoji":"","name":"De quervain\u0027s thyroiditis","synonyms":["Subacute thyroiditis"],"description":null,"position":null,"createdAt":"2024-09-23T04:54:08+09:30","updatedAt":"2024-09-23T04:54:08+09:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"2"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4962","links":{"self":"https://app.emedici.com/api/tags/4962"},"attributes":{"emoji":"","name":"Endocrine and Metabolic Health","synonyms":null,