{"data":[{"type":"questionAttempts","id":"17642755","links":{"self":"https://app.emedici.com/api/questionAttempts/17642755"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T19:43:44+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T19:43:44+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17964"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17964","links":{"self":"https://app.emedici.com/api/questions/17964"},"relationships":{"item":{"data":{"type":"items","id":"10678"}},"activeRevision":{"data":{"type":"questionRevisions","id":"79246"}}}},{"type":"items","id":"10678","links":{"self":"https://app.emedici.com/api/items/10678"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17964"}},"activeRevision":{"data":{"type":"itemRevisions","id":"64588"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4931"},{"type":"tags","id":"4941"},{"type":"tags","id":"7272"}]},"contributions":{"data":[{"type":"contributions","id":"24869"},{"type":"contributions","id":"24871"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"79246","links":{"self":"https://app.emedici.com/api/questionRevisions/79246"},"attributes":{"stem":"\u003Cp\u003EA medical student is studying facial muscle anatomy. \u003C/p\u003E","stemQuestion":"Which one of the following muscles is primarily responsible for creating these vertical wrinkles?","responseType":"sba","marks":1,"options":["Procerus","Levator labii superioris","Orbicularis oculi (orbital and palpebral)","Occipitofrontalis","Corrugator supercilii"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Ecorrugator supercilii\u003C/strong\u003E muscle is primarily responsible for drawing the eyebrows downward and medially, which results in the formation of vertical wrinkles above the nose. This muscle is involved in frowning and is often targeted in cosmetic procedures to reduce the appearance of these lines.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Eprocerus\u003C/strong\u003E muscle also contributes to frowning by pulling the skin between the eyebrows downward, but it primarily creates horizontal lines over the bridge of the nose rather than vertical lines.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Elevator labii superioris\u003C/strong\u003E is involved in elevating the upper lip and does not contribute to the formation of wrinkles between the eyebrows.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Eorbicularis oculi\u003C/strong\u003E muscle encircles the eye and is responsible for closing the eyelids. It does not create vertical wrinkles between the eyebrows.\u003C/p\u003E\u003Cp\u003EThe \u003Cstrong\u003Eoccipitofrontalis\u003C/strong\u003E muscle elevates the eyebrows and creates horizontal wrinkles on the forehead, not vertical wrinkles between the eyebrows.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["The corrugator supercilii muscle is responsible for drawing the eyebrows downward and medially, creating vertical wrinkles above the nose.","Understanding the function of facial muscles is crucial for diagnosing and treating facial nerve disorders."],"references":["Singh, V. (2023). Textbook of Anatomy-Head, Neck and Brain, Volume III-E-Book. Elsevier Health Sciences","Patestas, M. A., \u0026 Gartner, L. P. (2016). A textbook of neuroanatomy. John Wiley \u0026 Sons","Patel, C. R., Fernandez-Miranda, J. C., Wang, W. H., \u0026 Wang, E. W. (2016). Skull Base Anatomy. Otolaryngologic clinics of North America, 49(1), 9\u201320. https://doi.org/10.1016/j.otc.2015.09.001","Anderson, B. W., Kortz, M. W., Black, A. C., \u0026 Al Kharazi, K. A. (2023). Anatomy, Head and Neck, Skull. In StatPearls. StatPearls Publishing"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"64588"}},"question":{"data":{"type":"questions","id":"17964"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"64588","links":{"self":"https://app.emedici.com/api/itemRevisions/64588"},"attributes":{"createdAt":"2025-01-13T21:08:18+10:30","updatedAt":"2025-01-13T21:09:54+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10678"}},"content":{"data":{"type":"questionRevisions","id":"79246"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4931","links":{"self":"https://app.emedici.com/api/tags/4931"},"attributes":{"emoji":"\ud83e\uddb4","name":"Musculoskeletal","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:16:52+10:30","updatedAt":"2024-10-31T09:50:31+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"13"}},"heading":{"data":null}},"me