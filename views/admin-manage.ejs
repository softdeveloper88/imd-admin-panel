<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>iMD Admin Panel</title>
  <style>
    :root {
      --bg: #f4efe7; --panel: rgba(255,251,245,0.9); --panel-strong: #fffdf8;
      --ink: #1d2a2f; --muted: #66757e; --line: rgba(35,50,58,0.12);
      --brand: #0f766e; --brand-deep: #0b4f49;
      --danger: #b42318; --danger-bg: #fff0ed;
      --success: #0f7b4d; --success-bg: #edf9f0;
      --shadow: 0 22px 50px rgba(31,38,43,0.12); --radius: 16px;
    }
    * { box-sizing: border-box; margin: 0; }
    body { font-family: "Avenir Next","Helvetica Neue","Segoe UI",sans-serif; color: var(--ink);
      background: radial-gradient(circle at top left,rgba(15,118,110,0.14),transparent 26%),
      radial-gradient(circle at top right,rgba(217,119,6,0.12),transparent 20%),
      linear-gradient(180deg,#f8f2e8 0%,var(--bg) 100%); min-height: 100vh; }
    a { color: var(--brand); text-decoration: none; }
    .page { max-width: 1440px; margin: 0 auto; padding: 20px; }

    /* Top bar */
    .topbar { display: flex; justify-content: space-between; align-items: center; padding: 18px 24px; margin-bottom: 20px;
      border-radius: 20px; background: linear-gradient(135deg,rgba(12,58,69,0.96),rgba(22,90,84,0.88));
      color: #f9fafb; box-shadow: var(--shadow); }
    .topbar h1 { font-size: 24px; font-weight: 700; }
    .topbar-actions { display: flex; gap: 10px; align-items: center; }
    .topbar-actions a { color: rgba(255,255,255,0.8); font-size: 14px; padding: 8px 16px; border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.2); transition: all 0.2s; }
    .topbar-actions a:hover { background: rgba(255,255,255,0.15); color: #fff; }

    /* Stats row */
    .stats { display: grid; grid-template-columns: repeat(auto-fill,minmax(180px,1fr)); gap: 14px; margin-bottom: 20px; }
    .stat-card { background: var(--panel); border: 1px solid rgba(255,255,255,0.7); border-radius: var(--radius);
      padding: 20px; box-shadow: 0 8px 24px rgba(0,0,0,0.06); text-align: center; }
    .stat-card .num { font-size: 32px; font-weight: 700; color: var(--brand-deep); }
    .stat-card .lbl { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; }

    /* Tab navigation */
    .tab-nav { display: flex; gap: 4px; margin-bottom: 16px; border-bottom: 2px solid var(--line); padding-bottom: 0; }
    .tab-btn { padding: 10px 20px; border: none; background: none; font-size: 14px; font-weight: 600; cursor: pointer;
      color: var(--muted); border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.2s; }
    .tab-btn.active { color: var(--brand-deep); border-bottom-color: var(--brand); }
    .tab-btn:hover { color: var(--ink); }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* Cards */
    .card { background: var(--panel); border: 1px solid rgba(255,255,255,0.7); border-radius: var(--radius);
      box-shadow: var(--shadow); backdrop-filter: blur(16px); margin-bottom: 16px; overflow: hidden; }
    .card-header { padding: 16px 20px; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; align-items: center; }
    .card-header h3 { font-size: 16px; font-weight: 600; }
    .card-body { padding: 16px 20px; }

    /* Table */
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 10px 12px; color: var(--muted); font-weight: 600; font-size: 11px;
      text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 2px solid var(--line); }
    td { padding: 10px 12px; border-bottom: 1px solid var(--line); vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(15,118,110,0.03); }

    /* Badges */
    .badge { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
    .badge-success { background: var(--success-bg); color: var(--success); }
    .badge-danger { background: var(--danger-bg); color: var(--danger); }
    .badge-muted { background: #f0f0f0; color: var(--muted); }
    .badge-brand { background: rgba(15,118,110,0.1); color: var(--brand-deep); }

    /* Buttons */
    .btn { padding: 7px 16px; border-radius: 10px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; }
    .btn-brand { background: var(--brand); color: #fff; }
    .btn-brand:hover { background: var(--brand-deep); }
    .btn-danger { background: var(--danger); color: #fff; }
    .btn-danger:hover { opacity: 0.85; }
    .btn-outline { background: none; border: 1px solid var(--line); color: var(--ink); }
    .btn-outline:hover { background: rgba(0,0,0,0.04); }
    .btn-sm { padding: 4px 10px; font-size: 12px; }

    /* Forms */
    .form-row { display: flex; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
    .form-group { display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 160px; }
    .form-group label { font-size: 12px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .form-group input, .form-group select, .form-group textarea {
      padding: 8px 12px; border: 1px solid var(--line); border-radius: 8px; font-size: 14px; background: var(--panel-strong); }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px rgba(15,118,110,0.12); }

    /* Modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: none; align-items: center; justify-content: center; z-index: 1000; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--panel-strong); border-radius: 20px; padding: 24px; max-width: 520px; width: 90%; box-shadow: var(--shadow); }
    .modal h3 { margin-bottom: 16px; }

    /* Responsive */
    @media (max-width: 768px) {
      .stats { grid-template-columns: repeat(2, 1fr); }
      .tab-nav { overflow-x: auto; flex-wrap: nowrap; }
      .form-row { flex-direction: column; }
      table { font-size: 12px; }
      th, td { padding: 8px 6px; }
    }

    .loading { text-align: center; padding: 40px; color: var(--muted); }
    .empty { text-align: center; padding: 40px; color: var(--muted); font-style: italic; }
  </style>
</head>
<body>
<div class="page">
  <!-- Top bar -->
  <div class="topbar">
    <div>
      <h1>⚙ Admin Panel</h1>
    </div>
    <div class="topbar-actions">
      <a href="/dashboard">← Content Dashboard</a>
      <a href="/logout" style="border-color:rgba(255,100,100,0.3);color:rgba(255,200,200,0.9);">Logout</a>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats" id="statsRow">
    <div class="stat-card"><div class="num" id="statUsers">-</div><div class="lbl">Total Users</div></div>
    <div class="stat-card"><div class="num" id="statActive">-</div><div class="lbl">Active Users</div></div>
    <div class="stat-card"><div class="num" id="statSessions">-</div><div class="lbl">Active Sessions</div></div>
    <div class="stat-card"><div class="num" id="statDownloads">-</div><div class="lbl">Total Downloads</div></div>
    <div class="stat-card"><div class="num" id="statPackages">-</div><div class="lbl">Packages</div></div>
  </div>

  <!-- Tab navigation -->
  <div class="tab-nav">
    <button class="tab-btn active" data-tab="users">Users</button>
    <button class="tab-btn" data-tab="subscriptions">Subscriptions</button>
    <button class="tab-btn" data-tab="content">Content Access</button>
    <button class="tab-btn" data-tab="tabs">Tab Management</button>
    <button class="tab-btn" data-tab="categories">Categories</button>
    <button class="tab-btn" data-tab="analytics">Analytics</button>
    <button class="tab-btn" data-tab="logs">Activity Log</button>
  </div>

  <!-- ═══ Users Tab ═══ -->
  <div class="tab-panel active" id="tab-users">
    <div class="card">
      <div class="card-header">
        <h3>User Management</h3>
        <button class="btn btn-brand" onclick="showCreateUser()">+ New User</button>
      </div>
      <div class="card-body">
        <table>
          <thead><tr>
            <th>ID</th><th>Username</th><th>Email</th><th>Subscription</th><th>Expires</th>
            <th>Status</th><th>Sessions</th><th>Downloads</th><th>Actions</th>
          </tr></thead>
          <tbody id="usersTable"><tr><td colspan="9" class="loading">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ═══ Subscriptions Tab ═══ -->
  <div class="tab-panel" id="tab-subscriptions">
    <div class="card">
      <div class="card-header">
        <h3>Subscription Plans</h3>
        <button class="btn btn-brand" onclick="showCreatePlan()">+ New Plan</button>
      </div>
      <div class="card-body">
        <table>
          <thead><tr><th>ID</th><th>Name</th><th>Duration</th><th>Price</th><th>Access Level</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="plansTable"><tr><td colspan="7" class="loading">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ═══ Content Access Tab ═══ -->
  <div class="tab-panel" id="tab-content">
    <div class="card">
      <div class="card-header">
        <h3>Package Access Control</h3>
        <span style="font-size:12px;color:var(--muted)">Set minimum subscription level for each package</span>
      </div>
      <div class="card-body">
        <table>
          <thead><tr><th>Package</th><th>Min Access Level</th><th>Visible</th><th>Actions</th></tr></thead>
          <tbody id="accessTable"><tr><td colspan="4" class="loading">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ═══ Tab Management ═══ -->
  <div class="tab-panel" id="tab-tabs">
    <div class="card">
      <div class="card-header">
        <h3>Tab Content Control</h3>
        <button class="btn btn-brand" onclick="showAddTabItem()">+ Pin Package to Tab</button>
      </div>
      <div class="card-body">
        <table>
          <thead><tr><th>Tab</th><th>Package</th><th>Order</th><th>Pinned</th><th>Actions</th></tr></thead>
          <tbody id="tabsTable"><tr><td colspan="5" class="loading">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ═══ Categories Tab ═══ -->
  <div class="tab-panel" id="tab-categories">
    <div class="card">
      <div class="card-header">
        <h3>Categories</h3>
        <button class="btn btn-brand" onclick="showCreateCategory()">+ New Category</button>
      </div>
      <div class="card-body">
        <table>
          <thead><tr><th>ID</th><th>Name</th><th>Order</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="catsTable"><tr><td colspan="5" class="loading">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ═══ Analytics Tab ═══ -->
  <div class="tab-panel" id="tab-analytics">
    <div class="card">
      <div class="card-header"><h3>Subscription Distribution</h3></div>
      <div class="card-body" id="subDistribution"><div class="loading">Loading...</div></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div class="card">
        <div class="card-header"><h3>Top Downloads</h3></div>
        <div class="card-body">
          <table><thead><tr><th>Package</th><th>Downloads</th></tr></thead>
          <tbody id="topDownloadsTable"><tr><td colspan="2" class="loading">Loading...</td></tr></tbody></table>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><h3>Recent Downloads</h3></div>
        <div class="card-body">
          <table><thead><tr><th>User</th><th>Package</th><th>Date</th></tr></thead>
          <tbody id="recentDownloadsTable"><tr><td colspan="3" class="loading">Loading...</td></tr></tbody></table>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ Logs Tab ═══ -->
  <div class="tab-panel" id="tab-logs">
    <div class="card">
      <div class="card-header"><h3>Admin Activity Log</h3></div>
      <div class="card-body">
        <table>
          <thead><tr><th>Time</th><th>Admin</th><th>Action</th><th>Target</th><th>Details</th></tr></thead>
          <tbody id="logsTable"><tr><td colspan="5" class="loading">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <h3 id="modalTitle">Modal</h3>
    <div id="modalBody"></div>
  </div>
</div>

<script>
const API = '';
let allPackageNames = [];

// ── Tab switching ──
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

function openModal(title, html) {
  document.getElementById('modalTitle').textContent = title;
  document.getElementById('modalBody').innerHTML = html;
  document.getElementById('modal').classList.add('open');
}
function closeModal() { document.getElementById('modal').classList.remove('open'); }
document.getElementById('modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });

function fmtDate(d) { return d ? new Date(d).toLocaleDateString() : '—'; }
function fmtTime(d) { return d ? new Date(d).toLocaleString() : '—'; }

async function api(url, opts = {}) {
  const res = await fetch(API + url, { ...opts, headers: { 'Content-Type': 'application/json', ...opts.headers } });
  if (!res.ok) { const e = await res.json().catch(() => ({})); throw new Error(e.error || res.statusText); }
  return res.json();
}

// ── Load analytics + stats ──
async function loadAnalytics() {
  try {
    const d = await api('/api/admin/analytics');
    document.getElementById('statUsers').textContent = d.total_users;
    document.getElementById('statActive').textContent = d.active_users;
    document.getElementById('statSessions').textContent = d.active_sessions;
    document.getElementById('statDownloads').textContent = d.total_downloads;
    document.getElementById('statPackages').textContent = d.total_packages;

    // Sub distribution
    const distHtml = d.subscription_counts.map(s =>
      `<span class="badge badge-brand" style="margin:4px;">${s.subscription_type}: ${s.count}</span>`
    ).join('') || '<span class="empty">No data</span>';
    document.getElementById('subDistribution').innerHTML = distHtml;

    // Top downloads
    document.getElementById('topDownloadsTable').innerHTML = d.top_downloads.length
      ? d.top_downloads.map(r => `<tr><td>${esc(r.package_name)}</td><td><strong>${r.download_count}</strong></td></tr>`).join('')
      : '<tr><td colspan="2" class="empty">No downloads yet</td></tr>';

    // Recent downloads
    document.getElementById('recentDownloadsTable').innerHTML = d.recent_downloads.length
      ? d.recent_downloads.map(r => `<tr><td>${esc(r.username)}</td><td>${esc(r.package_name)}</td><td>${fmtTime(r.downloaded_at)}</td></tr>`).join('')
      : '<tr><td colspan="3" class="empty">No downloads yet</td></tr>';
  } catch (err) { console.error('Analytics load error:', err); }
}

// ── Users ──
async function loadUsers() {
  try {
    const users = await api('/api/admin/users');
    document.getElementById('usersTable').innerHTML = users.length ? users.map(u => `
      <tr>
        <td>${u.id}</td>
        <td><strong>${esc(u.username)}</strong></td>
        <td>${esc(u.email || '—')}</td>
        <td><span class="badge badge-brand">${esc(u.subscription_type)}</span></td>
        <td>${fmtDate(u.subscription_expires)}</td>
        <td>${u.is_active ? '<span class="badge badge-success">Active</span>' : '<span class="badge badge-danger">Disabled</span>'}</td>
        <td>${u.active_sessions} <small>(${esc(u.last_device || '—')})</small></td>
        <td>${u.download_count}</td>
        <td>
          <button class="btn btn-outline btn-sm" onclick="editUser(${u.id},'${esc(u.username)}','${esc(u.email||'')}','${esc(u.subscription_type)}','${u.subscription_expires||''}',${u.is_active})">Edit</button>
          <button class="btn btn-outline btn-sm" onclick="forceLogout(${u.id})">Logout</button>
          <button class="btn btn-danger btn-sm" onclick="deleteUser(${u.id},'${esc(u.username)}')">Del</button>
        </td>
      </tr>
    `).join('') : '<tr><td colspan="9" class="empty">No users</td></tr>';
  } catch (err) { document.getElementById('usersTable').innerHTML = `<tr><td colspan="9" class="empty">Error: ${esc(err.message)}</td></tr>`; }
}

function showCreateUser() {
  openModal('Create User', `
    <div class="form-row"><div class="form-group"><label>Username</label><input id="nu_user" required></div>
    <div class="form-group"><label>Password</label><input id="nu_pass" type="password" required></div></div>
    <div class="form-row"><div class="form-group"><label>Email</label><input id="nu_email" type="email"></div>
    <div class="form-group"><label>Subscription</label><select id="nu_sub"><option>free</option><option>premium</option></select></div></div>
    <div class="form-row"><div class="form-group"><label>Expires</label><input id="nu_exp" type="date"></div></div>
    <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-brand" onclick="createUser()">Create</button></div>
  `);
}

async function createUser() {
  try {
    await api('/api/admin/users', { method: 'POST', body: JSON.stringify({
      username: document.getElementById('nu_user').value,
      password: document.getElementById('nu_pass').value,
      email: document.getElementById('nu_email').value || undefined,
      subscription_type: document.getElementById('nu_sub').value,
      subscription_expires: document.getElementById('nu_exp').value || undefined,
    })});
    closeModal(); loadUsers(); loadAnalytics();
  } catch (err) { alert(err.message); }
}

function editUser(id, username, email, sub, exp, active) {
  openModal('Edit User: ' + username, `
    <div class="form-row"><div class="form-group"><label>Email</label><input id="eu_email" value="${esc(email)}"></div>
    <div class="form-group"><label>New Password (blank=keep)</label><input id="eu_pass" type="password"></div></div>
    <div class="form-row"><div class="form-group"><label>Subscription</label>
      <select id="eu_sub"><option ${sub==='free'?'selected':''}>free</option><option ${sub==='premium'?'selected':''}>premium</option></select></div>
    <div class="form-group"><label>Expires</label><input id="eu_exp" type="date" value="${exp ? exp.substring(0,10) : ''}"></div></div>
    <div class="form-row"><div class="form-group"><label>Active</label>
      <select id="eu_active"><option value="1" ${active?'selected':''}>Yes</option><option value="0" ${!active?'selected':''}>No</option></select></div></div>
    <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-brand" onclick="updateUser(${id})">Save</button></div>
  `);
}

async function updateUser(id) {
  try {
    const body = {
      email: document.getElementById('eu_email').value || undefined,
      subscription_type: document.getElementById('eu_sub').value,
      subscription_expires: document.getElementById('eu_exp').value || undefined,
      is_active: parseInt(document.getElementById('eu_active').value),
    };
    const pw = document.getElementById('eu_pass').value;
    if (pw) body.password = pw;
    await api('/api/admin/users/' + id, { method: 'PUT', body: JSON.stringify(body) });
    closeModal(); loadUsers(); loadAnalytics();
  } catch (err) { alert(err.message); }
}

async function forceLogout(id) {
  if (!confirm('Force logout all sessions for this user?')) return;
  try { await api('/api/admin/users/' + id + '/force-logout', { method: 'POST' }); loadUsers(); } catch (err) { alert(err.message); }
}

async function deleteUser(id, name) {
  if (!confirm('Delete user "' + name + '"? This cannot be undone.')) return;
  try { await api('/api/admin/users/' + id, { method: 'DELETE' }); loadUsers(); loadAnalytics(); } catch (err) { alert(err.message); }
}

// ── Plans ──
async function loadPlans() {
  try {
    const plans = await api('/api/admin/plans');
    document.getElementById('plansTable').innerHTML = plans.length ? plans.map(p => `
      <tr>
        <td>${p.id}</td><td><strong>${esc(p.name)}</strong></td>
        <td>${p.duration_days} days</td><td>$${parseFloat(p.price).toFixed(2)}</td>
        <td><span class="badge badge-brand">Level ${p.access_level}</span></td>
        <td>${p.is_active ? '<span class="badge badge-success">Active</span>' : '<span class="badge badge-muted">Inactive</span>'}</td>
        <td>
          <button class="btn btn-outline btn-sm" onclick="editPlan(${p.id},'${esc(p.name)}','${esc(p.description||'')}',${p.duration_days},${p.price},${p.access_level},${p.is_active})">Edit</button>
          <button class="btn btn-danger btn-sm" onclick="deletePlan(${p.id},'${esc(p.name)}')">Del</button>
        </td>
      </tr>
    `).join('') : '<tr><td colspan="7" class="empty">No plans</td></tr>';
  } catch (err) { document.getElementById('plansTable').innerHTML = `<tr><td colspan="7" class="empty">Error: ${esc(err.message)}</td></tr>`; }
}

function showCreatePlan() {
  openModal('Create Plan', `
    <div class="form-row"><div class="form-group"><label>Name</label><input id="np_name" required></div>
    <div class="form-group"><label>Duration (days)</label><input id="np_days" type="number" value="30"></div></div>
    <div class="form-row"><div class="form-group"><label>Price</label><input id="np_price" type="number" step="0.01" value="0"></div>
    <div class="form-group"><label>Access Level</label><input id="np_level" type="number" value="1" min="1" max="4"></div></div>
    <div class="form-row"><div class="form-group"><label>Description</label><textarea id="np_desc" rows="2"></textarea></div></div>
    <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-brand" onclick="createPlan()">Create</button></div>
  `);
}

async function createPlan() {
  try {
    await api('/api/admin/plans', { method: 'POST', body: JSON.stringify({
      name: document.getElementById('np_name').value,
      description: document.getElementById('np_desc').value || undefined,
      duration_days: parseInt(document.getElementById('np_days').value),
      price: parseFloat(document.getElementById('np_price').value),
      access_level: parseInt(document.getElementById('np_level').value),
    })});
    closeModal(); loadPlans();
  } catch (err) { alert(err.message); }
}

function editPlan(id, name, desc, days, price, level, active) {
  openModal('Edit Plan: ' + name, `
    <div class="form-row"><div class="form-group"><label>Name</label><input id="ep_name" value="${esc(name)}"></div>
    <div class="form-group"><label>Duration (days)</label><input id="ep_days" type="number" value="${days}"></div></div>
    <div class="form-row"><div class="form-group"><label>Price</label><input id="ep_price" type="number" step="0.01" value="${price}"></div>
    <div class="form-group"><label>Access Level</label><input id="ep_level" type="number" value="${level}" min="1" max="4"></div></div>
    <div class="form-row"><div class="form-group"><label>Active</label>
      <select id="ep_active"><option value="1" ${active?'selected':''}>Yes</option><option value="0" ${!active?'selected':''}>No</option></select></div></div>
    <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-brand" onclick="updatePlan(${id})">Save</button></div>
  `);
}

async function updatePlan(id) {
  try {
    await api('/api/admin/plans/' + id, { method: 'PUT', body: JSON.stringify({
      name: document.getElementById('ep_name').value,
      duration_days: parseInt(document.getElementById('ep_days').value),
      price: parseFloat(document.getElementById('ep_price').value),
      access_level: parseInt(document.getElementById('ep_level').value),
      is_active: parseInt(document.getElementById('ep_active').value),
    })});
    closeModal(); loadPlans();
  } catch (err) { alert(err.message); }
}

async function deletePlan(id, name) {
  if (!confirm('Delete plan "' + name + '"?')) return;
  try { await api('/api/admin/plans/' + id, { method: 'DELETE' }); loadPlans(); } catch (err) { alert(err.message); }
}

// ── Content Access ──
async function loadAccess() {
  try {
    const pkgs = await api('/api/admin/package-access');
    allPackageNames = pkgs.map(p => p.name);
    document.getElementById('accessTable').innerHTML = pkgs.length ? pkgs.map(p => `
      <tr>
        <td><strong>${esc(p.name)}</strong></td>
        <td>
          <select onchange="updateAccess('${esc(p.name)}', this.value, ${p.is_visible})" style="padding:4px 8px;border-radius:6px;border:1px solid var(--line);">
            ${[1,2,3,4].map(l => `<option value="${l}" ${p.min_access_level===l?'selected':''}>Level ${l}</option>`).join('')}
          </select>
        </td>
        <td>
          <select onchange="updateAccess('${esc(p.name)}', ${p.min_access_level}, parseInt(this.value))" style="padding:4px 8px;border-radius:6px;border:1px solid var(--line);">
            <option value="1" ${p.is_visible?'selected':''}>Visible</option>
            <option value="0" ${!p.is_visible?'selected':''}>Hidden</option>
          </select>
        </td>
        <td><span class="badge badge-muted">Level ${p.min_access_level}</span></td>
      </tr>
    `).join('') : '<tr><td colspan="4" class="empty">No packages found</td></tr>';
  } catch (err) { document.getElementById('accessTable').innerHTML = `<tr><td colspan="4" class="empty">Error: ${esc(err.message)}</td></tr>`; }
}

async function updateAccess(name, level, visible) {
  try { await api('/api/admin/package-access/' + encodeURIComponent(name), { method: 'PUT', body: JSON.stringify({ min_access_level: level, is_visible: visible }) }); }
  catch (err) { alert(err.message); loadAccess(); }
}

// ── Tab Content ──
async function loadTabs() {
  try {
    const items = await api('/api/admin/tabs');
    document.getElementById('tabsTable').innerHTML = items.length ? items.map(t => `
      <tr>
        <td><span class="badge badge-brand">${esc(t.tab_name)}</span></td>
        <td>${esc(t.package_name)}</td>
        <td>${t.sort_order}</td>
        <td>${t.is_pinned ? '<span class="badge badge-success">Pinned</span>' : '<span class="badge badge-muted">No</span>'}</td>
        <td><button class="btn btn-danger btn-sm" onclick="deleteTabItem(${t.id})">Remove</button></td>
      </tr>
    `).join('') : '<tr><td colspan="5" class="empty">No pinned items — tabs use auto-sorting</td></tr>';
  } catch (err) { document.getElementById('tabsTable').innerHTML = `<tr><td colspan="5" class="empty">Error: ${esc(err.message)}</td></tr>`; }
}

function showAddTabItem() {
  const pkgOpts = allPackageNames.map(n => `<option value="${esc(n)}">${esc(n)}</option>`).join('');
  openModal('Pin Package to Tab', `
    <div class="form-row"><div class="form-group"><label>Tab</label>
      <select id="nt_tab"><option>newest</option><option>popular</option><option>trending</option><option>updates</option><option>paid</option></select></div>
    <div class="form-group"><label>Package</label><select id="nt_pkg">${pkgOpts}</select></div></div>
    <div class="form-row"><div class="form-group"><label>Sort Order</label><input id="nt_order" type="number" value="0"></div>
    <div class="form-group"><label>Pinned</label><select id="nt_pin"><option value="1">Yes</option><option value="0">No</option></select></div></div>
    <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-brand" onclick="addTabItem()">Add</button></div>
  `);
}

async function addTabItem() {
  try {
    await api('/api/admin/tabs', { method: 'POST', body: JSON.stringify({
      tab_name: document.getElementById('nt_tab').value,
      package_name: document.getElementById('nt_pkg').value,
      sort_order: parseInt(document.getElementById('nt_order').value),
      is_pinned: parseInt(document.getElementById('nt_pin').value),
    })});
    closeModal(); loadTabs();
  } catch (err) { alert(err.message); }
}

async function deleteTabItem(id) {
  if (!confirm('Remove this pinned item?')) return;
  try { await api('/api/admin/tabs/' + id, { method: 'DELETE' }); loadTabs(); } catch (err) { alert(err.message); }
}

// ── Categories ──
async function loadCategories() {
  try {
    const cats = await api('/api/admin/categories');
    document.getElementById('catsTable').innerHTML = cats.length ? cats.map(c => `
      <tr>
        <td>${c.id}</td><td><strong>${esc(c.name)}</strong></td><td>${c.sort_order}</td>
        <td>${c.is_active ? '<span class="badge badge-success">Active</span>' : '<span class="badge badge-muted">Inactive</span>'}</td>
        <td>
          <button class="btn btn-outline btn-sm" onclick="editCategory(${c.id},'${esc(c.name)}',${c.sort_order},${c.is_active})">Edit</button>
          <button class="btn btn-danger btn-sm" onclick="deleteCategory(${c.id},'${esc(c.name)}')">Del</button>
        </td>
      </tr>
    `).join('') : '<tr><td colspan="5" class="empty">No categories</td></tr>';
  } catch (err) { document.getElementById('catsTable').innerHTML = `<tr><td colspan="5" class="empty">Error: ${esc(err.message)}</td></tr>`; }
}

function showCreateCategory() {
  openModal('Create Category', `
    <div class="form-row"><div class="form-group"><label>Name</label><input id="nc_name" required></div>
    <div class="form-group"><label>Sort Order</label><input id="nc_order" type="number" value="0"></div></div>
    <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-brand" onclick="createCategory()">Create</button></div>
  `);
}

async function createCategory() {
  try {
    await api('/api/admin/categories', { method: 'POST', body: JSON.stringify({
      name: document.getElementById('nc_name').value,
      sort_order: parseInt(document.getElementById('nc_order').value),
    })});
    closeModal(); loadCategories();
  } catch (err) { alert(err.message); }
}

function editCategory(id, name, order, active) {
  openModal('Edit Category: ' + name, `
    <div class="form-row"><div class="form-group"><label>Name</label><input id="ec_name" value="${esc(name)}"></div>
    <div class="form-group"><label>Sort Order</label><input id="ec_order" type="number" value="${order}"></div></div>
    <div class="form-row"><div class="form-group"><label>Active</label>
      <select id="ec_active"><option value="1" ${active?'selected':''}>Yes</option><option value="0" ${!active?'selected':''}>No</option></select></div></div>
    <div style="margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-brand" onclick="updateCategory(${id})">Save</button></div>
  `);
}

async function updateCategory(id) {
  try {
    await api('/api/admin/categories/' + id, { method: 'PUT', body: JSON.stringify({
      name: document.getElementById('ec_name').value,
      sort_order: parseInt(document.getElementById('ec_order').value),
      is_active: parseInt(document.getElementById('ec_active').value),
    })});
    closeModal(); loadCategories();
  } catch (err) { alert(err.message); }
}

async function deleteCategory(id, name) {
  if (!confirm('Delete category "' + name + '"?')) return;
  try { await api('/api/admin/categories/' + id, { method: 'DELETE' }); loadCategories(); } catch (err) { alert(err.message); }
}

// ── Logs ──
async function loadLogs() {
  try {
    const logs = await api('/api/admin/logs');
    document.getElementById('logsTable').innerHTML = logs.length ? logs.map(l => `
      <tr>
        <td style="white-space:nowrap;">${fmtTime(l.created_at)}</td>
        <td>${esc(l.admin_username)}</td>
        <td><span class="badge badge-brand">${esc(l.action)}</span></td>
        <td>${esc(l.target_type || '')} ${esc(l.target_id || '')}</td>
        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${esc(l.details || '—')}</td>
      </tr>
    `).join('') : '<tr><td colspan="5" class="empty">No activity yet</td></tr>';
  } catch (err) { document.getElementById('logsTable').innerHTML = `<tr><td colspan="5" class="empty">Error: ${esc(err.message)}</td></tr>`; }
}

// ── HTML escape ──
function esc(s) { const d = document.createElement('div'); d.textContent = String(s ?? ''); return d.innerHTML; }

// ── Load all data on page load ──
Promise.all([loadAnalytics(), loadUsers(), loadPlans(), loadAccess(), loadTabs(), loadCategories(), loadLogs()]);
</script>
</body>
</html>
