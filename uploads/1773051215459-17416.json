{"data":[{"type":"questionAttempts","id":"17632013","links":{"self":"https://app.emedici.com/api/questionAttempts/17632013"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T17:36:48+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T17:36:48+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17416"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17416","links":{"self":"https://app.emedici.com/api/questions/17416"},"relationships":{"item":{"data":{"type":"items","id":"10106"}},"activeRevision":{"data":{"type":"questionRevisions","id":"70529"}}}},{"type":"items","id":"10106","links":{"self":"https://app.emedici.com/api/items/10106"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17416"}},"activeRevision":{"data":{"type":"itemRevisions","id":"55993"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"5326"},{"type":"tags","id":"5520"},{"type":"tags","id":"5531"}]},"contributions":{"data":[{"type":"contributions","id":"23669"},{"type":"contributions","id":"23674"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"70529","links":{"self":"https://app.emedici.com/api/questionRevisions/70529"},"attributes":{"stem":"\u003Cp\u003EAustralia is a signatory to the United Nations 1951 Refugee Convention and its 1967 Protocol, which outline international obligations regarding the protection of refugees.\u003C/p\u003E","stemQuestion":"Which one of the following best describes the status of refugees who are granted protection in Australia?","responseType":"sba","marks":1,"options":["Temporary access to healthcare only","Conditional residency requiring annual renewal","Permanent residency with full access to Medicare","Limited work rights without social services access","Restricted movement within designated zones"],"correctOptions":[2],"correctResponses":null,"explanation":"\u003Cp\u003ERefugees who are granted protection in Australia receive \u003Cstrong\u003Epermanent residency with full access to Medicare\u003C/strong\u003E and other social services. This reflects Australia\u0027s obligations under international law and ensures refugees can fully participate in Australian society.\u003C/p\u003E\u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003ETemporary access to healthcare only\u003C/strong\u003E - Refugees receive permanent access to healthcare and other services as part of their protection visa status.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ELimited work rights without social services access\u003C/strong\u003E - Refugees are entitled to full working rights and complete access to social services, including Centrelink benefits.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ERestricted movement within designated zones\u003C/strong\u003E - Refugees have complete freedom of movement throughout Australia, similar to other permanent residents.\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EConditional residency requiring annual renewal\u003C/strong\u003E - Once refugee status is granted, the residency is permanent and does not require regular renewal.\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EThis differs from asylum seekers, whose access to services may vary depending on their visa status and method of arrival. The permanent status granted to recognised refugees allows them to rebuild their lives with security and access to essential services.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Refugees are entitled to permanent residency and full access to Medicare and social services in Australia.","Asylum seekers who arrive with valid visas can access Medicare while their claims are processed.","The United Nations defines a refugee as someone who has fled their country due to persecution based on race, religion, nationality, social group or political opinion."],"references":["Shultz JM, Sullivan LM, Galea S. Public Health: An Introduction to the Science and Practice of Population Health. Springer Publishing Company; 2021.","Healthcare for refugees and asylum seekers. RACGP. Available from: https://www.racgp.org.au/advocacy/position-statements/view-all-position-statements/health-systems-and-environmental/healthcare-for-refugees-and-asylum-seekers"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"55993"}},"question":{"data":{"type":"questions","id":"17416"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"55993","links":{"self":"https://app.emedici.com/api/itemRevisions/55993"},"attributes":{"createdAt":"2024-12-15T19:03:29+10:30","updatedAt":"2025-01-04T00:10:18+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10106"}},"content":{"data":{"type":"questionRevisions","id":"70529"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"c