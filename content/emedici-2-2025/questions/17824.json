{"data":[{"type":"questionAttempts","id":"17640374","links":{"self":"https://app.emedici.com/api/questionAttempts/17640374"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T19:15:55+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T19:15:55+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17824"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17824","links":{"self":"https://app.emedici.com/api/questions/17824"},"relationships":{"item":{"data":{"type":"items","id":"10538"}},"activeRevision":{"data":{"type":"questionRevisions","id":"75177"}}}},{"type":"items","id":"10538","links":{"self":"https://app.emedici.com/api/items/10538"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17824"}},"activeRevision":{"data":{"type":"itemRevisions","id":"60685"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4947"},{"type":"tags","id":"5631"},{"type":"tags","id":"5684"}]},"contributions":{"data":[{"type":"contributions","id":"24582"},{"type":"contributions","id":"25017"},{"type":"contributions","id":"26000"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"75177","links":{"self":"https://app.emedici.com/api/questionRevisions/75177"},"attributes":{"stem":"\u003Cp\u003EA medical student observes a consultation where a doctor tells a patient which treatment they will receive without discussing alternatives or seeking the patient\u0027s input into the decision-making process.\u003C/p\u003E","stemQuestion":"Which one of the following best describes this approach to medical decision-making?","responseType":"sba","marks":1,"options":["Patient autonomy","Informed consent","Therapeutic privilege","Shared decision-making","Medical paternalism"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003E\u003Cstrong\u003EMedical paternalism\u003C/strong\u003E describes healthcare providers making decisions for patients based on their professional judgement of what is best, without involving the patient in the decision-making process. This approach was historically common but conflicts with modern ethical principles.\u003C/p\u003E    \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E    \u003Cul\u003E        \u003Cli\u003E\u003Cstrong\u003EPatient autonomy\u003C/strong\u003E respects the fundamental right of patients to make informed decisions about their own healthcare after receiving appropriate information.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EInformed consent\u003C/strong\u003E requires healthcare providers to disclose relevant information about treatments, including risks and benefits, allowing patients to make informed choices about their care.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003ETherapeutic privilege\u003C/strong\u003E is the practice of withholding certain information that could cause serious psychological harm to the patient, though it still requires patient participation in decision-making.\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EShared decision-making\u003C/strong\u003E represents a collaborative approach where healthcare providers and patients work together to make treatment decisions based on clinical evidence and patient preferences.\u003C/li\u003E    \u003C/ul\u003E    \u003Cp\u003EModern medical ethics emphasises respect for patient autonomy and informed decision-making, moving away from paternalistic approaches except in specific circumstances such as emergencies or when patients lack decision-making capacity.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Medical paternalism occurs when healthcare providers make decisions for patients without their input, based on the provider\u0027s perception of the patient\u0027s best interests.","Paternalism conflicts with patient autonomy and informed consent principles in modern medical ethics.","Historical medical practice was largely paternalistic, whereas contemporary healthcare emphasises shared decision-making."],"references":["Mandal J, Ponnambath DK, Parija SC. Bioethics: A brief review. Trop Parasitol. 2017;7(1):5-7. doi:10.4103/tp.TP_4_17","Varkey B. Principles of Clinical Ethics and Their Application to Practice. Med Princ Pract. 2021;30(1):17-28. doi:10.1159/000509119"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"60685"}},"question":{"data":{"type":"questions","id":"17824"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"60685","links":{"self":"https://app.emedici.com/api/itemRevisions/60685"},"attributes":{"createdAt":"2024-12-29T09:18:46+10:30","updatedAt":"2024-12-29T09:19:23+10:30"},"relationships":{"item":{"data":{"type":"items","id":"10538"}},"content":{"data":{"type":"questionRevisions","id":"75177"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"