{"data":[{"type":"questionAttempts","id":"17488452","links":{"self":"https://app.emedici.com/api/questionAttempts/17488452"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-29T03:42:28+09:30","options":[1],"response":null,"finalizedAt":"2025-09-29T03:42:28+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"449"}},"bookmark":{"data":null}}},{"type":"questionAttempts","id":"17582627","links":{"self":"https://app.emedici.com/api/questionAttempts/17582627"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T06:49:58+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T06:49:58+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"449"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"449","links":{"self":"https://app.emedici.com/api/questions/449"},"attributes":{"optionProportions":[0.22,0.02,0.01,0.01,0.74]},"relationships":{"item":{"data":{"type":"items","id":"449"}},"activeRevision":{"data":{"type":"questionRevisions","id":"103951"}}}},{"type":"items","id":"449","links":{"self":"https://app.emedici.com/api/items/449"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"449"}},"activeRevision":{"data":{"type":"itemRevisions","id":"86357"}},"tags":{"data":[{"type":"tags","id":"36"},{"type":"tags","id":"65"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"631"},{"type":"tags","id":"4947"}]},"contributions":{"data":[{"type":"contributions","id":"682"},{"type":"contributions","id":"30235"},{"type":"contributions","id":"37106"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"103951","links":{"self":"https://app.emedici.com/api/questionRevisions/103951"},"attributes":{"stem":"\u003Cp\u003ETesticular cancer is the commonest solid tumour in young men. Provided the disease is detected at a relatively early stage, it has a five-year survival rate of over 97%. This cancer has a number of recognised risk factors.\u003C/p\u003E","stemQuestion":"Which one of the following is associated with the greatest risk of a patient developing testicular cancer?","responseType":"sba","marks":1,"options":["Family history of testicular cancer","African-American background","Human immunodeficiency infection","Down\u0027s syndrome","History of testicular maldescent"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EProbably the greatest risk for testicular cancer is cryptorchidism, with about 10% of these tumours occurring on this background. \u003Cstrong\u003ETesticular maldescent\u003C/strong\u003E or malpositioning is a variant of cryptorchidism. The risk of malignant change in the undescended testis is about 2% - and this is some four to five times greater than the general population. However, this risk is still small. The cancer risk is increased when orchidopexy is not performed until after puberty or not done at all. Performing an orchidopexy does not reduce the cancer risk - but does allow the testis to be palpated with greater ease in the scrotum.\u003C/p\u003E\u003Cp\u003EThe incidence of testicular cancer in African Americans is about one-quarter of that in other races. The risk is also increased where there is a family background of such tumours. The risk of cancer is increased with human immunodeficiency virus infection, but this risk is reduced with retroviral treatment. There is a small, but increased risk with Down\u0027s syndrome.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Cryptorchidism is an important risk factor for testicular cancer."],"references":["Baird DC, Meyers GJ, Hu JS. Testicular Cancer: Diagnosis and Treatment. Am Fam Physician 2018; 97:261-68.","Hanna NH, Einhorn LH. Testicular Cancer - Discoveries and Updates. N Engl J Med 2014; 371:2005-16."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"86357"}},"question":{"data":{"type":"questions","id":"449"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"86357","links":{"self":"https://app.emedici.com/api/itemRevisions/86357"},"attributes":{"createdAt":"2025-05-29T05:32:43+09:30","updatedAt":"2025-05-29T05:33:39+09:30"},"relationships":{"item":{"data":{"type":"items","id":"449"}},"content":{"data":{"type":"questionRevisions","id":"103951"}}},"meta":{"canDelete":false}},{"type":"tags","id":"36","links":{"self":"https://app.emedici.com/api/tags/36"},"attributes":{"emoji":"\ud83e\udd43","name":"Urology","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"2"}}},"meta":{"itemCount":0}},{"type":"tags","id":"65","links":{"self":"https://app.emedici.com/api/tags/65"},"attributes":{"emoji":"","name":"Investigations","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups