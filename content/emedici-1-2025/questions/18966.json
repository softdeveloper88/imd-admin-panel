{"data":[{"type":"questionAttempts","id":"17567371","links":{"self":"https://app.emedici.com/api/questionAttempts/17567371"},"attributes":{"position":0,"marks":1,"score":1,"answeredAt":"2025-09-30T00:00:17+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T00:00:17+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18966"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18966","links":{"self":"https://app.emedici.com/api/questions/18966"},"attributes":{"optionProportions":[0.06,0.75,0.01,0.16,0.01]},"relationships":{"item":{"data":{"type":"items","id":"11700"}},"activeRevision":{"data":{"type":"questionRevisions","id":"92810"}}}},{"type":"items","id":"11700","links":{"self":"https://app.emedici.com/api/items/11700"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18966"}},"activeRevision":{"data":{"type":"itemRevisions","id":"76169"}},"tags":{"data":[{"type":"tags","id":"28"},{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"5715"},{"type":"tags","id":"5719"},{"type":"tags","id":"11260"},{"type":"tags","id":"12867"}]},"contributions":{"data":[{"type":"contributions","id":"27525"},{"type":"contributions","id":"27526"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"92810","links":{"self":"https://app.emedici.com/api/questionRevisions/92810"},"attributes":{"stem":"\u003Cp\u003EA 78-year-old woman with end-stage heart failure is admitted to hospital with respiratory distress. After discussion with the healthcare team, her family decides to focus on comfort measures only and discontinue mechanical ventilation.\u003C/p\u003E","stemQuestion":"Which one of the following best describes this end-of-life care decision?","responseType":"sba","marks":1,"options":["Active voluntary euthanasia","Passive voluntary euthanasia","Medical homicide","Therapeutic nihilism","Assisted suicide"],"correctOptions":[1],"correctResponses":null,"explanation":"\u003Cp\u003EThis scenario describes \u003Cstrong\u003Epassive voluntary euthanasia\u003C/strong\u003E, which involves withdrawing or withholding life-sustaining treatments while providing comfort care, allowing natural death to occur. This is legally and ethically accepted in many healthcare systems when treatment is considered futile or overly burdensome.\u003C/p\u003E        \u003Cp\u003EThe incorrect options can be explained:\u003C/p\u003E        \u003Cul\u003E        \u003Cli\u003E\u003Cstrong\u003EActive voluntary euthanasia\u003C/strong\u003E involves deliberately administering substances to end life, which is illegal in most jurisdictions\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EAssisted suicide\u003C/strong\u003E refers to providing means for a patient to end their own life, which is distinct from withdrawing treatment\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003EMedical homicide\u003C/strong\u003E implies wrongful killing, which does not apply to appropriate end-of-life care decisions\u003C/li\u003E        \u003Cli\u003E\u003Cstrong\u003ETherapeutic nihilism\u003C/strong\u003E refers to the belief that medical interventions are pointless, rather than making considered decisions about treatment withdrawal\u003C/li\u003E    \u003C/ul\u003E        \u003Cp\u003EThe key distinction is that passive euthanasia allows natural death to occur by withdrawing artificial life support, while continuing to provide comfort care and symptom management.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Passive euthanasia involves withdrawing or withholding life-sustaining treatment, allowing natural death to occur.","Active euthanasia involves deliberately administering substances to end life.","Passive euthanasia is legally permitted in many jurisdictions when treatment is considered futile or burdensome."],"references":["QUT. End of Life Law in Australia - Voluntary Assisted Dying. [online]. 2024. [Cited 2025 Jan 21]. Available at: https://end-of-life.qut.edu.au/assisteddying","Medical Board of Australia. Good medical practice: a code of conduct for doctors in Australia [online]. 2020 [Cited 2025 Jan 21]. Available at: https://www.medicalboard.gov.au/codes-guidelines-policies/code-of-conduct.aspx","Euthanasia, human rights and the law. Australian Human Rights Commission. May 2016. Available at: https://humanrights.gov.au/our-work/age-discrimination/publications/euthanasia-human-rights-and-law#Heading95"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"76169"}},"question":{"data":{"type":"questions","id":"18966"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"76169","links":{"self":"https://app.emedici.com/api/itemRevisions/76169"},"attributes":{"createdAt":"2025-03-19T13:57:21+10:30","updatedAt":"2025-03-19T13:57:21+10:30"},"relationships":{"item":{"data":{"type":"items","id":"11700"}},"content":{"data":{"type":"questionRevisions","id":"92810"}}},"meta":{"canDelete":false}},{"type":"tags","id":"28","links":{"self":"https://app.emedici.com/api/tags/28"},"attributes":{"emoji":"\ud83d\udc95","name":"Palliative Care","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"1"}}},"meta":{"itemCount":0}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","