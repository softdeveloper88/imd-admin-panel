":"contributions","id":"40724","links":{"self":"https://app.emedici.com/api/contributions/40724"},"attributes":{"createdAt":"2025-07-16T16:39:36+09:30","finalizedAt":"2025-07-29T16:01:26+09:30","userDetails":{"name":"Jess Sullivan","title":"","isExpert":false,"position":"","training":"Medical Student","credentials":"","institutionOther":"Flinders University"},"instructions":"","lastViewedAt":"2025-07-29T16:01:26+09:30","lastActivityAt":"2025-07-29T16:01:26+09:30","readAt":"2025-07-29T16:01:26+09:30","price":null,"paidAt":null,"toCharity":false,"fromWorklist":true,"onWorklist":false,"isPriority":false,"isHidden":false},"relationships":{"item":{"data":{"type":"items","id":"8946"}},"contributionTier":{"data":null},"source":{"data":{"type":"feedback","id":"52286"}},"user":{"data":{"type":"users","id":"12201"}},"contributionType":{"data":{"type":"contributionTypes","id":"5"}}}},{"type":"contributions","id":"40763","links":{"self":"https://app.emedici.com/api/contributions/40763"},"attributes":{"createdAt":"2025-07-18T16:00:17+09:30","finalizedAt":"2025-07-29T16:01:26+09:30","userDetails":{"name":"Belinda Lowe","title":"A/Prof","isExpert":false,"position":"Obstetrician Gynaecologist","training":"Consultant","credentials":"MBBS, FRANZCOG","institutionOther":"Gold Coast University Hospital, Bond University"},"instructions":"\u003Cp\u003EHi Belinda, I wonder if you would mind commenting on the feedback being received for this question, namely whether repeat ultrasound is required for ovarian cysts \u0026lt;5cm diameter. I note that the reference you link states that for\u0026nbsp;\u003Cstrong\u003Easymptomatic\u0026nbsp;\u003C/strong\u003Esimple cysts 30\u201350 mm in diameter do not require follow-up, cysts 50\u201370 mm require follow-up, and cysts more than 70 mm in diameter should be considered for either further imaging (MRI) or surgical intervention due to difficulties in examining the entire cyst adequately at time of ultrasound.\u0022 As this patient is \u003Cstrong\u003Esymptomatic\u003C/strong\u003E does this change the follow up recommendations and if so do you have a specific guideline or resource you point students to? Similar queries have been raised in other ovarian cyst questions which I am happy to amend as per your recommendations to ensure consistency amongst questions (884, 14557/1288, 4182, 14560, 2435). Cheers, Jess\u003C/p\u003E","lastViewedAt":"2025-07-28T18:41:44+09:30","lastActivityAt":"2025-07-22T13:27:22+09:30","readAt":"2025-07-22T13:27:22+09:30","price":0,"paidAt":null,"toCharity":false,"fromWorklist":false,"onWorklist":false,"isPriority":false,"isHidden":false},"relationships":{"item":{"data":{"type":"items","id":"8946"}},"contributionTier":{"data":null},"source":{"data":{"type":"users","id":"12201"}},"user":{"data":{"type":"users","id":"13481"}},"contributionType":{"data":{"type":"contributionTypes","id":"5"}}}},{"type":"contributions","id":"41774","links":{"self":"https://app.emedici.com/api/contributions/41774"},"attributes":{"createdAt":"2025-08-01T13:46:28+09:30","finalizedAt":"2025-08-01T13:56:19+09:30","userDetails":null,"instructions":"","lastViewedAt":null,"lastActivityAt":null,"readAt":null,"price":null,"paidAt":null,"toCharity":false,"fromWorklist":true,"onWorklist":false,"isPriority":false,"isHidden":false},"relationships":{"item":{"data":{"type":"items","id":"8946"}},"contributionTier":{"data":null},"source":{"data":{"type":"feedback","id":"55780"}},"user":{"data":null},"contributionType":{"data":{"type":"contributionTypes","id":"5"}}}},{"type":"users","id":"13481","links":{"self":"https://app.emedici.com/api/users/13481"},"attributes":{"title":"A/Prof","name":"Belinda Lowe","avatarUrl":null,"training":"Consultant","institutionOther":"Gold Coast University Hospital, Bond University","industry":null,"specialty":"Obstetrics","graduationYear":2007,"position":"Obstetrician Gynaecologist","credentials":"MBBS, FRANZCOG","createdAt":"2024-02-23T08:02:44+10:30","isContributor":false,"isReviewer":fals