{"data":[{"type":"questionAttempts","id":"17606349","links":{"self":"https://app.emedici.com/api/questionAttempts/17606349"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T13:11:51+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T13:11:51+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"15919"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"15919","links":{"self":"https://app.emedici.com/api/questions/15919"},"relationships":{"item":{"data":{"type":"items","id":"8610"}},"activeRevision":{"data":{"type":"questionRevisions","id":"63162"}}}},{"type":"items","id":"8610","links":{"self":"https://app.emedici.com/api/items/8610"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"15919"}},"activeRevision":{"data":{"type":"itemRevisions","id":"48613"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4935"},{"type":"tags","id":"4940"},{"type":"tags","id":"4949"},{"type":"tags","id":"7646"},{"type":"tags","id":"8690"}]},"contributions":{"data":[{"type":"contributions","id":"20625"},{"type":"contributions","id":"20629"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"63162","links":{"self":"https://app.emedici.com/api/questionRevisions/63162"},"attributes":{"stem":"\u003Cp\u003EDuring human female development, oogenesis begins in the fetal period when primordial germ cells differentiate into oogonia. These cells then enter meiosis I and become arrested at a specific stage until puberty.\u003C/p\u003E","stemQuestion":"Which one of the following stages of meiosis represents the arrest point of primary oocytes during fetal development?","responseType":"sba","marks":1,"options":["Prophase I","Metaphase II","Anaphase I","Prophase II","Metaphase I"],"correctOptions":[0],"correctResponses":null,"explanation":"\u003Cp\u003EPrimary oocytes arrest at \u003Cstrong\u003Eprophase I\u003C/strong\u003E during fetal development and remain in this state until puberty. The long prophase I arrest is essential for maintaining the oocyte pool throughout a female\u0027s reproductive years. During this arrest, the oocyte synthesizes and stores materials needed for early embryonic development.\u003C/p\u003E\u003Cp\u003EOf note from the other incorrect options, \u003Cstrong\u003Emetaphase II\u003C/strong\u003E is the second arrest point in oogenesis, occurring after meiosis I completion following ovulation and lasting until fertilisation\u003C/p\u003E\u003Cp\u003E\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Oogenesis begins during fetal development with primordial germ cells forming primary oocytes that arrest in prophase I of meiosis I.","Primary oocytes remain arrested until puberty when hormonal signals trigger completion of meiosis I.","The first polar body forms during meiosis I and contains half the chromosomes but minimal cytoplasm."],"references":["Sadler TW. Langman\u0027s Medical Embryology: Wolters Kluwer; 2015."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"48613"}},"question":{"data":{"type":"questions","id":"15919"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"48613","links":{"self":"https://app.emedici.com/api/itemRevisions/48613"},"attributes":{"createdAt":"2024-11-20T09:50:56+10:30","updatedAt":"2024-11-20T09:51:36+10:30"},"relationships":{"item":{"data":{"type":"items","id":"8610"}},"content":{"data":{"type":"questionRevisions","id":"63162"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group