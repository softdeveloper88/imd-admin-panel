{"data":[{"type":"questionAttempts","id":"17641107","links":{"self":"https://app.emedici.com/api/questionAttempts/17641107"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T19:22:57+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T19:22:57+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"17863"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"17863","links":{"self":"https://app.emedici.com/api/questions/17863"},"attributes":{"optionProportions":[0,0.02,0.16,0.74,0.08]},"relationships":{"item":{"data":{"type":"items","id":"10577"}},"activeRevision":{"data":{"type":"questionRevisions","id":"115358"}}}},{"type":"items","id":"10577","links":{"self":"https://app.emedici.com/api/items/10577"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"17863"}},"activeRevision":{"data":{"type":"itemRevisions","id":"97361"}},"tags":{"data":[{"type":"tags","id":"67"},{"type":"tags","id":"71"},{"type":"tags","id":"74"},{"type":"tags","id":"4926"},{"type":"tags","id":"4931"},{"type":"tags","id":"4942"},{"type":"tags","id":"10069"}]},"contributions":{"data":[{"type":"contributions","id":"24658"},{"type":"contributions","id":"24661"},{"type":"contributions","id":"26835"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"115358","links":{"self":"https://app.emedici.com/api/questionRevisions/115358"},"attributes":{"stem":"\u003Cp\u003EFree fatty acids are released into the circulation from adipose tissue and are transported to various organs for metabolism.\u003C/p\u003E","stemQuestion":"Which one of the following organs primarily takes up free fatty acids?","responseType":"sba","marks":1,"options":["Kidneys","Pancreas","Skeletal muscle","Liver","Heart"],"correctOptions":[3],"correctResponses":[],"explanation":"\u003Cp\u003EThe \u003Cstrong\u003Eliver\u003C/strong\u003E is the primary organ responsible for the uptake of free fatty acids. It plays a crucial role in lipid metabolism, including the conversion of free fatty acids into triglycerides and ketone bodies. While the \u003Cstrong\u003Eheart\u003C/strong\u003E and \u003Cstrong\u003Eskeletal muscle\u003C/strong\u003E can also utilise free fatty acids as an energy source, the liver is the main site of uptake and processing.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ESkeletal muscle\u003C/strong\u003E can use free fatty acids for energy but is not the primary site of uptake. Similarly, the \u003Cstrong\u003Eheart\u003C/strong\u003E can utilise free fatty acids but is not the main site of uptake. The \u003Cstrong\u003Ekidneys\u003C/strong\u003E do not primarily take up free fatty acids, and the \u003Cstrong\u003Epancreas\u003C/strong\u003E is not involved in the primary uptake of free fatty acids.\u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Free fatty acids are primarily taken up by the liver for metabolism.","The liver plays a central role in lipid metabolism, including the uptake and processing of free fatty acids.","Free fatty acids can also be used by the heart and skeletal muscle as an energy source, but the liver is the primary site of uptake."],"references":["Bender DA, Cunningham SM. Introduction to nutrition and metabolism. Boca Raton: CRC Press; 2021.","Salway JG. Metabolism at a Glance. Hoboken: John Wiley \u0026 Sons; 2016.","Chandel NS. Lipid Metabolism. Cold Spring Harb Perspect Biol. 2021 Sep 1;13(9):a040576. doi: 10.1101/cshperspect.a040576. PMID: 34470787; PMCID: PMC8411952.","Wakil SJ, Abu-Elheiga LA. Fatty acid metabolism: target for metabolic syndrome. J Lipid Res. 2009 Apr;50 Suppl(Suppl):S138-43. doi: 10.1194/jlr.R800079-JLR200. Epub 2008 Dec 1. PMID: 19047759; PMCID: PMC2674721.","Hall JE. Guyton and Hall Textbook of Medical Physiology. 14th ed. Philadelphia: Elsevier; 2021. Chapter 69; pg. 855."]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"97361"}},"question":{"data":{"type":"questions","id":"17863"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"97361","links":{"self":"https://app.emedici.com/api/itemRevisions/97361"},"attributes":{"createdAt":"2025-09-23T12:46:51+09:30","updatedAt":"2025-09-23T12:46:51+09:30"},"relationships":{"item":{"data":{"type":"items","id":"10577"}},"content":{"data":{"type":"questionRevisions","id":"115358"}}},"meta":{"canDelete":false}},{"type":"tags","id":"67","links":{"self":"https://app.emedici.com/api/tags/67"},"attributes":{"emoji":"","name":"Basic Science","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"74","links":{"self":"https://app.emedici.com/api/tags/74"},"attributes":{"emoji":"","name":"Level I","synonyms":null,"description":"Remember (identifying and retrieving information)","position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"7"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"4926","links":{"self":"https://app.emedici.com/api/tags/4926"},"attributes":{"emoji":"\ud83e\udec0","name":"Cardiovascular","synonyms":[],"description":null,"position":null,"createdAt":"2024-10-17T23:14:59+10:30","updatedAt":"2024-10-31T09:50:20+10:30"},"relationships":{"group":{"data":{"type":"tagGroups","id":"13"}},"heading":{"data":null}},"met