links":{"related":"https://app.emedici.com/api/items/14326/specialtyTags","self":"https://app.emedici.com/api/items/14326/relationships/specialtyTags"}},"primaryTags":{"links":{"related":"https://app.emedici.com/api/items/14326/primaryTags","self":"https://app.emedici.com/api/items/14326/relationships/primaryTags"}},"contributionTypes":{"links":{"related":"https://app.emedici.com/api/items/14326/contributionTypes","self":"https://app.emedici.com/api/items/14326/relationships/contributionTypes"}},"contributors":{"links":{"related":"https://app.emedici.com/api/items/14326/contributors","self":"https://app.emedici.com/api/items/14326/relationships/contributors"}},"contribution":{"links":{"related":"https://app.emedici.com/api/items/14326/contribution","self":"https://app.emedici.com/api/items/14326/relationships/contribution"}},"myContribution":{"links":{"related":"https://app.emedici.com/api/items/14326/myContribution","self":"https://app.emedici.com/api/items/14326/relationships/myContribution"}},"activeRevision":{"data":{"type":"itemRevisions","id":"104337"},"links":{"related":"https://app.emedici.com/api/items/14326/activeRevision","self":"https://app.emedici.com/api/items/14326/relationships/activeRevision"}},"tags":{"data":[{"type":"tags","id":"3"},{"type":"tags","id":"9"},{"type":"tags","id":"14"},{"type":"tags","id":"23"},{"type":"tags","id":"25"},{"type":"tags","id":"38"},{"type":"tags","id":"64"},{"type":"tags","id":"73"},{"type":"tags","id":"76"},{"type":"tags","id":"1061"},{"type":"tags","id":"1063"},{"type":"tags","id":"4955"},{"type":"tags","id":"7971"},{"type":"tags","id":"11629"}],"links":{"related":"https://app.emedici.com/api/items/14326/tags","self":"https://app.emedici.com/api/items/14326/relationships/tags"}},"contributions":{"data":[{"type":"contributions","id":"35759"},{"type":"contributions","id":"35760"},{"type":"contributions","id":"35761"},{"type":"contributions","id":"35762"}],"links":{"related":"https://app.emedici.com/api/items/14326/contributions","self":"https://app.emedici.com/api/items/14326/relationships/contributions"}}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"122934","links":{"self":"https://app.emedici.com/api/questionRevisions/122934"},"attributes":{"stem":"\u003Cp\u003EA two-year-old boy presents to the General Practice clinic with his mother with a three-day history of low-grade fever and a rash. His mother mentions she is 28 weeks pregnant. The child has no significant medical history and does not take any regular medications. His immunisations are up to date. He attends childcare five days per week.\u003C/p\u003E\u003Cp\u003EOn examination, he appears well with vital signs within normal limits. There are small, red, oval-shaped lesions with a grey centre on the soles of his feet (Image). Similar lesions are noted on his palms. He becomes upset and starts screaming, refusing further examination.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate advice regarding the pregnant mother?","responseType":"sba","marks":1,"options":["Urgent administration of varicella zoster immunoglobulin","Urgent serology to check for measles immunity","Urgent serology to assess for varicella immunity","No specific intervention required","Urgent serology to check for rubella immunity"],"correctOptions":[3],"correctResponses":null,"explanation":"\u003Cp\u003EThis child presents with hand, foot and mouth disease, which is caused by enteroviruses (most commonly \u003Cem\u003ECoxsackievirus A16\u003C/em\u003E and \u003Cem\u003EEnterovirus 71\u003C/em\u003E). The characteristic presentation includes fever and vesicular lesions on the hands, feet, and sometimes in the mouth. This common childhood illness is highly contagious but generally mild and self-limiting.\u003C/p\u003E\u003Cp\u003E\u003Cstrong\u003ENo specific intervention required\u003C/strong\u003E is the correct answer. Hand, foot and mouth disease does not pose significant risks to pregnant women or their unborn babies. There is no evidence of increased risk of congenital abnormalities or adverse pregnancy outcomes from maternal exposure to enteroviruses during pregnancy.\u003C/p\u003E\u003Cp\u003EThe other options would be appropriate in different clinical scenarios:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EUrgent administration of varicella zoster immunoglobulin\u003C/strong\u003E - indicated for non-immune pregnant women exposed to chickenpox, as varicella infection in pregnancy can cause congenital varicella syndrome if infection occurs before 20 weeks gestation, or severe neonatal varicella if maternal infection occurs around delivery\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EUrgent serology to check for measles immunity\u003C/strong\u003E - indicated for pregnant contacts of measles cases, as measles in pregnancy can cause severe maternal complications and increases the risk of miscarriage, stillbirth, and preterm delivery\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EUrgent serology to assess for varicella immunity\u003C/strong\u003E - appropriate for pregnant contacts of chickenpox cases to determine if varicella zoster immunoglobulin is needed\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EUrgent serology to check for rubella immunity\u003C/strong\u003E - indicated for pregnant contacts of rubella cases, as rubella infection in the first trimester can cause congenital rubella syndrome with serious birth defects including deafness, cataracts, and cardiac abnormalities\u003C/li\u003E\u003C/ul\u003E","optionExplanations":null,"learningPoints":["Hand, foot and mouth disease during pregnancy does not increase the risk of congenital abnormalities.","Pregnant contacts of hand, foot and mouth disease do not require specific intervention.","Viral infections like rubella, varicella, and measles can have serious consequences in pregnancy and require urgent assessment."],"references":["Rayner M. A case of sore throat and vesicular hand lesions. Aust J Gen Pract. 2024;53(3):144-145. doi:10.31128/AJGP-08-23-6917. Available from: https://www1.racgp.org.au/ajgp/2024/march/a-case-of-sore-throat-and-vesicular-hand-lesions/","NSW Health. Control Guidelines: Measles control guideline [Internet]. NSW Health. 2009. Available from: https://www.health.nsw.gov.au/Infectious/controlguideline/Pages/measles.aspx","Australian Society for Infectious Diseases. Management of Perinatal Infections [Internet]. Australian Society for Infectious Diseases; 2022. Available from: https://ranzcog.edu.au/wp-content/uploads/ASID-Management-Perinatal-Infections.pdf"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"104337"},"links":{"related":"https://app.emedici.com/api/questionRevisions/122934/itemRevision","self":"https://app.emedici.com/api/questionRevisions/122934/relationships/itemRevision"}},"question":{"data":{"type":"questions","id":"21457"},"links":{"related":"https://app.emedici.com/api/questionRevisions/122934/question","self":"https://app.emedici.com/api/questionRevisions/122934/relationships/question"}},"stemMedia":{"data":[{"type":"media","id":"20983"}],"links":{"related":"https://app.emedici.com/api/questionRevisions/122934/stemMedia","self":"https://app.emedici.com/api/questionRevisions/122934/relationships/stemMedia"}},"explanationMedia":{"data":[],"links":{"related":"https://app.emedici.com/api/questionRevisions/122934/explanationMedia","self":"https://app.emedici.com/api/questionRevisions/122934/relationships/explanationMedia"}}}},{"type":"media","id":"20983","links":{"self":"https://app.emedici.com/api/media/20983"},"attributes":{"mimeType":"image/jpeg","url":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/TIXrXcrF414NkHxtxu09TMwcqFYO6F.jpg","thumbUrl":"https://fls-a01fe75b-dba0-4809-a542-37feae35ca4a.laravel.cloud/media/TIXrXcrF414NkHxtxu09TMwcqFYO6F.jpg","isProcessed":true,"width":1024,"height":768}},{"type":"itemRevisions","id":"104337",