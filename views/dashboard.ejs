<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>iMD Control Room</title>
  <style>
    :root {
      --bg: #f4efe7;
      --panel: rgba(255, 251, 245, 0.9);
      --panel-strong: #fffdf8;
      --ink: #1d2a2f;
      --muted: #66757e;
      --line: rgba(35, 50, 58, 0.12);
      --brand: #0f766e;
      --brand-deep: #0b4f49;
      --danger: #b42318;
      --danger-bg: #fff0ed;
      --success: #0f7b4d;
      --success-bg: #edf9f0;
      --shadow: 0 22px 50px rgba(31, 38, 43, 0.12);
      --radius: 22px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Avenir Next", "Helvetica Neue", "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(15, 118, 110, 0.14), transparent 26%),
        radial-gradient(circle at top right, rgba(217, 119, 6, 0.12), transparent 20%),
        linear-gradient(180deg, #f8f2e8 0%, var(--bg) 100%);
      min-height: 100vh;
    }

    a { color: inherit; }
    .page { max-width: 1440px; margin: 0 auto; padding: 28px; }
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      margin-bottom: 24px;
      padding: 24px 28px;
      border: 1px solid rgba(255,255,255,0.55);
      border-radius: 28px;
      background: linear-gradient(135deg, rgba(12, 58, 69, 0.96), rgba(22, 90, 84, 0.88));
      color: #f9fafb;
      box-shadow: var(--shadow);
    }

    .brand-kicker {
      margin: 0 0 8px;
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      opacity: 0.78;
    }

    .topbar h1 {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(30px, 4vw, 42px);
      line-height: 1.02;
      font-weight: 700;
      letter-spacing: -0.03em;
    }

    .topbar p {
      margin: 10px 0 0;
      max-width: 720px;
      color: rgba(244, 247, 247, 0.8);
      font-size: 15px;
      line-height: 1.6;
    }

    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .admin-pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border-radius: 999px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.18);
      font-size: 13px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
      margin-bottom: 20px;
    }

    .card {
      background: var(--panel);
      border: 1px solid rgba(255,255,255,0.7);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(16px);
    }

    .card-section { padding: 24px; }
    .metric-label {
      display: inline-flex;
      align-items: center;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(15, 118, 110, 0.09);
      color: var(--brand-deep);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .metric-value {
      margin: 18px 0 8px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(36px, 4vw, 52px);
      line-height: 0.95;
    }

    .metric-copy,
    .card-subtitle,
    .meta {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 20px;
    }

    .filter-panel { grid-column: span 12; }
    .upload-panel { grid-column: span 8; }
    .tools-panel { grid-column: span 4; }
    .table-panel { grid-column: span 12; }
    .card-title { margin: 0; font-size: 20px; font-weight: 700; letter-spacing: -0.02em; }

    .stacked-sections {
      display: grid;
      gap: 18px;
    }

    .subsection-title {
      margin: 0 0 10px;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .inline-note {
      margin-top: 10px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.6;
    }

    .credential-form {
      display: grid;
      gap: 14px;
      margin-top: 18px;
    }

    .credential-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .credential-banner {
      margin-top: 14px;
      padding: 13px 14px;
      border-radius: 14px;
      font-size: 13px;
      line-height: 1.6;
    }

    .credential-banner.error {
      color: var(--danger);
      background: rgba(180, 35, 24, 0.08);
      border: 1px solid rgba(180, 35, 24, 0.14);
    }

    .credential-banner.success {
      color: var(--success);
      background: rgba(15, 123, 77, 0.08);
      border: 1px solid rgba(15, 123, 77, 0.14);
    }

    .security-chip {
      display: inline-flex;
      align-items: center;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .security-chip.default {
      color: #b42318;
      background: rgba(180, 35, 24, 0.1);
    }

    .security-chip.custom {
      color: #067647;
      background: rgba(15, 123, 77, 0.12);
    }

    .filters-form {
      display: grid;
      grid-template-columns: minmax(240px, 2fr) repeat(3, minmax(150px, 1fr)) auto auto;
      gap: 14px;
      align-items: end;
      margin-top: 18px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .field label {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .field input,
    .field select {
      min-height: 46px;
      padding: 0 14px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.88);
      color: var(--ink);
      font: inherit;
    }

    .field input:focus,
    .field select:focus {
      outline: none;
      border-color: rgba(15, 118, 110, 0.36);
      box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
    }

    .status-banner {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      font-size: 14px;
      line-height: 1.5;
      border: 1px solid transparent;
    }

    .status-banner.error { color: var(--danger); background: var(--danger-bg); border-color: rgba(180, 35, 24, 0.16); }
    .status-banner.success { color: var(--success); background: var(--success-bg); border-color: rgba(15, 123, 77, 0.16); }

    .upload-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
      margin-top: 18px;
    }

    .upload-option {
      padding: 18px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: var(--panel-strong);
    }

    .upload-option.drag-over {
      border-color: rgba(15, 118, 110, 0.45);
      box-shadow: inset 0 0 0 1px rgba(15, 118, 110, 0.2);
      background: rgba(233, 250, 247, 0.95);
    }

    .upload-option h3 { margin: 0; font-size: 16px; font-weight: 700; }
    .upload-option p { margin: 10px 0 0; color: var(--muted); font-size: 13px; line-height: 1.6; }

    .drop-zone {
      margin-top: 16px;
      min-height: 160px;
      padding: 22px;
      border-radius: 18px;
      border: 1.5px dashed rgba(15, 118, 110, 0.28);
      background: linear-gradient(180deg, rgba(245, 255, 253, 0.9), rgba(255, 255, 255, 0.95));
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      cursor: pointer;
      transition: 0.2s ease;
    }

    .drop-zone:hover,
    .drop-zone.drag-over {
      transform: translateY(-1px);
      border-color: rgba(15, 118, 110, 0.52);
      background: linear-gradient(180deg, rgba(232, 250, 247, 1), rgba(255, 255, 255, 1));
    }

    .drop-icon { font-size: 34px; margin-bottom: 12px; }
    .drop-title { font-size: 15px; font-weight: 700; color: var(--brand-deep); }
    .drop-copy { margin-top: 8px; color: var(--muted); font-size: 13px; line-height: 1.5; }

    .upload-option input[type="text"] {
      width: 100%;
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #fff;
      font: inherit;
      color: var(--ink);
    }

    .hint { margin-top: 12px; color: var(--muted); font-size: 13px; line-height: 1.5; }
    .hint.error { color: var(--danger); }

    .file-info {
      display: none;
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 14px;
      background: #f4f7f7;
      color: #304047;
      font-size: 13px;
      line-height: 1.5;
    }

    .actions-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 20px;
    }

    .btn,
    button { font: inherit; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 46px;
      padding: 0 18px;
      border-radius: 999px;
      border: 1px solid transparent;
      text-decoration: none;
      cursor: pointer;
      transition: 0.2s ease;
      font-size: 14px;
      font-weight: 700;
    }

    .btn-primary { color: #fff; background: linear-gradient(135deg, var(--brand), #115e59); box-shadow: 0 14px 28px rgba(15, 118, 110, 0.22); }
    .btn-primary:hover { transform: translateY(-1px); }
    .btn-secondary { color: var(--ink); background: rgba(255,255,255,0.64); border-color: var(--line); }
    .btn-secondary:hover { background: #fff; border-color: rgba(15, 118, 110, 0.18); }
    .btn-danger { color: #fff; background: linear-gradient(135deg, #c43f2e, #a61b12); }

    .tools-list { margin: 18px 0 0; padding: 0; list-style: none; display: grid; gap: 12px; }
    .tool-item { padding: 16px; border-radius: 18px; background: rgba(255,255,255,0.72); border: 1px solid var(--line); }
    .tool-item strong { display: block; font-size: 14px; margin-bottom: 6px; }
    .tool-item span { color: var(--muted); font-size: 13px; line-height: 1.5; }

    .panel-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .table-shell {
      overflow: auto;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.78);
    }

    table { width: 100%; border-collapse: collapse; min-width: 1040px; }
    thead th {
      position: sticky;
      top: 0;
      background: #f6f4ef;
      text-align: left;
      padding: 16px;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #536067;
      border-bottom: 1px solid var(--line);
    }

    tbody td { padding: 16px; border-bottom: 1px solid rgba(29, 42, 47, 0.08); vertical-align: top; font-size: 14px; }
    tbody tr:hover td { background: rgba(255,255,255,0.62); }
    .name-cell { min-width: 280px; }
    .name-title { font-weight: 700; font-size: 15px; word-break: break-word; }
    .name-meta { margin-top: 6px; color: var(--muted); font-size: 12px; }

    .pill {
      display: inline-flex;
      align-items: center;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .pill.ready { color: var(--success); background: rgba(15, 123, 77, 0.12); }
    .pill.issue { color: var(--danger); background: rgba(180, 35, 24, 0.1); }
    .pill.type { color: var(--brand-deep); background: rgba(15, 118, 110, 0.09); }

    .row-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .row-actions form { margin: 0; }
    .btn-sm { min-height: 38px; padding: 0 14px; font-size: 13px; }
    .empty-state { padding: 40px 24px; text-align: center; color: var(--muted); font-size: 14px; line-height: 1.7; }
    .table-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .page-summary {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }

    .pagination {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }

    .page-link,
    .page-current {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 40px;
      min-height: 40px;
      padding: 0 14px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.74);
      font-size: 13px;
      text-decoration: none;
    }

    .page-current {
      color: #fff;
      background: linear-gradient(135deg, var(--brand), #115e59);
      border-color: transparent;
    }

    .danger-note {
      margin-top: 16px;
      padding: 14px 16px;
      border-radius: 16px;
      background: rgba(180, 35, 24, 0.06);
      border: 1px solid rgba(180, 35, 24, 0.12);
      color: #7a271a;
      font-size: 13px;
      line-height: 1.6;
    }

    @media (max-width: 1100px) {
      .stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .upload-panel, .tools-panel { grid-column: span 12; }
      .filters-form { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .credential-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 720px) {
      .page { padding: 18px; }
      .topbar { padding: 22px; border-radius: 22px; }
      .stats { grid-template-columns: 1fr; }
      .upload-grid { grid-template-columns: 1fr; }
      .filters-form { grid-template-columns: 1fr; }
      .credential-grid { grid-template-columns: 1fr; }
      .panel-header { flex-direction: column; }
      .actions-row { flex-direction: column; align-items: stretch; }
      .btn { width: 100%; }
      .table-footer { flex-direction: column; align-items: stretch; }
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="topbar">
      <div>
        <p class="brand-kicker">Authenticated Dashboard</p>
        <h1>iMD Control Room</h1>
        <p>Manage package imports, validate upload structure before it reaches users, and keep the live content library clean enough for future tooling.</p>
      </div>
      <div class="topbar-actions">
        <a href="/admin/manage" class="admin-pill" style="text-decoration:none;background:rgba(255,255,255,0.15);cursor:pointer;">⚙ User &amp; Sub Management</a>
        <div class="admin-pill">Signed in as <strong><%= currentAdminUser || 'admin' %></strong></div>
        <form action="/logout" method="POST">
          <button type="submit" class="btn btn-secondary">Logout</button>
        </form>
      </div>
    </section>

    <section class="stats">
      <article class="card"><div class="card-section"><span class="metric-label">Library</span><div class="metric-value"><%= stats.readyPackages %></div><p class="metric-copy">Packages currently recognized as valid content and shown to the app.</p></div></article>
      <article class="card"><div class="card-section"><span class="metric-label">Quizzes + Docs</span><div class="metric-value"><%= stats.totalQuestions %></div><p class="metric-copy">Aggregate question or document count detected across valid packages.</p></div></article>
      <article class="card"><div class="card-section"><span class="metric-label">Media</span><div class="metric-value"><%= stats.totalMedia %></div><p class="metric-copy">Resolved media files attached to valid packages.</p></div></article>
      <article class="card"><div class="card-section"><span class="metric-label">Needs Attention</span><div class="metric-value"><%= stats.invalidPackages %></div><p class="metric-copy">Broken or incomplete uploads isolated from the public package list.</p></div></article>
    </section>

    <section class="grid">
      <section class="card filter-panel">
        <div class="card-section">
          <div class="panel-header">
            <div>
              <h2 class="card-title">Search and Filters</h2>
              <p class="card-subtitle">Search by package name, type, category, or issue, then page through matching results.</p>
            </div>
            <div class="meta"><%= hasActiveFilters ? 'Filters active' : 'Showing full library' %></div>
          </div>

          <form class="filters-form" method="GET" action="/dashboard">
            <div class="field">
              <label for="filter-q">Search</label>
              <input id="filter-q" type="search" name="q" value="<%= dashboardFilters.q %>" placeholder="Search packages, category, type, issue">
            </div>
            <div class="field">
              <label for="filter-type">Type</label>
              <select id="filter-type" name="type">
                <option value="">All types</option>
                <% filterOptions.types.forEach(type => { %>
                  <option value="<%= type %>" <%= dashboardFilters.type === type ? 'selected' : '' %>><%= type %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="filter-category">Category</label>
              <select id="filter-category" name="category">
                <option value="">All categories</option>
                <% filterOptions.categories.forEach(category => { %>
                  <option value="<%= category %>" <%= dashboardFilters.category === category ? 'selected' : '' %>><%= category %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="filter-page-size">Rows per page</label>
              <select id="filter-page-size" name="pageSize">
                <% filterOptions.pageSizes.forEach(size => { %>
                  <option value="<%= size %>" <%= dashboardFilters.pageSize === size ? 'selected' : '' %>><%= size %></option>
                <% }) %>
              </select>
            </div>
            <button type="submit" class="btn btn-primary">Apply</button>
            <a class="btn btn-secondary" href="/dashboard">Reset</a>
          </form>
        </div>
      </section>

      <article class="card upload-panel">
        <div class="card-section">
          <h2 class="card-title">Import Package</h2>
          <p class="card-subtitle">Upload one zip file or one intact folder tree. Existing packages with the same resolved name are replaced. Unsupported structures are rejected instead of quietly appearing as junk entries.</p>

          <% if (uploadError) { %>
            <div class="status-banner error"><%= uploadError %></div>
          <% } %>
          <% if (uploadSuccess) { %>
            <div class="status-banner success"><%= uploadSuccess %></div>
          <% } %>

          <form id="uploadForm" action="/upload" method="POST" enctype="multipart/form-data">
            <div class="upload-grid">
              <section class="upload-option" id="zipOption">
                <h3>Zip archive</h3>
                <p>Best for packaged exports. Nested single-root archives are automatically resolved before validation.</p>
                <div class="drop-zone" id="zipDrop">
                  <div class="drop-icon">[ZIP]</div>
                  <div class="drop-title">Drop a single .zip file here</div>
                  <div class="drop-copy">or click to browse your machine</div>
                </div>
                <input type="file" id="packageZip" name="packageZip" accept=".zip" hidden>
                <div class="hint" id="zipHint">Choose one non-empty zip file.</div>
                <div class="file-info" id="zipFileInfo"></div>
              </section>

              <section class="upload-option" id="folderOption">
                <h3>Folder import</h3>
                <p>Use this when the original decrypted or extracted package folder is already on disk.</p>
                <div class="drop-zone" id="folderDrop">
                  <div class="drop-icon">[DIR]</div>
                  <div class="drop-title">Select one package folder</div>
                  <div class="drop-copy">keep the internal structure exactly as-is</div>
                </div>
                <input type="file" id="packageFolder" name="packageFolder" webkitdirectory directory multiple hidden>
                <input type="text" name="packageName" placeholder="Optional package name override for folder imports">
                <div class="hint" id="folderHint">Choose one folder only. Do not mix files from multiple packages.</div>
                <div class="file-info" id="folderFileInfo"></div>
              </section>
            </div>

            <div class="actions-row">
              <button type="submit" class="btn btn-primary" id="uploadButton">Upload Package</button>
              <% if (staleCount > 0) { %>
                <button type="submit" class="btn btn-secondary" formaction="/cleanup-uploads" formmethod="POST" onclick="return confirm('Remove <%= staleCount %> stale zero-byte files from the uploads folder?')">Clean <%= staleCount %> stale files</button>
              <% } %>
              <span class="card-subtitle">The server now validates package structure before the item is accepted into the library.</span>
            </div>
          </form>
        </div>
      </article>

      <aside class="card tools-panel">
        <div class="card-section">
          <div class="stacked-sections">
            <section>
              <h2 class="card-title">Access Control</h2>
              <p class="card-subtitle">Change the admin username, password, and cookie secret directly from the dashboard. First-run default password is <strong>admin123</strong>.</p>

              <% if (settingsError) { %>
                <div class="credential-banner error"><%= settingsError %></div>
              <% } %>
              <% if (settingsSuccess) { %>
                <div class="credential-banner success"><%= settingsSuccess %></div>
              <% } %>

              <div class="inline-note">Current username: <strong><%= authSettings.username %></strong></div>
              <div class="inline-note">Last changed: <strong><%= authSettings.updatedAtLabel %></strong></div>
              <div class="inline-note">
                <span class="security-chip <%= authSettings.usesDefaultPassword ? 'default' : 'custom' %>">
                  <%= authSettings.usesDefaultPassword ? 'Default password active' : 'Custom password active' %>
                </span>
              </div>

              <form class="credential-form" action="/settings/credentials" method="POST">
                <div class="credential-grid">
                  <div class="field">
                    <label for="cred-username">Username</label>
                    <input id="cred-username" type="text" name="username" value="<%= authSettings.username %>" required>
                  </div>
                  <div class="field">
                    <label for="cred-current-password">Current password</label>
                    <input id="cred-current-password" type="password" name="currentPassword" placeholder="Enter current password" required>
                  </div>
                </div>
                <div class="credential-grid">
                  <div class="field">
                    <label for="cred-new-password">New password</label>
                    <input id="cred-new-password" type="password" name="newPassword" placeholder="Leave blank to keep current password">
                  </div>
                  <div class="field">
                    <label for="cred-confirm-password">Confirm new password</label>
                    <input id="cred-confirm-password" type="password" name="confirmPassword" placeholder="Repeat new password">
                  </div>
                </div>
                <div class="field">
                  <label for="cred-cookie-secret">New cookie secret</label>
                  <input id="cred-cookie-secret" type="text" name="cookieSecret" placeholder="Leave blank to keep current cookie secret">
                </div>
                <button type="submit" class="btn btn-primary">Save Credentials</button>
              </form>
            </section>

            <section>
              <h3 class="subsection-title">Future Tools</h3>
              <p class="card-subtitle">Reserved space for the extra controls you asked for, without forcing another UI rewrite later.</p>
              <ul class="tools-list">
                <li class="tool-item"><strong>Package diagnostics</strong><span>Surface missing databases, empty media folders, and nested archive problems before an import is committed.</span></li>
                <li class="tool-item"><strong>Bulk actions</strong><span>Prepared for future multi-select operations such as revalidate, export, or delete selected packages.</span></li>
                <li class="tool-item"><strong>Release workflow</strong><span>Room for later actions like publish states, notes, tags, or package version history.</span></li>
              </ul>
            </section>
          </div>
        </div>
      </aside>

      <section class="card table-panel">
        <div class="card-section">
          <div class="panel-header">
            <div>
              <h2 class="card-title">Valid Packages</h2>
              <p class="card-subtitle">These packages passed structure validation and are exposed to the library API.</p>
            </div>
            <div class="meta"><%= packagesPage.totalItems %> matching valid package<%= packagesPage.totalItems === 1 ? '' : 's' %> out of <%= stats.readyPackages %>.</div>
          </div>

          <% if (packagesPage.totalItems === 0) { %>
            <div class="empty-state"><%= hasActiveFilters ? 'No valid packages match the current search and filters.' : 'No valid packages are available yet. Upload a supported zip or folder to populate the library.' %></div>
          <% } else { %>
            <div class="table-shell">
              <table>
                <thead>
                  <tr>
                    <th>Package</th>
                    <th>Status</th>
                    <th>Type</th>
                    <th>Category</th>
                    <th>Questions</th>
                    <th>Media</th>
                    <th>Size</th>
                    <th>Updated</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% packages.forEach(pkg => { %>
                    <tr>
                      <td class="name-cell"><div class="name-title"><%= pkg.name %></div><div class="name-meta"><%= pkg.directItemCount %> direct item<%= pkg.directItemCount === 1 ? '' : 's' %> detected in package root</div></td>
                      <td><span class="pill ready"><%= pkg.statusLabel %></span></td>
                      <td><span class="pill type"><%= pkg.type %></span></td>
                      <td><%= pkg.category %></td>
                      <td><%= pkg.questionCount %></td>
                      <td><%= pkg.mediaCount %></td>
                      <td><%= pkg.sizeLabel %></td>
                      <td><%= pkg.updatedLabel %></td>
                      <td>
                        <div class="row-actions">
                          <a class="btn btn-primary btn-sm" href="/package/<%= encodeURIComponent(pkg.name) %>">Open</a>
                          <a class="btn btn-secondary btn-sm" href="/api/packages/<%= encodeURIComponent(pkg.name) %>/download">Download</a>
                          <form class="delete-package-form" action="/delete/<%= encodeURIComponent(pkg.name) %>" method="POST" data-package-name="<%= pkg.name %>">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div class="table-footer">
              <div class="page-summary">Showing <%= packagesPage.startItem %>-<%= packagesPage.endItem %> of <%= packagesPage.totalItems %> matching valid packages.</div>
              <% if (packagesPage.totalPages > 1) { %>
                <div class="pagination">
                  <% if (packagesPage.page > 1) { %>
                    <a class="page-link" href="<%= buildDashboardHref({ page: packagesPage.page - 1 }) %>">Previous</a>
                  <% } %>
                  <span class="page-current"><%= packagesPage.page %> / <%= packagesPage.totalPages %></span>
                  <% if (packagesPage.page < packagesPage.totalPages) { %>
                    <a class="page-link" href="<%= buildDashboardHref({ page: packagesPage.page + 1 }) %>">Next</a>
                  <% } %>
                </div>
              <% } %>
            </div>
          <% } %>
        </div>
      </section>

      <section class="card table-panel">
        <div class="card-section">
          <div class="panel-header">
            <div>
              <h2 class="card-title">Rejected or Broken Uploads</h2>
              <p class="card-subtitle">Folders listed here stay out of the public package API until they match a supported package structure.</p>
            </div>
            <div class="meta"><%= invalidPackagesPage.totalItems %> matching isolated item<%= invalidPackagesPage.totalItems === 1 ? '' : 's' %> out of <%= stats.invalidPackages %>.</div>
          </div>

          <% if (invalidPackagesPage.totalItems === 0) { %>
            <div class="empty-state"><%= hasActiveFilters ? 'No rejected uploads match the current search and filters.' : 'No broken uploads are currently parked in the library folder.' %></div>
          <% } else { %>
            <div class="table-shell">
              <table>
                <thead>
                  <tr>
                    <th>Folder</th>
                    <th>Status</th>
                    <th>Issue</th>
                    <th>Updated</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% invalidPackages.forEach(pkg => { %>
                    <tr>
                      <td class="name-cell"><div class="name-title"><%= pkg.name %></div><div class="name-meta"><%= pkg.directItemCount %> direct item<%= pkg.directItemCount === 1 ? '' : 's' %> in root folder</div></td>
                      <td><span class="pill issue"><%= pkg.statusLabel %></span></td>
                      <td><%= pkg.issue %></td>
                      <td><%= pkg.updatedLabel %></td>
                      <td>
                        <div class="row-actions">
                          <form class="delete-invalid-form" action="/delete/<%= encodeURIComponent(pkg.name) %>" method="POST" data-package-name="<%= pkg.name %>">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div class="table-footer">
              <div class="page-summary">Showing <%= invalidPackagesPage.startItem %>-<%= invalidPackagesPage.endItem %> of <%= invalidPackagesPage.totalItems %> matching rejected uploads.</div>
              <% if (invalidPackagesPage.totalPages > 1) { %>
                <div class="pagination">
                  <% if (invalidPackagesPage.page > 1) { %>
                    <a class="page-link" href="<%= buildDashboardHref({ invalidPage: invalidPackagesPage.page - 1 }) %>">Previous</a>
                  <% } %>
                  <span class="page-current"><%= invalidPackagesPage.page %> / <%= invalidPackagesPage.totalPages %></span>
                  <% if (invalidPackagesPage.page < invalidPackagesPage.totalPages) { %>
                    <a class="page-link" href="<%= buildDashboardHref({ invalidPage: invalidPackagesPage.page + 1 }) %>">Next</a>
                  <% } %>
                </div>
              <% } %>
            </div>
            <div class="danger-note">If a zip reported success earlier but never showed up properly, it was likely extracted into an unsupported structure. Those folders now stay quarantined here instead of polluting the main package list.</div>
          <% } %>
        </div>
      </section>
    </section>
  </div>

  <script>
    const uploadForm = document.getElementById('uploadForm');
    const packageZipInput = document.getElementById('packageZip');
    const packageFolderInput = document.getElementById('packageFolder');
    const zipDrop = document.getElementById('zipDrop');
    const folderDrop = document.getElementById('folderDrop');
    const zipOption = document.getElementById('zipOption');
    const folderOption = document.getElementById('folderOption');
    const zipHint = document.getElementById('zipHint');
    const folderHint = document.getElementById('folderHint');
    const zipFileInfo = document.getElementById('zipFileInfo');
    const folderFileInfo = document.getElementById('folderFileInfo');
    const uploadButton = document.getElementById('uploadButton');

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
      return (bytes / (1024 * 1024 * 1024)).toFixed(1) + ' GB';
    }

    function setHint(element, message, isError) {
      element.textContent = message;
      element.classList.toggle('error', Boolean(isError));
    }

    function describeSelections() {
      const zipFile = packageZipInput.files[0];
      const folderFiles = Array.from(packageFolderInput.files || []);

      if (zipFile) {
        zipFileInfo.style.display = 'block';
        zipFileInfo.innerHTML = '<strong>' + zipFile.name + '</strong><br>' + formatSize(zipFile.size);
        setHint(zipHint, zipFile.size === 0 ? 'The selected zip is empty.' : 'Zip ready for upload.', zipFile.size === 0);
      } else {
        zipFileInfo.style.display = 'none';
        setHint(zipHint, 'Choose one non-empty zip file.', false);
      }

      if (folderFiles.length > 0) {
        const roots = new Set(folderFiles.map(file => (file.webkitRelativePath || file.name).split('/')[0]).filter(Boolean));
        const totalSize = folderFiles.reduce((sum, file) => sum + file.size, 0);
        const dbCount = folderFiles.filter(file => file.name.toLowerCase().endsWith('.db')).length;
        folderFileInfo.style.display = 'block';
        folderFileInfo.innerHTML = '<strong>' + folderFiles.length + ' files</strong><br>' + roots.size + ' root folder' + (roots.size === 1 ? '' : 's') + ' · ' + formatSize(totalSize) + (dbCount ? '<br>' + dbCount + ' database file' + (dbCount === 1 ? '' : 's') : '');
        setHint(folderHint, roots.size > 1 ? 'Select one folder only, not multiple roots.' : 'Folder ready for upload.', roots.size > 1);
      } else {
        folderFileInfo.style.display = 'none';
        setHint(folderHint, 'Choose one folder only. Do not mix files from multiple packages.', false);
      }
    }

    function preventDefaults(event) {
      event.preventDefault();
      event.stopPropagation();
    }

    function bindDropZone(zone, option, onDrop) {
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(type => {
        zone.addEventListener(type, preventDefaults);
      });

      ['dragenter', 'dragover'].forEach(type => {
        zone.addEventListener(type, () => {
          zone.classList.add('drag-over');
          option.classList.add('drag-over');
        });
      });

      ['dragleave', 'drop'].forEach(type => {
        zone.addEventListener(type, () => {
          zone.classList.remove('drag-over');
          option.classList.remove('drag-over');
        });
      });

      zone.addEventListener('drop', onDrop);
    }

    zipDrop.addEventListener('click', () => packageZipInput.click());
    folderDrop.addEventListener('click', () => packageFolderInput.click());
    packageZipInput.addEventListener('change', describeSelections);
    packageFolderInput.addEventListener('change', describeSelections);

    bindDropZone(zipDrop, zipOption, event => {
      const files = event.dataTransfer.files;
      if (!files.length) return;
      const file = files[0];
      if (!file.name.toLowerCase().endsWith('.zip')) {
        setHint(zipHint, 'Only .zip files are accepted for archive uploads.', true);
        return;
      }
      const transfer = new DataTransfer();
      transfer.items.add(file);
      packageZipInput.files = transfer.files;
      describeSelections();
    });

    uploadForm.addEventListener('submit', event => {
      const zipFile = packageZipInput.files[0];
      const folderFiles = Array.from(packageFolderInput.files || []);

      if (!zipFile && folderFiles.length === 0) {
        event.preventDefault();
        setHint(zipHint, 'Select a zip file or one folder before uploading.', true);
        return;
      }

      if (zipFile && folderFiles.length > 0) {
        event.preventDefault();
        setHint(zipHint, 'Use only one upload method at a time.', true);
        setHint(folderHint, 'Use only one upload method at a time.', true);
        return;
      }

      if (zipFile && zipFile.size === 0) {
        event.preventDefault();
        setHint(zipHint, 'The selected zip file is empty.', true);
        return;
      }

      if (folderFiles.length > 0) {
        const roots = new Set(folderFiles.map(file => (file.webkitRelativePath || file.name).split('/')[0]).filter(Boolean));
        if (roots.size > 1) {
          event.preventDefault();
          setHint(folderHint, 'Choose one package folder only.', true);
          return;
        }
      }

      uploadButton.disabled = true;
      uploadButton.textContent = 'Uploading...';
    });

    document.querySelectorAll('.delete-package-form, .delete-invalid-form').forEach(form => {
      form.addEventListener('submit', event => {
        const packageName = form.getAttribute('data-package-name') || 'this package';
        if (!window.confirm('Delete ' + packageName + '?')) {
          event.preventDefault();
        }
      });
    });

    describeSelections();
  </script>
</body>
</html>
