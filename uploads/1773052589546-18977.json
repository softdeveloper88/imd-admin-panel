{"data":[{"type":"questionAttempts","id":"17656971","links":{"self":"https://app.emedici.com/api/questionAttempts/17656971"},"attributes":{"position":0,"marks":1,"score":0,"answeredAt":"2025-09-30T22:21:09+09:30","options":[1],"response":null,"finalizedAt":"2025-09-30T22:21:09+09:30"},"relationships":{"user":{"data":{"type":"users","id":"50098"}},"questionSession":{"data":null},"session":{"data":null},"question":{"data":{"type":"questions","id":"18977"}},"bookmark":{"data":null}}}],"included":[{"type":"questions","id":"18977","links":{"self":"https://app.emedici.com/api/questions/18977"},"attributes":{"optionProportions":[0,0,0.06,0.03,0.91]},"relationships":{"item":{"data":{"type":"items","id":"11711"}},"activeRevision":{"data":{"type":"questionRevisions","id":"80708"}}}},{"type":"items","id":"11711","links":{"self":"https://app.emedici.com/api/items/11711"},"attributes":{"contentType":"question"},"relationships":{"content":{"data":{"type":"questions","id":"18977"}},"activeRevision":{"data":{"type":"itemRevisions","id":"66007"}},"tags":{"data":[{"type":"tags","id":"25"},{"type":"tags","id":"66"},{"type":"tags","id":"71"},{"type":"tags","id":"76"},{"type":"tags","id":"928"},{"type":"tags","id":"3016"},{"type":"tags","id":"3996"},{"type":"tags","id":"4947"},{"type":"tags","id":"4956"},{"type":"tags","id":"5631"},{"type":"tags","id":"5665"},{"type":"tags","id":"11421"},{"type":"tags","id":"11471"},{"type":"tags","id":"11640"}]},"contributions":{"data":[{"type":"contributions","id":"27559"}]}},"meta":{"canRevise":false,"canManage":false,"canDelete":false}},{"type":"questionRevisions","id":"80708","links":{"self":"https://app.emedici.com/api/questionRevisions/80708"},"attributes":{"stem":"\u003Cp\u003EA 28-year-old woman with moderate intellectual disability presents to the General Practice clinic with her support worker. She lives in supported accommodation with multiple carers across different shifts. She has a medical history of focal epilepsy, autism spectrum disorder, and anxiety. Her medications include carbamazepine and escitalopram. She communicates verbally but has difficulty with complex instructions. On examination, she appears well with vital signs within normal limits. You decide to increase her carbamazepine dose due to increased seizure frequency.\u003C/p\u003E","stemQuestion":"Which one of the following is the most appropriate next step in management?","responseType":"sba","marks":1,"options":["Email the new prescription directly to the pharmacy alone","Give written instructions to the patient only and explain verbally to the carer","Provide verbal instructions to the support worker only and email the script to the pharmacy","Write the new dosing instructions in the patient\u0027s medical record only","Document the change in the patient\u0027s care plan and confirm understanding with both patient and support worker"],"correctOptions":[4],"correctResponses":null,"explanation":"\u003Cp\u003EThis scenario demonstrates best practice in disability care communication, as it involves communicating to all those involved in the patient\u0027s care. \u003Cstrong\u003EDocumenting the change in the patient\u0027s care plan and confirming understanding with both patient and support worker\u003C/strong\u003E ensures safety and continuity of care while respecting patient autonomy. \u003C/p\u003E\u003Cp\u003EThe incorrect options are inappropriate because they do not prioritise clear, tailored and open communication with all parties involved. While \u003Cstrong\u003Eemailing the new prescription directly to the pharmacy \u003C/strong\u003Emight be a helpful thing to do in conjunction with clear communication, only completing this step bypasses patient and carer understanding. \u003C/p\u003E","optionExplanations":["","","","",""],"learningPoints":["Effective communication in disability care requires validation of understanding with both patients and their carers.","Medical instructions should be provided in clear, accessible formats appropriate to the patient\u0027s communication needs.","Documentation and handover must include all relevant parties involved in the patient\u0027s care team."],"references":["Agaronnik N, Campbell EG, Ressalam J, Iezzoni LI. Communicating with Patients with Disability: Perspectives of Practicing Physicians. J Gen Intern Med. 2019;34(7):1139-1145. doi:10.1007/s11606-019-04911-0"]},"relationships":{"itemRevision":{"data":{"type":"itemRevisions","id":"66007"}},"question":{"data":{"type":"questions","id":"18977"}},"stemMedia":{"data":[]},"explanationMedia":{"data":[]}}},{"type":"itemRevisions","id":"66007","links":{"self":"https://app.emedici.com/api/itemRevisions/66007"},"attributes":{"createdAt":"2025-01-22T14:48:35+10:30","updatedAt":"2025-01-22T14:49:35+10:30"},"relationships":{"item":{"data":{"type":"items","id":"11711"}},"content":{"data":{"type":"questionRevisions","id":"80708"}}},"meta":{"canDelete":false}},{"type":"tags","id":"25","links":{"self":"https://app.emedici.com/api/tags/25"},"attributes":{"emoji":"\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66","name":"General Practice","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"1"}},"heading":{"data":{"type":"tagHeadings","id":"6"}}},"meta":{"itemCount":0}},{"type":"tags","id":"66","links":{"self":"https://app.emedici.com/api/tags/66"},"attributes":{"emoji":"","name":"Management","synonyms":null,"description":null,"position":null,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"5"}},"heading":{"data":null}},"meta":{"itemCount":0}},{"type":"tags","id":"71","links":{"self":"https://app.emedici.com/api/tags/71"},"attributes":{"emoji":"","name":"Junior","synonyms":null,"description":"Suitable for a junior, pre-clinical medical student","position":0,"createdAt":null,"updatedAt":null},"relationships":{"group":{"data":{"type":"tagGroups","id":"6"}},"heading":{"data":null}},